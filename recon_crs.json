n\n            // 盲驴庐忙颅拢/氓聠聧莽聰鲁猫芦聥茫聛搂氓\u0085聝茫聙\u0085莽虏戮莽庐聴忙聹聼忙聴楼茫聜聮忙聦聛茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞莽聰鲁猫芦聥茫聛搂茫聙聛莽虏戮莽庐聴忙聹聼忙聴楼茫聛聦猫篓聢莽庐聴氓聫炉猫聝陆茫聛搂忙聹陋茫聛聽茫聛芦莽虏戮莽庐聴忙聹聼忙聴楼茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢莽垄潞猫陋聧莽聰禄茅聺垄茫聛搂莽虏戮莽庐聴忙聹聼忙聴楼茫聜聮茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n            if (($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY ||\n                $scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.FEEDBACK) \u0026\u0026\n                (util.isUndefinedOrNull($scope.settlement_deadline.deadline_date_old) \u0026\u0026\n                    util.isUndefinedOrNull($scope.settlement_deadline.deadline_date))\n            ) {\n                $scope.settlement_deadline.deadline_date = $scope.settlement_deadline.deadline_date_new;\n                $scope.settlement_deadline.is_expired = $scope.settlement_deadline.is_expired_new;\n            }\n\n            // 莽聰鲁猫芦聥盲驴庐忙颅拢忙聶聜茫聛庐氓路庐莽聲掳茅聽\u0085莽聸庐茫聜聮莽垄潞猫陋聧茫聛聶茫聜聥\n            if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                var data = {_new: {}, _old: {}, _other: {}};\n                data._new.form_data = $scope.form_data; // 盲驴庐忙颅拢氓戮聦茫聛庐茫聝聲茫聜漏茫聝录茫聝聽氓聠\u0085氓庐鹿\n                data._new.last_approval_period = $scope.last_approval_period; // 盲驴庐忙颅拢氓戮聦茫聛庐忙聣驴猫陋聧忙聹聼茅聶聬\n                data._new.request_files = $scope.request_files; // 盲驴庐忙颅拢氓戮聦茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦(茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢茅聽\u0085莽聸庐)\n                // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛搂EC茫聜碌茫聜陇茫聝聢茫聛赂茫聛庐莽聰禄茅聺垄茅聛路莽搂禄茫聛聦莽聶潞莽聰聼茫聛聴茫聛聼氓聽麓氓聬聢茫聛炉盲潞聥氓聣聧茫聛芦茅聙聙茅聛驴茫聛聴茫聛聼localStorage茫聛聥茫聜聣氓聫聳氓戮聴茫聛聶茫聜聥\n                if ($scope.form_data_old || $scope.last_approval_period_old || $scope.request_files_old) {\n                    data._old.form_data = $scope.form_data_old; // 盲驴庐忙颅拢氓聣聧茫聛庐茫聝聲茫聜漏茫聝录茫聝聽氓聠\u0085氓庐鹿\n                    data._old.last_approval_period = $scope.last_approval_period_old; // 盲驴庐忙颅拢氓聣聧茫聛庐忙聣驴猫陋聧忙聹聼茅聶聬\n                    data._old.request_files = $scope.request_files_old; // 盲驴庐忙颅拢氓聣聧茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦(茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢茅聽\u0085莽聸庐)\n                }\n                else {\n                    data._old.form_data = form_data_old; // 盲驴庐忙颅拢氓聣聧茫聛庐茫聝聲茫聜漏茫聝录茫聝聽氓聠\u0085氓庐鹿\n                    data._old.last_approval_period = last_approval_period_old; // 盲驴庐忙颅拢氓聣聧茫聛庐忙聣驴猫陋聧忙聹聼茅聶聬\n                    data._old.request_files = request_files_old; // 盲驴庐忙颅拢氓聣聧茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦(茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢茅聽\u0085莽聸庐)\n                }\n                data._other.payment_types = $scope.payment_types; // 忙聰炉忙聣聲忙聳鹿忙鲁聲茫聝陋茫聜鹿茫聝聢(莽碌聦猫虏禄莽虏戮莽庐聴)\n                data._other.payment_options = $scope.display_payment_options; // 忙聰炉忙聣聲忙聣聥忙庐碌茫聝陋茫聜鹿茫聝聢(莽碌聦猫虏禄莽虏戮莽庐聴)\n                data._other.proxy_payment_option = payment_option_old; // 盲驴庐忙颅拢氓聣聧茫聛庐忙聰炉忙聣聲忙聣聥忙庐碌茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n                data._other.payment_date_terms = $scope.reflect_payment_date_terms; // 茅聛赂忙聤聻氓聫炉猫聝陆茫聛陋忙聰炉忙聣聲忙聺隆盲禄露茫聝陋茫聜鹿茫聝聢\n                data._other.proxy_payment_date_term = paymentDateTermOld; // 盲驴庐忙颅拢氓聣聧茫聛庐忙聰炉忙聣聲忙聺隆盲禄露茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n                // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聢漏莽聰篓猫篓颅氓庐職\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    data._other.payment_due_date_setting = $scope.form_data.expense.payment_due_date_setting;\n                }\n                // Hubble\n                data._new.hubble_selected_files = $scope.hubbleCreateData.selectedFiles;\n                data._old.hubble_selected_files = [];\n                data._new.hubble_selected_signed_file_data = $scope.hubbleCreateData.selectedSignedFileData;\n                data._old.hubble_selected_signed_file_data = {};\n                // 莽虏戮莽庐聴忙聹聼忙聴楼\n                data._new.settlement_deadline_date = $scope.settlement_deadline.deadline_date; // 盲驴庐忙颅拢氓戮聦\n                data._old.settlement_deadline_date = $scope.settlement_deadline.deadline_date_old; // 盲驴庐忙颅拢氓聣聧\n                // 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥\n                data._new.modify_settlement_deadline = $scope.modify_settlement_deadline; // 盲驴庐忙颅拢氓戮聦\n                data._old.modify_settlement_deadline = $scope.modify_settlement_deadline_old; // 盲驴庐忙颅拢氓聣聧\n\n                // 盲禄庐忙聣聲忙聹聼忙聴楼茫聛篓忙聰炉忙聣聲盲潞聢氓庐職忙聴楼(忙聰炉忙聣聲氓赂聦忙聹聸忙聴楼)茫聛篓忙聰炉忙聣聲忙聣聥忙庐碌\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    // 盲禄庐忙聣聲忙聹聼忙聴楼茫聛庐氓陇聣忙聸麓氓聣聧茫聜聮忙聽录莽麓聧(盲禄庐忙聣聲忙聹聼忙聴楼茫聛篓忙聰炉忙聣聲盲潞聢氓庐職忙聴楼/忙聰炉忙聣聲氓赂聦忙聹聸忙聴楼茫聛炉忙聨聮盲禄聳茅聳垄盲驴聜)\n                    data._old.form_data.expense.suspense_payment_date = suspense_payment_date_old; // 盲驴庐忙颅拢氓聣聧\n\n                    // 忙聰炉忙聣聲忙聣聥忙庐碌\n                    data._new.form_data.expense.payment_option = $scope.form_data.expense.payment_option; // 盲驴庐忙颅拢氓戮聦\n                    data._old.form_data.expense.payment_option = payment_option_old.id; // 盲驴庐忙颅拢氓聣聧\n\n                    // 茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聛聥氓聢陇氓庐職\n                    const po_result = PaymentOptionService.isFormRelatedPaymentOption(\n                        $scope.form_related_payment_options, $scope.form_data.expense.payment_option\n                    );\n                    // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茫聛聦茫聙聦茫聜芦茫聝卢茫聝鲁茫聝聙茫聝录茫聙聧茫聛聥氓聢陇氓庐職\n                    const is_payment_date_type_calendar = paymentDateService.isPaymentDateTypeCalendar(\n                        $scope.payment_date_type\n                    );\n                    // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茫聛聦茫聙聦茫聜芦茫聝卢茫聝鲁茫聝聙茫聝录茫聙聧茫聛搂茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聛庐氓聽麓氓聬聢\n                    // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛聦猫聡陋氓聥聲猫篓聢莽庐聴茫聛聲茫聜聦茫聜聥\n                    if (is_payment_date_type_calendar \u0026\u0026 po_result) {\n                        // 盲驴庐忙颅拢氓戮聦茫聛庐忙聰炉忙聣聲氓赂聦忙聹聸忙聴楼茫聜聮null茫聛芦茫聜禄茫聝聝茫聝聢茫聛聴茫聛娄茫聙聛忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛炉盲驴庐忙颅拢氓聣聧氓戮聦茫聜聮茫聜禄茫聝聝茫聝聢\n                        data._new.form_data.expense.desire_payment_date = null; // 盲驴庐忙颅拢氓戮聦\n                        data._old.form_data.expense.desire_payment_date = $scope.desire_payment_date_old; // 盲驴庐忙颅拢氓聣聧\n                        data._new.form_data.expense.payment_due_date = $scope.payment_due_date.new; // 盲驴庐忙颅拢氓戮聦\n                        data._old.form_data.expense.payment_due_date = $scope.payment_due_date.old; // 盲驴庐忙颅拢氓聣聧\n                    } else {\n                        // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茫聛聦茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聙聧茫聜聜茫聛聴茫聛聫茫聛炉茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聛搂茫聛炉茫聛陋茫聛聞氓聽麓氓聬聢\n                        // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼(忙聰炉忙聣聲氓赂聦忙聹聸忙聴楼)茫聛炉莽聰鲁猫芦聥猫聙\u0085茫聛聦氓\u0085楼氓聤聸茫聛聶茫聜聥\n                        const _FORM_TYPE = Const.miscellaneous._FORM_TYPE;\n                        const expense_settlement_flg = _FORM_TYPE.EXPENSE.settlement_flg;\n                        const expense_pre_settlement_flg = _FORM_TYPE.EXPENSE_PRE_APPLY.settlement_flg;\n                        // 莽碌聦猫虏禄茫聝禄莽虏戮莽庐聴\n                        if ($scope.form_data.expense.settlement_flg === expense_settlement_flg) {\n                            const desire_payment_date = $scope.form_data.expense.desire_payment_date;\n                            if (desire_payment_date) {\n                                data._new.form_data.expense.payment_due_date = desire_payment_date; // 盲驴庐忙颅拢氓戮聦\n                                data._old.form_data.expense.payment_due_date = $scope.desire_payment_date_old; // 盲驴庐忙颅拢氓聣聧\n                            } else {\n                                data._new.form_data.expense.payment_due_date = $scope.payment_due_date.new; // 盲驴庐忙颅拢氓戮聦\n                                data._old.form_data.expense.payment_due_date = $scope.payment_due_date.old; // 盲驴庐忙颅拢氓聣聧\n                            }\n\n                            data._new.form_data.expense.desire_payment_date = desire_payment_date; // 盲驴庐忙颅拢氓戮聦\n                            data._old.form_data.expense.desire_payment_date = desire_payment_date; // 盲驴庐忙颅拢氓聣聧\n                        }\n                        // 莽碌聦猫虏禄茫聝禄盲潞聥氓聣聧\n                        else if ($scope.form_data.expense.settlement_flg === expense_pre_settlement_flg) {\n                            data._new.form_data.expense.payment_due_date = null;\n                            data._old.form_data.expense.payment_due_date = $scope.payment_due_date.old; // 盲驴庐忙颅拢氓聣聧\n                            data._old.form_data.expense.desire_payment_date = $scope.desire_payment_date_old; // 盲驴庐忙颅拢氓聣聧\n                        }\n                    }\n                }\n\n                ModifyService.processToModify(data);\n                $scope.modifyFormItem = ModifyService.getDifferenceForm();\n                $scope.modifyFreeItem = ModifyService.getDifferenceFree();\n                $scope.modifyRequestFormCustomItem = ModifyService.getDifferenceRequestFormCustomItem();\n                // TODO 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓路庐氓聢聠茫聜聮盲赂聙忙聴娄茫聛聯茫聛聯茫聛搂猫驴陆氓聤聽茫聛聶茫聜聥\n                const correction_history = ModifyService.getCorrectionHistory();\n                CustomSpecificsConvertService.addDifferenceForm(\n                    $scope.form_type, data, $scope.modifyFormItem, correction_history);\n                $scope.modified = (ModifyService.getCorrectionHistory().length !== 0)\n                               || CloudsignService.hasDocument($scope.req);\n            }\n\n            // 莽碌聦猫虏禄莽虏戮莽庐聴莽聰鲁猫芦聥茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢茫聙聛氓聥陇忙聙聽忙聣聯氓聢禄忙聝\u0085氓聽卤氓聫聳氓戮聴\n            if (\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE \u0026\u0026\n                $scope.form_data.expense.settlement_flg === Const.miscellaneous._FORM_TYPE.EXPENSE.settlement_flg\n            ) {\n                _getAttendanceData();\n            }\n\n            // 忙聰炉忙聣聲茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n                // 盲潞聥氓聣聧莽聰鲁猫芦聥茫聜篓茫聝漏茫聝录茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聝聲茫聝漏茫聜掳茫聜聮茫聜炉茫聝陋茫聜垄\n                $scope.form_data.payment.error_not_allowed_new_company = false;\n                $scope.form_data.payment.error_un_match_payment_format = false;\n            }\n            $scope.isConfirm = true;\n            $location.hash(\u0027top\u0027);\n            $anchorScroll();\n            $location.url($location.path()); // 茫聝聫茫聝聝茫聜路茫聝楼茫聜炉茫聝陋茫聜垄\n        })\n        .catch(function(res){\n            if (res \u0026\u0026 res.data) {\n                notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n            }\n        });\n    }\n\n    /**\n     * 莽聰鲁猫芦聥猫聙\u0085茫聛聦忙聹聙氓聢聺茫聛庐茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐忙聣驴猫陋聧猫聙\u0085茫聛聥\n     * @return {boolean}\n     */\n    function requestUserIsFirstApprover() {\n        var flag = false;\n        var user_id;\n        if (angular.isUndefined($scope.requester_id)) {\n            user_id = $scope.login_user.id;\n        }\n        else {\n            user_id = $scope.requester_id;\n        }\n\n        if ($scope.flow_data.flow_steps.length) {\n            angular.forEach($scope.flow_data.flow_steps[0].flow_step_users, function(v) {\n                if (!flag) {\n                    if (user_id === v.user_id) {\n                        flag = true;\n                    }\n                }\n            });\n        }\n\n        return flag;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥莽垄潞猫陋聧莽聰禄茅聺垄茫聛聥茫聜聣盲陆聹忙聢聬莽聰禄茅聺垄茫聛芦忙聢禄茫聜聥氓聡娄莽聬聠\n     */\n    function editRequest() {\n        $scope.isConfirm = false;\n        $location.hash(\u0027top\u0027);\n        $anchorScroll();\n        $location.url($location.path()); // 茫聝聫茫聝聝茫聜路茫聝楼茫聜炉茫聝陋茫聜垄\n    }\n\n    /**\n     * 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉莽路篓茅聸聠忙聶聜茫聛庐茫聙聛莽碌聦猫路炉莽路篓茅聸聠氓庐聦盲潞聠氓聡娄莽聬聠\n     */\n    function modifyRequestStep() {\n        CreateRequestFlowService.prepareFlowStepData($scope.flow_data);\n        var post_data = {\n            flow_data: $scope.flow_data,\n            target_version: $scope.modify_step_data.update_target_version,\n            current_flow_step_number: $scope.modify_step_data.current_flow_step_number,\n            modify_step_logs_count: $scope.modify_step_data.modify_step_logs_count,\n        };\n\n        UnloadAlertService.stop();\n\n        CreateRequestFlowService.modifyRequestStep($scope.request_id, post_data)\n            .then(function() {\n                notifyService.showNotify(gettextCatalog.getString(\u0027忙聣驴猫陋聧莽碌聦猫路炉茫聜聮盲驴庐忙颅拢茫聛聴茫聛戮茫聛聴茫聛聼\u0027), \u0027alert-success\u0027);\n                backToPreviousPage();\n            }).catch(function(res) {\n                notifyService.showNotify(res.data.message, \u0027alert-danger\u0027);\n            });\n    }\n\n    /**\n     * 盲赂聥忙聸赂茫聛聧莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴莽聶禄茅聦虏\n     * @param {object} request_form\n     */\n    function createDraftRequest(request_form) {\n        generateTitleAuto()\n        .then(function(res) {\n            if (res \u0026\u0026 res.data){\n                request_form.title.$setViewValue(res.data.title);\n                if (!$scope.form_data.title || request_form.title.$invalid) {\n                    $scope.clicked_confirm = true;\n                    return $q.reject();\n                }\n            }\n\n            // 茫聝聛茫聜搂茫聝聝茫聜炉茫聜聮氓垄聴茫聜聞茫聛聶氓炉戮氓驴聹茫聜聮猫隆聦茫聛聠氓聽麓氓聬聢茫聙聛confirmRequest茫聜聮氓聫聜猫聙聝茫聛芦忙聰鹿盲驴庐茫聛聶茫聜聥茫聛聯茫聛篓茂录聢茫聛聺茫聛庐茅職聸茫聛炉茫聛聯茫聛庐茫聜鲁茫聝隆茫聝鲁茫聝聢茫聜聜氓聣聤茅聶陇茂录聣\n            if (checkDraftError().result === EDIT_FLOW_STEP_MODE_ERROR) {\n                dialogService.showConfirmDialog(\n                    gettextCatalog.getString(\u0027忙聣驴猫陋聧莽碌聦猫路炉茫聜聮莽路篓茅聸聠盲赂颅茫聛搂茫聛聶\u0027),\n                    gettextCatalog.getString(\u0027忙聣驴猫陋聧莽碌聦猫路炉茫聛庐莽路篓茅聸聠茫聜聮氓庐聦盲潞聠茫聛聴茫聛娄茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u0027),\n                    Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP.hide,\n                    Const.miscellaneous._DIALOG_OK_BUTTON_TYPE.consent\n                );\n                return $q.reject();\n            }\n\n            // 盲赂聥忙聸赂茫聛聧盲驴聺氓颅聵茫聛搂茫聜聜忙聵聨莽麓掳猫隆篓茫聛聦忙聹聣茫聜聦茫聛掳茫聙聛氓\u0085楼氓聤聸忙赂聢茫聛驴忙聵聨莽麓掳猫隆聦茫聛芦No茫聜聮忙聨隆莽聲陋茫聛聶茫聜聥\n            if (isSpecificsSheet() \u0026\u0026\n                ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE ||\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT)\n            ) {\n                const tables = journalizableSpecificsTables();\n                updateDisplayedPropOfTables(tables);\n                // 忙聹陋氓\u0085楼氓聤聸茫聛庐忙聵聨莽麓掳猫隆篓茫聛炉茫聙聛0猫隆聦茫聛芦莽陆庐茫聛聧忙聫聸茫聛聢茫聜聥\n                const sheet_index_for_clear = [];\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛搂忙聹陋盲陆驴莽聰篓茫聛庐request_custom_specific_items茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n                CustomSpecificsConvertService.removeItemsForPassChecks(\n                    tables,\n                );\n                tables.forEach(function (sheet, idx) {\n                    const isSheetInputted = CustomSpecificsService.isCustomSpecifics(sheet) ?\n                        createRequestService.isSheetInputtedCustom(sheet, $scope.form_type) :\n                        createRequestService.isSheetInputted(sheet, $scope.form_type);\n                    if (!isSheetInputted) {\n                        sheet_index_for_clear.push(idx);\n                    }\n                });\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽茅聽\u0085莽聸庐茫聛搂氓驴\u0085猫娄聛茫聛陋氓聙陇茫聛庐氓聠聧猫篓颅氓庐職(removeItemsForPassChecks茫聛搂忙露聢茫聛聲茫聜聦茫聛娄茫聛聴茫聛戮茫聛聠茫聛聼茫聜聛)\n                CustomSpecificsConvertService.resettingItemsForPassChecks(\n                    tables,\n                );\n                _clearSpecificsSheet(sheet_index_for_clear);\n                CreateRequestSpecificsService.updateSpecificsRowNumber(tables);\n            }\n            createRequest(0);\n        })\n        .catch(function(res){\n            if (res \u0026\u0026 res.data) {\n                notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n            }\n        });\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聛庐莽聶禄茅聦虏茫聛聶茫聜聥氓聣聧茫聛庐氓聥陇忙聙聽忙聣聯氓聢禄茫聛聦忙聹陋忙聣驴猫陋聧茫聛陋忙聴楼盲禄聵茫聛聦忙聹聣茫聜聥氓聽麓氓聬聢茫聛炉茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聜聮忙聦聼茫聜聙氓聡娄莽聬聠\n     * @param {number} kind 盲赂聥忙聸赂茫聛聧: 0茫聙聛莽聰鲁猫芦聥: 1\n     */\n    function createRequest(kind) {\n        var un_engraving = [];\n        // 莽聰鲁猫芦聥忙聶聜茫聛庐茫聛驴茫聙聛氓聥陇忙聙聽茅聙拢忙聬潞茫聛聴茫聛娄茫聛聞茫聛娄茫聙聛氓聥陇忙聙聽忙聣聯氓聢禄茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞忙聴楼盲禄聵茫聛聦忙聹聣茫聜聥氓聽麓氓聬聢茫聛炉茫聙聛莽垄潞猫陋聧茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聜聮忙聦聼茫聜聙\n        if (kind === 1) {\n            un_engraving = _getUnEngraving();\n        }\n        if (!un_engraving.length) {\n            _createRequest(kind);\n        } else {\n            _showUnEngravingDialog(un_engraving).then(function (flg) {\n                if (!flg) {\n                    return;\n                }\n                _createRequest(kind);\n            });\n        }\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聛庐莽聶禄茅聦虏\n     * @param {number} kind 盲赂聥忙聸赂茫聛聧: 0茫聙聛莽聰鲁猫芦聥: 1\n     */\n    function _createRequest(kind) {\n        // post茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n        var request_data = prepareRequestData(kind); // 莽聰鲁猫芦聥忙聸赂茫聛庐氓陇搂忙聻聽茫聛庐茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n        request_data.form_data = {};\n        request_data.form_data.form_items = prepareFormItemsData(); // 莽聰鲁猫芦聥茅聽\u0085莽聸庐茫聛庐茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE\n            \u0026\u0026 !util.isUndefinedOrNull($scope.form_data.expense.request_expense_specifics)) {\n            // 茫聜芦茫聜鹿茫聜驴茫聝聽盲潞陇茅聙職猫虏禄忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聙聛忙聵聨莽麓掳猫隆篓茫聛芦忙聵聨莽麓掳猫隆聦index茫聛芦氓炉戮氓驴聹茫聛聶茫聜聥莽碌聦莽聰卤茅搂\u0085茫聜聮忙聽录莽麓聧\n            CreateRequestSpecificsService.setSpecificsViaPlaces(\n                $scope.form_data.expense.request_expense_specifics);\n            // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聣聥氓陆聯忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聙聛忙聵聨莽麓掳猫隆篓茫聛芦忙聵聨莽麓掳猫隆聦index茫聛芦氓炉戮氓驴聹茫聛聶茫聜聥忙聣聥氓陆聯猫漏鲁莽麓掳茫聛篓茅聡聭茅隆聧茫聛庐猫漏鲁莽麓掳猫篓颅氓庐職茫聝聲茫聝漏茫聜掳茫聜聮忙聽录莽麓聧\n            CreateRequestSpecificsService.setSpecificsAllowanceAmountDetails(\n                $scope.form_data.expense.request_expense_specifics);\n            // 茫聜芦茫聝录茫聝聣忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥忙聶聜茫聛庐氓聦潞氓聢聠茫聝陋茫聜鹿茫聝聢茫聜聮card_integration_id氓聧聵盲陆聧茫聛搂盲驴聺忙聦聛茫聛聶茫聜聥\n            CustomSpecificsConvertService.setJsonDivisionByIntegrationIds($scope.form_data);\n\n            // 莽聰鲁猫芦聥茫聛聶茫聜聥茫聝聹茫聜驴茫聝鲁茫聛聦忙聤录盲赂聥茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢\n            if (kind === 1) {\n                // 氓聠\u0085猫篓鲁茫聜鲁茫聝聰茫聝录茫聜篓茫聝漏茫聝录茫聝聲茫聝漏茫聜掳茫聛聦茫聜陋茫聝鲁茫聛搂茫聛聜茫聛拢茫聛娄茫聜聜茫聙聛茫聛聯茫聛聯茫聜聮茅聙職茅聛聨茫聛聶茫聜聥忙聶聜茫聛芦茫聛炉茫聜篓茫聝漏茫聝录茫聛炉猫搂拢忙露聢茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛庐茫聛搂茫聝聲茫聝漏茫聜掳茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n                for (const i in $scope.form_data.expense.request_expense_specifics) {\n                    if ($scope.form_data.expense.request_expense_specifics.hasOwnProperty(i) \u0026\u0026\n                        $scope.form_data.expense.request_expense_specifics[i].is_account_title_part_copy_error) {\n                        delete $scope.form_data.expense.request_expense_specifics[i].is_account_title_part_copy_error;\n                    }\n                }\n            }\n        }\n\n        // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐茫聝聡茫聝录茫聜驴忙聲麓氓陆垄\n        if (isSpecificsSheet() \u0026\u0026\n            ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE ||\n             $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT)\n        ) {\n            const request_custom_specifics = [];\n            const request_custom_specific_items = {};\n            const mapping_request_custom_specific_rows = [];\n            const isPayeePerRequest = (\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT\n                \u0026\u0026 $scope.form_data.payment.is_payee_per_request\n            );\n            // 茅聺聻猫隆篓莽陇潞茫聛庐忙聵聨莽麓掳猫隆篓茫聛炉莽聶禄茅聦虏茫聛聴茫聛陋茫聛聞\n            const form_data_specifics = _getDisplayingSpecificsSheets(journalizableSpecificsTables());\n            var row_counter = 0;\n            var cell_counter = 0;\n            form_data_specifics.map(function(sheet, index) {\n                if (!CustomSpecificsService.isCustomSpecifics(sheet)) {\n                    return;\n                }\n                const custom_specific = CustomSpecificsConvertService.makeRequestCustomSpecific(\n                    sheet, index, row_counter, cell_counter, request_custom_specific_items,\n                    mapping_request_custom_specific_rows, isPayeePerRequest\n                );\n                if (!util.isUndefinedOrNull(custom_specific)){\n                    request_custom_specifics.push(custom_specific);\n                    row_counter+=custom_specific[\u0027rows_count\u0027];\n                    cell_counter+=custom_specific[\u0027cells_count\u0027];\n                }\n            });\n            if (request_custom_specifics.length \u003e 0) {\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢\n                request_data.form_data.request_custom_specifics = request_custom_specifics;\n                request_data.form_data.request_custom_specific_items = request_custom_specific_items;\n                request_data.form_data.mapping_request_custom_specific_rows = mapping_request_custom_specific_rows;\n                // 莽碌聦猫虏禄莽聰鲁猫芦聥茫聛庐忙聵聨莽麓掳猫隆篓茂录聫忙聰炉忙聣聲莽聰鲁猫芦聥茫聛庐忙聵聨莽麓掳猫隆篓茫聛芦茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛篓莽麓聬茫聛楼茫聛聭茫聜聥忙職芦氓庐職茫聛庐ID茫聜聮氓聢禄茫聜聙\n                CustomSpecificsConvertService.relateCustomSpecifics(request_custom_specifics, form_data_specifics);\n                // 莽碌聦猫虏禄莽聰鲁猫芦聥茂录聫忙聰炉忙聣聲莽聰鲁猫芦聥忙聝\u0085氓聽卤茫聛聥茫聜聣茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐猫隆聦茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n                $scope.custom_specific_buck_up\n                    = CustomSpecificsConvertService.deleteCustomSpecificRows(form_data_specifics);\n            }\n        }\n\n        // form_type莽聣鹿忙聹聣茫聛庐茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            // 忙聰炉忙聣聲忙聳鹿忙鲁聲茫聛聦0盲禄露茫聛庐氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茅聛赂忙聤聻茫聛聴茫聛聼忙聰炉忙聣聲忙聳鹿忙鲁聲茫聛炉null\n            if ($scope.payment_types.length === 0) {\n                $scope.form_data.expense.payment_type = null;\n            }\n            // 氓聣聤茅聶陇忙赂聢茫聛驴茫聛庐忙聰炉忙聣聲忙聳鹿忙鲁聲茫聛聦莽聰鲁猫芦聥茫聛芦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聜聥氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茅聛赂忙聤聻茫聛聴茫聛聼忙聰炉忙聣聲忙聳鹿忙鲁聲茫聛炉null\n            else if ($scope.form_data.expense.payment_type \u0026\u0026\n                !$scope.payment_types.some(function(type) {\n                    return type.id === $scope.form_data.expense.payment_type;\n                })\n            ) {\n                $scope.form_data.expense.payment_type = null;\n            }\n            var request_expense = angular.copy($scope.form_data.expense);\n            request_expense.payment_type_name = PaymentTypeService.getPaymentTypeName(\n                $scope.form_data.expense.payment_type,\n                $scope.payment_types\n            );\n            if (isSpecificsSheet()\n                \u0026\u0026 $scope.form_data.settlement_flg !==\n                    Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg) {\n                request_expense.request_expense_specifics = _getDisplayingSpecificsSheets(\n                    $scope.form_data.expense.request_expense_specifics\n                );\n                updateDisplayedPropOfTables(journalizableSpecificsTables());\n                // 忙聵聨莽麓掳茫聛芦氓炉戮茫聛聶茫聜聥氓聡娄莽聬聠\n                angular.forEach(request_expense.request_expense_specifics, function(sheet) {\n                    angular.forEach(sheet.request_expense_specifics_rows, function(row) {\n                        if (\u0027limit_amount_alert_level\u0027 in row) {\n                            delete row.limit_amount_alert_level;\n                        }\n                        delete row.old_row_number;\n                    });\n                    // 氓聠\u0085猫篓鲁忙聝\u0085氓聽卤茫聜聮忙聽录莽麓聧茫聛聶茫聜聥茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛聦茫聛聜茫聜聦茫聛掳氓聣聤茅聶陇\n                    if (angular.isDefined(sheet.account_title_parts)) {\n                        delete sheet.account_title_parts;\n                    }\n                    delete sheet.default_exchange_settings;\n                    delete sheet.operation;\n                });\n            }\n\n            // 莽碌聦猫虏禄茫聝禄莽虏戮莽庐聴茫聛庐氓聽麓氓聬聢茫聙聛忙聵聨莽麓掳忙聝\u0085氓聽卤氓聠\u0085茫聛庐忙聹陋忙聣驴猫陋聧茫聛陋忙聴楼盲禄聵盲赂聙猫娄搂茫聜聮茫聝陋茫聜炉茫聜篓茫聜鹿茫聝聢茫聝聡茫聝录茫聜驴茫聛聥茫聜聣氓聣聤茅聶陇\n            if (isSpecificsSheet() \u0026\u0026 request_expense.settlement_flg ===\n                Const.miscellaneous._FORM_TYPE.EXPENSE.settlement_flg\n            ) {\n                request_expense.request_expense_specifics.forEach(function (sheet) {\n                    delete sheet.un_engraving;\n                });\n            }\n\n            request_data.form_data.request_expense = request_expense;\n\n            // 氓聡潞氓录碌氓\u0085聢茫聛篓氓聡潞氓录碌忙聴楼茫聛庐猫篓颅氓庐職\n            request_data.business_trip_info = $scope.form_data.business_trip_info;\n        }\n\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            var request_payment = angular.copy($scope.form_data.payment);\n            if (isSpecificsSheet()) {\n                request_payment.request_payment_specifics = _getDisplayingSpecificsSheets(\n                    $scope.form_data.payment.request_payment_specifics\n                );\n                updateDisplayedPropOfTables(journalizableSpecificsTables());\n                // 氓聠\u0085猫篓鲁忙聝\u0085氓聽卤茫聜聮忙聽录莽麓聧茫聛聶茫聜聥茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛聦茫聛聜茫聜聦茫聛掳氓聣聤茅聶陇\n                angular.forEach(request_payment.request_payment_specifics, function(sheet) {\n                    angular.forEach(sheet.request_payment_specifics_rows, function(row) {\n                        delete row.old_row_number;\n                    });\n                    if (angular.isDefined(sheet.account_title_parts)) {\n                        delete sheet.account_title_parts;\n                    }\n                });\n            }\n            request_data.form_data.request_payment = request_payment;\n\n            // 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐茫聛驴忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聝聲茫聝漏茫聜掳茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n            request_data.form_data.request_payment.is_allowed_new_company = $scope.form_data.is_allowed_new_company;\n        }\n\n        // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EC) {\n            request_data.form_data.request_ec = angular.copy($scope.form_data.ec);\n        }\n\n        // 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢\n        if (\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE \u0026\u0026\n            $scope.form_data.expense.settlement_flg ==\n                Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg\n        ) {\n            delete request_data.form_data.request_expense.request_expense_specifics;\n        }\n\n        // 氓\u0085楼氓聤聸茫聝聡茫聝录茫聜驴茫聜聮json茫聛芦茫聛聴茫聛娄茫聝聠茫聝录茫聝聳茫聝芦茫聛芦莽聶禄茅聦虏\n        if (angular.isDefined($scope.form_data.request_data_json)) {\n            delete $scope.form_data.request_data_json;\n        }\n\n        request_data.currency_code = $scope.form_data.currency_code;\n        request_data.currency_show_flg = $scope.form_data.currency_show_flg;\n        delete $scope.form_data.currency_code;\n        delete $scope.form_data.currency_show_flg;\n\n        // 盲禄聲猫篓鲁茅聽\u0085莽聸庐猫篓颅氓庐職茫聛庐猫驴陆氓聤聽\n        request_data.form_data.request_form_custom_item = CreateRequestFormCustomItemService.createRequestData(\n            $scope.form_data.request_form_custom_item\n        );\n\n        // 茅聺聻猫隆篓莽陇潞茅聽\u0085莽聸庐茫聛庐氓聠\u0085氓庐鹿茫聛炉request_data_json茫聛芦盲驴聺氓颅聵茫聛聴茫聛陋茫聛聞\n        request_data.request_data_json = _editRequestDataJson();\n        request_data.total_amount = $scope.totalAmount;\n\n        // 莽聰鲁猫芦聥氓陇卤忙聲聴忙聶聜茫聛芦氓聜聶茫聛聢茫聛娄茅聙聙茅聛驴\n        const savedExtraFlows = angular.copy($scope.form_data.extra_flows);\n        if (angular.isDefined($scope.form_data.extra_flows)) {\n            // 莽碌聦猫路炉氓聢聠氓虏聬忙聝\u0085氓聽卤茫聛炉莽聰鲁猫芦聥API茫聛搂茫聛炉盲赂聧猫娄聛茫聛陋茫聛庐茫聛搂氓聣聤茅聶陇茫聛聶茫聜聥\n            delete $scope.form_data.extra_flows;\n        }\n\n        // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮茫聝陋茫聜炉茫聜篓茫聜鹿茫聝聢茫聝聡茫聝录茫聜驴茫聛聥茫聜聣氓聣聤茅聶陇茫聛聶茫聜聥\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            if (!util.isUndefinedOrNull(request_data.request_data_json.expense.payment_due_date)) {\n                delete request_data.request_data_json.expense.payment_due_date;\n            }\n            if (!util.isUndefinedOrNull(request_data.form_data.request_expense.payment_due_date)) {\n                delete request_data.form_data.request_expense.payment_due_date;\n            }\n        }\n\n        // 莽聰鲁猫芦聥茫聝聲茫聝颅茫聝录茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n        // 茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼茫聝娄茫聝录茫聜露茫聜聮flow_detai_user茫聛芦猫篓颅氓庐職茫聛聴莽聸麓茫聛聶\n        if (angular.isUndefinedOrNull($scope.isModify)) {\n            CreateRequestFlowService.prepareFlowStepData($scope.flow_data);\n        }\n        request_data.flow_data = $scope.flow_data;\n        request_data.circulation_data = $scope.flow_circulation_users;\n        request_data.last_approval_period = $scope.last_approval_period;\n        request_data.request_files = _editRequestFiles();\n\n        // API 茫聛芦忙聤聲茫聛聮茫聜聥莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聛芦茫聜炉茫聝漏茫聜娄茫聝聣茫聜碌茫聜陇茫聝鲁忙聸赂茅隆聻 ID 茫聜聮盲鹿聴茫聛聸茫聜聥\n        if (CloudsignService.hasDocument($scope.req)) {\n            request_data.cloudsign_document = $scope.req.cloudsign_document.id;\n        }\n\n        // Hubble茫聝聡茫聝录茫聜驴茫聛庐猫驴陆氓聤聽\n        if ($scope.form_data.hubble_setting_flg) {\n            request_data.hubble_data = $scope.hubbleCreateData;\n        }\n\n        /**\n         * 莽聰鲁猫芦聥猫聙\u0085茫聛聦莽卢卢1茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐忙聣驴猫陋聧猫聙\u0085茫聛搂茫聜聜茫聛聜茫聜聥氓聽麓氓聬聢茫聛芦莽聰鲁猫芦聥忙聶聜忙聣驴猫陋聧茫聜聮猫隆聦茫聛聠\n         * @param {Object} data\n         * @return {Promise}\n         */\n        function approveRequest(data) {\n            if (angular.isDefined(data.request_object)) {\n                var requester_id = angular.isUndefinedOrNull(data.requester_id) ? null : data.requester_id;\n                return ApproveService.approve(data.request_object, Const.request.STATUS_FIN, null, false, null,\n                    requester_id);\n            }\n        }\n\n        /**\n         * kind茫聛聰茫聛篓茫聛芦氓驴\u0085猫娄聛茫聛陋茫聝聡茫聝录茫聜驴茫聜聮post\n         */\n        function postRequest() {\n            // 2茅聡聧茫聛芦茫聝卢茫聜鲁茫聝录茫聝聣茫聜聮莽聰聼忙聢聬茫聛聴茫聛陋茫聛聞茫聜聢茫聛聠茫聙聛氓聡娄莽聬聠盲赂颅茫聛庐氓聽麓氓聬聢茫聛炉return\n            if ($scope.createing_request) {\n                return;\n            }\n            $scope.createing_request = true;\n\n            UnloadAlertService.stop();\n\n            // 盲赂聤茅聶聬茅聡聭茅隆聧茫聛庐猫篓颅氓庐職茫聝聬茫聝录茫聜赂茫聝搂茫聝鲁茫聜聮盲驴聺氓颅聵\n            if ($scope.form_limit_amount_setting \u0026\u0026 $scope.form_limit_amount_setting.length \u003e 0) {\n                request_data.request_data_json.form_limit_amount_version =\n                    $scope.form_limit_amount_setting[0].form_limit_amount_version;\n                request_data.request_data_json.requester_position_id = request_data.requester_position_id;\n            }\n\n            // 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥茫聛庐莽聶禄茅聦虏茫聝聡茫聝录茫聜驴茫聜聮猫篓颅氓庐職\n            if (\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE \u0026\u0026\n                $scope.form_data.expense.settlement_flg ===\n                Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg\n            ) {\n                request_data.request_change_period_settlement_deadlines = [];\n                request_data.request_settlement_deadline = {\n                    \u0027settlement_deadline_date\u0027: $scope.modify_settlement_deadline.settlement_deadline_date,\n                };\n                if ($scope.modify_settlement_deadline.reference_date) {\n                    const reference_date = $scope.modify_settlement_deadline.reference_date;\n                    if (reference_date.item_type === Const.form.ITEM_TYPE_DATE) {\n                        request_data.request_change_date_settlement_deadline = {\n                            \u0027form_item\u0027: reference_date.id,\n                            \u0027reference_date\u0027: reference_date.custom_date,\n                        };\n                    }\n                    if (reference_date.item_type === Const.form.ITEM_TYPE_DATE_PERIOD) {\n                        request_data.request_change_period_settlement_deadlines.push({\n                            \u0027form_item\u0027: reference_date.id,\n                            \u0027start_date\u0027: reference_date.start_date,\n                            \u0027end_date\u0027: reference_date.end_date,\n                        });\n                    }\n                }\n                if ($scope.modify_settlement_deadline.condition_date) {\n                    request_data.request_change_period_settlement_deadlines.push({\n      