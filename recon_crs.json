$scope.form_data.default_atp = angular.fromJson(data.request_data_json || \u0027null\u0027).default_atp || null;\n\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聫聳氓戮聴茂录聢custom_specific_promise茂录聣茫聛庐莽碌聬忙聻聹茫聜聮氓戮\u0085茫聛聼茫聛陋茫聛聞茫聛篓茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聛芦氓聠\u0085猫篓鲁茫聛聦氓聫聳茫聜聦茫聛職茫聙聛_setDefaultFlow茫聛聦莽漏潞茫聛露茫聜聤茫聛聶茫聜聥茫聛聼茫聜聛茫聙聛氓戮\u0085茫聛陇氓驴\u0085猫娄聛茫聛聦茫聛聜茫聜聥茫聙聜\n                $q.all([\n                    circulation_promise,\n                    extraflow_promise,\n                    feedbackflow_promise,\n                    comment_promise,\n                    custom_specific_promise,\n                ]).then(function(result) {\n                    // 莽碌聦猫路炉氓聢聠氓虏聬茫聛搂茫聙聛莽聰鲁猫芦聥忙聝\u0085氓聽卤茫聜聮忙聢禄茫聛聶莽聰篓茫聛庐氓陇聣忙聲掳茫聛芦茫聜禄茫聝聝茫聝聢\n                    $scope.request_flow_data = angular.copy($scope.flow_data);\n                    $scope.flow_circulation_users = result[0];\n                    setCirculationPositionAndUsers($scope.flow_circulation_users);\n                    _setDefaultFlow(data.request_form.flow, true, false);\n                    $scope.request_comments = result[4];\n                    _getSumPaymentExchangeSpecificsAmount();\n                    // 氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聛庐猫隆篓莽陇潞氓聢露氓戮隆茫聝聲茫聝漏茫聜掳氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n                    _setCompanyIsShowFlagsByRequest();\n                    $scope.request_comments = result[3];\n                    $scope.$broadcast(\u0027update_invalid_allocation_date_info\u0027);\n                });\n\n                // 莽聰鲁猫芦聥忙聶聜茫聛庐茅聤聙猫隆聦忙聝\u0085氓聽卤茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥\n                $scope.isDisplayBank = true;\n            }\n\n            // 茫聜炉茫聝漏茫聜娄茫聝聣茫聜碌茫聜陇茫聝鲁忙聸赂茅隆聻茫聛庐猫陋颅茫聛驴氓聡潞茫聛聴\n            loadCloudsignDocument();\n\n            // 猫陋卢忙聵聨猫鲁聡忙聳聶茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴氓聫聳氓戮聴\n            getFormFiles($scope.form_data.form_id);\n\n            // form_type茫聛聰茫聛篓茫聛庐茫聝聡茫聝录茫聜驴猫陋颅茫聛驴猫戮录茫聛驴\n            // 莽碌聦猫虏禄莽聰鲁猫芦聥\n\n            /**\n             * 莽碌聦猫虏禄盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐忙聝\u0085氓聽卤茫聜聮茫聙聛盲禄庐忙聣聲茫聛聞忙聝\u0085氓聽卤茫聜聮氓聬芦茫聜聛茫聛娄氓聫聳茫聛拢茫聛娄茫聛聫茫聜聥\n             */\n            function getRelatedRequestExpense() {\n                // TODO 茫聛禄茫聛录氓聢陇氓庐職莽聰篓茫聛庐氓聙陇茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聛聞茫聜聥茫聛聦茫聙聛氓聢陇氓庐職茫聛炉茫聜碌茫聝录茫聝聬茫聝录氓聛麓茫聛搂茫聛聶茫聜聥茫聛鹿茫聛聧\n                RequestService.getRequestExpenseForRelatedRequest(\n                    $scope.form_data.expense.related_request\n                ).then(function (response) {\n                    $scope.pre_data = response.data;\n                    // 盲禄庐忙聣聲忙聝\u0085氓聽卤茫聜聮氓聫聳茫聛拢茫聛娄茫聛聫茫聜聥\n                    if (\n                        $scope.pre_data.settlement_flg ==\n                            Const.miscellaneous._FORM_TYPE.EXPENSE_PRE_APPLY.settlement_flg\n                        \u0026\u0026 response.data.use_suspense_payment\n                    ) {\n                        SuspensePaymentService.getByRequestId({\u0027request_id\u0027: $scope.form_data.expense.related_request})\n                            .then(function(fp_res) {\n                                // TODO 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛篓茫聛聴茫聛娄茫聛庐忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥API茫聛庐盲赂颅茫聛芦盲禄庐忙聣聲茫聛聞茫聛庐忙聝\u0085氓聽卤茫聜聜氓\u0085楼茫聜聦茫聜聥茫聜聢茫聛聠茫聛芦盲驴庐忙颅拢茫聛聶茫聜聦茫聛掳猫聣炉茫聛聲茫聛聺茫聛聠茫聙聜\n                                $scope.suspense_payment_data = fp_res.data;\n                            });\n                    }\n                }).catch(function (res) {\n                    // eslint-disable-next-line angular/typecheck-string\n                    if (typeof res.data === \u0027string\u0027) {\n                        notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n                    }\n                });\n            }\n\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                $scope.form_data.expense = $scope.form_data.request_data_json.expense;\n                $scope.form_data.expense.settlement_flg = data.request_form.settlement_flg;\n                $scope.form_data.expense.allow_suspense_payment = data.request_form.allow_suspense_payment;\n\n                // 莽聰鲁猫芦聥茫聜鲁茫聝聰茫聝录茫聛庐氓聽麓氓聬聢茫聛炉忙聹聙忙聳掳茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聜聮盲陆驴茫聛聠\n                if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.COPY) {\n                    // 忙聰炉忙聣聲忙聣聥忙庐碌氓聢漏莽聰篓猫篓颅氓庐職\n                    $scope.form_data.expense.payment_option_setting = data.request_form.payment_option_setting;\n                    // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聢漏莽聰篓猫篓颅氓庐職\n                    $scope.form_data.expense.payment_due_date_setting = data.request_form.payment_due_date_setting;\n                    // 忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼\n                    _getFormPaymentDateTermReflectConditions(data.request_form.id);\n                }\n                // 忙聰鹿盲驴庐氓聣聧莽聰鲁猫芦聥茫聛庐氓炉戮莽颅聳茫聛搂request_data_json茫聛芦莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢氓聙陇茫聜聮茫聜禄茫聝聝茫聝聢\n                if (util.isUndefinedOrNull($scope.form_data.expense.payment_option_setting)) {\n                    $scope.form_data.expense.payment_option_setting = Const.miscellaneous._FLAG.OFF;\n                }\n                if (util.isUndefinedOrNull($scope.form_data.expense.payment_due_date_setting)) {\n                    $scope.form_data.expense.payment_due_date_setting = Const.miscellaneous._FLAG.OFF;\n                }\n\n                if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                    // 盲驴庐忙颅拢氓卤楼忙颅麓莽聰篓茫聛芦盲禄庐忙聣聲忙聹聼忙聴楼茫聜聮old茫聛芦氓\u0085楼茫聜聦茫聜聥\n                    suspense_payment_date_old = $scope.form_data.expense.suspense_payment_date;\n                }\n                RequestService.getRequestExpenseForPaymentOption($scope.request_id).then(function (expense_response) {\n                    if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                        // 盲驴庐忙颅拢茫聛庐氓聽麓氓聬聢茫聛炉盲驴庐忙颅拢氓卤楼忙颅麓莽聰篓茫聛庐盲驴庐忙颅拢氓聣聧莽聰篓茫聛芦忙聰炉忙聣聲忙聣聥忙庐碌茫聛篓忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮氓聫聳氓戮聴\n                        if (!util.isUndefinedOrNull(expense_response.data.payment_option)) {\n                            payment_option_old = expense_response.data.payment_option;\n                        }\n                        $scope.payment_due_date.old = expense_response.data.payment_due_date;\n                        $scope.desire_payment_date_old = expense_response.data.payment_due_date;\n                    }\n\n                    // 忙聰炉忙聣聲忙聣聥忙庐碌盲赂聙猫娄搂氓聫聳氓戮聴\n                    PaymentOptionService.getList().then(function (response) {\n                        $scope.payment_options = response.data;\n                        $scope.display_payment_options = angular.copy($scope.payment_options);\n                        // 茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聰炉忙聣聲忙聣聥忙庐碌氓聢漏莽聰篓猫篓颅氓庐職茫聛聦茫聙聦氓聢漏莽聰篓茫聛聴茫聛陋茫聛聞茫聙聧茫聛庐氓聽麓氓聬聢茫聙聛忙聰炉忙聣聲忙聣聥忙庐碌茫聜聮氓聣聤茅聶陇\n                        if (!$scope.form_data.expense.payment_option_setting) {\n                            delete $scope.form_data.expense.payment_option;\n                            return;\n                        }\n                        // 忙聰炉忙聣聲忙聣聥忙庐碌茫聛聦忙聹聣茫聜聦茫聛掳忙聰炉忙聣聲忙聣聥忙庐碌茫聜聮茫聜禄茫聝聝茫聝聢\n                        if (util.isUndefinedOrNull(expense_response.data.payment_option)) {\n                            return;\n                        }\n                        // 氓聫聳氓戮聴茫聛聴茫聛聼忙聰炉忙聣聲忙聣聥忙庐碌茫聛聦茫聙聦莽聫戮氓颅聵茫聛庐忙聰炉忙聣聲忙聣聥忙庐碌盲赂聙猫娄搂茫聙聧茫聛芦莽聞隆茫聛聞氓聽麓氓聬聢\n                        const is_exist_payment_option = PaymentOptionService.existPaymentOption(\n                            expense_response.data.payment_option.id,\n                            $scope.payment_options\n                        );\n                        if (is_exist_payment_option) {\n                            // 氓聫聳氓戮聴茫聛聴茫聛聼莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聛庐忙聰炉忙聣聲忙聣聥忙庐碌茫聛聽茫聛篓茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛陋茫聛庐茫聛搂id茫聜聮茫聜禄茫聝聝茫聝聢\n                            $scope.form_data.expense.payment_option = expense_response.data.payment_option.id;\n                        }\n                        else if (kind !== Const.miscellaneous.CREATE_REQUEST_KIND.COPY) {\n                            // 氓聣聤茅聶陇忙赂聢茫聛驴茫聛庐忙聰炉忙聣聲忙聣聥忙庐碌茫聜聜忙聰炉忙聣聲忙聣聥忙庐碌茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁茫聛庐茅聛赂忙聤聻猫聜垄茫聛芦氓\u0085楼茫聜聦茫聜聥茫聛聼茫聜聛茫聛芦\n   