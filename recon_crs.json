s_data);\n            mapped_items = CreateRequestFormItemService.makeMappedItems($scope.form_data.form_json);\n\n            // 氓聸潞氓庐職氓聙陇茫聛庐猫篓聢莽庐聴茅聽\u0085莽聸庐茫聜聮氓聫聧忙聵聽茫聛聲茫聛聸茫聜聥茫聛聼茫聜聛茫聛芦猫陋颅猫戮录忙聶聜茫聛芦氓聬聢猫篓聢茅聡聭茅隆聧茫聜聮猫篓聢莽庐聴\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_GENERAL\n                    \u0026\u0026 !angular.isUndefinedOrNull($scope.form_data.form_json)) {\n                initializeItems($scope.form_data.form_json);\n            }\n\n            // 忙鲁篓猫篓聵茫聛庐猫篓颅氓庐職\n            if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_GENERAL) {\n                var form_type = $scope.form_type;\n                var specifics = null;\n                if ($scope.isSpecificsSheet()) {\n                    if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                        specifics = $scope.form_data.expense.request_expense_specifics;\n                    }\n                    else if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n                        specifics = $scope.form_data.payment.request_payment_specifics;\n                    }\n                }\n                const _nonSpecificsItem = (\n                    !specifics\n                    || (\n                        $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT\n                        \u0026\u0026 $scope.form_data.payment\n                        \u0026\u0026 $scope.form_data.payment.is_payee_per_request\n                    )\n                );\n                // 茫聝聶茫聝录茫聜鹿茫聛篓茫聛陋茫聜聥茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢氓聙陇茫聜聮氓庐職莽戮漏茫聛聶茫聜聥\n                const baseFormItemsNote = {\n                    BASE_ITEM: FormService.getNoteBase(form_type),\n                    NON_SPECIFICS_ITEM: _nonSpecificsItem ? FormService.getNoteNonSpecifics(form_type) : null,\n                    SPECIFICS_ITEM: (specifics) ? FormService.getNoteSpecificsAll(form_type, specifics) : null,\n                };\n\n                // form_json茫聛庐氓聠\u0085氓庐鹿茫聜聮盲赂聙忙聶聜氓陇聣忙聲掳茫聛芦盲驴聺忙聦聛茫聛聶茫聜聥\n                const formJsonItemsNote = angular.copy(form_data_json.form_items_note);\n                const resultFormItemsNote = {};\n                if (!util.isUndefinedOrNull(formJsonItemsNote)) {\n                    // baseFormItemsNote茫聛芦form_json茫聛庐BASE_ITEM茫聛篓NON_SPECIFICS_ITEM茫聛庐氓聠\u0085氓庐鹿茫聜聮盲赂聤忙聸赂茫聛聧茫聛聶茫聜聥\n                    resultFormItemsNote.BASE_ITEM = FormService.getFormJsonNote(\n                        baseFormItemsNote.BASE_ITEM,\n                        formJsonItemsNote.BASE_ITEM\n                    );\n                    resultFormItemsNote.NON_SPECIFICS_ITEM = FormService.getFormJsonNote(\n                        baseFormItemsNote.NON_SPECIFICS_ITEM,\n                        formJsonItemsNote.NON_SPECIFICS_ITEM\n                    );\n\n                    if (\n                        !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM) \u0026\u0026\n                        util.isUndefinedOrNull(specifics)\n                    ) {\n                        // 忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛搂忙聵聨莽麓掳茫聛聜茫聜聤茫聛庐忙鲁篓猫篓聵茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛氓聣聤茅聶陇茫聛聶茫聜聥\n                        // 茅聛聨氓聨禄茫聛庐忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥茫聛聦盲禄聤茫聛庐茫聛篓茫聛聯茫聜聧猫漏虏氓陆聯茫聛聶茫聜聥\n                        formJsonItemsNote.SPECIFICS_ITEM = null;\n                    }\n\n                    // form_json茫聛庐盲赂颅茫聛芦氓陇聳猫虏篓氓聬聢猫篓聢茅聡聭茅隆聧(TOTAL_EXCHANGE_FEE)茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛芦猫驴陆氓聤聽茫聛聶茫聜聥\n                    if (\n                        !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM)\n                        \u0026\u0026 util.isUndefinedOrNull(\n                            formJsonItemsNote.SPECIFICS_ITEM.TOTAL_EXCHANGE_FEE\n                        )\n                    ) {\n                        formJsonItemsNote.SPECIFICS_ITEM.TOTAL_EXCHANGE_FEE = (\n                            FormService.getNoteSpecificsTotalExchangeFee(\n                                form_type,\n                                specifics\n                            )\n                        );\n                    }\n\n                    // 忙聵聨莽麓掳茅聽\u0085莽聸庐茫聛庐忙鲁篓猫篓聵茫聛庐\u003cbr\u003e茫聜聮忙聰鹿猫隆聦忙聳聡氓颅聴茫聛芦氓陇聣忙聫聸\n                    if (\n                        !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM)\n                        \u0026\u0026 !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM.ROW)\n                    ) {\n                        formJsonItemsNote.SPECIFICS_ITEM.ROW.forEach((noteRow) =\u003e {\n                            if (util.isUndefinedOrNull(noteRow)) {\n                                return;\n                            }\n                            Object.keys(noteRow).forEach((key) =\u003e {\n                                const item = noteRow[key];\n                                if (util.isUndefinedOrNull(item)) {\n                                    return;\n                                }\n                                item.note = item.note ? FormService.convertLineBreak(item.note, false) : item.note;\n                            });\n                        });\n                    }\n                    // SPECIFICS_ITEM茫聛芦茫聛陇茫聛聞茫聛娄茫聛炉茫聙聛忙聴垄氓颅聵忙聵聨莽麓掳茫聛庐茅聽\u0085莽聸庐茫聛聦盲禄聤氓戮聦氓垄聴茫聛聢茫聜聥茫聛聯茫聛篓茫聛炉茫聛聤茫聛聺茫聜聣茫聛聫茫聛陋茫聛聞茫聛聼茫聜聛form_json茫聛庐忙聝\u0085氓聽卤茫聜聮莽聸麓忙聨楼忙聽录莽麓聧茫聛聶茫聜聥\n                    resultFormItemsNote.SPECIFICS_ITEM = formJsonItemsNote.SPECIFICS_ITEM;\n                } else {\n                    // 忙鲁篓猫篓聵茫聛庐茫聜颅茫聝录茫聜聮忙聦聛茫聛聼茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛氓庐職忙聲掳茫聛聥茫聜聣莽聸麓忙聨楼茫聜鲁茫聝聰茫聝录茫聛聶茫聜聥\n                    const baseFormItemsNoteKeys = Object.keys(baseFormItemsNote);\n                    baseFormItemsNoteKeys.forEach((key) =\u003e {\n                        resultFormItemsNote[key] = baseFormItemsNote[key];\n                    });\n                }\n\n                // 忙聹聙忙聳掳茫聛芦盲陆聹忙聢聬茫聛聴茫聛聼忙鲁篓猫篓聵茫聛庐氓聠\u0085氓庐鹿茫聜聮茫聙聛茫聝聲茫聜漏茫聝录茫聝聽茫聛庐忙聝\u0085氓聽卤茫聛芦忙聽录莽麓聧茫聛聶茫聜聥\n                form_data_json.form_items_note = resultFormItemsNote;\n\n                // 茫聝聠茫聝鲁茫聝聴茫聝卢茫聝录茫聝聢氓聛麓茫聛庐茫聝聬茫聜陇茫聝鲁茫聝聣莽聰篓茫聛芦莽聼颅莽赂庐\n                $scope.BASE_ITEM = form_data_json.form_items_note.BASE_ITEM;\n                $scope.NON_SPECIFICS_ITEM = form_data_json.form_items_note.NON_SPECIFICS_ITEM;\n                $scope.SPECIFICS_ITEM = form_data_json.form_items_note.SPECIFICS_ITEM;\n            }\n\n            // 盲禄聲猫篓鲁茅聽\u0085莽聸庐猫篓颅氓庐職茫聛庐氓聫聳氓戮聴\n            $scope.form_data.request_form_custom_item = CreateRequestFormCustomItemService.initFormCustomItem(\n                data.form_custom_item_settings\n            );\n\n            $scope.form_data.approval_group_position_setting_flg\n                = data.approval_group_position_setting_flg;\n\n            // 忙聹聙忙聳掳茫聛庐flow茫聝聡茫聝录茫聜驴氓聫聳氓戮聴\n            var flow_promise = _getLatestFlow(data.flow.id);\n            var extraflow_promise = getExtraFlowData(form_id);\n            var circulation_promise =\n                getLatestCirculationUsers(data.flow.id, $scope.requester_info.requester_group_id);\n\n            // EC茫聜碌茫聜陇茫聝聢茫聛聥茫聜聣茫聛庐茫聜鲁茫聝录茫聝芦茫聝聬茫聝聝茫聜炉茫聛搂茫聛聜茫聜聦茫聛掳茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛聥茫聜聣茫聝聡茫聝录茫聜驴茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n            const ec_session_data_promise = getEcCallBackSessionData();\n\n            $q.all([flow_promise, circulation_promise, extraflow_promise, ec_session_data_promise])\n                .then(function(result) {\n                $scope.flow_data = result[0];\n                $scope.flow_circulation_users = result[1];\n\n                // EC茫聜碌茫聜陇茫聝聢茫聛聥茫聜聣茫聜鲁茫聝录茫聝芦茫聝聬茫聝聝茫聜炉茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢茫聛庐茫聛驴茫聙聛茫聜鹿茫聝聢茫聝卢茫聝录茫聜赂茫聜聞茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛庐茫聝聡茫聝录茫聜驴茫聜聮莽聰鲁猫芦聥茫聛芦氓聫聧忙聵聽茫聛聶茫聜聥\n                const ec_session_data_promise_result = result[3];\n                if (ec_session_data_promise_result.CALLBACK_FROM_EC_FLG) {\n                    getEcEvacuationData(ec_session_data_promise_result);\n                }\n\n                setCirculationPositionAndUsers($scope.flow_circulation_users);\n                _setDefaultFlow($scope.flow_data.id, false, false);\n            });\n\n            // 莽虏戮莽庐聴忙聹聼忙聴楼猫篓颅氓庐職茫聜聮氓聫聳氓戮聴\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE\n                \u0026\u0026 !util.isUndefinedOrNull($scope.form_data.expense)) {\n                if ($scope.form_data.expense.settlement_flg\n                    == Const.miscellaneous._FORM_TYPE.EXPENSE_PRE_APPLY.settlement_flg\n                ) {\n                    SettlementDeadlineService.getSetting($scope.form_data.form_id).then(function (result) {\n                        $scope.settlement_deadline.setting = result.settlement_deadline_setting;\n                    });\n                }\n            }\n\n            // 猫陋卢忙聵聨猫鲁聡忙聳聶茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴氓聫聳氓戮聴\n            getFormFiles(form_id);\n\n            // 氓聡潞氓录碌忙聝\u0085氓聽卤茫聛庐猫篓颅氓庐職\n            $scope.form_data.business_trip_info = null;\n            $q.all([\n                attendanceService.getBusinessTripDestination(),\n                attendanceService.getBusinessTripDateFormItems(form_id),\n            ]).then(function(res){\n                if (Object.keys(res[1].data).length) {\n                    // 氓聡潞氓录碌忙聝\u0085氓聽卤茫聜聮茅聙拢忙聬潞茫聛聶茫聜聥\n                    $scope.form_data.is_share_business_trip_date = true;\n                    $scope.form_data.business_trip_info = {\n                        // 氓聡潞氓录碌氓\u0085聢茫聛庐茅聛赂忙聤聻猫聜垄猫篓颅氓庐職茂录聢氓聢聺忙聹聼猫隆篓莽陇潞茂录聣\n                        destinations: res[0].data,\n                        // 茂录聭盲禄露莽聸庐茫聜聮茅聛赂忙聤聻茫聛聶茫聜聥 芒聙禄destinations茫聛炉{id:\u0027\u0027, name=\u0027\u0027}茫聛庐茅\u0085聧氓聢聴茫聜聮忙聦聛茫聛陇\n                        destination: res[0].data[0].id,\n                        // 氓聡潞氓录碌忙聴楼茫聛篓茫聛聴茫聛娄氓聫聜莽\u0085搂茫聛聶茫聜聥茅聽\u0085莽聸庐茫聜聮茫聛聺茫聛庐茫聛戮茫聛戮盲驴聺忙聦聛\n                        date_or_term_item: mapped_items[res[1].data.form_item],\n                        // 氓聡潞氓录碌忙聴楼茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐id茂录聢莽聰禄茅聺垄茅聺聻猫隆篓莽陇潞茫聙聛莽聶禄茅聦虏忙聶聜茫聛芦盲陆驴莽聰篓茂录聣\n                        business_trip_date_form_items_id: res[1].data.id,\n                    };\n                } else {\n                    // 氓聡潞氓录碌忙聝\u0085氓聽卤茫聜聮茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞\n                    $scope.form_data.is_share_business_trip_date = false;\n                }\n            });\n            // 氓聥陇忙聙聽忙聣聯氓聢禄茅聙拢忙聬潞忙聝\u0085氓聽卤氓聫聳氓戮聴\n            _getAttendanceSettings();\n            // 莽碌聦猫虏禄茫聝禄忙聰炉忙聣聲茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聙聛忙聵聨莽麓掳茫聛聦忙聹聣茫聜聤茫聙聛茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛聦忙聹聣茫聜聥氓聽麓氓聬聢茫聙聛茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐忙聹聙忙聳掳茫聛庐忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n            if (\n                $scope.isSpecificsSheet() \u0026\u0026\n                ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE ||\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT)\n            ) {\n                specifics.map(function (specific) {\n                    if (!CustomSpecificsService.isCustomSpecifics(specific)) {\n                        // 忙聴垄氓庐職茫聛庐忙聵聨莽麓掳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n                        return;\n                    }\n                    CustomSpecificsService.getCustomSpecifics(specific.form_custom_specific_id).then(function (res) {\n                        // TODO DB茫聝聡茫聝录茫聜驴茫聜聮盲陆驴茫聛拢茫聛娄茫聝聠茫聝录茫聝聳茫聝芦茫聛庐茫聝聡茫聝录茫聜驴茫聜聮忙搂聥忙聢聬茫聛聴茫聛娄茫聛聞茫聛聫茫聙聜\n                        _makeCustomSpecifics(res.data, specific);\n                    });\n                });\n            }\n        }, function(data) {\n            notifyService.showNotify(data, \u0027alert-danger\u0027);\n            $scope.is_request_error = true;\n            $scope.error_message = data;\n            $location.path(\u0027/request\u0027);\n        });\n    }\n\n    /**\n     * 莽碌聦猫虏禄莽虏戮莽庐聴忙聵聨莽麓掳茫聛庐茫聝聬茫聝录茫聜赂茫聝搂茫聝鲁氓路庐氓聢聠茫聜聮氓聼聥茫聜聛茫聜聥\n     * @param {Array} specificsSheets\n     * @return {Array}\n     */\n    function _fixVersionDifferenceForExpenseSpecifics(specificsSheets) {\n        return FormService.fixVersionDifferenceForExpenseSpecifics(specificsSheets);\n    }\n\n    /**\n     * 忙聲掳氓聙陇茫聜聮忙聳聡氓颅聴氓聢聴茫聛篓茫聛聴茫聛娄氓聫聴茫聛聭氓聫聳茫聜聤茫聙聛忙聲麓忙聲掳茅聝篓氓聢聠茫聛芦茫聜芦茫聝鲁茫聝聻氓聦潞氓聢聡茫聜聤茂录聢3忙隆聛茫聛聰茫聛篓茂录聣茫聛聦忙聦驴氓\u0085楼茫聛聲茫聜聦茫聛聼忙聳聡氓颅聴氓聢聴茫聛芦氓陇聣忙聫聸茫聛聶茫聜聥(氓掳聫忙聲掳莽聜鹿盲禄楼盲赂聥茫聛炉氓\u0085聝茫聛庐茫聛戮茫聛戮盲驴聺忙聦聛)\n     * 19忙隆聛茫聛庐忙聲掳氓聙陇茫聛芦氓炉戮氓驴聹茫聛聴盲赂赂茫聜聛猫陋陇氓路庐茫聛聦莽聶潞莽聰聼茫聛聴茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n     * @param {string} value 茫聜芦茫聝鲁茫聝聻氓聦潞氓聢聡茫聜聤茫聜聮茅聛漏莽聰篓茫聛聴茫聛聼茫聛聞忙聲掳氓聙陇茫聜聮猫隆篓茫聛聶忙聳聡氓颅聴氓聢聴\n     * @return {string} 氓陇聣忙聫聸氓戮聦忙聳聡氓颅聴氓聢聴\n     */\n    $scope.formatWithCommas = function(value) {\n        if (util.isUndefinedOrNull(value)) return \u0027\u0027;\n\n        const strValue = String(value);\n        const decimalSeparator = util.getDecimalSeparator();\n\n        // 氓掳聫忙聲掳莽聜鹿猫篓聵氓聫路茫聛搂氓聢聠氓聣虏\n        const parts = strValue.split(decimalSeparator);\n        let [integerPart, decimalPart] = [Number(parts[0]).toLocaleString(), parts[1]];\n\n        // 氓掳聫忙聲掳茅聝篓氓聢聠茫聛庐氓聡娄莽聬聠茂录聢忙聹芦氓掳戮茫聛庐茫聜录茫聝颅茫聜聮氓聣聤茅聶陇茂录聣\n        if (decimalPart) {\n            decimalPart = decimalPart.replace(/0+$/, \u0027\u0027);\n            if (decimalPart === \u0027\u0027) {\n                return integerPart;\n            }\n            return `${integerPart}${decimalSeparator}${decimalPart}`;\n        }\n\n        return integerPart;\n    };\n\n    /**\n     * 氓\u0085篓茫聛娄茫聛庐忙聵聨莽麓掳猫隆篓茫聛芦盲赂颅茫聛芦茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳(莽聜潞忙聸驴茫聝卢茫聝录茫聝聢)茫聛聦氓颅聵氓聹篓茫聛聶茫聜聥茫聛聥茫聛陇猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥茫聛庐氓聢陇忙聳颅\n     * @return {boolean}\n     */\n    $scope.isDisplayCustomPaymentExchangeSpecifics = function() {\n        if (!$scope.form_data || !$scope.form_data.payment || !$scope.form_data.payment.request_payment_specifics) {\n            return false;\n        }\n        const displaySpecifics = _getDisplayingSpecificsSheets($scope.form_data.payment.request_payment_specifics);\n        const targetSheets = displaySpecifics.filter(\n            (sheet) =\u003e createRequestService.isCustomPaymentExchange(sheet.specifics_type));\n        return targetSheets.length \u003e 0;\n    };\n\n    /**\n     * 莽碌聦猫虏禄莽虏戮莽庐聴忙聵聨莽麓掳茫聛庐氓聢聠氓聣虏忙聵聨莽麓掳茫聛庐氓颅聬忙聵聨莽麓掳茫聛芦猫娄陋忙聵聨莽麓掳茫聛庐忙聝\u0085氓聽卤茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n     * @param {Array} specificsSheets\n     * @return {Array}\n     */\n    function _setParentRow(specificsSheets) {\n        return FormService.setParentRow(specificsSheets);\n    }\n\n    /**\n     * 氓聫聳氓录聲氓\u0085聢氓聬聧茫聜聮氓\u0085聝茫聛芦氓聫聳氓录聲氓\u0085聢茫聝聻茫聜鹿茫聜驴茫聛芦莽聶禄茅聦虏茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿莽聶禄茅聦虏莽聲陋氓聫路茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n     * @param {boolean} needs_company_info 氓聫聳氓录聲氓\u0085聢茫聝聻茫聜鹿茫聜驴茫聛芦莽聶禄茅聦虏茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥莽聶禄茅聦虏莽聲陋氓聫路茫聛聦氓驴\u0085猫娄聛茫聛聥\n     *                                      (True: 氓驴\u0085猫娄聛茫聙聛False: 盲赂聧猫娄聛)\n     * @return {promise}\n     */\n    function setInvoiceRegistratedNumber(needs_company_info) {\n        const defer = $q.defer();\n        if (!needs_company_info || $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            // 氓聫聳氓录聲氓\u0085聢茫聝聻茫聜鹿茫聜驴茫聛聥茫聜聣莽聶禄茅聦虏莽聲陋氓聫路茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥氓驴\u0085猫娄聛茫聛聦茫聛陋茫聛聞茫聙聛\n            // 茫聛戮茫聛聼茫聛炉莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            defer.resolve();\n            return defer.promise;\n        }\n\n        var company_ids = [];\n        const _isPayeePerRequest = (\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT\n            \u0026\u0026 $scope.form_data.payment.is_payee_per_request\n        );\n        if (!$scope.isSpecificsSheet() || _isPayeePerRequest) {\n            // 茅聺聻忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n            if ($scope.form_data.payment.is_new_company) {\n                // 忙聰炉忙聣聲盲戮聺茅聽录茫聛搂忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛庐氓聽麓氓聬聢盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n                defer.resolve();\n                return defer.promise;\n            }\n\n            if (angular.isUndefinedOrNull($scope.form_data.payment.company_id)) {\n                // 氓聫聳氓录聲氓\u0085聢茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n                defer.resolve();\n                return defer.promise;\n            }\n            company_ids.push($scope.form_data.payment.company_id);\n            // 氓聫聳氓戮聴茫聛聴茫聛聼氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓\u0085聝茫聛芦莽聰鲁猫芦聥茫聛庐莽聶禄茅聦虏莽聲陋氓聫路茫聜聮忙聸麓忙聳掳\n            createRequestService.getCompanyListByIds(company_ids)\n            .then(function (res) {\n                if (res.data.length \u003e 0\n                    \u0026\u0026 res.data[0].id === $scope.form_data.payment.company_id\n                    \u0026\u0026 res.data[0].name === $scope.form_data.payment.company_name) {\n                    $scope.form_data.payment.invoice_registrated_number =\n                        res.data[0].invoice_registrated_number;\n                }\n                defer.resolve();\n            });\n            return defer.promise;\n        }\n\n        // 忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n        // 氓\u0085篓忙聵聨莽麓掳茫聛庐氓聫聳氓录聲氓\u0085聢茫聜聮company_ids茫聛芦忙聽录莽麓聧\n        $scope.form_data.payment.request_payment_specifics.forEach(function(specifics) {\n            specifics.request_payment_specifics_rows.forEach(function(row) {\n                if (!angular.isUndefinedOrNull(row.company_id)\n                    \u0026\u0026 !angular.isUndefinedOrNull(row.is_new_company)\n                    \u0026\u0026 !row.is_new_company) {\n                        company_ids.push(row.company_id);\n                }\n            });\n        });\n\n        if (company_ids.length === 0) {\n            // 氓聫聳氓录聲氓\u0085聢茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            defer.resolve();\n            return defer.promise;\n        }\n        // 氓聫聳氓戮聴茫聛聴茫聛聼氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓\u0085聝茫聛芦莽聰鲁猫芦聥茫聛庐莽聶禄茅聦虏莽聲陋氓聫路茫聜聮忙聸麓忙聳掳\n        // eslint-disable-next-line es5/no-es6-static-methods\n        createRequestService.getCompanyListByIds(Array.from(new Set(company_ids)))\n        .then(function (res) {\n            $scope.form_data.payment.request_payment_specifics.forEach(function(specifics) {\n                specifics.request_payment_specifics_rows.forEach(function(row) {\n                    const item = res.data.filter(function(result) {\n                        return (result.id === row.company_id \u0026\u0026 result.name === row.company_name);\n                    });\n                    if (item.length \u003e 0) {\n                        row.invoice_registrated_number = item[0].invoice_registrated_number;\n                    }\n                });\n            });\n\n            defer.resolve();\n        });\n        return defer.promise;\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛庐茅聺聻忙聵聨莽麓掳茫聜驴茫聜陇茫聝聴茫聛庐忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛庐莽聶禄茅聦虏莽聲陋氓聫路茫聝聛茫聜搂茫聝聝茫聜炉氓聡娄莽聬聠茫聜聮猫隆聦茫聛聠\n     * @return {promise}\n     */\n    function checkNewCompanyInvoiceRegistratedNumber() {\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            // 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            return;\n        }\n        if (\n            (\n                $scope.isSpecificsSheet()\n                \u0026\u0026 !$scope.form_data.payment.is_payee_per_request\n            )\n            || !$scope.form_data.payment.is_new_company\n        ) {\n            // 忙聵聨莽麓掳茫聜聮氓聬芦茫聜聙茫聛聦莽聰鲁猫芦聥忙聸赂茫聛聰茫聛篓茫聛芦忙聰炉忙聣聲氓\u0085聢茫聜聮忙聦聡氓庐職茫聛聴茫聛陋茫聛聞莽聰鲁猫芦聥茫聙聛茫聛戮茫聛聼茫聛炉忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢茫聛庐茅聺聻忙聵聨莽麓掳茫聛庐莽聰鲁猫芦聥茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            return;\n        }\n        if ($scope.form_data.payment.is_new_company \u0026\u0026 !$scope.form_data.payment.invoice_registrated_number_part) {\n            // 莽聶禄茅聦虏莽聲陋氓聫路茫聛聦盲赂聙氓潞娄氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛娄氓聣聤茅聶陇茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢茫聛炉invoice_registrated_number茫聛芦氓聙陇茫聛聦忙庐聥茫聛拢茫聛娄茫聛聞茫聜聥茫聛庐茫聛搂茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n            // 茫聛戮茫聛聼茫聙聛氓\u0085聝茫聙\u0085忙聹陋氓\u0085楼氓聤聸茫聛搂undefined茫聛聽茫聛拢茫聛聼氓聽麓氓聬聢茫聜聜null茫聜聮茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥茂录聢猫漏鲁莽麓掳茫聛炉#15596茫聛庐氓炉戮氓驴聹忙聳鹿茅聡聺茫聜聮氓聫聜莽\u0085搂茂录聣\n            if (\n                angular.isUndefined($scope.form_data.payment.invoice_registrated_number) ||\n                $scope.form_data.payment.invoice_registrated_number\n            ) {\n                $scope.form_data.payment.invoice_registrated_number = null;\n            }\n            // 忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛搂莽聶禄茅聦虏莽聲陋氓聫路茫聛聦氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞茫聙聛茫聜聜茫聛聴茫聛聫茫聛炉盲赂聙氓潞娄氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛娄茫聜炉茫聝陋茫聜垄茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            return;\n        }\n\n        // 莽聶禄茅聦虏莽聲陋氓聫路茫聛庐氓颅聵氓聹篓茫聝聛茫聜搂茫聝聝茫聜炉\n        // 莽聰禄茅聺垄茫聛庐氓\u0085楼氓聤聸氓聙陇茫聛聥茫聜聣莽聶禄茅聦虏莽聲陋氓聫路茫聜聮猫篓颅氓庐職\n        const invoice_registrated_number = \u0027T\u0027 + $scope.form_data.payment.invoice_registrated_number_part;\n        $scope.form_data.payment.invoice_registrated_number = invoice_registrated_number;\n        return createRequestService.checkInvoiceRegistratedNumbers([invoice_registrated_number]);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥氓聠\u0085茫聛芦茫聛聜茫聜聥茫聛聶茫聛鹿茫聛娄茫聛庐茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿莽聶禄茅聦虏莽聲陋氓聫路茫聜聮氓颅聵氓聹篓茫聝聛茫聜搂茫聝聝茫聜炉茫聛聴茫聙聛莽\u0085搂盲录職莽碌聬忙聻聹茫聜聮忙聸麓忙聳掳茫聛聶茫聜聥茫聙聜\n     * @param {boolean} needs_company_info 氓聫聳氓录聲氓\u0085聢茫聝聻茫聜鹿茫聜驴茫聛芦莽聶禄茅聦虏茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥莽聶禄茅聦虏莽聲陋氓聫路茫聛聦氓驴\u0085猫娄聛茫聛聥\n     *                                     (True: 氓驴\u0085猫娄聛茫聙聛False: 盲赂聧猫娄聛)\n     */\n    function checkInvoiceRegistratedNumbers(needs_company_info) {\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_EXPENSE \u0026\u0026\n            $scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽茫聛篓忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            return;\n        }\n\n        setInvoiceRegistratedNumber(needs_company_info).then(function () {\n            var invoice_registrated_numbers = [];\n            const _isPayeePerRequest = (\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT\n                \u0026\u0026 $scope.form_data.payment.is_payee_per_request\n            );\n            if (!$scope.isSpecificsSheet() || _isPayeePerRequest) {\n                // 茅聺聻忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n                var invoice_registrated_number = null;\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    invoice_registrated_number = $scope.form_data.expense.invoice_registrated_number;\n                } else {\n                    invoice_registrated_number = $scope.form_data.payment.invoice_registrated_number;\n                }\n                if (angular.isUndefinedOrNull(invoice_registrated_number)) {\n                    // 茫聝聛茫聜搂茫聝聝茫聜炉氓炉戮猫卤隆茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳盲陆聲