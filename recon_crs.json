  });\n            }\n\n            if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.COPY) {\n                // 茫聜驴茫聜陇茫聝聢茫聝芦茫聛庐茫聜鲁茫聝聰茫聝录\n                $scope.form_data.title = gettextCatalog.getString(\u0027茫聜鲁茫聝聰茫聝录茂录職\u0027) + $scope.form_data.request_data_json.title;\n\n                // 氓陇聳茅聝篓茅聙拢忙聬潞忙聹聣莽聞隆茫聛庐茫聜鲁茫聝聰茫聝录\n                $scope.form_data.cloudsign_setting_flg = $scope.form_data.request_data_json.cloudsign_setting_flg;\n                $scope.form_data.box_setting_flg = $scope.form_data.request_data_json.box_setting_flg;\n                $scope.form_data.hubble_setting_flg = $scope.form_data.request_data_json.hubble_setting_flg;\n\n                // 忙聰炉忙聣聲氓\u0085聢氓\u0085楼氓聤聸忙聹聣莽聞隆茫聛庐茫聜鲁茫聝聰茫聝录\n                $scope.form_data.company_input_setting_flg =\n                    $scope.form_data.request_data_json.company_input_setting_flg;\n\n                // 忙聹聙莽碌聜忙聣驴猫陋聧忙聹聼茅聶聬茫聛炉茫聜鲁茫聝聰茫聝录茫聛聴茫聛陋茫聛聞\n                $scope.last_approval_period.selected_flg = 0;\n                // 茫聝漏茫聜赂茫聜陋茫聝聹茫聜驴茫聝鲁茫聛聦氓聢聺忙聹聼氓聦聳茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聭茫聜聦茫聛掳氓聢聺忙聹聼氓聦聳茫聛聶茫聜聥\n                angular.forEach($scope.form_data.request_data_json.form_json, function(item) {\n                    if (item.item_type === Const.form.ITEM_TYPE_RADIO\n                            \u0026\u0026 angular.isUndefinedOrNull(item.request_content)) {\n                        item.custom_radio = item.select_item_labels[0];\n                        item.request_content = item.select_item_labels[0];\n                    }\n                });\n\n                // 忙聹聙忙聳掳茫聛庐莽碌聦猫路炉氓聫聳氓戮聴\n                flow_promise = _getLatestFlow(flow_id);\n                // 忙聹聙忙聳掳茫聛庐茅聳虏猫娄搂猫聙\u0085氓聫聳氓戮聴\n                circulation_promise = getLatestCirculationUsers(flow_id, $scope.requester_info.requester_group_id);\n                // 忙聹聙忙聳掳茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聥茫聜聣茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢氓聠\u0085猫篓鲁茫聜聮氓聫聳氓戮聴\n                $scope.form_data.default_atp = angular.fromJson(data.default_atp || \u0027null\u0027);\n\n                // 茫聜鲁茫聝聰茫聝录茫聛庐氓聽麓氓聬聢茫聛炉氓\u0085聝茫聛庐忙聝\u0085氓聽卤茫聛聦莽漏潞茫聛搂茫聜聜茅聤聙猫隆聦忙聝\u0085氓聽卤茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n                // 茂录聢忙聞聫氓聸鲁莽職聞茫聛芦氓聫拢氓潞搂忙聝\u0085氓聽卤茫聜聮莽漏潞茫聛芦茫聛聴茫聛聼茫聛庐茫聛聥茫聛漏茫聛聠茫聛聥氓聢陇氓庐職茫聛聦茅聸拢茫聛聴茫聛聞莽聜潞茂录聣\n                $scope.isDisplayBank = true;\n\n                // 氓聥陇忙聙聽茅聙拢忙聬潞盲潞陇茅聙職猫虏禄茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛茫聜鲁茫聝聰茫聝录茫聛炉茫聛搂茫聛聧茫聛娄茫聜聜莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聙聛茫聛聺茫聛庐忙聵聨莽麓掳茫聛芦茫聝聛茫聜搂茫聝聝茫聜炉茫聜聮茫聛陇茫聛聭茫聜聥\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    CreateRequestExpenseSpecificsService.setRowAsCopyKintaiTransport(\n                        $scope.form_data.request_data_json.expense.request_expense_specifics);\n                }\n\n                // 盲鹿聴忙聫聸忙隆聢氓聠\u0085忙陇聹莽麓垄茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛庐猫篓颅氓庐職茫聜聮茫聝聲茫聜漏茫聝录茫聝聽忙聝\u0085氓聽卤茫聛聥茫聜聣氓聫聳氓戮聴茫聛聶茫聜聥\n                // 忙聵聨莽麓掳忙聝\u0085氓聽卤specifics茫聛芦茫聛炉莽聰鲁猫芦聥忙聶聜茫聛庐猫篓颅氓庐職茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聥茫聛庐茫聛搂莽陆庐茫聛聧忙聫聸茫聛聢茫聜聥\n                if (data.request_form.specifics_json) {\n                    var specifics_json = angular.fromJson(data.request_form.specifics_json);\n                    for(var i = 0 ; i \u003c specifics_json.length ; i++) {\n                        if (specifics_json[i].specific_route_search_settings) {\n                            specifics[i].specific_route_search_settings =\n                                specifics_json[i].specific_route_search_settings;\n                        }\n                    }\n                }\n\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聫聳氓戮聴茂录聢custom_specific_promise茂录聣茫聛庐莽碌聬忙聻聹茫聜聮氓戮\u0085茫聛聼茫聛陋茫聛聞茫聛篓茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聛芦氓聠\u0085猫篓鲁茫聛聦氓聫聳茫聜聦茫聛職茫聙聛_setDefaultFlow茫聛聦莽漏潞茫聛露茫聜聤茫聛聶茫聜聥茫聛聼茫聜聛茫聙聛氓戮\u0085茫聛陇氓驴\u0085猫娄聛茫聛聦茫聛聜茫聜聥茫聙聜\n                $q.all([\n                    flow_promise,\n                    circulation_promise,\n                    extraflow_promise,\n                    custom_specific_promise,\n                    AllowanceCategoryService.getAllowancesForRequest($scope.login_user.id),\n                ]).then(function(result) {\n                    $scope.flow_data = result[0];\n                    $scope.request_flow_data = angular.copy($scope.flow_data);\n                    $scope.flow_circulation_users = result[1];\n                    // 盲陆驴莽聰篓氓聫炉猫聝陆茫聛陋忙聣聥氓陆聯忙聝\u0085氓聽卤\n                    $scope.available_allowances = result[4].data;\n                    return _setLatestExchange();\n                }).then(function(){\n                    checkInvoiceRegistratedNumbers(true);\n                    setCirculationPositionAndUsers($scope.flow_circulation_users);\n                    _setDefaultFlow(data.request_form.flow.id, true, false);\n                    _recalcAllowanceAmount();\n                    // 氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n                    _setCompanyDataByRequest();\n                    _getSumPaymentExchangeSpecificsAmount();\n\n                    // TODO: 茫聝聬茫聝聝茫聜炉茫聜篓茫聝鲁茫聝聣茫聛庐茫聝陋茫聝聲茫聜隆茫聜炉茫聜驴茫聝陋茫聝鲁茫聜掳氓戮聦茫聛芦氓聣聤茅聶陇氓聡娄莽聬聠茫聜聮茫聝聬茫聝聝茫聜炉茫聜篓茫聝鲁茫聝聣茫聛搂猫隆聦茫聛聠茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n                    const isDeleteNewCompany = _deleteNewCompanyByCopy();\n                    const isDeletedAllowance = _deleteAllowanceByCopy();\n\n                    // 茫聜鲁茫聝聰茫聝录茫聛搂茫聛聧茫聛陋茫聛聞茅聽\u0085莽聸庐茫聛聦茫聛聜茫聛拢茫聛聼氓聽麓氓聬聢茫聛炉notify\n                    if (!$scope.form_data.request_data_json.is_success_to_all_copy ||\n                        isDeleteNewCompany ||\n                        isDeletedAllowance\n                    ) {\n                        notifyService.showNotify(\n                            gettextCatalog.getString(\u0027茫聝聲茫聜漏茫聝录茫聝聽茫聛庐茅聽\u0085莽聸庐茫聛聦氓陇聣忙聸麓茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聼茫聜聛茫聙聛盲赂聙茅聝篓茫聛庐茅聽\u0085莽聸庐茫聛炉茫聜鲁茫聝聰茫聝录茫聛聲茫聜聦茫聛戮茫聛聸茫聜聯茫聛搂茫聛聴茫聛聼\u0027),\n                            \u0027alert-danger\u0027);\n                    }\n                    // 氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聛庐猫隆篓莽陇潞氓聢露氓戮隆茫聝聲茫聝漏茫聜掳氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n                    _setCompanyIsShowFlagsByRequest();\n                    _validatePayeeAndFormS