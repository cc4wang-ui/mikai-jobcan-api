ssage.join(\u0027\u003cbr/\u003e\u0027) : data.error_message;\n                            notifyService.showNotify(message, \u0027alert-danger\u0027);\n                        }\n                        $scope.createing_request = false;\n                        CustomSpecificsConvertService.restoration_custom_specifics(\n                            $scope.form_type, $scope.form_data, $scope.custom_specific_buck_up);\n\n                        // 茅聙聙茅聛驴茫聛聴茫聛娄茫聛聞茫聛聼忙聝\u0085氓聽卤茫聜聮忙聢禄茫聛聶\n                        $scope.form_data.extra_flows = savedExtraFlows;\n                    });\n            }\n            else if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                // 盲驴庐忙颅拢氓卤楼忙颅麓茫聛芦忙聶聜氓聢禄茫聛篓茫聝娄茫聝录茫聜露氓聬聧茫聛篓氓聠\u0085氓庐鹿茫聜聮猫篓颅氓庐職\n                // 忙聣驴猫陋聧氓戮聦茫聛芦盲驴庐忙颅拢茫聛聦茫聛聜茫聛拢茫聛聼茫聛聥茫聛漏茫聛聠茫聛聥茫聜聮氓聢陇氓庐職茫聛聶茫聜聥茫聛聼茫聜聛茫聛芦莽路篓茅聸聠忙聶聜茫聛庐忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聜聮猫驴陆氓聤聽 #10193\n                const userName = `${$scope.login_user.last_name} ${$scope.login_user.first_name}`;\n                const currentFlow = CreateRequestFlowService.getCurrentVersionSteps($scope.prev_flow);\n                const log = {\n                    \u0027datetime\u0027: dateFormat.format(new Date(), \u0027yyyy/MM/dd hh:mm\u0027),\n                    \u0027user\u0027: {\u0027id\u0027: $scope.login_user.id, \u0027name\u0027: userName},\n                    \u0027detail\u0027: ModifyService.getCorrectionHistory(),\n                    \u0027flow_step_number\u0027: CreateRequestFlowService.getCurrentFlowStepNumber(currentFlow),\n                };\n                // 忙聴垄氓颅聵茫聛庐盲驴庐忙颅拢氓卤楼忙颅麓茫聛聦茫聛陋茫聛聭茫聜聦茫聛掳氓聢聺忙聹聼氓聦聳茫聛聴茫聙聛忙聳掳猫娄聫茫聛庐盲驴庐忙颅拢氓卤楼忙颅麓茫聜聮猫驴陆氓聤聽茫聛聶茫聜聥\n                if (angular.isUndefinedOrNull($scope.modify_logs)) {\n                    $scope.modify_logs = [];\n                }\n                $scope.modify_logs.unshift(log);\n\n                request_data.modify_logs = $scope.modify_logs;\n                request_data.version = version;\n\n                // 茫聝聲茫聝陋