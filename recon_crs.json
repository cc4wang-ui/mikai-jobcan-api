    "login":  "ok",
    "files":  {
                  "create_request_services.js":  "\u0027use strict\u0027;\n\nvar wfServices = angular.module(\u0027WfApp.create_request_services\u0027, []);\n\nwfServices.factory(\u0027createRequestService\u0027, function (\n    Const,\n    util,\n    $http,\n    $q,\n    CustomSpecificsConvertService,\n    CreateRequestExpenseSpecificsService\n) {\n    return {\n        clearGroup: clearGroup,\n        clearProject: clearProject,\n        clearShippingAddress: clearShippingAddress,\n        clearBillingAddress: clearBillingAddress,\n        hasExtraOptions: hasExtraOptions,\n        getItemValue: getItemValue,\n        checkThresholdValue: checkThresholdValue,\n        checkItemOptionStatus: checkItemOptionStatus,\n        isSpecificsSheet: isSpecificsSheet,\n        isSheetInputted: isSheetInputted,\n        isFormExpense: isFormExpense,\n        isFormPayment: isFormPayment,\n        isFormEc: isFormEc,\n        isFormExpenseSpecifics: isFormExpenseSpecifics,\n        isFormChangeSettlementDeadline: isFormChangeSettlementDeadline,\n        isFormPaymentSpecifics: isFormPaymentSpecifics,\n        isCustomPaymentExchange: isCustomPaymentExchange,\n        isFormEcSpecifics: isFormEcSpecifics,\n        createRequestContent: createRequestContent,\n        initFormItemForCopy: initFormItemForCopy,\n        setRequestFilesOldToNew: setRequestFilesOldToNew,\n        extractSpecificAccountTitlePartIds: extractSpecificAccountTitlePartIds,\n        extractAccountTitlePartIds: extractAccountTitlePartIds,\n        isRelatedFormLimitSettingFromRequestId: isRelatedFormLimitSettingFromRequestId,\n        getDivisionsByCardId: getDivisionsByCardId,\n        extractCardId: extractCardId,\n        _getDivisionsByCardId: _getDivisionsByCardId,\n        getCompanyListByIds: getCompanyListByIds,\n        checkInvoiceRegistratedNumbers: checkInvoiceRegistratedNumbers,\n        setTransactionExpired: setTransactionExpired,\n        isSheetInputtedCustom: isSheetInputtedCustom,\n        setCardDivisionsByCardIdOnlyNull: setCardDivisionsByCardIdOnlyNull,\n    };\n\n    function clearGroup(form_data) {\n        form_data.group = undefined;\n        form_data.group_cleared = true;\n\n        // 茅聺聻猫隆篓莽陇潞茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茫聜聜氓聣聤茅聶陇茫聛聶茫聜聥\n        if(form_data.expense){\n            form_data.expense.request_expense_specifics.filter(_isGroupHidden).forEach(function(table){\n                _clearGroupOfSpecificsRows(table.request_expense_specifics_rows);\n            });\n        }\n        if(form_data.payment){\n            form_data.payment.request_payment_specifics.filter(_isGroupHidden).forEach(function(table){\n                _clearGroupOfSpecificsRows(table.request_payment_specifics_rows);\n            });\n        }\n    }\n\n    function _isGroupHidden(table){\n        return table.specifics_group_setting === Const.miscellaneous.SPECIFICS_GROUP_SETTING_HIDE;\n    }\n\n    function _clearGroupOfSpecificsRows(rows){\n        rows.forEach(function(row){\n            row.group = null;\n        });\n    }\n\n    function clearProject(form_data) {\n        form_data.project = undefined;\n        form_data.project_name = undefined;\n        form_data.project_code = undefined;\n        form_data.project_cleared = true;\n\n        // 茅聺聻猫隆篓莽陇潞茫聛庐茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢茫聜聜氓聣聤茅聶陇茫聛聶茫聜聥\n        if(form_data.expense){\n            form_data.expense.request_expense_specifics.filter(_isProjectHidden).forEach(function(table){\n                _clearProjectOfSpecificsRows(table.request_expense_specifics_rows);\n            });\n        }\n        if(form_data.payment){\n            form_data.payment.request_payment_specifics.filter(_isProjectHidden).forEach(function(table){\n                _clearProjectOfSpecificsRows(table.request_payment_specifics_rows);\n            });\n        }\n    }\n\n    function _isProjectHidden(table){\n        return table.specifics_project_setting === Const.miscellaneous.SPECIFICS_PROJECT_SETTING_HIDE;\n    }\n\n    function _clearProjectOfSpecificsRows(rows){\n        rows.forEach(function(row){\n            row.project = null;\n        });\n    }\n\n    /**\n     * 茅\u0085聧茅聙聛氓\u0085聢茫聜聮茫聜炉茫聝陋茫聜垄\n     * @param {Object} form_data 茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     */\n    function clearShippingAddress(form_data) {\n        form_data.ec.shipping_address = {};\n        form_data.ec.shipping_address_cleared = true;\n    }\n\n    /**\n     * 猫芦聥忙卤聜氓\u0085聢茫聜聮茫聜炉茫聝陋茫聜垄\n     * @param {Object} form_data 茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     */\n    function clearBillingAddress(form_data) {\n        form_data.ec.billing_address = {};\n        form_data.ec.billing_address_cleared = true;\n    }\n\n    /**\n     * form_item茫聛芦茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁忙聝\u0085氓聽卤茫聛聦茫聛聜茫聜聥茫聛聥茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {Object} form_item 茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @param {string} option_key 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛庐莽篓庐茅隆聻\n     * @return {boolean}\n     */\n    function hasExtraOptions(form_item, option_key) {\n        return (\n            angular.isDefined(form_item.extra_options) \u0026\u0026\n            angular.isDefined(form_item.extra_options[option_key])\n        );\n    }\n\n    /**\n     * form_item茫聛庐氓聙陇茫聜聮猫驴聰氓聧麓茫聛聶茫聜聥茫聙聜item_type茫聜聮猫娄聥茫聛娄茫聙聛氓陇聣忙聲掳茫聜聮氓聢陇忙聳颅茫聛聶茫聜聥\n     * @param {Object} form_item 茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @return {number|string}\n     */\n    function getItemValue(form_item) {\n        if (form_item.item_type === Const.form.ITEM_TYPE_NUMBER) {\n            return form_item.custom_number;\n        }\n        else if (form_item.item_type === Const.form.ITEM_TYPE_RADIO) {\n            return form_item.custom_radio;\n        }\n        else if (form_item.item_type === Const.form.ITEM_TYPE_PULL_DOWN) {\n            return form_item.custom_pulldown;\n        }\n        else if (form_item.item_type === Const.form.ITEM_TYPE_CHECK) {\n            return form_item.request_content;\n        }\n    }\n\n    /**\n     * data茫聛聦忙聺隆盲禄露茫聛芦氓聬聢猫聡麓茫聛聶茫聜聥茫聛聥茫聜聮氓聢陇氓庐職茫聙聜莽碌聦猫路炉氓聢聠氓虏聬茫聙聛猫隆篓莽陇潞茫聝禄氓驴\u0085茅聽聢茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁氓聢陇氓庐職莽聰篓\n     * @param {number|string|null|undefined} data 氓聢陇氓庐職茫聛聴茫聛聼茫聛聞氓聙陇\n     * @param {string} condition_type 氓聢陇氓庐職忙聺隆盲禄露茫聛庐茫聜驴茫聜陇茫聝聴 EQ:0 GTE:1 LTE:2 IN:3 SUBSET:4 ONLY:5\n     * @param {number|string} threshold_value 氓聢聠氓虏聬茫聛聦忙卤潞茫聛戮茫聜聥氓聙陇\n     *     condition_type茫聛聦IN(氓聠\u0085猫篓鲁茫聛庐氓聽麓氓聬聢),ONLY茫聛庐氓聽麓氓聬聢茫聙聛茫聜芦茫聝鲁茫聝聻氓聦潞氓聢聡茫聜聤茫聛庐氓聠\u0085猫篓鲁ID茫聜聮忙聳聡氓颅聴氓聢聴茫聛篓茫聛聴茫聛娄忙聦聡氓庐職茫聛聶茫聜聥茫聛聯茫聛篓茫聙聜\n     *     condition_type茫聛聦EQ,GTE,LTE,IN,SUBSET茫聛庐氓聽麓氓聬聢茫聙聛data茫聛篓忙炉聰猫录聝氓聫炉猫聝陆茫聛陋氓聙陇茫聜聮忙聦聡氓庐職茫聛聶茫聜聥茫聛聯茫聛篓茫聙聜\n     * @return {boolean}\n     *     data茫聛聦null or undefined 茫聛庐氓聽麓氓聬聢茫聛炉 false 茫聜聮猫驴聰茫聛聶茫聙聜\n     *\n     * 猫拢聹猫露鲁\n     * 氓聠\u0085猫篓鲁茫聛芦茫聜聢茫聜聥莽碌聦猫路炉氓聢聠氓虏聬茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛盲禄楼盲赂聥茫聛庐氓聙陇茫聛聦氓\u0085楼茫聜聥茫聙聜\n     * data(氓聢陇氓庐職茫聛聴茫聛聼茫聛聞氓聙陇) : 莽聰鲁猫芦聥忙聶聜茫聛芦茅聛赂忙聤聻茫聛聴茫聛聼氓聠\u0085猫篓鲁ID茫聛庐忙聳聡氓颅聴氓聢聴\n     * condition_type(氓聢陇氓庐職忙聺隆盲禄露茫聛庐茫聜驴茫聜陇茫聝聴) : IN:3 茫聜聜茫聛聴茫聛聫茫聛炉 ONLY:5\n     * threshold_value(氓聢聠氓虏聬茫聛聦忙卤潞茫聛戮茫聜聥氓聙陇) : 莽碌聦猫路炉氓聢聠氓虏聬忙聺隆盲禄露茫聛芦猫篓颅氓庐職茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁ID茫聛庐忙聳聡氓颅聴氓聢聴\n     */\n    function checkThresholdValue(data, condition_type, threshold_value) {\n        var threshold_array = [];\n        var data_array = [];\n\n        if (angular.isUndefinedOrNull(data)) {\n            return false;\n        }\n        if (condition_type === Const.miscellaneous._COMPARISON.EQ) {\n            return data === threshold_value;\n        }\n        if (condition_type === Const.miscellaneous._COMPARISON.GTE) {\n            return data \u003e= threshold_value;\n        }\n        if (condition_type === Const.miscellaneous._COMPARISON.LTE) {\n            return data \u003c= threshold_value;\n        }\n        if (condition_type === Const.miscellaneous._COMPARISON.IN) {\n            // 茅聛赂忙聤聻茫聛聴茫聛聼茅聽\u0085莽聸庐茫聛聦茂录聭茫聛陇茫聛搂茫聜聜忙聺隆盲禄露茫聛篓氓聬聢猫聡麓茫聛聶茫聜聥氓聽麓氓聬聢茫聙聛True茫聜聮猫驴聰茫聛聶\n            threshold_array = threshold_value.split(\u0027,\u0027);\n            data_array = data.split(\u0027,\u0027);\n            return data_array.some(function(elem) {\n                return threshold_array.indexOf(elem) \u003e -1;\n            });\n        }\n        if (condition_type === Const.miscellaneous._COMPARISON.SUBSET) {\n            // 茅聛赂忙聤聻茫聛聴茫聛聼茅聽\u0085莽聸庐茫聛聦茫聛聶茫聛鹿茫聛娄忙聺隆盲禄露茫聛篓氓聬聢猫聡麓茫聛聶茫聜聥氓聽麓氓聬聢茫聙聛True茫聜聮猫驴聰茫聛聶\n            threshold_array = threshold_value.split(\u0027,\u0027);\n            data_array = data.split(\u0027,\u0027);\n            return threshold_array.every(function(elem) {\n                return data_array.indexOf(elem) \u003e -1;\n            });\n        }\n        if (condition_type === Const.miscellaneous._COMPARISON.ONLY){\n            // 茅聛赂忙聤聻茫聛聴茫聛聼氓\u0085篓茫聛娄茫聛庐茅聽\u0085莽聸庐茫聛聦忙聺隆盲禄露茫聛芦氓聬芦茫聛戮茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛True茫聜聮猫驴聰茫聛聶\n            threshold_array = threshold_value.split(\u0027,\u0027);\n            data_array = data.split(\u0027,\u0027);\n            return data_array.every(function(elem) {\n                return threshold_array.indexOf(elem) \u003e -1;\n            });\n        }\n    }\n\n    /**\n     * form_item茫聛庐茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛聦忙潞聙茫聛聼茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {Object} form_item 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茫聛聴茫聛聼茫聛聞茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @param {string} option_key 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛庐莽篓庐茅隆聻\n     * @param {Array.\u003cObject\u003e} mapped_items CreateRequestFormItemService.makeMappedItems茫聛搂盲陆聹茫聜聣茫聜聦茫聛聼茫聝聛茫聜搂茫聝聝茫聜炉莽聰篓茫聝聠茫聝录茫聝聳茫聝芦\n     * @return {boolean} 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛聦忙潞聙茫聛聼茫聛聲茫聜聦茫聛娄茫聛聞茫聜聦茫聛掳true\n     */\n    function checkItemOptionStatus(form_item, option_key, mapped_items) {\n        /**\n         * 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉氓聡娄莽聬聠\n         * @param {Object} form_item\n         * @param {string} option_key\n         * @param {Array.\u003cObject\u003e} mapped_items\n         * @param {Array.\u003cObject\u003e} checked_form_items 茫聝聛茫聜搂茫聝聝茫聜炉忙赂聢茫聛驴茅聽\u0085莽聸庐茫聜聮忙聽录莽麓聧茫聛聴茫聙聛氓聡娄莽聬聠茫聛聦莽聞隆茅聶聬茫聛芦氓聠聧氓赂掳茫聛聴茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n         * @return {boolean}\n         */\n        function checkMain(form_item, option_key, mapped_items, checked_form_items) {\n            // 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茂录聢茅聙職氓赂赂茫聛庐茅聽\u0085莽聸庐茫聛庐氓聽麓氓聬聢茂录聣茫聛炉忙潞聙茫聛聼茫聛聴茫聛娄茫聛聞茫聜聥茫聛篓茫聛聶茫聜聥\n            if (!hasExtraOptions(form_item, option_key)) {\n                return true;\n            }\n            // 茫聝聛茫聜搂茫聝聝茫聜炉忙赂聢茫聛驴茫聛庐form_item茫聛聦氓聠聧氓潞娄忙赂隆茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢茫聙聛莽聞隆茅聶聬茫聛芦氓聠聧氓赂掳茫聛聴茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦false茫聜聮猫驴聰茫聛聶\n            if (checked_form_items.indexOf(form_item.id) \u003e -1) {\n                return false;\n            }\n\n            checked_form_items.push(form_item.id);\n            // 忙聺隆盲禄露氓聢陇氓庐職茫聛芦盲陆驴茫聛聠茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐茫聜聮氓聫聳氓戮聴\n            var check_form_item = mapped_items[form_item.extra_options[option_key].item_id];\n            // 茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁忙聺隆盲禄露茫聛聦忙潞聙茫聛聼茫聛聲茫聜聦茫聜聥茫聛聥氓聢陇氓庐職\n            var result = check_form_item \u0026\u0026 checkThresholdValue(getItemValue(check_form_item),\n                                             form_item.extra_options[option_key].condition_type,\n                                             form_item.extra_options[option_key].threshold_value);\n            if (result) {\n                // 茫聜聜茫聛聴忙聺隆盲禄露氓聢陇氓庐職茫聛芦茫聛陇茫聛聥茫聛聠茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐猫聡陋盲陆聯茫聛聦茫聙聛盲禄聳茫聛庐茅聽\u0085莽聸庐茫聛芦茫聜聢茫聜聥猫隆篓莽陇潞忙聺隆盲禄露茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聛炉茫聙聛茫聛聺茫聛庐忙聺隆盲禄露茫聛聦忙潞聙茫聛聼茫聛聲茫聜聦茫聜聥茫聛聥茫聜聜氓聢陇氓庐職茫聛聶茫聜聥\n                // 盲戮聥茂录聣茅聽\u0085莽聸庐A茫聛炉茅聽\u0085莽聸庐B茫聛聦1茫聛庐茫聛篓茫聛聧茫聛芦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聙聜茅聽\u0085莽聸庐B茫聛炉茅聽\u0085莽聸庐C茫聛聦x茫聛庐茫聛篓茫聛聧茫聛芦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聙聜\n                // 茅聽\u0085莽聸庐B茫聛聦1茫聛搂茫聛聜茫聛拢茫聛娄茫聜聜茫聙聛茅聽\u0085莽聸庐C茫聛聦y茫聛庐茫聛篓茫聛聧茫聛炉茫聙聛茅聽\u0085莽聸庐A茫聛炉猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n                if (hasExtraOptions(check_form_item, \u0027is_disp\u0027)) {\n                    return checkMain(check_form_item, \u0027is_disp\u0027, mapped_items, checked_form_items);\n                }\n                return true;\n            }\n            return false;\n        }\n\n        return checkMain(form_item, option_key, mapped_items, []);\n    }\n\n    function isSpecificsSheet(form_type, form_data) {\n        if (form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            if (!form_data.expense.request_expense_specifics) {\n                return false;\n            }\n        } else if (form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            if (!form_data.payment.request_payment_specifics) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    function isSheetInputted(sheet, form_type) {\n        // 氓\u0085楼氓聤聸茫聝聛茫聜搂茫聝聝茫聜炉茅聶陇氓陇聳茅聽\u0085莽聸庐茫聛庐猫篓颅氓庐職\n        var rows;\n        var exclude_columns;\n        if (form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            rows = sheet.request_expense_specifics_rows;\n            if (util.isUndefinedOrNull(rows)) {\n                return false;\n            }\n            exclude_columns = {\n                \u0027normal\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027transport\u0027: [\u0027id\u0027, \u0027is_iccard\u0027, \u0027is_icreader\u0027, \u0027is_lowprice\u0027, \u0027is_manual_input\u0027, \u0027is_norikae_input\u0027,\n                              \u0027is_teiki\u0027, \u0027round_trip_flg\u0027, \u0027group\u0027, \u0027project\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027entertainment\u0027: [\u0027id\u0027, \u0027unit_price\u0027, \u0027group\u0027, \u0027project\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027allowance\u0027: [\u0027id\u0027, \u0027is_manual_input\u0027, \u0027group\u0027, \u0027project\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027exchange_normal\u0027: [\u0027id\u0027, \u0027is_manual_input\u0027, \u0027group\u0027, \u0027project\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027exchange_transport\u0027: [\u0027id\u0027, \u0027is_manual_input\u0027, \u0027round_trip_flg\u0027, \u0027group\u0027, \u0027project\u0027,\n                                       \u0027attachment_setting\u0027, \u0027errors\u0027],\n            };\n        } else if (form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            rows = sheet.request_payment_specifics_rows;\n            exclude_columns = {\n                \u0027normal\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027,\n                           \u0027is_new_company\u0027, \u0027withholding_tax_calc\u0027,\u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027user\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027, \u0027withholding_tax_calc\u0027,\n                         \u0027attachment_setting\u0027, \u0027errors\u0027],\n                // TODO: create_request_controllers茫聛庐checkFormError茫聜聢茫聜聤茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聢陇氓庐職茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞茫聛聼茫聜聛茫聙聛\n                // 氓聡娄莽聬聠茫聛聦茫聜篓茫聝漏茫聝录茫聛篓茫聛陋茫聛拢茫聛娄茫聛聴茫聛戮茫聛聠茫聛庐茫聛搂茫聙聛茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛聽茫聛聦茫聙聛忙聴垄氓庐職忙聵聨莽麓掳氓聬聭茫聛聭茫聛庐茫聜聜茫聛庐茫聛芦氓\u0085楼茫聜聦茫聛娄茫聛聤茫聛聫\n                \u0027exchange_company\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027,\n                                     \u0027is_manual_input\u0027, \u0027is_jpy_rate_manual_input\u0027,\n                                     \u0027is_new_company\u0027, \u0027withholding_tax_calc\u0027,\u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027exchange_user\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027, \u0027withholding_tax_calc\u0027,\n                                  \u0027is_manual_input\u0027, \u0027is_jpy_rate_manual_input\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n            };\n        }\n\n        // 忙聵聨莽麓掳猫隆篓茫聛庐氓聬聞猫隆聦茫聝禄氓聬聞茅聽\u0085莽聸庐茫聛芦氓炉戮茫聛聴茫聛娄氓\u0085楼氓聤聸茫聝聛茫聜搂茫聝聝茫聜炉茫聜聮猫隆聦茫聛聠\n        // 茫聜颅茫聝录茫聛聦茫聝聛茫聜搂茫聝聝茫聜炉茅聶陇氓陇聳氓炉戮猫卤隆茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳茫聙聛氓聙陇茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n        var result = false;\n        angular.forEach(rows, function (row) {\n            if (!(util.isUndefinedOrNull(row.is_parent_specifics)) \u0026\u0026 row.is_parent_specifics) {\n                // 氓聢聠氓聣虏氓戮聦茫聛庐猫娄陋忙聵聨莽麓掳茫聛炉氓驴\u0085茅聽聢茫聝聛茫聜搂茫聝聝茫聜炉茫聛庐氓炉戮猫卤隆氓陇聳\n                return;\n            }\n            angular.forEach(row, function (value, key) {\n                if (exclude_columns[sheet.specifics_type].indexOf(key) === -1) {\n                    // $$hashKey茫聛炉氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                    if (key.indexOf(\u0027$$\u0027) \u003e -1) {\n                        return;\n                    }\n                    // 盲陆聲茫聜聣茫聛聥茫聛庐氓聙陇茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢\n                    if (!(util.isUndefinedOrNull(value) || value == \u0027\u0027)) {\n                        // 猫聡陋氓聥聲猫篓颅氓庐職茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                        if ([\u0027account_title_part\u0027, \u0027account_title_part_name\u0027, \u0027attachment_setting\u0027].indexOf(key) \u003e -1) {\n                            if (angular.isArray(sheet.account_title_part_ids) \u0026\u0026\n                                sheet.account_title_part_ids.length === 1\n                            ) {\n                                return;\n                            } else if (sheet.transport_account_title_part_setting\n                                        === Const.miscellaneous.ACCOUNT_TITLE_PART_SETTING_FIX) {\n                                return;\n                            }\n                        }\n\n                        result = true;\n                    }\n                }\n            });\n        });\n        return result;\n    }\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳猫隆篓茫聛芦忙聵聨莽麓掳猫隆聦茫聜聮氓\u0085楼氓聤聸忙赂聢茫聛聥氓聢陇氓庐職茫聛聶茫聜聥\n     * TODO\n     * isSheetInputted茅聳垄忙聲掳茫聛聦茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛芦氓炉戮氓驴聹茫聛聶茫聜聥茫聛戮茫聛搂茫聛庐忙職芦氓庐職氓炉戮氓驴聹\n     * 忙聴垄氓颅聵忙聵聨莽麓掳茫聛篓茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛炉茫聝聡茫聝录茫聜驴忙搂聥茅聙聽茫聛聦莽聲掳茫聛陋茫聜聥\n     * 盲禄聤茫聛炉忙聴垄氓颅聵茫聝隆茫聜陆茫聝聝茫聝聣茫聛芦忙聣聥茫聜聮氓聤聽茫聛聢茫聛陋茫聛聞忙聳鹿茅聡聺茫聛陋茫聛庐茫聛搂茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳莽聰篓茫聛庐氓聢陇氓庐職茫聝隆茫聜陆茫聝聝茫聝聣茫聜聮盲陆聹忙聢聬茫聛聴茫聛聼\n     * @param {Object} sheet 忙聵聨莽麓掳猫隆篓\n     * @param {Number} form_type 茫聝聲茫聜漏茫聝录茫聝聽茫聜驴茫聜陇茫聝聴\n     * @return {boolean} true:氓\u0085楼氓聤聸忙赂聢/false:氓\u0085楼氓聤聸氓聣聧\n     */\n    function isSheetInputtedCustom(sheet, form_type) {\n        var result = false;\n        // 氓聢陇氓庐職氓炉戮猫卤隆茫聛庐忙聵聨莽麓掳猫隆聦茫聜聮氓聫聳氓戮聴\n        var rows = [];\n        var exclude_columns = {};\n        if (form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            rows = sheet.request_expense_specifics_rows;\n            exclude_columns = {\n                \u0027normal\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027errors\u0027],\n                \u0027transport\u0027: [\n                    \u0027id\u0027,\n                    \u0027is_iccard\u0027,\n                    \u0027is_icreader\u0027,\n                    \u0027is_lowprice\u0027,\n                    \u0027is_manual_input\u0027,\n                    \u0027is_norikae_input\u0027,\n                    \u0027is_teiki\u0027,\n                    \u0027round_trip_flg\u0027,\n                    \u0027group\u0027,\n                    \u0027project\u0027,\n                    \u0027errors\u0027,\n                ],\n                \u0027entertainment\u0027: [\u0027id\u0027, \u0027unit_price\u0027, \u0027group\u0027, \u0027project\u0027, \u0027errors\u0027],\n                \u0027allowance\u0027: [\u0027id\u0027, \u0027is_manual_input\u0027, \u0027group\u0027, \u0027project\u0027, \u0027errors\u0027],\n                \u0027exchange_normal\u0027: [\u0027id\u0027, \u0027is_manual_input\u0027, \u0027group\u0027, \u0027project\u0027, \u0027errors\u0027],\n                \u0027exchange_transport\u0027: [\u0027id\u0027, \u0027is_manual_input\u0027, \u0027round_trip_flg\u0027, \u0027group\u0027, \u0027project\u0027, \u0027errors\u0027],\n            };\n        } else if (form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            rows = sheet.request_payment_specifics_rows;\n            exclude_columns = {\n                \u0027normal\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027,\n                           \u0027is_new_company\u0027, \u0027withholding_tax_calc\u0027],\n                \u0027user\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027, \u0027withholding_tax_calc\u0027],\n                \u0027exchange_company\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027,\n                                     \u0027is_manual_input\u0027, \u0027is_jpy_rate_manual_input\u0027,\n                                     \u0027is_new_company\u0027, \u0027withholding_tax_calc\u0027,\u0027attachment_setting\u0027, \u0027errors\u0027],\n                \u0027exchange_user\u0027: [\u0027id\u0027, \u0027group\u0027, \u0027project\u0027, \u0027bank_transfer_fee_type\u0027, \u0027withholding_tax_calc\u0027,\n                                  \u0027is_manual_input\u0027, \u0027is_jpy_rate_manual_input\u0027, \u0027attachment_setting\u0027, \u0027errors\u0027],\n            };\n        }\n\n        // 忙聵聨莽麓掳猫隆篓茫聛庐氓聬聞猫隆聦茫聝禄氓聬聞茅聽\u0085莽聸庐茫聛芦氓炉戮茫聛聴茫聛娄氓\u0085楼氓聤聸茫聝聛茫聜搂茫聝聝茫聜炉茫聜聮猫隆聦茫聛聠\n        // 茫聜颅茫聝录茫聛聦茫聝聛茫聜搂茫聝聝茫聜炉茅聶陇氓陇聳氓炉戮猫卤隆茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳茫聙聛氓聙陇茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n        rows.forEach(function (row) {\n            // 忙聴垄茫聛芦氓\u0085楼氓聤聸忙赂聢氓聢陇氓庐職茫聛聦氓聡潞茫聛娄茫聛聞茫聜聦茫聛掳茫聝芦茫聝录茫聝聴盲赂聧猫娄聛\n            if (result) {\n                return;\n            }\n            // 茫聜芦茫聜鹿茫聜驴茫聝聽茅聽\u0085莽聸庐茫聛芦氓炉戮茫聛聶茫聜聥氓\u0085楼氓聤聸茫聝聛茫聜搂茫聝聝茫聜炉\n            if (CustomSpecificsConvertService.isInputedRow(row, sheet.columns)) {\n                result = true;\n                return;\n            }\n            // 忙聴垄氓庐職茅聽\u0085莽聸庐茫聛芦氓炉戮茫聛聶茫聜聥氓\u0085楼氓聤聸茫聝聛茫聜搂茫聝聝茫聜炉\n            Object.keys(row).forEach(function (key) {\n                // 忙聴垄茫聛芦氓\u0085楼氓聤聸忙赂聢氓聢陇氓庐職茫聛聦氓聡潞茫聛娄茫聛聞茫聜聦茫聛掳茫聝芦茫聝录茫聝聴盲赂聧猫娄聛\n                if (result) {\n                    return;\n                }\n                // 茅聶陇氓陇聳茅聽\u0085莽聸庐茫聛庐氓聽麓氓聬聢茫聛炉氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                if (exclude_columns[sheet.specifics_type].indexOf(key) \u003e -1) {\n                    return;\n                }\n                // $$hashKey茫聛炉氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                if (key.indexOf(\u0027$$\u0027) \u003e -1) {\n                    return;\n                }\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽茅聽\u0085莽聸庐茫聛炉氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                if (key === \u0027request_custom_specific_items\u0027) {\n                    return;\n                }\n                // 氓聙陇茫聛聦氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                if (util.isUndefinedOrNull(row[key]) || row[key] == \u0027\u0027) {\n                    return;\n                }\n                // 猫聡陋氓聥聲猫篓颅氓庐職茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁茫聛庐氓聽麓氓聬聢茫聛炉氓聢陇氓庐職茫聛聥茫聜聣氓陇聳茫聛聶\n                if ([\u0027account_title_part\u0027, \u0027account_title_part_name\u0027, \u0027attachment_setting\u0027].indexOf(key) \u003e -1) {\n                    if (angular.isArray(sheet.account_title_part_ids) \u0026\u0026\n                        sheet.account_title_part_ids.length === 1\n                    ) {\n                        return;\n                    } else if (sheet.transport_account_title_part_setting\n                        === Const.miscellaneous.ACCOUNT_TITLE_PART_SETTING_FIX) {\n                        return;\n                    }\n                }\n                // 氓\u0085楼氓聤聸忙赂聢茫聛庐茅聽\u0085莽聸庐茫聜聮忙陇聹莽聼楼\n                result = true;\n            });\n        });\n        return result;\n    }\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳(莽聜潞忙聸驴茫聝卢茫聝录茫聝聢)茫聛庐氓聢陇忙聳颅\n     * @param {string} specific_type\n     * @return {boolean}\n     */\n    function isCustomPaymentExchange(specific_type) {\n        const targetSpecificsTypes = [\n            Const.miscellaneous.PAYMENT_SPECIFICS_EXCHANGE_COMPANY,\n            Const.miscellaneous.PAYMENT_SPECIFICS_EXCHANGE_USER,\n        ];\n        return targetSpecificsTypes.includes(specific_type);\n    }\n\n    function isFormExpense(form_data) {\n        return angular.isDefined(form_data.expense);\n    }\n\n    function isFormPayment(form_data) {\n        return angular.isDefined(form_data.payment);\n    }\n\n    function isFormEc(form_data) {\n        return angular.isDefined(form_data.ec);\n    }\n\n    function isFormExpenseSpecifics(form_data) {\n        return isFormExpense(form_data) \u0026\u0026 angular.isDefined(form_data.expense.request_expense_specifics);\n    }\n\n    function isFormChangeSettlementDeadline(form_data) {\n        return isFormExpense(form_data) \u0026\u0026\n        (form_data.expense.settlement_flg === Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg);\n    }\n\n    function isFormPaymentSpecifics(form_data) {\n        return isFormPayment(form_data) \u0026\u0026 angular.isDefined(form_data.payment.request_payment_specifics);\n    }\n\n    function isFormEcSpecifics(form_data) {\n        return isFormEc(form_data) \u0026\u0026 angular.isDefined(form_data.ec.request_ec_specifics_rows);\n    }\n\n    function createRequestContent(labels_obj) {\n        var selected_labels = [];\n        angular.forEach(labels_obj, function (label_obj) {\n            if (label_obj.checked === true) {\n                selected_labels.push(label_obj.label);\n            }\n        });\n        return selected_labels.join(\",\");\n    }\n\n    // 茫聜鲁茫聝聰茫聝录忙聶聜茫聛庐茫聝聲茫聝陋茫聝录猫篓颅氓庐職茅聽\u0085莽聸庐氓聢聺忙聹聼氓聦聳\n    function initFormItemForCopy(form_json) {\n        // 莽聰鲁猫芦聥茫聜鲁茫聝聰茫聝录茫聙聛莽路篓茅聸聠忙聶聜茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉茫聝聹茫聝聝茫聜炉茫聜鹿茫聝聡茫聝录茫聜驴茫聛庐猫篓颅氓庐職\n        var _setCheckBoxData = function (item) {\n            // select_item_labels_obj茫聛聦氓颅聵氓聹篓茫聛聴茫聛娄茫聛聞茫聛陋茫聛聭茫聜聦茫聛掳茫聙聛莽聰聼忙聢聬茫聛聶茫聜聥\n            // #6372茫聛芦茫聛聤茫聛聞茫聛娄茫聙聛select_item_labels_obj茫聛聦茫聜碌茫聝录茫聝聬茫聝录氓聛麓茫聛芦盲驴聺氓颅聵茫聛聲茫聜聦茫聜聥茫聜聢茫聛聠茫聛芦茫聛陋茫聛拢茫聛聼茫聛聦茫聙聛\n            // 茫聛聺茫聜聦盲禄楼氓聣聧茫聛芦盲陆聹忙聢聬茫聛聲茫聜聦茫聛聼莽聰鲁猫芦聥茫聛芦茫聛陇茫聛聞茫聛娄茫聛炉茫聙聛茫聛聯茫聛庐氓聡娄莽聬聠茫聛聦氓驴\u0085猫娄聛\n            if (angular.isUndefinedOrNull(item.select_item_labels_obj)) {\n                // 茫聛漏茫聛庐茫聝漏茫聝聶茫聝芦茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥茫聜聮盲驴聺忙聦聛茫聛聶茫聜聥茅\u0085聧氓聢聴茫聜聮盲陆聹忙聢聬\n                item.select_item_labels_obj = [];\n\n                // request_content茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛氓\u0085篓茫聛娄忙聹陋茅聛赂忙聤聻莽聤露忙\u0085聥茫聛篓茫聛聴茫聛娄莽聰聼忙聢聬茫聛聶茫聜聥\n                if (angular.isUndefinedOrNull(item.request_content)) {\n                    angular.forEach(item.select_item_labels, function (label, i) {\n                        item.select_item_labels_obj[i] = {\u0027label\u0027: label, checked: false};\n                    });\n                    item.request_content = \u0027\u0027;\n                    return;\n                }\n\n                // 茫聝漏茫聝聶茫聝芦氓聬聧茫聜聮茫聙聛茅聲路茫聛聞茅聽聠茫聛芦盲赂娄茫聛鹿忙聸驴茫聛聢茫聛聼茅\u0085聧氓聢聴茫聜聮莽聰篓忙聞聫\n                var labels = angular.copy(item.select_item_labels);\n                labels.sort(function (a, b) {\n                    return b.length - a.length;\n                });\n\n                // 茫聝漏茫聝聶茫聝芦茫聛聦氓聬芦茫聛戮茫聜聦茫聜聥茫聛聥茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉\n                angular.forEach(labels, function (label, i) {\n                    item.select_item_labels_obj[i] = {};\n                    item.select_item_labels_obj[i].label = label;\n\n                    // 茫聝漏茫聝聶茫聝芦茫聛庐request_content氓聠\u0085茫聛庐盲陆聧莽陆庐茫聜聮氓聫聳氓戮聴\n                    var index = item.request_content.indexOf(label);\n\n                    // 茫聝漏茫聝聶茫聝芦茫聛庐氓聣聧氓戮聦茫聛芦茫聜芦茫聝鲁茫聝聻茫聛聦氓聬芦茫聛戮茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聛庐猫驴陆氓聤聽氓聡娄莽聬聠\n                    if (index \u003e -1) {\n                        // 茫聝漏茫聝聶茫聝芦茫聛庐忙聹聙氓聢聺茫聛庐忙聳聡氓颅聴茫聛聦茫聜芦茫聝鲁茫聝聻茫聛庐氓聽麓氓聬聢\n                        if (label[0] === \u0027,\u0027) {\n                            // 茫聛聲茫聜聣茫聛芦1忙聳聡氓颅聴氓聣聧茫聛戮茫聛搂猫陋驴茫聛鹿茫聜聥氓驴\u0085猫娄聛茫聛聦茫聛聜茫聜聥\n                            if (index !== 0 \u0026\u0026 item.request_content[index - 1] !== \u0027,\u0027) {\n                                index = -1;\n                            }\n                        }\n                        // 茫聝漏茫聝聶茫聝芦茫聛庐忙聹聙氓戮聦茫聛庐忙聳聡氓颅聴茫聛聦茫聜芦茫聝鲁茫聝聻茫聛庐氓聽麓氓聬聢\n                        if (label[label.length - 1] === \u0027,\u0027) {\n                            // 茫聛聲茫聜聣茫聛芦1忙聳聡氓颅聴氓\u0085聢茫聛戮茫聛搂猫陋驴茫聛鹿茫聜聥氓驴\u0085猫娄聛茫聛聦茫聛聜茫聜聥\n                            if (index + label.length \u003c item.request_content.length - 1 \u0026\u0026 item.request_content[index + label.length] !== \u0027,\u0027) {\n                                index = -1;\n                            }\n                        }\n                    }\n\n                    // 茫聝漏茫聝聶茫聝芦茫聛聦氓颅聵氓聹篓茫聛聴茫聛聼茫聜聣\n                    if (index \u003e -1) {\n                        item.select_item_labels_obj[i].checked = true;\n\n                        // request_content茫聛聥茫聜聣茫聝漏茫聝聶茫聝芦茅聝篓氓聢聠茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n                        var str;\n                        if (item.request_content.length === label.length) {\n                            // request_content茫聛芦氓炉戮猫卤隆茫聝漏茫聝聶茫聝芦茫聛聴茫聛聥氓聬芦茫聛戮茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢\n                            str = label;\n                        } else if (index === 0) {\n                            // 茫聝漏茫聝聶茫聝芦茫聛聦request_content茫聛庐忙聹聙氓聢聺茫聛芦茫聛聜茫聛拢茫聛聼氓聽麓氓聬聢\n                            str = label + \",\";\n                        } else {\n                            // 忙聹聙氓聢聺茫聛搂茫聛炉茫聛陋茫聛聥茫聛拢茫聛聼氓聽麓氓聬聢\n                            str = \",\" + label;\n                        }\n                        item.request_content = item.request_content.replace(str, \"\");\n                    } else {\n                        // 茫聝漏茫聝聶茫聝芦茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聥茫聛拢茫聛聼氓聽麓氓聬聢\n                        item.select_item_labels_obj[i].checked = false;\n                    }\n                });\n\n                // select_item_labels_obj茫聜聮select_item_labels茫聛庐茅聽聠莽聲陋茫聛篓氓聬聦茫聛聵茫聛芦茫聛聶茫聜聥\n                angular.forEach(item.select_item_labels, function (label, i) {\n                    for (var j = i; j \u003c item.select_item_labels_obj.length; ++j) {\n                        if (item.select_item_labels_obj[j].label === label) {\n                            // i莽聲陋莽聸庐茫聛庐猫娄聛莽麓聽茫聛篓氓\u0085楼茫聜聦忙聸驴茫聛聢\n                            item.select_item_labels_obj[j] = item.select_item_labels_obj.splice(i, 1, item.select_item_labels_obj[j])[0];\n                            break;\n                        }\n                    }\n                });\n            }\n\n            // request_content茫聜聮忙搂聥莽炉聣\n            item.request_content = createRequestContent(item.select_item_labels_obj);\n        };\n\n        angular.forEach(form_json, function (item) {\n            if (item.item_type === Const.form.ITEM_TYPE_CHECK) {\n                _setCheckBoxData(item);\n            }\n            if (item.item_type === Const.form.ITEM_TYPE_TIME) {\n                // #8331茫聛搂氓炉戮氓驴聹茫聛聶茫聜聥盲赂聧氓\u0085路氓聬聢茫聛庐茫聛聼茫聜聛茫聛芦茫聙聛忙聴垄氓颅聵茫聛庐茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聛庐忙聶聜氓聢禄茫聛庐request_content茫聛芦茫聙聛\n                // 忙聳聡氓颅聴氓聢聴\u0027Invalid date\u0027茫聜聞\u0027\u0027茫聛聦莽聶禄茅聦虏茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聛聦茫聛聜茫聜聥茫聙聜\n                // 盲驴庐忙颅拢莽聰禄茅聺垄猫隆篓莽陇潞忙聶聜茫聛芦茫聙聛氓聢聺忙聹聼氓聦聳茫聛聴茫聛娄茫聛聤茫聛聫茫聙聜\n                // see also #8331\n                if (angular.isDefined(item.request_content) \u0026\u0026\n                        (item.request_content === \u0027Invalid date\u0027 || item.request_content === \u0027\u0027)) {\n                    item.request_content = null;\n                }\n                if (angular.isUndefinedOrNull(item.request_content)) {\n                    item.time = null;\n                } else {\n                    item.time = new Date(\u00271970/01/01 \u0027 + item.request_content + \u0027:00\u0027);\n                }\n            }\n            // 茫聝垄茫聝聬茫聜陇茫聝芦莽聣聢茫聛搂忙聴楼盲禄聵氓\u0085楼氓聤聸茫聜聮input茫聜驴茫聜掳茫聛庐type=\"date\"茫聛搂氓炉戮氓驴聹茫聛聴茫聛娄茫聛聞茫聛聼忙聶聜忙聹聼茫聛聦茫聛聜茫聜聥茫聛庐茫聛搂茫聙聛氓陇聣忙聫聸茫聜鲁茫聝录茫聝聣茫聜聮氓\u0085楼茫聜聦茫聜聥\n            if (item.item_type === Const.form.ITEM_TYPE_DATE) {\n                item.custom_date = item.request_content;\n            }\n        });\n\n        return form_json;\n    }\n\n    /**\n     * 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴(忙卤聨莽聰篓)茫聛庐忙聴搂盲禄聲忙搂聵茫聜聮忙聳掳盲禄聲忙搂聵茫聛芦氓陇聣忙聫聸\n     * @param {Array.\u003cObject\u003e} form_json\n     */\n    function setRequestFilesOldToNew(form_json) {\n        /**\n         * 忙卤聨莽聰篓忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茅聽\u0085莽聸庐茫聛芦忙聴搂盲禄聲忙搂聵氓陆垄氓录聫茫聛搂猫篓颅氓庐職茫聛聲茫聜聦茫聛聼忙聝\u0085氓聽卤茫聜聮忙聳掳盲禄聲忙搂聵氓陆垄氓录聫茫聛芦莽陆庐茫聛聧忙聫聸茫聛聢茫聜聥\n         * @param {Array.\u003cObject\u003e} form_json\n         */\n        function setKey(form_json) {\n            angular.forEach(form_json, function(f_json) {\n                if (f_json.item_type === Const.form.ITEM_TYPE_ATTACHMENT) {\n                    if (angular.isDefined(f_json.all_request_files)) {\n                        // type -\u003e file_type 茫聛芦氓陇聣忙聫聸\n                        angular.forEach(f_json.all_request_files, function(file) {\n                            file.file_type = file.type;\n                            delete file.type;\n                        });\n                        // all_request_files -\u003e request_files 茫聛芦氓陇聣忙聫聸\n                        f_json.request_files = angular.copy(f_json.all_request_files);\n                        delete f_json.all_request_files;\n                    }\n                    if (angular.isDefined(f_json.request_content_json)) {\n                        if (angular.isDefined(f_json.request_content_json.all_request_files)) {\n                            // type -\u003e file_type 茫聛芦氓陇聣忙聫聸\n                            angular.forEach(f_json.request_content_json.all_request_files, function(file) {\n                                file.file_type = file.type;\n                                delete file.type;\n                            });\n                            // all_request_files -\u003e request_files 茫聛芦氓陇聣忙聫聸\n                            f_json.request_content_json.request_files = angular.copy(\n                                f_json.request_content_json.all_request_files\n                            );\n                            delete f_json.request_content_json.all_request_files;\n                        }\n                    }\n                }\n            });\n        }\n\n        if (form_json.length !== 0) {\n            setKey(form_json);\n        }\n    }\n\n    /**\n     * 忙聵聨莽麓掳猫隆篓氓聠\u0085茫聛芦氓聬芦茫聛戮茫聜聦茫聜聥氓聠\u0085猫篓鲁茫聜聮忙聤陆氓聡潞茫聛聶茫聜聥\n     * @param {number} form_type 茫聝聲茫聜漏茫聝录茫聝聽茫聜驴茫聜陇茫聝聴\n     * @param {Object} form_data 茫聝聲茫聜漏茫聝录茫聝聽茫聝聡茫聝录茫聜驴\n     * @return {Array.\u003cinteger\u003e} 忙聵聨莽麓掳茫聛搂茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁ID\n     */\n    function extractSpecificAccountTitlePartIds(form_type, form_data) {\n        var specificRows = [];\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐氓聽麓氓聬聢\n        if (form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            const specifics = form_data.expense.request_expense_specifics;\n            specificRows = specifics.map(function(specific) {\n                const rows = specific.request_expense_specifics_rows;\n                if (rows == null) {\n                    return [];\n                }\n                return rows;\n            }).reduce(function(prev, current) {\n                return prev.concat(current);\n            });\n        }\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐氓聽麓氓聬聢\n        else if (form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            const specifics = form_data.payment.request_payment_specifics;\n            specificRows = specifics.map(function(specific) {\n                const rows = specific.request_payment_specifics_rows;\n                if (rows == null) {\n                    return [];\n                }\n                return rows;\n            }).reduce(function(prev, current) {\n                return prev.concat(current);\n            });\n        }\n        const ids = specificRows.map(function(specificRow) {\n            return specificRow.account_title_part;\n        }).filter(function(id) {\n            return id;\n        });\n        return ids;\n    }\n\n    /**\n     * 茫聝聲茫聜漏茫聝录茫聝聽氓聠\u0085茫聛芦氓聬芦茫聛戮茫聜聦茫聜聥氓聠\u0085猫篓鲁茫聜聮忙聤陆氓聡潞茫聛聶茫聜聥\n     * @param {number} form_type 茫聝聲茫聜漏茫聝录茫聝聽茫聜驴茫聜陇茫聝聴\n     * @param {Object} form_data 茫聝聲茫聜漏茫聝录茫聝聽茫聝聡茫聝录茫聜驴\n     * @return {Array.\u003cinteger\u003e} 莽碌聦猫虏禄茫聛庐氓聠\u0085猫篓鲁/忙聰炉忙聣聲茫聛庐氓聠\u0085猫篓鲁茅聽\u0085莽聸庐茫聛搂茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁\n     */\n    function extractAccountTitlePartIds(form_type, form_data) {\n        const accountTitlePartIds = [];\n        if (form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            if (form_data.expense.account_title_part != null) {\n                accountTitlePartIds.push(form_data.expense.account_title_part);\n            }\n        }\n        else if (form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            if (form_data.payment.account_title_part != null) {\n                accountTitlePartIds.push(form_data.payment.account_title_part);\n            }\n        }\n        return accountTitlePartIds;\n    }\n\n\n    /**\n     * 莽聰鲁猫芦聥ID茫聛聥茫聜聣盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐猫篓颅氓庐職茫聜聮猫陋颅茫聛驴猫戮录茫聜聙茫聛聥茫聛漏茫聛聠茫聛聥\n     * @param {string} kind 莽聰鲁猫芦聥茫聛庐莽篓庐茅隆聻\n     * @return {bool}\n     */\n    function isRelatedFormLimitSettingFromRequestId(kind){\n        const CREATE_REQUEST_KIND = Const.miscellaneous.CREATE_REQUEST_KIND;\n        return [\n            CREATE_REQUEST_KIND.NEW,\n            CREATE_REQUEST_KIND.EDIT,\n            CREATE_REQUEST_KIND.COPY,\n            CREATE_REQUEST_KIND.FEEDBACK,\n        ].indexOf(kind) === -1;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聛聲茫聜聦茫聛聼茫聜芦茫聝录茫聝聣ID茫聛庐茅聡聧猫陇聡茫聛陋茫聛聴茫聝陋茫聜鹿茫聝聢盲陆聹忙聢聬\n     * @param {number} form_type 茫聝聲茫聜漏茫聝录茫聝聽莽篓庐茅隆聻\n     * @param {object} form_data 莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴\n     * @return {Array} 莽聰鲁猫芦聥茫聛聲茫聜聦茫聛聼茫聜芦茫聝录茫聝聣ID茫聛庐茅聡聧猫陇聡茫聛陋茫聛聴茫聝陋茫聜鹿茫聝聢\n     */\n    function extractCardId(form_type, form_data){\n        var card_ids = [];\n        if (form_type !== Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            return card_ids;\n        }\n        if (!util.isUndefinedOrNull(form_data.expense.request_expense_specifics)\n                \u0026\u0026 angular.isArray(form_data.expense.request_expense_specifics)) {\n            form_data.expense.request_expense_specifics.map(function (sheet) {\n                if (util.isUndefinedOrNull(sheet.request_expense_specifics_rows)) {\n                    return;\n                }\n                sheet.request_expense_specifics_rows.map(function(row) {\n                    if (row.is_credit_card \u0026\u0026 !util.isUndefinedOrNull(row.card_id)) {\n                        card_ids.push(row.card_id);\n                    }\n                });\n            });\n            // 茅聡聧猫陇聡氓聣聤茅聶陇\n            card_ids = card_ids.filter(function(card_id, index){\n                if (card_ids.indexOf(card_id)===index) {\n                    return true;\n                }\n            });\n        }\n        return card_ids;\n    }\n\n    /**\n     * 茫聜芦茫聝录茫聝聣ID茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠盲赂聙猫娄搂茫聛庐氓聫聳氓戮聴\n     * @param {Array} card_ids 茫聜芦茫聝录茫聝聣ID茫聝陋茫聜鹿茫聝聢\n     * @return {promise}\n     */\n    function getDivisionsByCardId(card_ids) {\n        return $q.all(card_ids.map(function(card_id) {\n            return _getDivisionsByCardId(card_id);\n        }));\n    }\n\n    /**\n     * 茫聜芦茫聝录茫聝聣ID茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠盲赂聙猫娄搂茫聛庐氓聫聳氓戮聴(茫聜芦茫聝录茫聝聣ID茫聛聰茫聛篓)\n     * @param {number} card_id 茫聜芦茫聝录茫聝聣ID茫聝陋茫聜鹿茫聝聢\n     * @return {promise}\n     */\n    function _getDivisionsByCardId(card_id) {\n        var defer = $q.defer();\n        _callApiDivisionsByCardId(card_id).then(function(result) {\n            defer.resolve(result.data);\n        }).catch(function() {\n            defer.reject();\n        });\n        return defer.promise;\n    }\n\n    /**\n     * 茫聜芦茫聝录茫聝聣ID茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠盲赂聙猫娄搂茫聛庐氓聫聳氓戮聴(茫聜芦茫聝录茫聝聣ID茫聛聰茫聛篓)\n     * @param {number} card_id 茫聜芦茫聝录茫聝聣ID茫聝陋茫聜鹿茫聝聢\n     * @return {promise}\n     */\n    function _callApiDivisionsByCardId(card_id) {\n        return $http.get(\u0027/api/v1/corporate_card/cards/\u0027 + card_id + \u0027/corporate_card_integration/\u0027);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聛搂莽麓聬茫聛楼茫聛聭茫聛娄茫聛聞茫聜聥茫聜芦茫聝录茫聝聣氓聢漏莽聰篓忙聵聨莽麓掳茫聛庐氓聢漏莽聰篓忙聹聼茅聳聯氓聢陇氓庐職茫聜聮氓聫聳氓戮聴\n     * @param {number} request_id\n     * @return {object}\n     */\n    function _getTransactionExpiredByRequest(request_id) {\n        return $http.get(\u0027api/v1/requests/\u0027 + request_id + \u0027/card_transactions/expired/\u0027);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聛芦莽麓聬茫聛楼茫聛聭茫聛娄茫聛聞茫聜聥茫聜芦茫聝录茫聝聣氓聢漏莽聰篓忙聵聨莽麓掳茫聛庐氓聢漏莽聰篓忙聹聼茅聳聯氓聢陇氓庐職茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * @param {number} request_id\n     * @param {Array} request_expense_specifics 忙聵聨莽麓掳猫隆篓茫聛聼茫聛隆\n     */\n    function setTransactionExpired(request_id, request_expense_specifics) {\n        _getTransactionExpiredByRequest(request_id).then(function (res) {\n            const res_data = res.data;\n            if (!res_data.length) {\n                return;\n            }\n            request_expense_specifics.forEach(function (sheet) {\n                if (!sheet.hasOwnProperty(\u0027request_expense_specifics_rows\u0027)) {\n                    return;\n                }\n                sheet.request_expense_specifics_rows.forEach(function (row) {\n                    var target_transaction = res_data.filter(function (transaction) {\n                        if (row.is_child_specifics) {\n                            return transaction.id === row.parent_row.transaction_id;\n                        }\n                        return transaction.id === row.transaction_id;\n                    });\n                    if (target_transaction.length \u003e 0) {\n                        const division_pattern\n                                = CreateRequestExpenseSpecificsService.corporateCardJournalDivisionIdToPattern(\n                                    row.corporate_card_journal_division, row.corporate_card_journal_divisions);\n                        if (division_pattern === Const.corporateCardSetting.DIVISION_PATTERN.GENERIC.pattern) {\n                            row.is_transaction_expired = target_transaction[0].is_transaction_expired;\n                            if (util.isUndefinedOrNull(row.errors)) {\n                                row.errors = {};\n                            }\n                            row.errors.division_term_range = row.is_transaction_expired;\n                        }\n                    }\n                });\n            });\n        });\n    }\n    /**\n     * API茫聛聥茫聜聣茫聜芦茫聝录茫聝聣茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠盲赂聙猫娄搂氓聫聳氓戮聴\n     * @param {number} corporate_card_id 茫聜芦茫聝录茫聝聣ID\n     * @return {promise} 茫聜芦茫聝录茫聝聣茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠盲赂聙猫娄搂\n     * @private\n     */\n    function _getCardDivisionsByCardIdFromApi(corporate_card_id) {\n        return $http.get(\u0027/api/v1/corporate_card/cards/\u0027 + corporate_card_id + \u0027/corporate_card_integration/\u0027);\n    }\n    /**\n     * 氓聦潞氓聢聠氓庐聼猫拢\u0085氓聣聧茫聛陋茫聛漏茫聛搂氓聢漏莽聰篓忙聵聨莽麓掳氓聦潞氓聢聠忙聝\u0085氓聽卤茫聛聦莽聞隆茫聛聞茫聜炉茫聝卢茫聜赂茫聝聝茫聝聢茫聜芦茫聝录茫聝聣忙聵聨莽麓掳猫隆聦茫聛芦氓聦潞氓聢聠盲赂聙猫娄搂茫聜聮茫聜禄茫聝聝茫聝聢\n     * 莽碌聦猫虏禄氓聦潞氓聢聠茫聛聦忙聹聣茫聜聦茫聛掳茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * @param {object} request_expense_specifics\n     * @return {promise}\n     */\n    function setCardDivisionsByCardIdOnlyNull(request_expense_specifics) {\n        const defer = $q.defer();\n        // 茫聜炉茫聝卢茫聜赂茫聝聝茫聝聢茫聜芦茫聝录茫聝聣忙聵聨莽麓掳猫隆聦茫聛搂茫聙聛茫聜芦茫聝录茫聝聣ID茫聛聦茫聛聜茫聛拢茫聛娄茫聙聛氓聢漏莽聰篓忙聵聨莽麓掳氓聦潞氓聢聠忙聝\u0085氓聽卤茫聛聦莽聞隆茫聛聞茫聛聥茫聜聮氓聢陇氓庐職\n        function _isCardDivisionsRow(row) {\n            return (\n                row.is_credit_card \u0026\u0026\n                !util.isUndefinedOrNull(row.card_id) \u0026\u0026\n                util.isUndefinedOrNull(row.corporate_card_journal_divisions) \u0026\u0026\n                util.isUndefinedOrNull(row.corporate_card_journal_division)\n            );\n        }\n        var card_ids = [];\n        var target_rows = [];\n        request_expense_specifics.forEach(function (sheet) {\n            if (!sheet.hasOwnProperty(\u0027request_expense_specifics_rows\u0027)) {\n                return;\n            }\n            // 氓炉戮猫卤隆茫聛庐忙聵聨莽麓掳猫隆聦茫聜聮茅聸聠莽麓聞\n            target_rows = target_rows.concat(sheet.request_expense_specifics_rows.filter(function (row) {\n                return _isCardDivisionsRow(row);\n            }));\n        });\n        // 茅聸聠莽麓聞茫聛聴茫聛聼忙聵聨莽麓掳猫隆聦茫聛聥茫聜聣card_id茫聛庐茫聝陋茫聜鹿茫聝聢茫聛搂氓聫聳氓戮聴\n        card_ids = target_rows.map(function (row) {\n            return row.card_id;\n        });\n        // card_ids茫聛庐茅聡聧猫陇聡氓聣聤茅聶陇\n        card_ids = Array.from(new Set(card_ids));\n\n        // 茫聜炉茫聝卢茫聜赂茫聝聝茫聝聢茫聜芦茫聝录茫聝聣忙聵聨莽麓掳猫隆聦茫聛搂茫聙聛茫聜芦茫聝录茫聝聣ID茫聛聦茫聛聜茫聛拢茫聛娄茫聙聛氓聢漏莽聰篓忙聵聨莽麓掳氓聦潞氓聢聠忙聝\u0085氓聽卤茫聛聦莽聞隆茫聛聞茫聙聛茫聜芦茫聝录茫聝聣ID茫聝陋茫聜鹿茫聝聢茫聛搂氓聦潞氓聢聠盲赂聙猫娄搂氓聫聳氓戮聴\n        const integration_id_and_card_id_pairs = {};\n        const divisions_by_card_ids = {};\n        $q.all(\n            card_ids.map(function (card_id) {\n                return _getCardDivisionsByCardIdFromApi(card_id);\n            })\n        ).then(function (res) {\n            card_ids.forEach(function (card_id, index) {\n                integration_id_and_card_id_pairs[card_id] = res[index].data.id;\n                divisions_by_card_ids[card_id] = res[index].data.corporate_card_journal_divisions;\n            });\n            // 氓聫聳氓戮聴茫聛聴茫聛聼氓聦潞氓聢聠盲赂聙猫娄搂茫聜聮茫聜炉茫聝卢茫聜赂茫聝聝茫聝聢茫聜芦茫聝录茫聝聣忙聵聨莽麓掳猫隆聦茫聛搂茫聙聛茫聜芦茫聝录茫聝聣ID茫聛聦茫聛聜茫聛拢茫聛娄茫聙聛氓聢漏莽聰篓忙聵聨莽麓掳氓聦潞氓聢聠忙聝\u0085氓聽卤茫聛聦莽聞隆茫聛聞茫聙聛忙聵聨莽麓掳猫隆聦茫聛芦茫聜禄茫聝聝茫聝聢\n            target_rows.forEach(function (row) {\n                row.corporate_card_journal_divisions = divisions_by_card_ids[row.card_id];\n                // 莽碌聦猫虏禄氓聦潞氓聢聠茫聛聦忙聹聣茫聜聦茫聛掳茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n                const expense_journal_division = row.corporate_card_journal_divisions.filter(function (division) {\n                    return (\n                        division.division_pattern === Const.corporateCardSetting.DIVISION_PATTERN.EXPENSE.pattern\n                    );\n                });\n                if (expense_journal_division.length \u003e= 1) {\n                    row.corporate_card_journal_division = expense_journal_division[0].id;\n                }\n            });\n            defer.resolve({\n                integration_id_and_card_id_pairs: integration_id_and_card_id_pairs,\n                divisions_by_card_ids: divisions_by_card_ids,\n            });\n        }).catch(function() {\n            defer.reject();\n        });\n        return defer.promise;\n    }\n\n    /**\n     * 氓聫聳氓录聲氓\u0085聢ID茫聜聮氓\u0085聝茫聛芦氓聫聳氓录聲氓\u0085聢茫聝聻茫聜鹿茫聜驴茫聛聥茫聜聣盲录職莽陇戮忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @param {Array.\u003cnumber\u003e} company_ids: 氓聫聳氓录聲氓\u0085聢ID茅\u0085聧氓聢聴\n     * @return {promise}\n     */\n    function getCompanyListByIds(company_ids) {\n        const param = {\u0027company_ids\u0027: company_ids};\n        return $http.post(\u0027/api/v1/company/by_ids/\u0027, param);\n    }\n\n    /**\n     * 茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿莽聶禄茅聦虏莽聲陋氓聫路茫聜聮氓\u0085聝茫聛芦茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿API茫聛聥茫聜聣莽聶禄茅聦虏忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @param {Object} param 茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿莽聶禄茅聦虏莽聲陋氓聫路\n     * @return {promise}\n     */\n    function _existsInvoiceRegistratedNumbers(param) {\n        return $http.post(\u0027/api/v1/company/invoice-kohyo/number/exists/\u0027, param);\n    }\n\n    /**\n     * 氓录聲忙聲掳茫聛庐invoice_registrated_numbers茫聛芦忙聽录莽麓聧茫聛聲茫聜聦茫聛聼茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿莽聶禄茅聦虏莽聲陋氓聫路茫聛庐氓颅聵氓聹篓莽垄潞猫陋聧茫聜聮猫隆聦茫聛聠\n     * @param {Array.\u003cstring\u003e} invoice_registrated_numbers\n     * @return {promise}\n     */\n    function checkInvoiceRegistratedNumbers(invoice_registrated_numbers) {\n        const defer = $q.defer();\n        var params = null;\n        if (angular.isUndefinedOrNull(invoice_registrated_numbers) || invoice_registrated_numbers.length === 0) {\n            return defer.promise;\n        }\n\n        // 莽聶禄茅聦虏莽聲陋氓聫路茫聛庐茅聡聧猫陇聡氓聣聤茅聶陇\n        // eslint-disable-next-line es5/no-es6-static-methods\n        invoice_registrated_numbers = Array.from(new Set(invoice_registrated_numbers));\n\n        params = {\u0027invoice_registrated_numbers\u0027: invoice_registrated_numbers};\n        _existsInvoiceRegistratedNumbers(params)\n        .then(function (res) {\n            defer.resolve({\n                check_results: res.data,\n            });\n        })\n        .catch(function() {\n            defer.reject();\n        });\n        return defer.promise;\n    }\n});\n\nwfServices.factory(\u0027FormPublishedService\u0027, function (Const) {\n    /**\n     * 氓\u0085卢茅聳聥猫篓颅氓庐職茫聛聦盲赂聙茅聝篓氓\u0085卢茅聳聥盲赂颅茫聛庐氓聽麓氓聬聢茫聛芦氓聭录茫聛鲁氓聡潞茫聛聲茫聜聦茫聜聥茫聙聜\n     * 忙聦聡氓庐職茫聝娄茫聝录茫聜露茫聝录茫聛芦氓炉戮茫聛聴茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴ID忙炉聨茫聛庐茫聝聲茫聜漏茫聝录茫聝聽氓\u0085卢茅聳聥忙聹聣莽聞隆猫篓颅氓庐職茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥茫聙聜\n     * @param {Array.\u003cObject\u003e} form_publish_settings 茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓\u0085卢茅聳聥猫篓颅氓庐職茫聛聦盲赂聙茅聝篓氓\u0085卢茅聳聥盲赂颅茫聛庐氓聽麓氓聬聢茫聛庐氓\u0085卢茅聳聥猫篓颅氓庐職茂录聢氓\u0085卢茅聳聥忙聹聼茅聳聯茫聙聛氓\u0085卢茅聳聥忙聺隆盲禄露茂录聣\n     * @param {Array.\u003cObject\u003e} user_groups 忙聦聡氓庐職茫聝娄茫聝录茫聜露茫聝录茫聛聦忙聣聙氓卤聻茫聛聶茫聜聥茫聜掳茫聝芦茫聝录茫聝聴茫聛庐茫聝聡茫聝录茫聜驴\n     * @param {Array.\u003cObject\u003e} user_positions 忙聦聡氓庐職茫聝娄茫聝录茫聜露茫聝录茫聛庐氓陆鹿猫聛路茫聝聡茫聝录茫聜驴\n     * @param {number} user_id 忙聦聡氓庐職茫聝娄茫聝录茫聜露茫聝录ID\n     * @return {Object.\u003c(number), {published: boolean, positions: Array.\u003c{position: string, published: boolean}\u003e}\u003e}\n     *     忙聦聡氓庐職茫聝娄茫聝录茫聜露茫聝录ID茫聛芦氓炉戮茫聛聴茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴ID忙炉聨茫聛庐茫聝聲茫聜漏茫聝录茫聝聽氓\u0085卢茅聳聥忙聹聣莽聞隆猫篓颅氓庐職茫聙聜published: 氓\u0085卢茅聳聥氓聫炉氓聬娄茫聙聛position: 氓陆鹿猫聛路\n     */\n    var getFormPublishedPatterns = function(form_publish_settings,\n                                            user_groups,\n                                            user_positions,\n                                            user_id) {\n        /**\n         * 忙聦聡氓庐職茫聝娄茫聝录茫聜露茫聝录ID茫聛芦氓炉戮茫聛聴茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴ID忙炉聨茫聛庐茫聝聲茫聜漏茫聝录茫聝聽氓\u0085卢茅聳聥忙聹聣莽聞隆猫篓颅氓庐職茫聙聜published: 氓\u0085卢茅聳聥氓聫炉氓聬娄茫聙聛position: 氓陆鹿猫聛路\n         * @type {Object.\u003cnumber, {published: boolean, positions: Array.\u003c{position: string, published: boolean}\u003e}\u003e}\n         */\n        var published_group_positions = [];\n\n        var user_groups_for_loop = {};\n        if (user_groups.length === 0) {\n            // 忙聣聙氓卤聻茫聜掳茫聝芦茫聝录茫聝聴茫聛陋茫聛聴茫聛庐氓聽麓氓聬聢\n            user_groups_for_loop = [{\u0027id\u0027: 0}];\n        } else {\n            // 忙聣聙氓卤聻茫聜掳茫聝芦茫聝录茫聝聴茫聛聜茫聜聤茫聛庐氓聽麓氓聬聢\n            user_groups_for_loop = user_groups;\n        }\n        angular.forEach(user_groups_for_loop, function(group) {\n            published_group_positions[group.id] = {\u0027published\u0027: false, \u0027positions\u0027: [], \u0027group\u0027: group};\n            angular.forEach(user_positions, function(position) {\n                if ((!angular.isUndefinedOrNull(position.group) \u0026\u0026 position.group.id === group.id)\n                    || angular.isUndefinedOrNull(position.group)) {\n                    published_group_positions[group.id][\u0027positions\u0027].push({\n                        \u0027position\u0027: position.position,\n                        \u0027published\u0027: false,\n                        \u0027group\u0027: group,\n                    });\n                }\n            });\n        });\n\n        // g1 茫聛聦 g2 茫聛庐氓颅聬茫聛陋茫聜聣 true 茫聜聮猫驴聰茫聛聶\n        function isChildOf(g1, g2) {\n            if (angular.isUndefinedOrNull(g2)) {\n                return false;\n            }\n            while (!angular.isUndefinedOrNull(g1)) {\n                if (g1.id === g2.id) {\n                    return true;\n                }\n                g1 = g1.parent_group;\n            }\n            return false;\n        }\n\n        // 茫聜掳茫聝芦茫聝录茫聝聴茫聛聦盲赂聙猫聡麓茫聛聴茫聛娄茫聛聞茫聜聦茫聛掳 true 茫聜聮猫驴聰茫聛聶茫聙聜\n        function hasMatchedGroup(user, form) {\n            if (angular.isUndefinedOrNull(user.group) || angular.isUndefinedOrNull(form.group)) {\n                return false;\n            }\n            switch (form.group_condition_type) {\n            case 0: // 氓庐聦氓\u0085篓茫聛芦盲赂聙猫聡麓茫聛聴茫聛娄茫聛聞茫聜聦茫聛掳 true\n                return user.group.id === form.group.id;\n            case 2: // 盲赂聥盲陆聧茫聜掳茫聝芦茫聝录茫聝聴茫聛芦氓卤聻茫聛聴茫聛娄茫聛聞茫聜聦茫聛掳 true\n                return isChildOf(user.group, form.group);\n            default:\n                return false;\n            }\n        }\n\n        // 氓\u0085卢茅聳聥猫篓颅氓庐職茫聝聛茫聜搂茫聝聝茫聜炉\n        angular.forEach(form_publish_settings, function(setting) {\n            // 忙聹聣氓聤鹿茫聛搂茫聛陋茫聛聞忙聦聡氓庐職忙聹聼茅聳聯氓聠\u0085茫聛庐猫篓颅氓庐職茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴茫聛聶茫聜聥\n            if (!moment().startOf(\u0027day\u0027).isBetween(\n                setting[\u0027publish_start_date\u0027].replace(/\\//g, \"-\"),\n                setting[\u0027publish_end_date\u0027].replace(/\\//g, \"-\"), null, \u0027[]\u0027)) {\n                return;\n            }\n            // 茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓\u0085卢茅聳聥猫篓颅氓庐職茫聜聮茅聽聠忙卢隆茫聝聛茫聜搂茫聝聝茫聜炉\n            // 氓聢陇氓庐職莽碌聬忙聻聹茫聛炉group_settings茫聙聛position_setting茫聛芦忙聽录莽麓聧茫聛聲茫聜聦茫聜聥\n            angular.forEach(setting.form_publish_setting_details, function(detail) {\n                // detail茅\u0085聧盲赂聥茫聛芦user,group,position茫聛聦茫聛聜茫聜聤茫聙聛氓\u0085卢茅聳聥忙聦聡氓庐職茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉null茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聜聥\n                // 盲戮聥茂录職茫聙聦茫聛聶茫聛鹿茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茫聙聧茫聛庐茫聜卤茫聝录茫聜鹿茫聛炉group茫聛聦null\n                // 盲戮聥茂录職茫聜掳茫聝芦茫聝录茫聝聴x氓陆鹿猫聛路 茫聛庐氓聽麓氓聬聢茫聙聛detail茫聛庐group茫聛篓position茫聛芦茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛聦氓\u0085楼茫聜聥\n                // 氓聢陇氓庐職茫聛炉茫聙聛(1)氓聬聧忙聦聡茫聛聴 (2)茫聜掳茫聝芦茫聝录茫聝聴x氓陆鹿猫聛路 (3)氓陆鹿猫聛路 (4)茫聜掳茫聝芦茫聝录茫聝聴茫聙聛茫聛庐茂录聰莽篓庐 氓聬聧忙聦聡茫聛聴茫聛炉忙聹聙氓聞陋氓\u0085聢茫聛搂氓聢陇氓庐職\n                // 茫聝聲茫聜漏茫聝录茫聝聽茫聛庐忙聺隆盲禄露茫聛庐氓聢陇氓庐職莽碌聬忙聻聹茫聜聮group-\u003eposition茫聛庐忙聹篓茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聜聥茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛芦猫禄垄氓聠聶茫聛聴茫聛娄茫聛聞茫聛聫\n                // 氓陆鹿猫聛路茫聛庐茫聛驴忙聦聡氓庐職茫聛庐氓聽麓氓聬聢茫聙聛氓\u0085篓茫聜掳茫聝芦茫聝录茫聝聴茫聛芦茫聛聺茫聛庐氓陆鹿猫聛路茫聛聦茫聛聜茫聜聥茫聜聜茫聛庐茫聛篓茫聛聴茫聛娄published_group_positions茫聛芦茫聝聻茫聝聝茫聝聴茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥\n\n                // (1)氓聬聧忙聦聡茫聛聴\n                if (!angular.isUndefinedOrNull(detail.user)) {\n                    angular.forEach(published_group_positions, function(group_settings) {\n                        if (detail.user.id === user_id) {\n                            group_settings.published = true;\n                        }\n                    });\n                    // 茫聝娄茫聝录茫聜露忙聦聡氓庐職茫聛庐detail茫聛炉group莽颅聣茫聛芦氓炉戮茫聛聶茫聜聥忙聦聡氓庐職茫聜聮氓聬芦茫聛戮茫聛陋茫聛聞茫聛聼茫聜聛茫聙聛氓聡娄莽聬聠茫聜聮莽露職猫隆聦茫聛聴茫聛陋茫聛聫茫聛娄茫聜聢茫聛聞\n                    return;\n                }\n\n                // (2)茫聜掳茫聝芦茫聝录茫聝聴x氓陆鹿猫聛路忙聦聡氓庐職 + (3)氓陆鹿猫聛路茫聛庐茫聛驴忙聦聡氓庐職\n                if (!angular.isUndefinedOrNull(detail.position)) {\n                    // 茫聜掳茫聝芦茫聝录茫聝聴茫聛庐忙聹聣莽聞隆茫聛芦茫聛聥茫聛聥茫聜聫茫聜聣茫聛職氓陆鹿猫聛路茫聛聦茫聛聜茫聛拢茫聛聼茫聜聣茫聛聯茫聛聯茫聛搂氓聢陇氓庐職\n                    angular.forEach(published_group_positions, function(group_settings) {\n                        // 茫聝娄茫聝录茫聜露忙聣聙氓卤聻茫聜掳茫聝芦茫聝录茫聝聴茫聛聦氓\u0085卢茅聳聥氓炉戮猫卤隆茫聛搂茫聛炉茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞 =\u003e published: false 茫聛庐茫聛戮茫聛戮(茅聺聻氓\u0085卢茅聳聥)\n                        if (detail.group !== null \u0026\u0026 !hasMatchedGroup(group_settings, detail)) return;\n                        angular.forEach(group_settings.positions, function (position_setting) {\n                            if (position_setting.published === false) {\n                                position_setting.published = isPositionPublishedBySetting(\n                                                                detail.position_condition_type,\n                                                                detail.position,\n                                                                position_setting.position);\n                            }\n                        });\n                    });\n                }\n                // (4)茫聜掳茫聝芦茫聝录茫聝聴茫聛庐茫聛驴忙聦聡氓庐職\n                else if (!angular.isUndefinedOrNull(detail.group)) {\n                    angular.forEach(published_group_positions, function(group_settings) {\n                        if (hasMatchedGroup(group_settings, detail)) {\n                            group_settings.published = true;\n                        }\n                    });\n                }\n                // 茫聛聶茫聛鹿茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茂录聥茫聛聶茫聛鹿茫聛娄茫聛庐氓陆鹿猫聛路\n                else {\n                    angular.forEach(published_group_positions, function(group_settings) {\n                        group_settings.published = true;\n                        angular.forEach(group_settings.positions, function(position_setting) {\n                            position_setting.published = true;\n                        });\n                    });\n                }\n            });\n        });\n        return published_group_positions;\n    };\n\n    // 忙聦聡氓庐職茫聛聴茫聛聼氓陆鹿猫聛路茫聛聦氓\u0085卢茅聳聥猫篓颅氓庐職茫聛庐忙聺隆盲禄露茫聜聮忙潞聙茫聛聼茫聛聴茫聛娄茫聛聞茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥\n    var isPositionPublishedBySetting = function(position_condition_type,\n                                                published_setting_detail_position,\n                                                user_position) {\n        if (angular.isUndefinedOrNull(user_position)) {\n            return false;\n        }\n\n        if (!(\u0027sort_num\u0027 in user_position) || angular.isUndefinedOrNull(user_position.sort_num)) {\n            return false;\n        }\n\n        // 氓陆鹿猫聛路忙聦聡氓庐職(氓\u0085篓茫聛娄猫篓卤氓聫炉or氓聙聥氓聢楼忙聦聡氓庐職猫篓卤氓聫炉茂录聣\n        if (position_condition_type === Const.miscellaneous._COMPARISON.EQ) {\n            if (angular.isUndefinedOrNull(published_setting_detail_position) ||\n                published_setting_detail_position.id === user_position.id) {\n                return true;\n            }\n        }\n        // 氓陆鹿猫聛路盲禄楼盲赂聤茫聛庐忙聦聡氓庐職猫篓卤氓聫炉\n        if (position_condition_type === Const.miscellaneous._COMPARISON.GTE) {\n            if (!angular.isUndefinedOrNull(published_setting_detail_position) \u0026\u0026\n                published_setting_detail_position.sort_num \u003e= user_position.sort_num) {\n                return true;\n            }\n        }\n        // 氓陆鹿猫聛路盲禄楼盲赂聥茫聛庐忙聦聡氓庐職猫篓卤氓聫炉\n        if (position_condition_type === Const.miscellaneous._COMPARISON.LTE) {\n            if (!angular.isUndefinedOrNull(published_setting_detail_position) \u0026\u0026\n                published_setting_detail_position.sort_num \u003c= user_position.sort_num) {\n                return true;\n            }\n        }\n        return false;\n    };\n\n    return {\n        getFormPublishedPatterns: getFormPublishedPatterns,\n    };\n});\n",
                  "create_request_controllers.js":  "\u0027use strict\u0027;\n\nangular\n    .module(\u0027WfApp.create_request_controllers\u0027, [\u0027WfApp.services\u0027])\n    .controller(\u0027CreateRequestController\u0027, CreateRequestController);\n\nCreateRequestController.$inject = [\n    \u0027$scope\u0027,\n    \u0027$rootScope\u0027,\n    \u0027$routeParams\u0027,\n    \u0027$location\u0027,\n    \u0027$locale\u0027,\n    \u0027$window\u0027,\n    \u0027$anchorScroll\u0027,\n    \u0027$filter\u0027,\n    \u0027$document\u0027,\n    \u0027$sce\u0027,\n    \u0027BrowserTabService\u0027,\n    \u0027loginUserService\u0027,\n    \u0027UserService\u0027,\n    \u0027$timeout\u0027,\n    \u0027$q\u0027,\n    \u0027$uibModal\u0027,\n    \u0027Const\u0027,\n    \u0027notifyService\u0027,\n    \u0027dialogService\u0027,\n    \u0027permissionService\u0027,\n    \u0027ApproveService\u0027,\n    \u0027$injector\u0027,\n    \u0027ProjectService\u0027,\n    \u0027gettextCatalog\u0027,\n    \u0027SuspensePaymentService\u0027,\n    \u0027RequestService\u0027,\n    \u0027dateFormat\u0027,\n    \u0027ModifyService\u0027,\n    \u0027AccountTitlePartService\u0027,\n    \u0027FlowService\u0027,\n    \u0027FormService\u0027,\n    \u0027RequestCommentService\u0027,\n    \u0027PaymentTypeService\u0027,\n    \u0027GroupService\u0027,\n    \u0027UserFileService\u0027,\n    \u0027calcItemService\u0027,\n    \u0027createRequestService\u0027,\n    \u0027CreateRequestFormCustomItemService\u0027,\n    \u0027CreateRequestFormItemService\u0027,\n    \u0027CreateRequestFlowService\u0027,\n    \u0027CreateRequestExpenseSpecificsService\u0027,\n    \u0027CreateRequestPaymentSpecificsService\u0027,\n    \u0027CreateRequestSpecificsService\u0027,\n    \u0027FormPublishedService\u0027,\n    \u0027UnloadAlertService\u0027,\n    \u0027FormLimitAmountService\u0027,\n    \u0027CloudsignService\u0027,\n    \u0027GroupPositionService\u0027,\n    \u0027util\u0027,\n    \u0027specificsTable\u0027,\n 