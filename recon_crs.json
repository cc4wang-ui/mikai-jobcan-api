          });\n                    });\n                }\n                RequestService.modify($scope.request_id, request_data)\n                    .then(function(res) {\n                        notifyService.showNotify(gettextCatalog.getString(\u0027莽聰鲁猫芦聥茫聜聮忙聸麓忙聳掳茫聛聴茫聛戮茫聛聴茫聛聼\u0027 +\n                            \u0027茂录聢\u003ca href=#/requests/[[cuid]]\u003e莽聰鲁猫芦聥茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥\u003c/a\u003e茂录聣\u0027, {cuid: res.data.cuid}), \u0027alert-success\u0027);\n                        backToPreviousPage();\n                    })\n                    .catch(function(res) {\n                        var data = res.data;\n                        if (angular.isDefined(data.error_message)) {\n                            const message = angular.isArray(data.error_message) ?\n                                data.error_message.join(\u0027\u003cbr\u003e\u0027): data.error_message;\n                            notifyService.showNotify(message, \u0027alert-danger\u0027);\n                        }\n                        CustomSpecificsConvertService.restoration_custom_specifics(\n                            $scope.form_type, $scope.form_data, $scope.custom_specific_buck_up);\n                    })\n                    .finally(function() {\n                        $scope.createing_request = false;\n                    });\n            }\n        }\n\n        // 莽聰鲁猫芦聥忙聶聜忙聣驴猫陋聧忙漏聼猫聝陆茫聜聮氓聢漏莽聰篓氓聫炉猫聝陆忙聺隆盲禄露茫聛炉盲赂聥猫篓聵茫聛庐茅聙職茫聜聤\n        // 茫聝禄莽聰鲁猫芦聥盲驴庐忙颅拢盲赂颅茫聛搂茫聛炉茫聛陋茫聛聞\n        // 茫聝禄忙聣驴猫陋聧忙篓漏茅聶聬茫聛庐忙聹聣莽聞隆茫聛芦茫聛聥茫聛聥茫聜聫茫聜聣茫聛職盲禄拢莽聬聠忙聣驴猫陋聧忙聶聜茫聛搂茫聛炉茫聛陋茫聛聞\n        // 茫聝禄莽卢卢1茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐忙聣驴猫陋聧猫聙\u0085茫聛聦莽聰鲁猫芦聥猫聙\u0085茫聛篓氓聬聦盲赂聙茫聛搂茫聛聜茫聜聥\n        // 茫聝禄Box茫聝聲茫聜漏茫聝芦茫聝聙忙聦聡氓庐職茫聛聦茫聛陋茫聛聞\n        // 茫聝禄kind==1茫聛炉茫聙聦莽聰鲁猫芦聥茫聛聶茫聜聥茫聙聧茫聝聹茫聜驴茫聝鲁忙聤录盲赂聥茂录聢not盲赂聥忙聸赂茫聛聧茂录聣\n        request_data.approve_in_request = false;\n        if (angular.isUndefinedOrNull($scope.isModify) \u0026\u0026\n            angular.isUndefinedOrNull(request_data.requester_id) \u0026\u0026\n            requestUserIsFirstApprover() \u0026\u0026\n            angular.isUndefinedOrNull($scope.box_folder_name) \u0026\u0026\n            kind === 1\n        ) {\n            // 莽碌聦猫虏禄莽虏戮莽庐聴 盲赂聰茫聛陇 (WF茫聝聴茫聝漏茫聝鲁茫聛聦氓聥陇忙聙聽忙聣聯氓聢禄忙聝\u0085氓聽卤茅聙拢忙聬潞氓聫炉猫聝陆茫聛陋茫聝聴茫聝漏茫聝鲁) 盲赂聰茫聛陇 氓聥陇忙聙聽茅聙拢忙聬潞茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥氓聽麓氓聬聢\n            if ($scope.form_type == 2 \u0026\u0026\n                (wf_atd_plan.can_expense_plan_link_attendance_info ||\n                    wf_atd_plan.can_expense_plan_link_stamp_location) \u0026\u0026\n                atd_settings.use_attendance_record\n            ) {\n                // 莽卢卢茂录聭茫聜鹿茫聝聠茫聝聝茫聝聴忙聣驴猫陋聧茫聛庐茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聜聮猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n                postRequest();\n            } else {\n                var title = gettextCatalog.getString(\u0027莽卢卢1茫聜鹿茫聝聠茫聝聝茫聝聴茫聜聮忙聣驴猫陋聧氓聫炉猫聝陆茫聛搂茫聛聶\u0027);\n                var body = gettextCatalog.getString(\u0027莽卢卢1茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐忙聣驴猫陋聧猫聙\u0085茫聛芦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聛戮茫聛聶茫聙聜忙聣驴猫陋聧茫聛聴茫聛戮茫聛聶茫聛聥茂录聼\u0027);\n                dialogService.showConfirmDialog(\n                    title,\n                    body,\n                    Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP.show,\n                    Const.miscellaneous._DIALOG_OK_BUTTON_TYPE.submit,\n                    gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聛聶茫聜聥\u0027),\n                    gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聛聸茫聛職茫聛芦茅聳聣茫聛聵茫聜聥\u0027)\n                ).then(function (flg) {\n                    if (flg) {\n                        // 莽聰鲁猫芦聥忙聶聜忙聣驴猫陋聧茫聛庐氓聽麓氓聬聢茫聙聛茫聙聛忙聣驴猫陋聧茫聛芦氓驴\u0085猫娄聛茫聛陋object茫聜聮猫娄聛忙卤聜\n                        request_data.approve_in_request = true;\n                    }\n                    postRequest();\n                });\n            }\n        } else {\n            postRequest();\n        }\n    }\n\n    /**\n     * 莽聰鲁猫芦聥忙聸赂茫聛庐氓陇搂忙聻聽茫聛庐茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n     * @param {string} kind 盲赂聥忙聸赂茫聛聧: 0茫聙聛莽聰鲁猫芦聥: 1\n     * @return {Object}\n     */\n    function prepareRequestData(kind) {\n        var request_data = {};\n        request_data.title = $scope.form_data.title;\n        request_data.kind = kind; // 盲赂聥忙聸赂茫聛聧or莽聰鲁猫芦聥\n        request_data.form_type = $scope.form_type; // 莽碌聦猫虏禄莽聰鲁猫芦聥etc..\n        request_data.edit_flow_flg = $scope.form_data.edit_flow_flg; // 莽碌聦猫路炉莽路篓茅聸聠忙赂聢FLG\n        request_data.project = $scope.form_data.project; // 茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢\n        request_data.project_name = $scope.form_data.project_name; // 茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢\n        request_data.project_code = $scope.form_data.project_code; // 茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢\n        if (!angular.isUndefinedOrNull($scope.form_data.group)) {\n            request_data.group = $scope.form_data.group.id; // 茫聜掳茫聝芦茫聝录茫聝聴\n            request_data.group_name = $scope.form_data.group.name;\n            request_data.group_code = $scope.form_data.group.group_code;\n        }\n        // 盲禄拢莽聬聠莽聰鲁猫芦聥猫聙\u0085茫聛庐莽聶禄茅聦虏\n        if (angular.isDefined($scope.requester_id)) {\n            request_data.requester_id = $scope.requester_id;\n        }\n\n        // 莽聰鲁猫芦聥氓\u0085聝茫聜掳茫聝芦茫聝录茫聝聴茫聙聛氓陆鹿猫聛路\n        request_data.requester_group_id = $scope.requester_info.requester_group_id;\n        request_data.requester_position_id = $scope.requester_info.requester_position_id;\n\n        // form_id茫聛炉茫聙聛kind茫聛芦茫聜聢茫聛拢茫聛娄氓聫聳氓戮聴忙聳鹿忙鲁聲茫聛聦莽聲掳茫聛陋茫聜聥茫聛聼茫聜聛茫聙聛kind茫聛聰茫聛篓茫聛芦猫篓颅氓庐職\n        if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.NEW) {\n            request_data.form_id = form_id;\n        }\n        else if ([\n            Const.miscellaneous.CREATE_REQUEST_KIND.EDIT,\n            Const.miscellaneous.CREATE_REQUEST_KIND.COPY,\n            Const.miscellaneous.CREATE_REQUEST_KIND.FEEDBACK,\n        ].indexOf($scope.kind) \u003e= 0) {\n            request_data.form_id = $scope.form_data.form_id;\n        }\n\n        // 茫聜鲁茫聝聰茫聝录莽聰鲁猫芦聥忙聶聜茫聙聛盲赂聥忙聸赂茫聛聧莽聰鲁猫芦聥忙聶聜茫聛炉氓\u0085聝茫聛庐莽聰鲁猫芦聥ID茫聜聮猫驴陆氓聤聽茂录聢茫聜驴茫聜陇茫聝聢茫聝芦莽聰聼忙聢聬忙漏聼猫聝陆茫聛芦茫聛娄盲陆驴莽聰篓茂录聣\n        if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.COPY ||\n            $scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.EDIT) {\n            request_data.source_request_id = $scope.request_id;\n        }\n\n        return request_data;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥忙聶聜茫聛庐莽聰鲁猫芦聥茅聽\u0085莽聸庐茫聝聡茫聝录茫聜驴盲陆聹忙聢聬\n     * @return {Array.\u003cObject\u003e}\n     */\n    function prepareFormItemsData() {\n        var form_items = [];\n        for (var i = 0; i \u003c $scope.form_data.form_json.length; i++) {\n            var item = $scope.form_data.form_json[i];\n\n            // 盲陆聶氓聢聠茫聛陋茫聝隆茫聝鲁茫聝聬忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇\n            if (!angular.isUndefinedOrNull(item.time)) {\n                delete item.time;\n            }\n            if (angular.isDefined(item.is_cleared)) {\n                delete item.is_cleared;\n            }\n\n            // request_detail莽聰篓茫聛庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢莽聰聼忙聢聬\n            var form_item = {};\n            // 猫隆篓莽陇潞茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛搂茅聺聻猫隆篓莽陇潞莽聤露忙\u0085聥茫聛庐茫聜垄茫聜陇茫聝聠茫聝聽茫聛炉茅聙聛盲驴隆茫聛聴茫聛陋茫聛聞茫聙聜\n            if (!isDisplayed(item)) {\n                continue;\n            }\n            form_item = {\n                \u0027row_number\u0027: item.row_number,\n                \u0027form_item_id\u0027: item.id,\n                \u0027form_item_type\u0027: item.item_type,\n                \u0027form_item_name\u0027: item.item_name,\n                \u0027content\u0027: item.request_content,\n            };\n            // checkbox 茫聛庐氓聽麓氓聬聢茫聙聛select_item_labels_obj茫聜聮猫驴陆氓聤聽茫聛搂盲驴聺氓颅聵\n            if (item.item_type === Const.form.ITEM_TYPE_CHECK) {\n                form_item.select_item_labels_obj = item.select_item_labels_obj;\n            }\n            // 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢\n            if (item.item_type === Const.form.ITEM_TYPE_ATTACHMENT) {\n                if (angular.isDefined(item.request_files) \u0026\u0026 item.request_files.length \u003e 0) {\n                    form_item.content_json = item.request_files;\n                }\n            }\n            else {\n                // json盲驴聺氓颅聵茫聛聶茫聜聥茅聽\u0085莽聸庐茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥忙聶聜茫聛庐茫聛驴茅聽\u0085莽聸庐猫篓颅氓庐職\n                if (angular.isDefined(item.request_content_json)) {\n                    form_item.content_json = item.request_content_json;\n                }\n            }\n            form_items.push(form_item);\n        }\n        return form_items;\n    }\n\n    /**\n     * 茅聺聻猫隆篓莽陇潞茫聛庐茅聽\u0085莽聸庐茫聛芦茫聛陇茫聛聞茫聛娄request_data_json茫聛聥茫聜聣氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛聼氓聙陇茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n     * @return {object}\n     */\n    function _editRequestDataJson() {\n        const request_data_json = $scope.form_data;\n        // 茅聺聻猫隆篓莽陇潞茫聛庐茅聽\u0085莽聸庐茫聛庐氓聠\u0085氓庐鹿茫聜聮氓聣聤茅聶陇\n        const form_json = request_data_json.form_json;\n        for (var i = 0; i \u003c form_json.length; i++) {\n            // 猫隆篓莽陇潞猫篓颅氓庐職茫聛庐茅聽\u0085莽聸庐茫聛炉茫聛聺茫聛庐茫聛戮茫聛戮\n            if (isDisplayed(form_json[i])) {\n                continue;\n            }\n            // TODO: 氓戮聦茫聙\u0085盲禄聳茫聛庐莽篓庐茅隆聻茫聛庐茅聽\u0085莽聸庐茫聛芦茫聛陇茫聛聞茫聛娄茫聜聜氓炉戮氓驴聹茫聛聴茫聛聼茫聛聞\n            // 茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵茫聛聲茫聜聦茫聛娄茫聛聞茫聛聼茫聜聣氓聣聤茅聶陇\n            if (form_json[i].item_type === Const.form.ITEM_TYPE_ATTACHMENT) {\n                if (angular.isDefined(form_json[i].request_files)) {\n                    delete form_json[i].request_files;\n                }\n            }\n        }\n        request_data_json.form_json = form_json;\n\n        // 茅聺聻猫隆篓莽陇潞茫聛庐忙聵聨莽麓掳\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            if ($scope.form_data.expense.settlement_flg !=\n                    Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg) {\n                request_data_json.expense = _editExpenseForRequestDataJson(request_data_json.expense);\n            } else {\n                // 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聙聛忙聵聨莽麓掳猫隆聦茫聝聡茫聝录茫聜驴茫聜聮氓聣聤茅聶陇\n                delete request_data_json.expense.request_expense_specifics;\n                delete request_data_json.expense.expense_specific_rows;\n            }\n        }\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢\n        else if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            request_data_json.payment = _editPaymentForRequestDataJson(request_data_json.payment);\n        }\n\n        return request_data_json;\n    }\n\n    /**\n     * 茅聺聻猫隆篓莽陇潞茫聛庐茅聽\u0085莽聸庐茫聛芦茫聛陇茫聛聞茫聛娄request_expense_specifics_rows茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n     * @param {object} expense\n     * @return {object}\n     */\n    function _editExpenseForRequestDataJson(expense) {\n        if (angular.isDefined(expense.request_expense_specifics)) {\n            const specifics = expense.request_expense_specifics;\n            for (var i = 0; i \u003c specifics.length; i++) {\n                if (!isDisplayed(specifics[i])) {\n                    specifics[i].request_expense_specifics_rows = [];\n                }\n            }\n            expense.request_expense_specifics = specifics;\n        }\n        return expense;\n    }\n\n    /**\n     * 茅聺聻猫隆篓莽陇潞茫聛庐茅聽\u0085莽聸庐茫聛芦茫聛陇茫聛聞茫聛娄request_payment_specifics_rows茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n     * @param {object} payment\n     * @return {object}\n     */\n    function _editPaymentForRequestDataJson(payment) {\n        if (angular.isDefined(payment.request_payment_specifics)) {\n            const specifics = payment.request_payment_specifics;\n            for (var i = 0; i \u003c specifics.length; i++) {\n                if (!isDisplayed(specifics[i])) {\n                    specifics[i].request_payment_specifics_rows = [];\n                }\n            }\n            payment.request_payment_specifics = specifics;\n        }\n        return payment;\n    }\n\n\n    /**\n     * 盲赂聧猫娄聛茫聛陋忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n     * @private\n     * @return {Array.\u003cObject\u003e} 茫聝聛茫聜搂茫聝聝茫聜炉氓戮聦茫聛庐request_files茫聜聮猫驴聰茫聛聶\n     */\n    function _editRequestFiles() {\n        if (!isDisplayedFileForm()) {\n            $scope.request_files = [];\n        }\n        return $scope.request_files;\n    }\n\n\n    /**\n     * 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聛聥氓聢陇氓庐職茫聛聶茫聜聥\n     * @return {boolean} 猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聛陋茫聜聣true茫聜聮猫驴聰茫聛聶\n     */\n    function isDisplayedFileForm() {\n        if (!showFileAttachment()) {\n            return true;\n        }\n        const show = Boolean($scope.form_data.attachment_setting_flg === 0);\n        const required = Boolean($scope.form_data.attachment_setting_flg === 1);\n        const is_free = permissionService.isFreeUser();\n        if ((show || required) \u0026\u0026 !is_free) {\n            return true;\n        }\n        return false;\n    }\n\n\n    /**\n     * 猫隆篓莽陇潞茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛芦茫聜聢茫聜聤茫聙聛猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥忙聵聨莽麓掳猫隆篓茫聜聮猫驴聰氓聧麓茫聛聶茫聜聥\n     * @param {Object} specifics_obj\n     * @return {Array.\u003cObject\u003e}\n     * @private\n     */\n    function _getDisplayingSpecificsSheets(specifics_obj) {\n        var result = [];\n        angular.forEach(specifics_obj, function(sheet) {\n            if (isDisplayed(sheet)) {\n                result.push(sheet);\n            }\n        });\n        return result;\n    }\n\n    /**\n     * 氓\u0085楼氓聤聸忙赂聢茫聛驴茫聛聥茫聛陇猫隆篓莽陇潞盲赂颅茫聛庐忙聵聨莽麓掳猫隆篓茫聜聮猫驴聰氓聧麓茫聛聶茫聜聥\n     * @param {Object} specifics_obj 忙聵聨莽麓掳猫隆篓\n     * @return {Array.\u003cObject\u003e}\n     * @private\n     */\n    function _getDisplayingInputtedSpecificsSheets(specifics_obj) {\n        if (isSpecificsSheet() \u0026\u0026\n            ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE ||\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT)\n        ) {\n            // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛搂忙聹陋盲陆驴莽聰篓茫聛庐request_custom_specific_items茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n            CustomSpecificsConvertService.removeItemsForPassChecks(\n                specifics_obj,\n            );\n        }\n        const result = specifics_obj.filter(function(sheet) {\n            const isInputted = CustomSpecificsService.isCustomSpecifics(sheet) ?\n                createRequestService.isSheetInputtedCustom(sheet, $scope.form_type) :\n                createRequestService.isSheetInputted(sheet, $scope.form_type);\n            // 氓\u0085楼氓聤聸忙赂聢茫聛驴茫聛聥茫聛陇猫隆篓莽陇潞盲赂颅茫聛庐忙聵聨莽麓掳茫聛庐茫聛驴茫聜聮猫驴陆氓聤聽茫聛聶茫聜聥\n            return (isInputted \u0026\u0026 isDisplayed(sheet));\n        });\n        CustomSpecificsConvertService.resettingItemsForPassChecks(\n            specifics_obj,\n        );\n        return result;\n    }\n\n    /**\n     * 莽聰禄茅聺垄猫陋颅猫戮录忙聶聜茫聛芦氓聬聢猫篓聢茅聡聭茅隆聧茫聜聮猫篓聢莽庐聴茫聛聶茫聜聥\n     * @param {object} form_items_data 莽聰鲁猫芦聥茫聛庐茅聽\u0085莽聸庐茫聛庐茫聝聡茫聝录茫聜驴\n     */\n    function initializeItems(form_items_data) {\n        for (var i = 0; i \u003c form_items_data.length; i++) {\n            if (form_items_data[i].item_type === Const.form.ITEM_TYPE_CALC) {\n                initializeCalcItem(form_items_data[i]);\n            }\n        }\n        updateTotalAmount();\n    }\n    /**\n     * 猫篓聢莽庐聴茅聽\u0085莽聸庐茫聛庐猫篓聢莽庐聴氓录聫茫聜聮茫聙聛忙聲掳氓颅聴茫聛搂猫隆篓莽聫戮茫聛聶茫聜聥忙聳聡氓颅聴氓聢聴茫聜聮猫驴聰茫聛聶茫聙聜\n     * 忙聳聡氓颅聴氓聢聴盲戮聥1: \"15 盲潞潞 脙聴 1000 氓聠聠 = 15000 氓聠聠\"\n     * 忙聳聡氓颅聴氓聢聴盲戮聥2: \"10,000 氓聠聠 脙聴 1.08 = 10,800氓聠聠\"\n     * @param {object} item\n     * @return {string} calcNumeralExpression\n     */\n    function makeCalcExpressionFromValue(item) {\n        return calcItemService.makeCalcExpressionFromValue(item);\n    }\n\n    /**\n     * 猫篓聢莽庐聴茅聽\u0085莽聸庐茫聛庐猫篓聢莽庐聴莽碌聬忙聻聹茫聜聮猫驴聰茫聛聶茫聙聜\n     *\n     * calcItem茫聛庐氓聫鲁茅聽\u0085茫聛篓氓路娄茅聽\u0085茫聛炉茫聙聛茫聝聴茫聝陋茫聝聼茫聝聠茫聜拢茫聝聳茫聛庐number氓聻聥茫聛搂茫聛聜茫聜聥茫聙聜\n     * 茫聛聯茫聛庐茫聛聼茫聜聛茫聙聛氓\u0085楼氓聤聸茫聛庐莽虏戮氓潞娄茫聛炉盲驴聺猫篓录茫聛聴茫聛陋茫聛聞茫聛聦茫聙聛莽碌聬忙聻聹茫聛庐莽虏戮氓潞娄茫聛炉盲驴聺猫篓录茫聛聶茫聜聥茫聜聢茫聛聠茫聛陋猫篓颅猫篓聢茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聜聥茫聙聜\n     * @param {object} item calcItem茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @return {string | null} 猫篓聢莽庐聴莽碌聬忙聻聹茫聜聮忙聳聡氓颅聴氓聢聴茫聛篓茫聛聴茫聛娄猫驴聰茫聛聶茫聙聜\n     */\n    function calculateCalcItem(item) {\n        return calcItemService.calculateCalcItem(item);\n    }\n\n    /**\n     * 盲赂隆茅聽\u0085莽聸庐茫聛聦氓庐職忙聲掳茫聛搂茫聛聜茫聜聥氓聽麓氓聬聢true茫聜聮猫驴聰茫聛聶\n     * @param {object} calcItem\n     * @return {boolean}\n     */\n    function hasBothTermValue(calcItem) {\n        return calcItemService.hasBothTermValue(calcItem);\n    }\n\n    /**\n     * 猫篓聢莽庐聴茅聽\u0085莽聸庐茫聛庐氓聢聺忙聹聼氓聦聳茫聜聮猫隆聦茫聛聠\n     * @param {object} form_item form_item茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     */\n    function initializeCalcItem(form_item){\n        form_item.calcItem.result.value = hasBothTermValue(form_item.calcItem)\n            ? calculateCalcItem(form_item)\n            : form_item.calcItem.result.value;\n        form_item.request_content = makeCalcExpressionFromValue(form_item);\n    }\n\n    /**\n     * 茅聽\u0085莽聸庐茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聛聥氓聬娄茫聛聥茫聜聮猫驴聰茫聛聶\n     * @param {Object} item 忙聵聨莽麓掳猫隆篓茫聛戮茫聛聼茫聛炉茫聝聲茫聝陋茫聝录猫篓颅氓庐職茅聽\u0085莽聸庐茫聛庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @return {boolean} 猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聛陋茫聜聣true茫聜聮猫驴聰茫聛聶\n     */\n    function isDisplayed(item) {\n        return checkItemOptionStatus(item, \u0027is_disp\u0027);\n    }\n\n    /**\n     * 茅聽\u0085莽聸庐茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聛聥氓聬娄茫聛聥茫聜聮猫驴聰茫聛聶\n     * @param {Object} item 忙聵聨莽麓掳猫隆篓茫聛戮茫聛聼茫聛炉茫聝聲茫聝陋茫聝录猫篓颅氓庐職茅聽\u0085莽聸庐茫聛庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @return {boolean} 猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茫聛陋茫聜聣true茫聜聮猫驴聰茫聛聶\n     */\n    $scope.isDisplayed = function(item) {\n        return checkItemOptionStatus(item, \u0027is_disp\u0027);\n    };\n\n    /**\n     * 忙聳掳猫娄聫莽聰鲁猫芦聥茫聛庐茅職聸茫聛芦茫聙聛form茫聝聡茫聝录茫聜驴氓聫聤茫聛鲁flow茫聝聡茫聝录茫聜驴茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     */\n    function readCustomForm() {\n        var params = {};\n        if (angular.isUndefined($scope.requester_id)) {\n            params.request_user_id = $scope.login_user.id;\n        }\n        else {\n            params.request_user_id = $scope.requester_id;\n        }\n        FormService.readCustomForm(form_id, params)\n        .then(function(data) {\n            // form氓聬聧茫聙聛猫陋卢忙聵聨茫聛庐氓聫聳氓戮聴\n            $scope.form_type = data.form_type;\n            $scope.form_data.default_atp = angular.fromJson(data.default_atp || \u0027null\u0027);\n\n            // 氓\u0085卢茅聳聥猫篓颅氓庐職\n            $scope.form_publish_settings = data.form_publish_settings;\n            $scope.publish_setting_kind = data.publish_setting_kind;\n            if ($scope.publish_setting_kind === Const.miscellaneous.PUBLISH_SETTING_KIND.PARTLY_PUBLIC.key) {\n                setFormPublishedPatterns();\n            }\n\n            // 忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛庐氓聫炉氓聬娄\n            $scope.form_data.is_allowed_new_company = data.is_allowed_new_company;\n\n            initRequesterInfo();\n\n            // form_type茫聛聰茫聛篓茫聛庐氓聢聺忙聹聼氓聙陇茫聜聮猫篓颅氓庐職\n            // 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐氓聽麓氓聬聢\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                $scope.form_data.expense = {};\n                $scope.form_data.expense.settlement_flg = data.settlement_flg;\n                $scope.form_data.expense.related_request_view_setting_flg = data.related_request_view_setting_flg;\n                $scope.form_data.expense.pay_content_setting_flg = data.pay_content_setting_flg;\n                $scope.form_data.expense.allow_suspense_payment = data.allow_suspense_payment;\n                $scope.form_data.expense.use_suspense_payment = data.allow_suspense_payment;\n\n                // 忙聰炉忙聣聲忙聣聥忙庐碌氓聢漏莽聰篓猫篓颅氓庐職\n                $scope.form_data.expense.payment_option_setting = data.payment_option_setting;\n                // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聢漏莽聰篓猫篓颅氓庐職\n                $scope.form_data.expense.payment_due_date_setting = data.payment_due_date_setting;\n\n                // 盲禄庐忙聣聲茫聙聦猫篓卤氓聫炉茫聛聶茫聜聥茫聙聧茫聛搂茫聙聛忙聰炉忙聣聲忙聣聥忙庐碌氓聢漏莽聰篓猫篓颅氓庐職茫聛聦茫聙聦氓聢漏莽聰篓茫聛聶茫聜聥茫聙聧茫聛陋茫聜聣忙聰炉忙聣聲忙聣聥忙庐碌盲赂聙猫娄搂氓聫聳氓戮聴\n                if ($scope.form_data.expense.allow_suspense_payment \u0026\u0026\n                    $scope.form_data.expense.payment_option_setting\n                ) {\n                    PaymentOptionService.getList().then(function (response) {\n                        $scope.payment_options = response.data;\n                        $scope.display_payment_options = angular.copy($scope.payment_options);\n                    });\n                }\n\n                // 忙聰炉忙聣聲忙聺隆盲禄露盲赂聙猫娄搂氓聫聳氓戮聴\n                paymentDateService.getPaymentDateTerms().then(function (response) {\n                    $scope.payment_date_terms = response.data.results;\n                }).catch(function(res) {\n                    notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n                });\n\n                // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聢漏莽聰篓猫篓颅氓庐職ON茫聛搂茫聙聛氓聼潞忙潞聳忙聴楼茫聛聦莽聰鲁猫芦聥忙聴楼茫聛庐氓聽麓氓聬聢茫聙聛忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮茫聜禄茫聝聝茫聝聢\n                if ($scope.form_data.expense.payment_due_date_setting \u0026\u0026\n                    $scope.payment_terms_reference_date_type\n                        === Const.miscellaneous.PAYMENT_TERMS_REFERENCE_DATE_TYPE.REQUEST_DATE\n                ) {\n                    // 忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼\n                    _getFormPaymentDateTermReflectConditions(form_id).then(function () {\n                        // 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛搂盲禄庐忙聣聲茫聙聦猫篓卤氓聫炉茫聛聴茫聛陋茫聛聞茫聙聧氓聽麓氓聬聢茫聛戮茫聛聼茫聛炉忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茂录職茫聜芦茫聝卢茫聝鲁茫聝聙茫聝录茫聛搂茫聛炉茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮氓聫聳氓戮聴茫聛聴茫聛陋茫聛聞\n                        if (\n                            !$scope.form_data.expense.allow_suspense_payment \u0026\u0026\n                            $scope.form_data.expense.settlement_flg ==\n                                Const.miscellaneous._FORM_TYPE.EXPENSE_PRE_APPLY.settlement_flg\n                        ) {\n                            return;\n                        }\n                        if (!paymentDateService.isPaymentDateTypeCalendar($scope.payment_date_type)) {\n                            return;\n                        }\n                        // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聫聳氓戮聴API茫聛庐莽碌聬忙聻聹茫聜聮茫聜禄茫聝聝茫聝聢\n                        // 莽聫戮氓聹篓忙聴楼忙聶聜茫聛搂忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮氓聫聳氓戮聴\n                        paymentDateService.getPaymentDueDate(\n                            $scope.payment_date_term,\n                            moment().format(\u0027YYYYMMDD\u0027)\n                        ).then(function (respose) {\n                            $scope.payment_due_date.new =\n                                moment(respose.data.payment_date, \u0027YYYYMMDD\u0027).format(\u0027YYYY/MM/DD\u0027);\n                        });\n                    });\n                }\n\n                // 忙聵聨莽麓掳茫聛庐猫篓颅氓庐職\n                if (data.specifics_json\n                    \u0026\u0026 $scope.form_data.settlement_flg !==\n                    Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg) {\n                    // 茫聝聬茫聝录茫聜赂茫聝搂茫聝鲁氓路庐氓聢聠茫聜聮氓聼聥茫聜聛茫聜聥\n                    $scope.form_data.expense.request_expense_specifics = _fixVersionDifferenceForExpenseSpecifics(\n                        angular.fromJson(data.specifics_json)\n                    );\n                }\n                getAccountTitleParts($scope.form_data.default_atp);\n                getPaymentTypes();\n\n                FormLimitAmountService.getLimitAmountSetting(\n                    form_id,\n                    $scope.kind,\n                    $scope.requester_info.requester_position_id,\n                    null\n                )\n                    .then(function(data) {\n                        $scope.form_limit_amount_setting = data;\n                    })\n                    .catch(function() {\n                        $scope.form_limit_amount_setting = null;\n                    });\n            }\n\n            // 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐氓聽麓氓聬聢\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n                $scope.isDisplayBank = true;\n                $scope.form_data.payment = {};\n                $scope.form_data.payment.bank_transfer_fee_type = 0;\n                $scope.form_data.payment.withholding_tax_calc = 0;\n                $scope.form_data.payment.bank_account_type_code = 1;\n                $scope.form_data.payment.is_new_company = false;\n                $scope.form_data.payment.payment_form_type = data.payment_form_type;\n                $scope.form_data.payment.related_request_view_setting_flg = data.related_request_view_setting_flg;\n                $scope.form_data.payment.pre_request_view_setting_flg = data.pre_request_view_setting_flg;\n                $scope.form_data.payment.pay_content_setting_flg = data.pay_content_setting_flg;\n                $scope.form_data.payment.is_allowed_edit_payee = data.is_allowed_edit_payee;\n                $scope.form_data.payment.payment_due_date_setting = data.payment_due_date_setting;\n\n                // 忙聵聨莽麓掳茫聛庐猫篓颅氓庐職\n                if (data.specifics_json) {\n                    $scope.form_data.payment.request_payment_specifics = angular.fromJson(data.specifics_json);\n                }\n                getAccountTitleParts($scope.form_data.default_atp);\n\n                // 忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤 莽聰鲁猫芦聥忙聸赂茫聛聰茫聛篓茫聛芦忙聰炉忙聣聲氓\u0085聢茫聜聮忙聦聡氓庐職\n                $scope.form_data.payment.is_payee_per_request = data.is_payee_per_request;\n                // 忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤 氓陆垄氓录聫\n                $scope.form_data.payment.is_company_payment_format = data.is_company_payment_format;\n                $scope.form_data.payment.is_user_payment_format = data.is_user_payment_format;\n\n                // 忙聰炉忙聣聲忙聺隆盲禄露盲赂聙猫娄搂氓聫聳氓戮聴\n                paymentDateService.getPaymentDateTerms().then(function (response) {\n                    $scope.payment_date_terms = response.data.results;\n                }).catch(function(res) {\n                    notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n                });\n\n                // 茫聝聲茫聜漏茫聝录茫聝聽茫聛芦莽麓聬茫聛楼茫聛聫忙聰炉忙聣聲忙聺隆盲禄露盲赂聙猫娄搂氓聫聳氓戮聴\n                _getFormPaymentDateTermReflectConditionsForPayment(form_id).then(function () {\n                    // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聫聳氓戮聴API茫聛庐莽碌聬忙聻聹茫聜聮茫聜禄茫聝聝茫聝聢\n                    // 莽聫戮氓聹篓忙聴楼忙聶聜茫聛搂忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮氓聫聳氓戮聴\n                    if (\n                        !paymentDateService.isCalculatePaymentDueDate(\n                            $scope.payment_date_term_detail.payment_date_type,\n                            $scope.form_data.payment.reference_date_type\n                        )\n                    ) {\n                        return;\n                    }\n                    // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聫聳氓戮聴API茫聛庐莽碌聬忙聻聹茫聜聮茫聜禄茫聝聝茫聝聢\n                    // 茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼忙聰炉忙聣聲忙聺隆盲禄露茫聛搂忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聜聮猫篓聢莽庐聴茫聛聶茫聜聥\n                    paymentDateService.getPaymentDueDate(\n                        $scope.form_data.payment.payment_date_term,\n                        moment().format(\u0027YYYYMMDD\u0027)\n                    ).then(function (response) {\n                        $scope.form_data.payment.payment_due_date =\n                            moment(response.data.payment_date, \u0027YYYYMMDD\u0027).format(\u0027YYYY/MM/DD\u0027);\n                    });\n                }).catch(function(res) {\n                    notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n                });\n            }\n\n            // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EC) {\n                $scope.form_data.ec = {};\n                // EC茅聙拢忙聬潞猫篓颅氓庐職茫聜聮氓聫聳氓戮聴\n                FormService.readFromEcSetting(form_id).then(function (res) {\n                    // 氓陆聯氓聢聺茫聛炉Amazon茫聝聯茫聜赂茫聝聧茫聜鹿茫聛庐茫聛驴茫聛陋茫聛庐茫聛搂res.data茫聛庐盲赂聙盲禄露莽聸庐茫聜聮盲陆驴莽聰篓茫聛聶茫聜聥\n                    $scope.form_data.ec.ec_retailer = res.data[0].ec_retailer;\n                    $scope.form_data.ec.ec_settings = res.data[0].ec_settings;\n                });\n                $scope.form_data.ec.settlement_flg = data.settlement_flg;\n                $scope.form_data.ec.related_request_view_setting_flg = data.related_request_view_setting_flg;\n                $scope.form_data.ec.pay_content_setting_flg = data.pay_content_setting_flg;\n            }\n\n            $scope.form_data.form_name = data.form_name;\n            $scope.form_data.description = data.description;\n            $scope.form_data.approval_period_setting_flg = data.approval_period_setting_flg;\n            