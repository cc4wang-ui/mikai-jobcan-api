fics) {\n                    const invalid_invoice_registrated_number_items = specifics.request_payment_specifics_rows.filter(\n                        function(row) {\n                            return row.invoice_registrated_number \u0026\u0026 row.is_valid_invoice_registrated_number === false;\n                    });\n                    if (invalid_invoice_registrated_number_items.length \u003e 0) {\n                        result.result = INVALID_INVOICE_REGISTRATED_NUMBER;\n                        return result;\n                    }\n                });\n            }\n        }\n\n        // 氓聠\u0085猫篓鲁茫聛芦莽麓聬茫聛楼茫聛聫盲潞聥忙楼颅猫聙\u0085氓聦潞氓聢聠茫聛篓莽聶禄茅聦虏莽聲陋氓聫路茫聛庐茅聳垄茅聙拢茫聝聛茫聜搂茫聝聝茫聜炉\n        if (checkInvalidInvoiceRequestError(request_form)) {\n            result.result = INVALID_INVOICE_REQUEST_ERROR;\n            return result;\n        }\n\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽氓聠\u0085茫聛庐氓聢漏莽聰篓忙聴楼茫聛聦盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐忙聴楼盲禄聵忙聹聼茅聳聯茫聝聛茫聜搂茫聝聝茫聜炉茫聛搂茫聜篓茫聝漏茫聝录茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n            if (expense_date_period_error) {\n                result.result = SPECIFICS_ROWS_VALIDATION_ERROR;\n                return result;\n            }\n            // 茅聡聭茅隆聧茫聛庐茫聝聻茫聜陇茫聝聤茫聜鹿氓聙陇茫聝聛茫聜搂茫聝聝茫聜炉\n            // TODO 茫聜碌茫聝录茫聝聬茫聝录氓聛麓茫聛搂茫聝聛茫聜搂茫聝聝茫聜炉茫聜聮茫聛聴茫聛娄茫聛聞茫聜聥茫聛庐茫聛搂茫聙聛茫聛聯茫聛聯茫聛搂茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉茫聛炉盲赂聧猫娄聛茫聛芦茫聛陋茫聜聥\n            // 忙聵聨莽麓掳茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢\n            if (isSpecificsSheet()) {\n                if (_isMinusAmountDetailError(displayingSheets)) {\n                    result.result = MINUS_AMOUNT_ERROR;\n                    return result;\n                }\n            // 忙聵聨莽麓掳茫聛聦茫聛陋茫聛聞茫聛聥茫聛陇茅聡聭茅隆聧茫聛聦茫聝聻茫聜陇茫聝聤茫聜鹿茫聛庐氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n            } else if ($scope.form_data.expense.amount \u003c 0) {\n                result.result = MINUS_AMOUNT_ERROR;\n                return result;\n            }\n        }\n\n        if (isSpecificsSheet() \u0026\u0026 $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            // 莽碌聦猫虏禄茫聝聲茫聜漏茫聝录茫聝聽茫聛庐盲潞陇茅聙職猫虏禄忙聵聨莽麓掳茫聛搂茫聙聛忙聴垄茫聛芦莽聰鲁猫芦聥忙赂聢茫聛庐盲潞陇茅聙職猫虏禄茫聛聽茫聛篓氓聢陇忙聳颅茫聛搂茫聛聧茫聛聼茫聜聣茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聫茫聛聶茫聜聥\n            for (i = 0; i \u003c displayingSheets.length; i++) {\n                var sheet = displayingSheets[i];\n                if (sheet.specifics_type !== Const.miscellaneous.EXPENSE_SPECIFICS_TRANSPORT) continue;\n                var rows = sheet.request_expense_specifics_rows;\n                for (var j = 0; j \u003c rows.length; j++) {\n                    if (angular.isUndefinedOrNull(rows[j].progress_request)) continue;\n                    result.result = PROGRESS_REQUEST_TRANSPORT_ERROR;\n                    return result;\n                }\n            }\n            // 氓垄聴莽篓聨茫聛庐忙聳陆猫隆聦忙聴楼茫聜聮茫聛戮茫聛聼茫聛聞茫聛聽忙聵聨莽麓掳茫聜聮茫聛戮茫聛篓茫聜聛茫聜聥茫聜聢茫聛聠茫聛陋莽聰鲁猫芦聥茫聜聮莽娄聛忙颅垄茫聛聶茫聜聥\n            var hasError = function(specific) {\n                if (specific.journal_summary_setting !== Const.miscellaneous.JOURNAL_SUMMARY_SETTING_SUMMARY) {\n                    return false; // 茫聛戮茫聛篓茫聜聛茫聜聥猫篓颅氓庐職茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳氓聲聫茅隆聦茫聛陋茫聛聴\n                }\n                var xday = Date.parse(\u00272019/10/1\u0027);\n                var hasOldDate = false;\n                var hasNewDate = false;\n                var rows = specific.request_expense_specifics_rows;\n                for (i = 0; i \u003c rows.length; ++i) {\n                    if (Date.parse(rows[i].allocation_date) \u003c xday) {\n                        hasOldDate = true;\n                    }\n                    else {\n                        hasNewDate = true;\n                    }\n                }\n                return hasOldDate \u0026\u0026 hasNewDate;\n            };\n            if (displayingSheets.some(hasError)) {\n                result.result = DIFFERENT_TAX_PERIODS_ERROR;\n                return result;\n            }\n        }\n\n        // 忙聰炉忙聣聲忙聣聥忙庐碌茫聛聦氓聢漏莽聰篓氓聫炉猫聝陆茫聛聥氓聢陇氓庐職\n        if (PaymentOptionService.canUsePaymentOptionForm($scope.form_data.expense)) {\n            // 忙聰炉忙聣聲忙聣聥忙庐碌茫聛庐茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁茅聛赂忙聤聻猫聜垄茫聛聦1盲禄露茫聜聜莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉茫聜篓茫聝漏茫聝录\n            if ($scope.display_payment_options.length \u003c 1) {\n                result.result = NOT_REGISTERD_PAYMENT_OPTIONS_ERROR;\n                return result;\n            }\n        }\n        // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛聦氓聢漏莽聰篓氓聫炉猫聝陆茫聛聥氓聢陇氓庐職\n        if (PaymentOptionService.canUsePaymentDueDateForm($scope.form_data.expense)) {\n            // 忙聰炉忙聣聲忙聺隆盲禄露茫聛聦1盲禄露茫聜聜莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉茫聜篓茫聝漏茫聝录\n            if ($scope.payment_date_terms.length \u003c 1) {\n                result.result = NOT_REGISTERD_PAYMENT_DATE_TERMS_ERROR;\n                return result;\n            }\n        }\n\n        // 茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼氓聦潞氓聢聠茫聛芦盲赂聧忙聲麓氓聬聢茫聛聦猫碌路茫聛聧茫聛娄茫聛聞茫聛陋茫聛聞茫聛聥茫聝聛茫聜搂茫聝聝茫聜炉\n        if (isSpecificsSheet() \u0026\u0026 $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            const request_expense_specifics = displayingSheets.filter(function(sheet) {\n                return !util.isUndefinedOrNull(sheet.request_expense_specifics_rows);\n            });\n\n            // 氓聦潞氓聢聠(茫聜鲁茫聝录茫聝聺茫聝卢茫聝录茫聝聢茫聜芦茫聝录茫聝聣氓聢漏莽聰篓忙聵聨莽麓掳氓聦潞氓聢聠)茫聛芦莽麓聬茫聛楼茫聛聥茫聛陋茫聛聞氓聠\u0085猫篓鲁茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聜聮莽娄聛忙颅垄茫聛聶茫聜聥\n            request_expense_specifics.forEach((sheet) =\u003e {\n                const hasError = sheet.request_expense_specifics_rows.filter((row) =\u003e {\n                    // 茅聛赂忙聤聻氓聫炉猫聝陆茫聛陋氓聠\u0085猫篓鲁茫聛聦莽麓聬茫聛楼茫聛聞茫聛聼氓聦潞氓聢聠茫聛聥茫聜聣猫篓颅氓庐職茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁茫聛聦忙颅拢茫聛聴茫聛聞茫聛聥茫聛庐氓聢陇氓庐職\n                    // 氓聠\u0085猫篓鲁茫聛芦莽麓聬茫聛楼茫聛聥茫聛陋茫聛聞茫聜聜茫聛庐茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聴茫聛戮茫聛拢茫聛聼盲赂聥忙聸赂茫聛聧莽路篓茅聸聠茫聛搂莽聰鲁猫芦聥茫聛庐茅職聸忙颅垄茫聜聛茫聜聥莽聜潞茫聙聜\n                    return row.is_credit_card \u0026\u0026 !row.is_parent_specifics\n                        \u0026\u0026 row.corporate_card_journal_divisions.some((journal_division) =\u003e {\n                            // 氓聢聠氓聣虏忙聵聨莽麓掳茫聛庐猫娄陋茫聛芦氓聠\u0085猫篓鲁茫聛炉氓颅聵氓聹篓茫聛聴茫聛陋茫聛聞茫聛聦茫聙聛氓聢聠氓聣虏茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳氓颅聵氓聹篓茫聛聶茫聜聥茫聙聜\n                            return journal_division.id === row.corporate_card_journal_division\n                                \u0026\u0026 journal_division.account_title_part_id\n                                \u0026\u0026 journal_division.account_title_part_id !== row.account_title_part;\n                        });\n                }).reduce((_, row) =\u003e {\n                    row.errors.validate_account_title_part = true;\n                    return true;\n                }, false);\n\n                if (hasError) {\n                    sheet.invalid_account_title_part = true;\n                    result.result = DIVISION_AND_ACCOUNT_TITLE_PART_INTEGRITY_ERROR;\n                }\n            });\n            if (!util.isUndefinedOrNull(result.result)) {\n                return result;\n            }\n\n            let division_check_target_rows = [];\n            displayingSheets.forEach(function(sheet) {\n                // 茫聝聛茫聜搂茫聝聝茫聜炉氓炉戮猫卤隆猫隆聦茫聛庐忙聤陆氓聡潞\n                const rows = sheet.request_expense_specifics_rows.filter(function(row) {\n                    return row.is_credit_card \u0026\u0026 row.isAutomaticSetting;\n                });\n                // 盲禄露忙聲掳氓聢露茅聶聬茫聜聮氓聸聻茅聛驴茫聛聶茫聜聥茫聛聼茫聜聛茫聛芦 push() 茫聜聮盲陆驴莽聰篓茫聛聴茫聛陋茫聛聞\n                division_check_target_rows = [...division_check_target_rows, ...rows];\n            });\n            division_check_target_rows.forEach(function(row){\n                // 莽垄潞猫陋聧茫聝聹茫聜驴茫聝鲁忙聤录盲赂聥忙聶聜莽聜鹿茫聛庐氓聦潞氓聢聠茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉\n                let selected_division = null;\n                if (!util.isUndefinedOrNull(present_divisions[row.card_id])){\n                    present_divisions[row.card_id].forEach(function(division){\n                        if (row.corporate_card_journal_division === division.id) {\n                            selected_division = division;\n                        }\n                    });\n                }\n\n                if (util.isUndefinedOrNull(selected_division)) {\n                    // 氓聦潞氓聢聠茫聛聦氓聣聤茅聶陇茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢\n                    row.errors.validate_division = true;\n                    result.result = DIVISION_INTEGRITY_ERROR;\n                } else if (selected_division.account_title_part_id !== row.account_title_part) {\n                    // 氓聦潞氓聢聠茫聛芦莽麓聬茫聛楼茫聛聥茫聛陋茫聛聞氓聠\u0085猫篓鲁茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢\n                    row.errors.validate_account_title_part = true;\n                    result.result = DIVISION_AND_ACCOUNT_TITLE_PART_INTEGRITY_ERROR;\n                }\n                if (!util.isUndefinedOrNull(selected_division) \u0026\u0026\n                        !util.isUndefinedOrNull(selected_division.boundary_transaction_date) \u0026\u0026\n                            selected_division.boundary_transaction_date \u003e row.allocation_date) {\n                    // 莽聰鲁猫芦聥忙聹聼茅聳聯茫聛聦猫露\u0085茅聛聨茫聛聴茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茂录聢莽聫戮莽聤露茫聙聛忙卤聨莽聰篓茂录聢盲赂聧忙聹聧茂录聣茫聛庐茫聛驴茂录聣\n                    // boundary_transaction_date 茫聛炉莽垄潞猫陋聧茫聝聹茫聜驴茫聝鲁忙聤录盲赂聥忙聶聜茫聛庐忙聴楼盲禄聵茫聜聮氓聼潞忙潞聳茫聛芦莽聰鲁猫芦聥氓聫炉猫聝陆茫聛陋氓垄聝莽聲聦茫聛庐氓聢漏莽聰篓忙聴楼\n                    row.errors.division_term_range = true;\n                    result.division_name = selected_division.name;\n                    result.result = DIVISION_TERM_RANGE_ERROR;\n                }\n            });\n            // 茫聜路茫聝录茫聝聢氓聧聵盲陆聧茫聛搂氓聠聧茅聸聠猫篓聢\n            request_expense_specifics.forEach(function(sheet){\n                sheet.invalid_division = sheet.request_expense_specifics_rows.some(function (row) {\n                    return !util.isUndefinedOrNull(row.errors)\n                        \u0026\u0026 !util.isUndefinedOrNull(row.errors.validate_division)\n                        \u0026\u0026 row.errors.validate_division;\n                });\n                sheet.invalid_account_title_part = sheet.request_expense_specifics_rows.some(function (row) {\n                    return !util.isUndefinedOrNull(row.errors)\n                        \u0026\u0026 !util.isUndefinedOrNull(row.errors.validate_account_title_part)\n                        \u0026\u0026 row.errors.validate_account_title_part;\n                });\n                const invalid_division_term_range = sheet.request_expense_specifics_rows.some(function (row) {\n                    return !util.isUndefinedOrNull(row.errors)\n                        \u0026\u0026 !util.isUndefinedOrNull(row.errors.validate_account_title_part)\n                        \u0026\u0026 row.errors.division_term_range;\n                });\n                if (invalid_division_term_range) {\n                    // 盲赂聧忙聹聧茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉茫聛炉盲禄聳茫聛庐茫聜篓茫聝漏茫聝录茫聛芦氓聞陋氓\u0085聢茫聛聲茫聛聸茫聜聥\n                    result.result = DIVISION_TERM_RANGE_ERROR;\n                    return result;\n                }\n                if (sheet.invalid_division || sheet.invalid_account_title_part) {\n                    return result;\n                }\n            });\n\n            // 氓聢聠氓聣虏忙聵聨莽麓掳茫聛庐氓聬聢猫篓聢茅聡聭茅隆聧茫聛庐盲赂聧忙聲麓氓聬聢茂录聢氓\u0085楼氓聤聸忙聶聜茫聛芦茫聝聛茫聜搂茫聝聝茫聜炉忙赂聢茫聛驴茂录聣\n            const split_total_amount_error_sheet = request_expense_specifics.some(function(sheet) {\n                return sheet.invalid_split_amount;\n            });\n            if (split_total_amount_error_sheet) {\n                result.result = SPLIT_TOTAL_AMOUNT_ERROR;\n                return result;\n            }\n        }\n\n        // 莽虏戮莽庐聴莽聰鲁猫芦聥忙聶聜茫聙聛茅聛赂忙聤聻盲赂聧氓聫炉茫聛庐盲潞聥氓聣聧莽聰鲁猫芦聥茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聜篓茫聝漏茫聝录茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聛聼茫聜聣莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE\n            \u0026\u0026 $scope.form_data.expense.settlement_flg === Const.miscellaneous._FORM_TYPE.EXPENSE.settlement_flg\n        ) {\n            if ($scope.finished_request_errors.unselectable === true) {\n                result.result = PROGRESS_REQUEST_EXPENSE_ERROR;\n                return result;\n            }\n        }\n\n        // 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥忙聶聜茫聙聛茅聛赂忙聤聻盲赂聧氓聫炉茫聛庐盲潞聥氓聣聧莽聰鲁猫芦聥茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聜篓茫聝漏茫聝录茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聛聼茫聜聣莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE\n            \u0026\u0026 $scope.form_data.expense.settlement_flg ===\n                Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg\n        ) {\n            if ($scope.settlement_request_errors.unselectable === true) {\n                result.result = PROGRESS_REQUEST_EXPENSE_ERROR;\n                return result;\n            }\n        }\n\n        // 莽碌聦猫虏禄茫聝禄盲潞聥氓聣聧茫聛搂茫聛庐忙聰炉忙聣聲氓赂聦忙聹聸忙聴楼(忙聰炉忙聣聲盲潞聢氓庐職忙聴楼)茫聛庐茅聛聨氓聨禄忙聴楼茫聝聛茫聜搂茫聝聝茫聜炉\n        if (\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE\n            \u0026\u0026\n            $scope.form_data.expense.settlement_flg ===\n                Const.miscellaneous._FORM_TYPE.EXPENSE_PRE_APPLY.settlement_flg\n        ) {\n            // 忙聰炉忙聣聲氓赂聦忙聹聸忙聴楼(忙聰炉忙聣聲盲潞聢氓庐職忙聴楼)茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛茅聛聨氓聨禄忙聴楼茫聝聛茫聜搂茫聝聝茫聜炉\n            if (!util.isUndefinedOrNull($scope.form_data.expense.desire_payment_date)) {\n                // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐茅聽\u0085莽聸庐茫聛陋茫聛庐茫聛聥氓聢陇氓庐職\n                const is_payment_due_date_name = PaymentOptionService.isFormRelatedPaymentOption(\n                    $scope.form_related_payment_options, $scope.form_data.expense.payment_option\n                );\n                // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茂录職莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聛陋茫聛庐茫聛聥氓聢陇氓庐職\n                const is_payment_date_type_app = paymentDateService.isPaymentDateTypeApplication(\n                    $scope.payment_date_type\n                );\n                // (茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聛搂茫聛炉茫聛陋茫聛聞 or 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茂录職莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職) and 忙聰炉忙聣聲忙聺隆盲禄露茫聛聦1盲禄露盲禄楼盲赂聤莽聶禄茅聦虏茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥\n                if (\n                    (!is_payment_due_date_name || is_payment_date_type_app) \u0026\u0026\n                    $scope.payment_date_terms.length \u003e 0\n                ) {\n                    // yyyy/mm/dd -\u003e yyyy-mm-dd -\u003e date\n                    const desire_payment_date_obj = moment(\n                        $scope.form_data.expense.desire_payment_date.replace(/\\//g, \u0027-\u0027)\n                    );\n                    if (SuspensePaymentService.isPastDay(desire_payment_date_obj)) {\n                        result.result = FORM_VALIDATION_ERROR;\n                        return result;\n                    }\n                }\n            }\n        }\n\n        // 莽碌聦猫虏禄茫聝禄莽虏戮莽庐聴茫聛搂茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐茅聛聨氓聨禄忙聴楼茫聝聛茫聜搂茫聝聝茫聜炉\n        // 莽碌聦猫虏禄茫聝禄莽虏戮莽庐聴茫聛搂茫聛炉忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛篓茫聛聞茫聛聠茅聽\u0085莽聸庐茫聛聽茫聛聦\n        // 猫聡陋氓聥聲猫篓聢莽庐聴茫聛庐氓聽麓氓聬聢茫聛炉 $scope.payment_due_date\n        // 莽聰鲁猫芦聥猫聙\u0085茫聛芦忙聴楼盲禄聵茫聜聮氓\u0085楼氓聤聸茫聛聴茫聛娄茫聜聜茫聜聣茫聛聠氓聽麓氓聬聢茫聛炉 $scope.form_data.expense.desire_payment_date\n        if (\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE\n            \u0026\u0026\n            $scope.form_data.expense.settlement_flg ===\n                Const.miscellaneous._FORM_TYPE.EXPENSE.settlement_flg\n        ) {\n            // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聛娄茫聙聛忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茫聛聦茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聙聧氓聽麓氓聬聢茫聙聛茅聛聨氓聨禄忙聴楼茫聝聛茫聜搂茫聝聝茫聜炉\n            if (\n                !util.isUndefinedOrNull($scope.form_data.expense.desire_payment_date) \u0026\u0026\n                paymentDateService.isPaymentDateTypeApplication($scope.payment_date_type)\n            ) {\n                // yyyy/mm/dd -\u003e yyyy-mm-dd -\u003e date\n                const desire_payment_date_obj = moment(\n                    $scope.form_data.expense.desire_payment_date.replace(/\\//g, \u0027-\u0027)\n                );\n                if (SuspensePaymentService.isPastDay(desire_payment_date_obj)) {\n                    result.result = FORM_VALIDATION_ERROR;\n                    return result;\n                }\n            }\n        }\n\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聛搂茫聛庐忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐茅聛聨氓聨禄忙聴楼茫聝聛茫聜搂茫聝聝茫聜炉\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛茅聛聨氓聨禄忙聴楼茫聝聛茫聜搂茫聝聝茫聜炉\n            if (!util.isUndefinedOrNull($scope.form_data.payment.payment_due_date)) {\n                // 莽聰鲁猫芦聥茫聛搂茅聛赂忙聤聻茫聛聴茫聛聼忙聰炉忙聣聲忙聺隆盲禄露茫聛庐猫篓颅氓庐職茫聛聦茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聙聧茫聛庐氓聽麓氓聬聢\n                if (!paymentDateService.isCalculatePaymentDueDate(\n                    $scope.payment_date_term_detail.payment_date_type,\n                    $scope.form_data.payment.reference_date_type\n                )) {\n                    // yyyy/mm/dd -\u003e yyyy-mm-dd -\u003e date\n                    const payment_due_date_obj = moment(\n                        $scope.form_data.payment.payment_due_date.replace(/\\//g, \u0027-\u0027)\n                    );\n                    if (SuspensePaymentService.isPastDay(payment_due_date_obj)) {\n                        result.result = FORM_VALIDATION_ERROR;\n                        return result;\n                    }\n                }\n            }\n        }\n\n        return result;\n    }\n\n    /**\n     * 盲赂聥忙聸赂茫聛聧茫聛聦茫聛搂茫聛聧茫聜聥莽聤露忙\u0085聥茫聛聥茫聛漏茫聛聠茫聛聥茫聙聛茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n     * @return {{result: (string|null)}}\n     */\n    function checkDraftError() {\n        var check_draft_error = {result: null};\n        const No_APPROVER_STEP_ERROR = \u0027茫聛聯茫聛庐茫聜鹿茫聝聠茫聝聝茫聝聴茫聛芦茫聛炉忙聣驴猫陋聧猫聙\u0085茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聛戮茫聛聸茫聜聯茫聙聜莽庐隆莽聬聠猫聙\u0085茫聛芦盲戮聺茅聽录茫聛聴茫聛娄茫聙聛忙聣驴猫陋聧猫聙\u0085茫聛庐猫篓颅氓庐職茫聜聮猫隆聦茫聛拢茫聛娄茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u0027;\n        // 忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茫聜篓茫聝漏茫聝录茫聜聮猫隆篓莽陇潞\n        if ($scope.flow_data.flow_steps.length === 0){\n            return notifyService.showNotify(_(No_APPROVER_STEP_ERROR), \u0027alert-danger\u0027);\n        }\n        // 忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮莽路篓茅聸聠盲赂颅茫聛炉茫聙聛盲赂聥忙聸赂茫聛聧茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if ($scope.edit_flow_step_mode) {\n            check_draft_error.result = EDIT_FLOW_STEP_MODE_ERROR;\n            return check_draft_error;\n        }\n        return check_draft_error;\n    }\n\n    /**\n     * 盲赂聨茫聛聢茫聜聣茫聜聦茫聛聼茅\u0085聧氓聢聴茂录聢氓聠\u0085氓庐鹿茫聛炉忙聵聨莽麓掳猫隆篓茫聛庐index茂录聣茫聛芦氓聼潞茫聛聧茫聙聛忙聵聨莽麓掳猫隆篓茫聜聮茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n     * @param {Array.\u003cnumber\u003e} sheet_index_for_clear\n     * @private\n     */\n    function _clearSpecificsSheet(sheet_index_for_clear) {\n        if (isSpecificsSheet()) {\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                angular.forEach(sheet_index_for_clear, function(record) {\n                    $scope.form_data.expense.request_expense_specifics[record].request_expense_specifics_rows = [];\n                });\n            }\n            else if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n                angular.forEach(sheet_index_for_clear, function(record) {\n                    $scope.form_data.payment.request_payment_specifics[record].request_payment_specifics_rows = [];\n                });\n            }\n        }\n    }\n\n    /**\n     * 茫聝聛茫聜搂茫聝聝茫聜炉茫聝聹茫聝聝茫聜炉茫聜鹿茫聛聦氓驴\u0085茅聽聢茫聛搂茫聙聛茫聛聥茫聛陇茫聙聛忙聹陋氓\u0085楼氓聤聸茫聛庐氓聽麓氓聬聢茫聛聥茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {object} item\n     * @return {boolean}\n     */\n    function isValidCheckbox(item) {\n        // 忙聶庐茅聙職茫聛芦氓驴\u0085茅聽聢猫篓颅氓庐職茫聛聦茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聙聛茫聜聜茫聛聴茫聛聫茫聛炉茫聙聛忙聺隆盲禄露盲禄聵茫聛聧茫聛搂氓驴\u0085茅聽聢茫聛篓茫聛陋茫聛拢茫聛聼氓聽麓氓聬聢(茂录聠猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥)\n        if (isDisplayed(item) \u0026\u0026 isRequired(item)) {\n            // request_content茫聛聦null茫聛聥undefined茫聛聥莽漏潞忙聳聡氓颅聴茫聛庐氓聽麓氓聬聢茫聛炉氓\u0085楼氓聤聸茫聛陋茫聛聴茫聛篓氓聢陇氓庐職\n            if (!item.request_content) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    /**\n     * 忙卤聨莽聰篓茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵茫聛庐氓驴\u0085茅聽聢茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {object} item\n     * @return {boolean}\n     */\n    function isValidAttachment(item) {\n        if (isDisplayed(item) \u0026\u0026 isRequired(item)) {\n            if (angular.isUndefined(item.request_files) || item.request_files.length === 0) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    /**\n     * 茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聛庐莽路篓茅聸聠茫聛聦氓聫炉猫聝陆茫聛聥\n     * @return {boolean}\n     */\n    function canEditCirculation() {\n        return !$scope.isConfirm \u0026\u0026\n            !$scope.isModify \u0026\u0026\n            !$scope.isModifyStep \u0026\u0026\n            $scope.form_data.circulation_user_setting_flg;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聛庐莽路篓茅聸聠茫聛聦氓聫炉猫聝陆茫聛聥茫聛漏茫聛聠茫聛聥\n     * @return {boolean}\n     */\n    function canEditForm() {\n        // (not 莽垄潞猫陋聧莽聰禄茅聺垄) and (not 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉盲驴庐忙颅拢忙聶聜)\n        return !$scope.isConfirm \u0026\u0026 !$scope.isModifyStep;\n    }\n\n    /**\n     * 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥莽聰禄茅聺垄茫聛庐猫隆篓莽陇潞猫篓颅氓庐職\n     * 盲潞聥氓聣聧莽聰鲁猫芦聥忙聸赂茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼茫聛篓茫聛聧茫聛芦true茫聛芦茫聛陋茫聜聥\n     * @return {boolean}\n     */\n     function isChangedDate() {\n        return ($scope.form_data.expense.settlement_flg ===\n                    Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg)\n                \u0026\u0026 $scope.form_data.expense.related_request_view_id\n                \u0026\u0026 $scope.request_settlement_deadline.reference_date;\n    }\n\n    /**\n     * 莽碌聦猫路炉氓聢聠氓虏聬忙聺隆盲禄露茫聛芦氓聬聢猫聡麓茫聛聶茫聜聥茫聛聥茫聜聮氓聢陇氓庐職\n     * @param {boolean} refresh_flow_flg\n     */\n    function checkExtraFlow(refresh_flow_flg) {\n        if ($scope.form_data.edit_flow_flg === true) {\n            if ($scope.copy_request_flow_flg) {\n                // 莽碌聦猫路炉茫聜鲁茫聝聰茫聝录氓戮聦茫聛芦莽碌聦猫路炉莽路篓茅聸聠茫聛聦猫隆聦茫聜聫茫聜聦茫聛聼氓聽麓氓聬聢茫聙聛莽碌聦猫路炉氓聢聠氓虏聬茫聛聴茫聛陋茫聛聞\n                if (edit_flow_after_copy_flg) {\n                    return;\n                }\n            }\n        }\n        // 莽聰鲁猫芦聥盲驴庐忙颅拢盲赂颅茫聛炉莽碌聦猫路炉氓聢聠氓虏聬茫聜聮猫隆聦茫聜聫茫聛陋茫聛聞\n        if ($scope.isModify === true) {\n            return;\n        }\n        // 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉盲驴庐忙颅拢忙聶聜茫聛炉莽碌聦猫路炉氓聢聠氓虏聬茫聜聮猫隆聦茫聜聫茫聛陋茫聛聞\n        if ($scope.isModifyStep === true) {\n            return;\n        }\n        var top_priority = checkExtraFlowPriority();\n        changeExtraFlow(top_priority, true, refresh_flow_flg);\n    }\n\n    /**\n     * 氓聬聢猫聡麓茫聛聶茫聜聥莽碌聦猫路炉氓聢聠氓虏聬忙聺隆盲禄露茫聛庐盲赂颅茫聛搂忙聹聙茫聜聜氓聞陋氓\u0085聢氓潞娄茫聛庐茅芦聵茫聛聞茫聜聜茫聛庐茫聜聮猫驴聰氓聧麓茫聛聶茫聜聥\n     * @return {Object|null}\n     */\n    function checkExtraFlowPriority() {\n        for (var index = 0; index \u003c $scope.form_data.extra_flows.length; ++index) {\n            var record = $scope.form_data.extra_flows[index];\n            var result = false;\n\n            // 茫聜掳茫聝芦茫聝录茫聝聴芒聹聲氓陆鹿猫聛路茫聛庐茫聛驴茫聛庐忙聦聡氓庐職茂录聢茅聽\u0085莽聸庐茫聜聞忙聺隆盲禄露茫聛炉null茂录聣茫聛庐氓聽麓氓聬聢茫聛炉result=true茫聜聮茫聜禄茫聝聝茫聝聢\n            // 氓聢聠氓虏聬莽碌聦猫路炉茫聛庐氓聫聳氓戮聴忙聶聜茫聛芦茫聙聛茫聜掳茫聝芦茫聝录茫聝聴芒聹聲氓陆鹿猫聛路茫聜聮忙潞聙茫聛聼茫聛聶茫聜聜茫聛庐茫聛聴茫聛聥氓聫聳氓戮聴茫聛聴茫聛娄茫聛聞茫聛陋茫聛聞茫聛聼茫聜聛\n            if (record.form_item === null \u0026\u0026 record.other_key === null) {\n                result = true;\n            }\n            else if (!angular.isUndefinedOrNull(record.other_key)) {\n                // 莽碌聦猫虏禄茫聙聛忙聰炉忙聣聲茫聛聞盲戮聺茅聽录茫聛庐茅聡聭茅隆聧茫聜聮氓陇聣忙聸麓茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢\n                if (record.other_key === \u0027amount\u0027) {\n                    var amount;\n                    if ($scope.form_type === 2) {\n                        // 忙聵聨莽麓掳茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茫聛炉氓聬聢猫篓聢茫聛聴茫聛娄茫聛聥茫聜聣茫聝聛茫聜搂茫聝聝茫聜炉\n                        if (isSpecificsSheet()) {\n                            amount = getSumSpecificsAmount();\n                        }\n                        else {\n                            amount = $scope.form_data.expense.amount;\n                        }\n                        result = createRequestService.checkThresholdValue(\n                            amount, record.condition_type, record.threshold_value);\n                    }\n                    else if ($scope.form_type === 3) {\n                        // 忙聵聨莽麓掳茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茫聛炉氓聬聢猫篓聢茫聛聴茫聛娄茫聛聥茫聜聣茫聝聛茫聜搂茫聝聝茫聜炉\n                        if (isSpecificsSheet()) {\n                            amount = getSumPaymentSpecificsAmount();\n                        }\n                        else {\n                            amount = $scope.form_data.payment.amount;\n                        }\n                        result = createRequestService.checkThresholdValue(\n                            amount, record.condition_type, record.threshold_value);\n                    }\n                    else if ($scope.form_type === 4) {\n                        // 忙聵聨莽麓掳猫隆篓茫聛庐氓聲聠氓聯聛盲禄拢茅聡聭猫篓聢茂录聢莽篓聨猫戮录茫聝禄茅聙聛忙聳聶猫戮录茂录聣茫聜聮盲陆驴莽聰篓\n                        if (\u0027request_ec_specifics_rows\u0027 in $scope.form_data.ec \u0026\u0026\n                            !angular.isUndefinedOrNull($scope.form_data.ec.request_ec_specifics_rows)) {\n                            amount = $scope.form_data.ec.request_ec_specifics_rows.total_price;\n                            result = createRequestService.checkThresholdValue(\n                                amount, record.condition_type, record.threshold_value\n                            );\n                        }\n                    }\n                }\n                // 氓聠\u0085猫篓鲁茫聛聦氓陇聣忙聸麓茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢\n                else if (record.other_key === Const.miscellaneous._OTHER_KEY.ACCOUNT_TITLE_PART) {\n                    var ids = [];\n                    if (isSpecificsSheet()) {\n                        ids = createRequestService.extractSpecificAccountTitlePartIds(\n                            $scope.form_type, $scope.form_data\n                        );\n                    }\n                    else {\n                        ids = createRequestService.extractAccountTitlePartIds($scope.form_type, $scope.form_data);\n                    }\n                    const account_title_part_id = ids.toString();\n                    // 莽碌聦猫路炉氓聢聠氓虏聬忙聺隆盲禄露茫聛芦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聠\u0085猫篓鲁ID茫聜聮茫聛聴茫聛聧茫聛聞氓聙陇茫聛芦盲禄拢氓\u0085楼茫聛聴茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n                    var threshold_value = record.extra_flow_account_title_parts.map(function(data) {\n                        return data.account_title_part.id;\n                    });\n                    const str_threshold_value = threshold_value.toString();\n                    result = createRequestService.checkThresholdValue(\n                        account_title_part_id, record.condition_type, str_threshold_value);\n                }\n            }\n            else {\n                var item = mapped_items[record.form_item.id];\n                // 莽碌聦猫路炉氓聢聠氓虏聬忙聺隆盲禄露茫聛庐氓炉戮猫卤隆茫聛庐茅聽\u0085莽聸庐茫聛聦氓颅聵氓聹篓茫聛聴茫聙聛茫聛聥茫聛陇猫隆篓莽陇潞莽聤露忙\u0085聥茫聛陋茫聜聣茫聙聛茫聛聴茫聛聧茫聛聞氓聙陇茫聝聛茫聜搂茫聝聝茫聜炉\n                if (!angular.isUndefinedOrNull(item) \u0026\u0026 isDisplayed(item)) {\n                    result = createRequestService.checkThresholdValue(\n                        createRequestService.getItemValue(item), record.condition_type, record.threshold_value);\n                }\n            }\n\n            // 茅聛漏莽聰篓氓聫炉猫聝陆茫聛陋氓聢聠氓虏聬忙聺隆盲禄露茫聛聦猫娄聥茫聛陇茫聛聥茫聛拢茫聛聼茫聜聣莽碌聜盲潞聠\n            if (result === true) {\n                return record;\n            }\n        }\n        return null;\n    }\n\n    /**\n     * 莽碌聦猫路炉茫聛庐氓聢聠氓虏聬氓聡娄莽聬聠茫聙聜莽碌聦猫路炉茫聛聦氓聢聡茫聜聤忙聸驴茫聜聫茫聛拢茫聛聼氓聽麓氓聬聢notify\n     * @param {Object|null} top_priority\n     * @param {boolean} notify_flg\n     * @param {boolean} refresh_flow_flg\n     * @param {boolean} change_group_flg\n     * @return {Number}\n     */\n    function changeExtraFlow(top_priority, notify_flg, refresh_flow_flg, change_group_flg) {\n        /**\n         * 莽碌聦猫路炉茫聛聦氓聢聡茫聜聤忙聸驴茫聜聫茫聜聥茫聛陋茫聜聣true茫聜聮猫驴聰茫聛聶\n         * @param {{flow: {id: number}} | null} top_priority\n         * @param {number} default_flow_id\n         * @param {number} current_flow_id\n         * @return {boolean}\n         */\n        function isChangedFlow(top_priority, default_flow_id, current_flow_id) {\n            if (top_priority === null) {\n                if (current_flow_id === default_flow_id) {\n                    return false;\n                }\n            }\n            else if (top_priority.flow.id === current_flow_id) {\n                return false;\n            }\n            return true;\n        }\n\n        /**\n         * 茅聛漏莽聰篓茫聛聲茫聜聦茫聛聼莽碌聦猫路炉茫聛搂莽聰鲁猫芦聥茫聛聴茫聛聼茫聙聛氓聣聧氓聸聻茫聛庐莽聰鲁猫芦聥忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴\n         * @param {number} flow_id\n         * @private\n         */\n        function _readLatestRequest(flow_id) {\n            var requester_id = angular.isDefined($scope.requester) ? $scope.requester.id : null;\n            var params = {\n                \u0027requester_id\u0027: requester_id,\n                \u0027form_id\u0027: form_id,\n                \u0027flow_id\u0027: flow_id,\n            };\n            RequestService.getLatestRequest(params).then(function(res) {\n                last_request = res.data;\n            });\n        }\n\n        var flow_id;\n        // 莽碌聦猫路炉氓聢聡茫聜聤忙聸驴茫聛聢氓聡娄莽聬聠茫聜聮猫隆聦茫聛聠氓聽麓氓聬聢\n        if (isChangedFlow(top_priority, $scope.default_flow_data.id, $scope.flow_data.id)) {\n            // 莽碌聦猫路炉氓聢聠氓虏聬茫聛聦茫聛陋茫聛聞\n            if (top_priority === null) {\n                if (notify_flg !== false) {\n                    notifyService.showNotify(gettextCatalog.getString(\u0027茅聙職氓赂赂茫聛庐忙聣驴猫陋聧茫聝聲茫聝颅茫聝录茫聛芦氓聢聡茫聜聤忙聸驴茫聜聫茫聜聤茫聛戮茫聛聴茫聛聼茫聙聜\u0027),\n                                             \u0027alert-success\u0027);\n                }\n                // 茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢莽碌聦猫路炉茫聜聮猫篓颅氓庐職\n                flow_id = $scope.default_flow_data.id;\n            }\n            else {\n                // 莽碌聦猫路炉氓聢聠氓虏聬茫聛聜茫聜聤\n                if (notify_flg) {\n                    var message = CreateRequestFlowService.createFlowChangeMessage(top_priority, $scope.flow_data);\n                    notifyService.showNotify(message, \u0027alert-success\u0027);\n                }\n\n                flow_id = top_priority.flow.id;\n            }\n\n            // 莽碌聦猫路炉忙聝\u0085氓聽卤茫聛庐忙聸麓忙聳掳\n            refreshFlow(flow_id, !change_group_flg);\n        }\n        else {\n            const areDifferentCurrentAndPreviousQuery =\n                !latestFlowFetcher.areSameCurrentAndPreviousRequestParams($scope.flow_data.id);\n            // 莽碌聦猫路炉氓聢聡忙聸驴氓聡娄莽聬聠茫聜聮猫隆聦茫聜聫茫聛陋茫聛聞氓聽麓氓聬聢茫聛搂茫聜聜茫聙聛莽碌聦猫路炉茫聛庐忙聸麓忙聳掳氓聡娄莽聬聠茫聛炉氓驴\u0085猫娄聛茫聙聜忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐忙聝\u0085氓聽卤茫聜聮忙聹聙忙聳掳氓聦聳茫聛聴茫聛聼茫聛聞茫聙聜\n            // 盲戮聥)忙聣聙氓卤聻茫聜掳茫聝芦茫聝录茫聝聴氓陇聣忙聸麓忙聶聜茫聛芦茫聙聛茫聙聦忙聣聙氓卤聻茫聜掳茫聝芦茫聝录茫聝聴芒聹聲氓陆鹿猫聛路茫聙聧茫聛庐忙聣驴猫陋聧猫聙\u0085茫聛庐茅隆聰茫聛露茫聜聦茫聜聮氓陇聣忙聸麓茫聛聴茫聛聼茫聛聞茫聙聜\n            // 茫聛聼茫聛聽茫聛聴茫聙聛莽碌聦猫路炉茫聜鲁茫聝聰茫聝录茫聝聹茫聜驴茫聝鲁茫聜聮忙聤录茫聛聴茫聛聼氓戮聦茫聛炉茫聙聛莽碌聦猫路炉氓聢聡忙聸驴氓聡娄莽聬聠茫聜聮猫隆聦茫聜聫茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛忙聣驴猫陋聧猫聙\u0085茫聛庐茅隆聰茫聛露茫聜聦茫聜聮氓陇聣忙聸麓茫聛聴茫聛聼茫聛聫茫聛陋茫聛聞茫聙聜\n            // 氓聣聧氓聸聻茫聛篓氓聬聦茫聛聵忙聺隆盲禄露茫聛搂莽碌聦猫路炉氓聫聧忙聵聽茫聛炉猫隆聦茫聜聫茫聛陋茫聛聞\n            if (!$scope.copy_request_flow_flg \u0026\u0026 areDifferentCurrentAndPreviousQuery) {\n                _getLatestFlow($scope.flow_data.id).then(function(data) {\n                    if (refresh_flow_flg === true) {\n                        $scope.flow_data = CreateRequestFlowService.setFlowVersion(data, $scope.prev_flow);\n                    }\n                });\n                $scope.copy_request_flow_flg = false;\n                $scope.form_data.edit_flow_flg = false;\n                $scope.edit_flow_step_mode = false;\n                if (notify_flg !== false) {\n                    notifyService.showNotify(gettextCatalog.getString(\u0027茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聛聦氓陇聣忙聸麓茫聛聲茫聜聦茫聛聼茫聛聼茫聜聛忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聛聦忙聸麓忙聳掳茫聛聲茫聜聦茫聛戮茫聛聴茫聛聼茫聙聜\u0027),\n                                             \u0027alert-success\u0027);\n                }\n            }\n            flow_id = (top_priority \u0026\u0026 top_priority.flow) ? top_priority.flow.id : $scope.default_flow_data.id;\n        }\n\n        // 茅聛漏莽聰篓茫聛聲茫聜聦茫聛聼莽碌聦猫路炉茫聛搂莽聰鲁猫芦聥茫聛聴茫聛聼茫聙聛氓聣聧氓聸聻茫聛庐莽聰鲁猫芦聥忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴\n        _readLatestRequest(flow_id);\n        return flow_id;\n    }\n\n\n    /**\n     * 莽碌聦猫路炉忙聝\u0085氓聽卤茫聛庐氓聫聳氓戮聴\n     * @param {Number} flowId\n     * @param {bool} isCirculationUsersRefresh\n     * @return {Promise}\n     */\n    function refreshFlow(flowId, isCirculationUsersRefresh) {\n        const deferred = $q.defer();\n        // 猫陋颅茫聛驴猫戮录茫聛驴莽聤露忙\u0085聥茫聜聮 \"猫陋颅茫聛驴猫戮录茫聛驴盲赂颅\" 莽聤露忙\u0085聥茫聛芦氓陇聣忙聸麓茫聛聶茫聜聥\n        $scope.setting_flow = true;\n        const promises = [\n            _getLatestFlow(flowId, $scope.prev_flow),\n        ];\n        // 茅聳虏猫娄搂猫聙\u0085忙聝\u0085氓聽卤茫聜聜忙聸麓忙聳掳茫聛聶茫聜聥氓聽麓氓聬聢\n        if (isCirculationUsersRefresh) {\n            promises.push(getLatestCirculationUsers(flowId, $scope.requester_info.requester_group_id));\n        }\n\n        $q.all(promises).then(function(result) {\n            $scope.flow_data = result[0];\n            // 茅聳虏猫娄搂猫聙\u0085茫聛庐忙聝\u0085氓聽卤茫聜聜氓聫聳氓戮聴茫聛聴茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢\n            if (result.length \u003e 1) {\n                const circulation_users = result[1];\n                $scope.flow_circulation_users = circulation_users;\n                setCirculationPositionAndUsers($scope.flow_circulation_users);\n            }\n            deferred.resolve();\n        }).catch(function(result) {\n            deferred.reject();\n        }).finally(function() {\n            // 猫陋颅茫聛驴猫戮录茫聛驴莽聤露忙\u0085聥茫聜聮 \"猫陋颅茫聛驴猫戮录茫聛驴莽碌聜盲潞聠\" 莽聤露忙\u0085聥茫聛芦氓陇聣忙聸麓茫聛聶茫聜聥\n            $scope.setting_flow = false;\n            // 莽碌聦猫路炉茫聛芦茅聳垄茫聛聶茫聜聥茫聝聲茫聝漏茫聜掳茫聜聮氓聢聺忙聹聼氓聦聳茫聛聶茫聜聥\n            $scope.copy_request_flow_flg = false;\n            $scope.form_data.edit_flow_flg = false;\n            $scope.edit_flow_step_mode = false;\n        });\n\n        return deferred.promise;\n    }\n\n    /**\n     * 茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聛聥茫聜聣盲陆聶氓聢聠茫聛陋茫聝聡茫聝录茫聜驴茫聜聮茅聶陇茫聛聫\n     * @param {Array.\u003cObject\u003e} circulation_users\n     * @return {Array.\u003cObject\u003e}\n     */\n    function prepareDispCirculation(circulation_users) {\n        function isUserNull(record) {\n            return record.user === null;\n        }\n        // 茫聜掳茫聝芦茫聝录茫聝聴茫聜聞氓陆鹿猫聛路茫聛聦null茫聛庐茫聜聜茫聛庐茫聛芦氓聬聧莽搂掳茫聜禄茫聝聝茫聝聢\n        function fillNameToNull(record) {\n            if (record.group === null) {\n                record.group = {id: null, name: gettextCatalog.getString(\u0027茫聛聶茫聛鹿茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴\u0027)};\n            }\n            else if (record.group.id === 0) {\n                record.group = {id: 0, name: gettextCatalog.getString(\u0027莽聰鲁猫芦聥猫聙\u0085茫聛聦忙聣聙氓卤聻茫聛聶茫聜聥茫聜掳茫聝芦茫聝录茫聝聴\u0027)};\n            }\n\n            if (record.position === null) {\n                record.position = {id: null, position_name: gettextCatalog.getString(\u0027茫聛聶茫聛鹿茫聛娄茫聛庐茫聝娄茫聝录茫聜露\u0027)};\n            }\n        }\n        circulation_users.filter(isUserNull).forEach(fillNameToNull);\n        return circulation_users;\n    }\n\n    /**\n     * 氓聠\u0085猫篓鲁茫聛芦莽麓聬盲禄聵茫聛聭茫聜聣茫聜聦茫聛聼茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢茫聛聦茫聛聜茫聜聦茫聛掳猫篓颅氓庐職茫聛聶茫聜聥\n     * @param {object} selected_account_title_part\n     * @param {object | undefined} data 忙聵聨莽麓掳猫隆聦茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茂录聢茅聺聻忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聛炉盲陆驴莽聰篓茫聛聴茫聛陋茫聛聞茂录聣\n     * @param {boolean | undefined} hide_notify true茫聛陋茫聜聣茫聙聛茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢氓聫聧忙聵聽茫聛庐notify茫聜聮氓聡潞茫聛聲茫聛陋茫聛聞\n     */\n    function setProject(selected_account_title_part, data, hide_notify) {\n        var project = selected_account_title_part.project;\n\n        // 茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼氓聠\u0085猫篓鲁茫聛芦茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢猫篓颅氓庐職茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳莽碌聜盲潞聠\n        if (angular.isUndefinedOrNull(project)) {\n            return;\n        }\n        // 忙聵聨莽麓掳茫聛篓茅聺聻忙聵聨莽麓掳茫聛搂氓聫聧忙聵聽氓聡娄莽聬聠茫聜聮氓聢聠茫聛聭茫聜聥\n        if (isSpecificsSheet()) {\n            data.project = project;\n        }\n        else {\n            $scope.form_data.project = project.id;\n            $scope.form_data.project_name = project.name;\n            $scope.form_data.project_code = project.project_code;\n        }\n\n        if (hide_notify !== true) {\n            notifyService.showNotify(gettextCatalog.getString(\u0027氓聠\u0085猫篓鲁茫聛芦猫篓颅氓庐職茫聛聲茫聜聦茫聛聼茅聳垄茅聙拢茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢茫聛聦氓聫聧忙聵聽茫聛聲茫聜聦茫聛戮茫聛聴茫聛聼茫聙聜\u0027),\n                                     \u0027alert-success\u0027);\n        }\n    }\n\n    /**\n     * 忙聵聨莽麓掳猫隆篓茫聛庐茫聜驴茫聜陇茫聝聢茫聝芦茫聜聮猫驴聰茫聛聶\n     * @param {object} sheet\n     * @return {string}\n     */\n    function getSpecificsTitle(sheet) {\n        return FormService.getSpecificsTitle($scope.form_type, sheet.specifics_type, sheet.specifics_title);\n    }\n\n    /**\n     * 茅\u0085聧氓聢聴茫聛庐氓聬聢猫篓聢茫聜聮猫驴聰茫聛聶忙卤聨莽聰篓茅聳垄忙聲掳\n     * @param {Array} items 茅\u0085聧氓聢聴\n     * @param {object} selector 氓陇聣忙聫聸茅聳垄忙聲掳\n     * @return {number} 氓聬聢猫篓聢氓聙陇\n     */\n    function getSum(items, selector) {\n        if (angular.isUndefinedOrNull(items) || items.length === 0) {\n            return 0;\n        }\n        return items.map(function(item) {\n            return selector(item) || 0;\n        }).reduce(function(sum, value) {\n            return sum + value;\n        });\n    }\n\n    /**\n     * 莽碌聦猫虏禄忙聵聨莽麓掳茫聛庐茅聡聭茅隆聧氓聬聢猫篓聢\n     * @return {number}\n     */\n    function getSumSpecificsAmount() {\n        if ($scope.isConfirm) {\n            // 莽垄潞猫陋聧莽聰禄茅聺垄茫聛搂忙聸麓忙聳掳茫聜聮忙颅垄茫聜聛茫聜聥\n            // 莽聰鲁猫芦聥茫聝聹茫聜驴茫聝鲁忙聤录盲赂聥忙聶聜茫聛芦茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐request_expense_specifics茅\u0085聧盲赂聥茫聛庐request_expense_specifics_rows茫聛炉忙露聢茫聛聢茫聜聥茂录聢json茫聛芦忙聦聛茫聛聼茫聛陋茫聛聞茫聛聼茫聜聛茂录聣\n            return $scope.form_data.expense.amount;\n        }\n        var displaying_sheets = _getDisplayingSpecificsSheets($scope.form_data.expense.request_expense_specifics);\n        var amountTotal = getSum(displaying_sheets, getSumSpecificsSheetAmount);\n        var amountCards = getSum(displaying_sheets, getSumSpecificsSheetAmountOfCards);\n        $scope.form_data.expense.amount = amountTotal;\n        $scope.form_data.expense.tatekae = amountTotal - amountCards;\n        return amountTotal;\n    }\n\n    /**\n     * 莽碌聦猫虏禄忙聵聨莽麓掳茫聛庐氓聬聞茫聝聠茫聝录茫聝聳茫聝芦茫聛庐茅聡聭茅隆聧氓聬聢猫篓聢\n     * @param {object} sheet\n     * @return {number}\n     */\n    function getSumSpecificsSheetAmount(sheet) {\n        var rows = sheet.request_expense_specifics_rows;\n        return getSum(\n            rows,\n            function(row) {\n                if (row.is_child_specifics) {\n                    // 氓聢聠氓聣虏茫聛聲茫聜聦茫聛聼氓颅聬忙聵聨莽麓掳茫聛庐茅聡聭茅隆聧茫聛炉氓炉戮猫卤隆氓陇聳茂录聢猫娄陋忙聵聨莽麓掳茫聛庐氓聬聢猫篓聢茫聛搂猫篓聢莽庐聴茫聛聲茫聜聦茫聜聥茫聛聼茫聜聛茂录聣\n                    return 0;\n                }\n                return row.amount;\n            }\n        );\n    }\n\n    /**\n     * 莽碌聦猫虏禄忙聵聨莽麓掳茫聛庐氓聬聞茫聝聠茫聝录茫聝聳茫聝芦茫聛庐茅聡聭茅隆聧氓聬聢猫篓聢茂录聢茫聜芦茫聝录茫聝聣忙聵聨莽麓掳茫聛芦茅聶聬茫聜聥茂录聣\n     * @param {object} sheet\n     * @return {number}\n     */\n    function getSumSpecificsSheetAmountOfCards(sheet) {\n        var rows = sheet.request_expense_specifics_rows;\n        return getSum(\n            rows,\n            function(row) {\n                return row.is_credit_card ? row.amount : 0;\n            }\n        );\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳茫聛庐茅聡聭茅隆聧氓聬聢猫篓聢\n     * @return {number}\n     */\n    function getSumPaymentSpecificsAmount() {\n        if ($scope.isConfirm) {\n            // 莽垄潞猫陋聧莽聰禄茅聺垄茫聛搂忙聸麓忙聳掳茫聜聮忙颅垄茫聜聛茫聜聥\n            // 莽聰鲁猫芦聥茫聝聹茫聜驴茫聝鲁忙聤录盲赂聥忙聶聜茫聛芦茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐request_payment_specifics茅\u0085聧盲赂聥茫聛庐request_payment_specifics_rows茫聛炉忙露聢茫聛聢茫聜聥茂录聢json茫聛芦忙聦聛茫聛聼茫聛陋茫聛聞茫聛聼茫聜聛茂录聣\n            return $scope.form_data.payment.amount;\n        }\n        var result = 0;\n        var displaying_sheets = _getDisplayingSpecificsSheets($scope.form_data.payment.request_payment_specifics);\n        for (var i = 0; i \u003c displaying_sheets.length; ++i) {\n            result += getSumPaymentSpecificsSheetAmount(displaying_sheets[i]);\n        }\n        $scope.form_data.payment.amount = result;\n        return result;\n    }\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳茂录聢莽聜潞忙聸驴茫聝卢茫聝录茫聝聢茂录聣盲赂聤茫聙聛猫驴陆氓聤聽茫聝禄茫聜鲁茫聝聰茫聝录茫聝禄氓聣聤茅聶陇茫聝禄茫聜炉茫聝陋茫聜垄茫聝禄忙聸麓忙聳掳茫聛聦茫聛聜茫聜聥茫聛聥茫聙聛盲潞聥氓聣聧莽聰鲁猫芦聥茫聛篓茫聛聴茫聛娄猫驴陆氓聤聽茫聛聲茫聜聦茫聛聼茫聛聥茫聛漏茫聛聠茫聛聥茫聜聮莽垄潞猫陋聧\n     */\n    $scope.changeSpecificsProperty = function() {\n        if ($scope.isDisplayCustomPaymentExchangeSpecifics) {\n            _getSumPaymentExchangeSpecificsAmount();\n        }\n    };\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳茫聛庐氓陇聳猫虏篓茫聛聰茫聛篓茫聛庐茅聡聭茅隆聧茫聜聮茅聸聠猫篓聢\n     * @private\n     */\n    function _getSumPaymentExchangeSpecificsAmount() {\n        const amountSummaryMap = {};\n        // 忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳茫聛庐莽聜潞忙聸驴茫聝卢茫聝录茫聝聢忙聵聨莽麓掳盲禄楼氓陇聳茫聛炉氓聡娄莽聬聠茫聛聴茫聛陋茫聛聞\n        if (\n            !$scope.form_data\n            || !$scope.form_data.payment\n            || !$scope.form_data.payment.request_payment_specifics\n        ) {\n            return;\n        }\n        // 猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳(莽聜潞忙聸驴茫聝卢茫聝录茫聝聢)茫聜聮氓聫聳氓戮聴\n        const displayingSheets = _getDisplayingSpecificsSheets($scope.form_data.payment.request_payment_specifics);\n        // 茫聜驴茫聝录茫聜虏茫聝聝茫聝聢忙聵聨莽麓掳茫聙聦茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳(莽聜潞忙聸驴茫聝卢茫聝录茫聝聢)茫聙聧茫聜聮氓庐職莽戮漏\n        const targetSpecificsTypes = [\n            Const.miscellaneous.PAYMENT_SPECIFICS_EXCHANGE_COMPANY,\n            Const.miscellaneous.PAYMENT_SPECIFICS_EXCHANGE_USER,\n        ];\n        // 猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥忙聵聨莽麓掳茫聛庐盲赂颅茫聛庐茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳(莽聜潞忙聸驴茫聝卢茫聝录茫聝聢)茫聜聮茫聝聲茫聜拢茫聝芦茫聜驴茫聝陋茫聝鲁茫聜掳\n        const paymentCustomExchangeSpecificsSheets = displayingSheets.filter(\n            (sheet) =\u003e targetSpecificsTypes.includes(sheet.specifics_type));\n        // row.currency_code茫聛芦氓\u0085楼氓聤聸茫聛聶茫聜聥氓聙陇茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n        function _getValueByCurrencyCodeRow(row, sheet_idx, row_idx) {\n            if (util.isUndefinedOrNull(row.currency_code)) {\n                return;\n            }\n            if (!Object.keys(amountSummaryMap).includes(row.currency_code)) {\n                amountSummaryMap[row.currency_code] = {\n                    currency_code: row.currency_code,\n                    currency_name: row.currency_name,\n                    allocation_date: row.allocation_date,\n                    amount: row.amount,\n                    exchange_amount: row.exchange_amount,\n                    sheet_idx: sheet_idx,\n                    row_idx: row_idx,\n                };\n                return;\n            }\n            // 茅聸聠猫篓聢茫聛搂猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥茅聙職猫虏篓氓聬聧莽搂掳茫聛炉茫聙聛氓聬聦茫聛聵茅聙職猫虏篓茫聜鲁茫聝录茫聝聣氓聠\u0085茫聛搂猫篓聢盲赂聤忙聴楼茫聛聦忙聹聙忙聳掳茫聛庐茅聙職猫虏篓氓聬聧莽搂掳茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥\n            const existingRowAllocationDate = new Date(amountSummaryMap[row.currency_code].allocation_date);\n            const newRowAllocationDate = new Date(row.allocation_date);\n            if (newRowAllocationDate \u003e existingRowAllocationDate) {\n                amountSummaryMap[row.currency_code].currency_name = row.currency_name;\n                amountSummaryMap[row.currency_code].allocation_date = row.allocation_date;\n            }\n            // 氓陇聳猫虏篓茅聡聭茅隆聧茫聛篓忙聴楼忙聹卢氓聠聠茅聡聭茅隆聧茫聜聮茅聸聠猫篓聢\n            amountSummaryMap[row.currency_code].exchange_amount =\n                new BigNumber(amountSummaryMap[row.currency_code].exchange_amount).plus(\n                    new BigNumber(row.exchange_amount)\n            );\n            amountSummaryMap[row.currency_code].amount = Number(\n                new BigNumber(amountSummaryMap[row.currency_code].amount).plus(\n                    new BigNumber(row.amount)\n                )\n            );\n        }\n\n        // 忙聵聨莽麓掳猫隆篓茫聜陇茫聝鲁茫聝聡茫聝聝茫聜炉茫聜鹿茫聙聛忙聵聨莽麓掳猫隆聦茫聜陇茫聝鲁茫聝聡茫聝聝茫聜炉茫聜鹿茫聜聮猫驴陆氓聤聽茫聛聴茫聙聛茅聙職猫虏篓茫聜鲁茫聝录茫聝聣茫聛聰茫聛篓茫聛芦茅聡聭茅隆聧茫聜聮茅聸聠猫篓聢\n        paymentCustomExchangeSpecificsSheets.forEach((sheet, sheet_idx) =\u003e\n            sheet.request_payment_specifics_rows.forEach((row, row_idx) =\u003e\n                _getValueByCurrencyCodeRow(row, sheet_idx, row_idx)\n            )\n        );\n        // obj茫聛庐氓聙陇茫聜聮茅\u0085聧氓聢聴茫聛芦盲禄拢氓\u0085楼茫聛聶茫聜聥\n        const amountSummaryList = Object.values(amountSummaryMap);\n\n        // 氓聬聞index(莽卢卢1key:忙聵聨莽麓掳猫隆篓index, 莽卢卢2key:忙聵聨莽麓掳猫隆聦index)茫聛庐茅聽聠莽聲陋茫聛芦氓戮聯茫聛拢茫聛娄猫隆篓莽陇潞茫聛庐盲赂娄茫聛鹿忙聸驴茫聛聢茫聜聮茫聛聶茫聜聥\n        amountSummaryList.sort((a, b) =\u003e {\n            if (a.sheet_idx \u003c b.sheet_idx) return -1;\n            if (a.sheet_idx \u003e b.sheet_idx) return 1;\n            if (a.row_idx \u003c b.row_idx) return -1;\n            if (a.row_idx \u003e b.row_idx) return 1;\n            return 0;\n        });\n\n        $scope.amountSummaryList = amountSummaryList;\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳茫聛庐氓聬聞茫聝聠茫聝录茫聝聳茫聝芦茫聛庐茅聡聭茅隆聧氓聬聢猫篓聢\n     * @param {object} sheet\n     * @return {number}\n     */\n    function getSumPaymentSpecificsSheetAmount(sheet) {\n        return CreateRequestPaymentSpecificsService.getSumPaymentSpecificsSheetAmount(sheet);\n    }\n\n    /**\n     * 茫聜垄茫聝聴茫聝陋莽聰篓茫聛芦茫聙聛莽聰禄氓聝聫猫隆篓莽陇潞茫聜陇茫聝聶茫聝鲁茫聝聢莽聶潞莽聛芦\n     * @param {object} file\n     */\n    function app__clickFile(file) {\n        if (UserFileService.canPreview(file)) {\n            $scope.$emit(\u0027app__showImageDialog\u0027, file);\n        }\n    }\n\n    $scope.isPresent = util.isPresent;\n    $scope.hasNumeralColumn = specificsTable.hasNumeralColumn;\n    $scope.sumsOfEachColumn = specificsTable.sumsOfEachColumn;\n    $scope.formatSumsOfEachColumn = specificsTable.formatSumsOfEachColumn;\n\n    // controller氓聣聤茅聶陇忙聶聜茫聙聛茫聜陇茫聝聶茫聝鲁茫聝聢茫聝陋茫聜鹿茫聝聤茫聝录茫聜聮茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n    $scope.$on(\u0027$destroy\u0027, function() {\n        fileUploadListener();\n    });\n\n    /**\n     * 莽碌聦猫虏禄莽虏戮莽庐聴忙聵聨莽麓掳茫聙聛忙聰炉忙聣聲忙聵聨莽麓掳茫聛芦茫聛聤茫聛聞茫聛娄茫聙聛\n     * 猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥氓聬娄茫聛聥茫聜聮莽陇潞茫聛聶displayed茫聝聴茫聝颅茫聝聭茫聝聠茫聜拢茫聜聮忙聸麓忙聳掳茫聛聶茫聜聥\n     * @param {Array.\u003cobject\u003e|undefined} tables 忙聵聨莽麓掳猫隆篓茫聛庐氓\u0085楼茫聛拢茫聛聼茅\u0085聧氓聢聴\n     */\n    function updateDisplayedPropOfTables(tables) {\n        angular.forEach(tables, function(table) {\n            table.displayed = isDisplayed(table);\n        });\n    }\n\n    /**\n     * 盲禄聲猫篓鲁茫聛芦茫聛陇茫聛陋茫聛聦茫聜聥忙聵聨莽麓掳猫隆篓茂录聢莽碌聦猫虏禄莽虏戮莽庐聴茫聝禄忙聰炉忙聣聲盲戮聺茅聽录茂录聣茫聛庐茅\u0085聧氓聢聴茫聜聮猫驴聰茫聛聶茫聙聜忙卤聨莽聰篓忙聵聨莽麓掳茫聛炉氓聬芦茫聛戮茫聜聦茫聛陋茫聛聞茫聙聜\n     * @return {Array.\u003cObject\u003e|undefined} 忙聵聨莽麓掳茫聛聦茫聛聜茫聜聦茫聛掳忙聵聨莽麓掳茫聛庐茅\u0085聧氓聢聴茫聙聛忙聵聨莽麓掳茫聛聦莽聞隆茫聛聭茫聜聦茫聛掳undefined\n     */\n    function journalizableSpecificsTables() {\n        switch ($scope.form_type) {\n            case Const.miscellaneous.FORM_TYPE_EXPENSE:\n                return $scope.form_data.expense.request_expense_specifics;\n            case Const.miscellaneous.FORM_TYPE_PAYMENT:\n                return $scope.form_data.payment.request_payment_specifics;\n            default:\n                throw new Error(\u0027Invalid form type.\u0027);\n        }\n    }\n\n    $scope.openBoxDialog = function() {\n        boxService.openDialog($scope.form_data.form_id).then(function(name) {\n            if (!angular.isUndefinedOrNull(name)) {\n                $scope.box_folder_name = name;\n            }\n        });\n    };\n\n    $scope.removeBox = function() {\n        boxService.remove($scope.form_data.form_id).then(function() {\n            $scope.box_folder_name = null;\n        });\n    };\n\n    // 茫聝聲茫聜隆茫聜陇茫聝芦氓聬聧茫聛聥茫聜聣忙聥隆氓录碌氓颅聬茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n    function _getExt(filename)\n    {\n        var pos = filename.lastIndexOf(\u0027.\u0027);\n        return (pos === -1) ? \u0027\u0027 : filename.slice(pos + 1).toLowerCase();\n    }\n\n    $scope.hasInconvertibleFiles = function(files) {\n        return files.map(function(file) {\n            return file.file_name;\n        }).some(function(filename) {\n            return !extensions.has(_getExt(filename));\n        });\n    };\n\n    $scope.hasInconvertibleItemTypeFiles = function() {\n        if (!$scope.form_data?.form_json) {\n            return false;\n        }\n        const files = $scope.form_data.form_json\n            .filter(\n                (item) =\u003e\n                    item.item_type === Const.form.ITEM_TYPE_ATTACHMENT \u0026\u0026\n                    item.request_files \u0026\u0026\n                    isDisplayed(item),\n            )\n            .flatMap((item) =\u003e item.request_files);\n        $scope.item_type_attachment_files = files;\n        return $scope.hasInconvertibleFiles(files);\n    };\n\n    $scope.getInconvertibleFiles = function(files) {\n        return files.map(function(file) {\n            return file.file_name;\n        }).filter(function(filename) {\n            return !extensions.has(_getExt(filename));\n        });\n    };\n\n    // CloudConvert 茫聛搂 PDF 茫聛芦氓陇聣忙聫聸氓聫炉猫聝陆茫聛陋忙聥隆氓录碌氓颅聬\n    // API 茫聛搂氓聫聳氓戮聴氓聫炉猫聝陆茫聛聽茫聛聦氓聸聻茫聜聤茫聛聫茫聛漏茫聛聞茫聛庐茫聛搂茫聛聯茫聛聯茫聛搂茫聝聠茫聝录茫聝聳茫聝芦氓聦聳茫聛聴茫聛娄茫聛聤茫聛聫\n    var extensions = new Set([\n        \u00273fr\u0027,\n        \u0027abw\u0027,\n        \u0027ai\u0027,\n        \u0027arw\u0027,\n        \u0027azw\u0027,\n        \u0027azw3\u0027,\n        \u0027azw4\u0027,\n        \u0027bmp\u0027,\n        \u0027cbc\u0027,\n        \u0027cbr\u0027,\n        \u0027cbz\u0027,\n        \u0027cdr\u0027,\n        \u0027cgm\u0027,\n        \u0027chm\u0027,\n        \u0027cr2\u0027,\n        \u0027crw\u0027,\n        \u0027csv\u0027,\n        \u0027dcr\u0027,\n        \u0027djvu\u0027,\n        \u0027dng\u0027,\n        \u0027doc\u0027,\n        \u0027docm\u0027,\n        \u0027docx\u0027,\n        \u0027dot\u0027,\n        \u0027dotx\u0027,\n        \u0027dps\u0027,\n        \u0027dwg\u0027,\n        \u0027dxf\u0027,\n        \u0027emf\u0027,\n        \u0027eps\u0027,\n        \u0027epub\u0027,\n        \u0027erf\u0027,\n        \u0027et\u0027,\n        \u0027fb2\u0027,\n        \u0027gif\u0027,\n        \u0027heic\u0027,\n        \u0027htm\u0027,\n        \u0027html\u0027,\n        \u0027htmlz\u0027,\n        \u0027hwp\u0027,\n        \u0027ico\u0027,\n        \u0027jpeg\u0027,\n        \u0027jpg\u0027,\n        \u0027key\u0027,\n        \u0027lit\u0027,\n        \u0027lrf\u0027,\n        \u0027lwp\u0027,\n        \u0027md\u0027,\n        \u0027mobi\u0027,\n        \u0027mos\u0027,\n        \u0027mrw\u0027,\n        \u0027nef\u0027,\n        \u0027numbers\u0027,\n        \u0027odd\u0027,\n        \u0027odp\u0027,\n        \u0027ods\u0027,\n        \u0027odt\u0027,\n        \u0027orf\u0027,\n        \u0027pages\u0027,\n        \u0027pdb\u0027,\n        \u0027pdf\u0027,\n        \u0027pef\u0027,\n        \u0027pml\u0027,\n        \u0027png\u0027,\n        \u0027pot\u0027,\n        \u0027potx\u0027,\n        \u0027ppm\u0027,\n        \u0027pps\u0027,\n        \u0027ppsx\u0027,\n        \u0027ppt\u0027,\n        \u0027pptm\u0027,\n        \u0027pptx\u0027,\n        \u0027prc\u0027,\n        \u0027ps\u0027,\n        \u0027psd\u0027,\n        \u0027raf\u0027,\n        \u0027raw\u0027,\n        \u0027rb\u0027,\n        \u0027rst\u0027,\n        \u0027rtf\u0027,\n        \u0027sda\u0027,\n        \u0027sdc\u0027,\n        \u0027sdw\u0027,\n        \u0027sk\u0027,\n        \u0027sk1\u0027,\n        \u0027snb\u0027,\n        \u0027svg\u0027,\n        \u0027svgz\u0027,\n        \u0027tcr\u0027,\n        \u0027tex\u0027,\n        \u0027tif\u0027,\n        \u0027tiff\u0027,\n        \u0027txt\u0027,\n        \u0027txtz\u0027,\n        \u0027vsd\u0027,\n        \u0027webp\u0027,\n        \u0027wmf\u0027,\n        \u0027wpd\u0027,\n        \u0027wps\u0027,\n        \u0027x3f\u0027,\n        \u0027xcf\u0027,\n        \u0027xls\u0027,\n        \u0027xlsm\u0027,\n        \u0027xlsx\u0027,\n        \u0027xps\u0027,\n        \u0027zabw\u0027,\n    ]);\n\n    /**\n     * Amazon茫聝聯茫聜赂茫聝聧茫聜鹿茫聛赂茫聛庐茫聝聭茫聝鲁茫聝聛茫聜垄茫聜娄茫聝聢氓聣聧茫聛庐莽垄潞猫陋聧茫聜聮猫隆聦茫聛聠\n     */\n    function showPunchoutConfirm() {\n        $scope.clicked_punchout = true;\n        $scope.shipping_address_empty = false;\n        $scope.billing_address_empty = false;\n\n        // 茅\u0085聧茅聙聛氓\u0085聢茫聙聛猫芦聥忙卤聜氓\u0085聢茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聝聭茫聝鲁茫聝聛茫聜垄茫聜娄茫聝聢茫聛聴茫聛陋茫聛聞\n        if (!$scope.form_data.ec.shipping_address || Object.keys($scope.form_data.ec.shipping_address).length === 0) {\n            $scope.shipping_address_empty = true;\n        }\n        if (!$scope.form_data.ec.billing_address || Object.keys($scope.form_data.ec.billing_address).length === 0) {\n            $scope.billing_address_empty = true;\n        }\n        if ($scope.shipping_address_empty || $scope.billing_address_empty) return;\n\n        // 忙聴垄茫聛芦忙聵聨莽麓掳茫聛芦氓聲聠氓聯聛茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聦茫聛掳莽垄潞猫陋聧茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聜聮氓聡潞氓聤聸\n        if ($scope.form_data.ec.request_ec_specifics_rows) {\n            var title = gettextCatalog.getString(\u0027氓聲聠氓聯聛茫聛庐氓聠聧茅聛赂忙聤聻\u0027);\n            var body = gettextCatalog.getString(\u0027莽聫戮氓聹篓茅聛赂忙聤聻盲赂颅茫聛庐氓聲聠氓聯聛忙聝\u0085氓聽卤茫聛炉莽聽麓忙拢聞茫聛聲茫聜聦茫聛戮茫聛聶茫聛聦茫聜聢茫聜聧茫聛聴茫聛聞茫聛搂茫聛聶茫聛聥茂录聼\u0027);\n            var close_button_flg = Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP[\u0027show\u0027];\n            var submit_button_flg = Const.miscellaneous._DIALOG_OK_BUTTON_TYPE[\u0027submit\u0027];\n\n            dialogService.showConfirmDialogYesNo(title, body, close_button_flg, submit_button_flg)\n            .then(function(flg) {\n                if (flg) punchoutForAmazon();\n            });\n        }\n        else {\n            punchoutForAmazon();\n        }\n    }\n\n    /**\n     * Amazon茫聝聯茫聜赂茫聝聧茫聜鹿茫聛赂茫聛庐茫聝聭茫聝鲁茫聝聛茫聜垄茫聜娄茫聝聢茫聜聮猫隆聦茫聛聠\n     */\n    function punchoutForAmazon() {\n        // value茫聛聦忙聹聣氓聤鹿茫聛陋氓聙陇茫聛陋茫聜聣value, 茫聛聺茫聛聠茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳defaultValue茫聜聮猫驴聰茫聛聶\n        const getOrElse = function (value, defaultValue) {\n            if (angular.isUndefinedOrNull(value)) return defaultValue;\n            return angular.toJson(value);\n        };\n\n        // 莽聰禄茅聺垄茫聛庐氓\u0085楼氓聤聸氓聠\u0085氓庐鹿茫聜聮氓戮漏氓\u0085聝茫聛聶茫聜聥茫聛聼茫聜聛茫聛芦茅聙聙茅聛驴茫聛聶茫聜聥\n        const accessor = EcStorageAccessorService.ecStorageData;\n        accessor.setStorageData(EcConst.evacuation.CALLBACK_FLG, EcConst.miscellaneous.TRUE);\n        accessor.setStorageData(EcConst.evacuation.FORM_DATA, getOrElse($scope.form_data, {}));\n        accessor.setStorageData(EcConst.evacuation.LAST_APPROVAL_PERIOD, getOrElse($scope.last_approval_period, {}));\n        accessor.setStorageData(EcConst.evacuation.REQUESTER_INFO, getOrElse($scope.requester_info, {}));\n        accessor.setStorageData(EcConst.evacuation.PREV_FLOW, getOrElse($scope.prev_flow, null));\n        accessor.setStorageData(EcConst.evacuation.FLOW_DATA, getOrElse($scope.flow_data, null));\n        accessor.setStorageData(EcConst.evacuation.REQUEST_FILES, getOrElse($scope.request_files, []));\n        accessor.setStorageData(EcConst.evacuation.FORM_FILES, getOrElse($scope.form_files, []));\n        accessor.setStorageData(\n            EcConst.evacuation.FLOW_CIRCULATION_USERS, getOrElse($scope.flow_circulation_users, []));\n\n        // 盲禄楼盲赂聥茫聙聛茫聝聭茫聝鲁茫聝聛茫聜垄茫聜娄茫聝聢茫聛芦氓驴\u0085猫娄聛茫聛陋茅聽\u0085莽聸庐茫聜聮猫篓颅氓庐職\n        var po_data = {};\n        po_data[\u0027ec_settings_id\u0027] = $scope.form_data.ec.ec_settings.id;\n        po_data[\u0027shipping_address\u0027] = $scope.form_data.ec.shipping_address;\n        po_data[\u0027billing_address\u0027] = $scope.form_data.ec.billing_address.code;\n        po_data[\u0027login_user\u0027] = $scope.login_user;\n        po_data[\u0027request_kind\u0027] = $scope.kind;\n        po_data[\u0027response_url\u0027] = $window.location.href;\n        po_data[\u0027xml_lang\u0027] = $locale.localeID.replace(\u0027_\u0027,\u0027-\u0027);\n\n        PunchOutService.postPunchOutDataForAmazon(po_data).then(function(result) {\n            $window.location.href = result.data.Response.PunchOutSetupResponse.StartPage.URL;\n        }).catch(function(result) {\n            const title = gettextCatalog.getString(\u0027茫聜篓茫聝漏茫聝录\u0027);\n            const body = result.data;\n            _showMessageDialog(title, body);\n            accessor.clearEcStorageData();\n        });\n\n        function _showMessageDialog(title, body) {\n            dialogService.showConfirmDialog(\n                title,\n                body,\n                Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP[\u0027hide\u0027],\n                Const.miscellaneous._DIALOG_OK_BUTTON_TYPE[\u0027consent\u0027]\n            ).then(function(flg) {\n            });\n        }\n    }\n\n    /**\n     * EC茫聜碌茫聜陇茫聝聢茫聛聥茫聜聣茫聜鲁茫聝录茫聝芦茫聝聬茫聝聝茫聜炉茫聛聴茫聛聼茅職聸茫聛芦茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛聥茫聜聣茫聝聡茫聝录茫聜驴茫聜聮氓戮漏氓\u0085聝茫聛聶茫聜聥氓聡娄莽聬聠\n     * @return {Promise}\n     */\n    function getEcCallBackSessionData() {\n        const deferred = $q.defer();\n\n        const accessor = EcStorageAccessorService.ecStorageData;\n        // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛搂茫聛陋茫聛聞茫聙聛茫聜聜茫聛聴茫聛聫茫聛炉EC茫聜碌茫聜陇茫聝聢茫聛聥茫聜聣茫聛庐茫聜鲁茫聝录茫聝芦茫聝聬茫聝聝茫聜炉茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉return\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_EC\n            || angular.isUndefinedOrNull(accessor.getStorageData(EcConst.evacuation.CALLBACK_FLG))) {\n            deferred.resolve({CALLBACK_FROM_EC_FLG: false});\n            return deferred.promise;\n        }\n\n        // 茫聜碌茫聝录茫聝聬茫聝录氓聛麓茫聛庐茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛芦茅聙聙茅聛驴茫聛聴茫聛娄茫聛聞茫聜聥Amazon茫聛庐氓聲聠氓聯聛茫聝聡茫聝录茫聜驴茫聛陋茫聛漏茫聜聮氓聫聳氓戮聴\n        EcCooperationService.getCallBackSessionData().then(function (res) {\n            const data = {};\n            if (!angular.isUndefinedOrNull(res[EcConst.receiving.RECEIVED_DATA])) {\n                if (EcConst.receiving.FOR_ORDER_REQUEST in res[EcConst.receiving.RECEIVED_DATA]) {\n                    data.FOR_ORDER_REQUEST = res[EcConst.receiving.RECEIVED_DATA][EcConst.receiving.FOR_ORDER_REQUEST];\n                }\n                if (EcConst.receiving.REQUEST_EC_SPECIFICS_ROWS in res[EcConst.receiving.RECEIVED_DATA]) {\n                    data.REQUEST_EC_SPECIFICS_ROWS =\n                        res[EcConst.receiving.RECEIVED_DATA][EcConst.receiving.REQUEST_EC_SPECIFICS_ROWS];\n                }\n                data.CALLBACK_FROM_EC_FLG = true;\n            }\n            deferred.resolve(data);\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛搂茫聜鹿茫聝聢茫聝卢茫聝录茫聜赂茫聜聞茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛庐茫聝聡茫聝录茫聜驴茫聜聮莽聰鲁猫芦聥茫聛芦氓聫聧忙聵聽茫聛聶茫聜聥氓聡娄莽聬聠\n     * @param {Object} session_data\n     */\n    function getEcEvacuationData(session_data) {\n        // value茫聛聦忙聹聣氓聤鹿茫聛陋氓聙陇茫聛陋茫聜聣value, 茫聛聺茫聛聠茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳defaultValue茫聜聮猫驴聰茫聛聶\n        const getOrElse = function (value, defaultValue) {\n            if (angular.isUndefinedOrNull(value)) return defaultValue;\n            return value;\n        };\n\n        const accessor = EcStorageAccessorService.ecStorageData;\n        $scope.form_data = accessor.getStorageData(EcConst.evacuation.FORM_DATA);\n        $scope.last_approval_period = accessor.getStorageData(EcConst.evacuation.LAST_APPROVAL_PERIOD);\n        $scope.requester_info = accessor.getStorageData(EcConst.evacuation.REQUESTER_INFO);\n        $scope.request_files = accessor.getStorageData(EcConst.evacuation.REQUEST_FILES);\n        $scope.form_files = accessor.getStorageData(EcConst.evacuation.FORM_FILES);\n        $scope.form_data_old = accessor.getStorageData(EcConst.evacuation.FORM_DATA_OLD);\n        $scope.last_approval_period_old = accessor.getStorageData(EcConst.evacuation.LAST_APPROVAL_PERIOD_OLD);\n        $scope.request_files_old = accessor.getStorageData(EcConst.evacuation.REQUEST_FILES_OLD);\n        // $scope.form_data茫聛庐忙聸麓忙聳掳茫聛芦氓聬聢茫聜聫茫聛聸茫聛娄忙聸麓忙聳掳\n        mapped_items = CreateRequestFormItemService.makeMappedItems($scope.form_data.form_json);\n\n        // 氓聠聧莽聰鲁猫芦聥忙聶聜茫聛庐忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聛炉氓颅聵氓聹篓茫聛聶茫聜聥氓聽麓氓聬聢茫聛庐茫聛驴茫聜禄茫聝聝茫聝聢茂录聢request_flow_services.js茫聛庐setFlowVersion茫聛搂茫聜篓茫聝漏茫聝录茫聛篓茫聛陋茫聜聥茫聛聼茫聜聛茂录聣\n        const prev_flow = accessor.getStorageData(EcConst.evacuation.PREV_FLOW);\n        if (!angular.isUndefinedOrNull(prev_flow)) {\n            $scope.prev_flow = prev_flow;\n        }\n        // 忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮茫聜鹿茫聝聢茫聝卢茫聝录茫聜赂茫聛聥茫聜聣氓聫聳氓戮聴茫聛聴茫聛聼茫聝聡茫聝录茫聜驴茫聛搂盲赂聤忙聸赂茫聛聧\n        const flow_data = accessor.getStorageData(EcConst.evacuation.FLOW_DATA);\n        if (!angular.isUndefinedOrNull(flow_data)) {\n            $scope.flow_data = flow_data;\n        }\n        // 茅聳虏猫娄搂猫聙\u0085忙聝\u0085氓聽卤茫聜聮茫聜鹿茫聝聢茫聝卢茫聝录茫聜赂茫聛聥茫聜聣氓聫聳氓戮聴茫聛聴茫聛聼茫聝聡茫聝录茫聜驴茫聛搂盲赂聤忙聸赂茫聛聧\n        // 茂录聢茫聛聼茫聛聽茫聛聴茫聙聛莽碌聦猫路炉氓聢聠氓虏聬茫聛搂莽碌聦猫路炉茫聛聦氓陇聣茫聜聫茫聜聥氓聽麓氓聬聢茫聛炉茫聙聛氓聢聠氓虏聬氓戮聦茫聛庐莽碌聦猫路炉茫聛庐茅聳虏猫娄搂猫聙\u0085忙聝\u0085氓聽卤茫聛搂盲赂聤忙聸赂茫聛聧茫聛聲茫聜聦茫聜聥茂录聣\n        const flow_circulation_users = accessor.getStorageData(EcConst.evacuation.FLOW_CIRCULATION_USERS);\n        if (!angular.isUndefinedOrNull(flow_circulation_users)) {\n            $scope.flow_circulation_users = flow_circulation_users;\n        }\n\n        // ecStorageData.storageData茫聛搂氓戮漏氓\u0085聝茫聛聴茫聛聼$scope.form_data茫聛芦茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛聥茫聜聣氓聫聳氓戮聴茫聛聴茫聛聼忙聝\u0085氓聽卤茫聜聮猫驴陆氓聤聽茫聛聶茫聜聥\n        $scope.form_data.ec.for_order_request = getOrElse(session_data.FOR_ORDER_REQUEST, {});\n        $scope.form_data.ec.request_ec_specifics_rows = getOrElse(session_data.REQUEST_EC_SPECIFICS_ROWS, {});\n        // 忙聵聨莽麓掳茫聛芦氓聲聠氓聯聛茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛氓聲聠氓聯聛氓聧聵盲戮隆茫聛庐莽篓聨猫戮录茫聙聛莽篓聨忙聤聹茫聜聮氓聢陇氓庐職茫聛聶茫聜聥\n        if($scope.form_data.ec.request_ec_specifics_rows) {\n            $scope.form_data.ec.tax_included = RequestEcService.isTaxIncludedFromRequest(\n                $scope.form_data.ec.request_ec_specifics_rows\n            );\n        }\n\n        // 茫聜鹿茫聝聢茫聝卢茫聝录茫聜赂茫聛芦茅聙聙茅聛驴茫聛聴茫聛娄茫聛聞茫聛聼茫聝聡茫聝录茫聜驴茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n        accessor.clearEcStorageData();\n    }\n\n    function backToPreviousPage() {\n        // 茅聛路莽搂禄氓\u0085聝莽聰禄茅聺垄茫聛赂茫聛庐莽搂禄氓聥聲\n        // 茅聛路莽搂禄氓\u0085聝莽聰禄茅聺垄茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢 (URL莽聸麓忙聨楼氓\u0085楼氓聤聸茫聙聛盲驴庐忙颅拢莽聰禄茅聺垄茫聝陋茫聝颅茫聝录茫聝聣) 茫聛炉茫聙聦忙聣驴猫陋聧茫聛聶茫聜聥茫聙聧莽聰禄茅聺垄茫聛芦莽搂禄氓聥聲\n        $location.path(angular.isUndefined($scope.referrer_url) ? \u0027/myapprovals\u0027 : $scope.referrer_url);\n        // 茫聜垄茫聝聴茫聝陋氓聬聭茫聛聭茫聛芦emit\n        $scope.$emit(\u0027app__reload\u0027, {state: \u0027app.myapprovals\u0027});\n    }\n\n    function clearGroup(form_data) {\n        createRequestService.clearGroup(form_data);\n    }\n\n    function clearProject(form_data) {\n        createRequestService.clearProject(form_data);\n    }\n\n    /**\n     * 茫聜驴茫聜陇茫聝聢茫聝芦猫聡陋氓聥聲莽聰聼忙聢聬氓聡娄莽聬聠\n     * @return {Promise}\n     */\n    function generateTitleAuto() {\n        // 氓\u0085楼氓聤聸猫篓卤氓聫炉茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉氓聡娄莽聬聠茫聛聴茫聛陋茫聛聞\n        if ($scope.form_data.edit_title_setting_flg) {\n            return $q.when();\n        }\n        return CreateRequestTitleService.postCreateTitle(\n            $scope.kind,\n            $scope.form_data.form_id,\n            $scope.request_id,\n            $scope.requester_id,\n            $scope.form_data.group,\n            $scope.form_data.project,\n            $scope.totalAmount,\n            $scope.form_data.form_json\n        );\n    }\n\n    /**\n     * 忙聵聨莽麓掳茫聛庐莽聞隆茫聛聞忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛庐忙聰炉忙聣聲氓\u0085聢茫聛芦氓聫聳氓录聲氓\u0085聢茫聛篓茫聝娄茫聝录茫聜露茫聛庐茫聛漏茫聛隆茫聜聣茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥茫聜聮氓聢陇氓庐職茫聛聶茫聜聥\n     * specifics_type茫聛聦undefined茫聜聞null茫聛庐氓聽麓氓聬聢茫聛炉忙篓聶忙潞聳茫聛搂茫聛聜茫聜聥normal茫聜聮猫驴聰茫聛聶\n     * @return {string}\n     */\n    function getPaymentSpecificsType() {\n        if ($scope.form_data.specifics_type === Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL\n            || angular.isUndefinedOrNull($scope.form_data.specifics_type)) {\n            return Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL;\n        }\n        else {\n            return Const.miscellaneous.PAYMENT_SPECIFICS_USER;\n        }\n    }\n\n    /**\n     * 忙聵聨莽麓掳茫聛庐莽聞隆茫聛聞忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛聦氓聫聳氓录聲氓\u0085聢茫聛聥氓聢陇氓庐職茫聛聶茫聜聥\n     * @return {bool}\n     */\n    function isPaymentSpecificsTypeNormal() {\n        return $scope.getPaymentSpecificsType() === Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL;\n    }\n\n    /**\n     * 忙聵聨莽麓掳茫聛庐莽聞隆茫聛聞忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛聦茫聝娄茫聝录茫聜露茫聛聥氓聢陇氓庐職茫聛聶茫聜聥\n     * @return {bool}\n     */\n    function isPaymentSpecificsTypeUser() {\n        return $scope.getPaymentSpecificsType() === Const.miscellaneous.PAYMENT_SPECIFICS_USER;\n    }\n\n    /**\n     * 盲赂聥忙聸赂茫聛聧莽聰鲁猫芦聥茫聝聹茫聜驴茫聝鲁茫聜聮disabled茫聛芦茫聛聶茫聜聥茫聛聥茫聛庐氓聢陇氓庐職\n     * @param {object} request_form\n     * @return {bool} disabled 茫聛庐氓聽麓氓聬聢茫聛炉true\n     */\n    function isDraftRequestDisabled(request_form) {\n        if ($scope.spinnerActive) {\n            return true;\n        }\n        else if ($scope.form_data.edit_title_setting_flg \u0026\u0026 request_form.title.$invalid) {\n            return true;\n        }\n        else if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EC\n                 \u0026\u0026 $scope.form_data.ec.request_ec_specifics_rows) {\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 猫聡陋氓聥聲莽聰聼忙聢聬茫聛聴茫聛聼茫聜驴茫聜陇茫聝聢茫聝芦茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥茫聛庐氓聢陇氓庐職\n     * @param {object} request_form\n     * @return {bool} 猫隆篓莽陇潞茫聛聶茫聜聥氓聽麓氓聬聢茫聛炉true\n     */\n    function showGenerateTitle(request_form) {\n        if ($scope.form_data.edit_title_setting_flg) {\n            return false;\n        }\n        else if ($scope.isConfirm) {\n            return true;\n        }\n        else if (isTitleError(request_form)) {\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 茫聜驴茫聜陇茫聝聢茫聝芦茫聛庐茫聜篓茫聝漏茫聝录氓聢陇氓庐職\n     * @param {object} request_form\n     * @return {bool} 茫聜篓茫聝漏茫聝录茫聛庐氓聽麓氓聬聢茫聛炉true\n     */\n    function isTitleError(request_form) {\n        return (request_form.title \u0026\u0026 request_form.title.$invalid === true \u0026\u0026 $scope.clicked_confirm);\n    }\n\n    /**\n     * 茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵茫聛聦氓驴\u0085猫娄聛茫聛陋忙聵聨莽麓掳茫聛聦忙庐聥茫聛拢茫聛娄茫聛聞茫聜聥茫聛聥茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {Array} specifics 忙聵聨莽麓掳猫隆篓\n     * @param {String} specifics_row_name 忙聵聨莽麓掳猫隆聦茫聛庐氓聬聧莽搂掳茂录聢request_expense_specifics_rows / request_payment_specifics_rows茂录聣\n     * @return {boolean} true:忙庐聥茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞/false:忙庐聥茫聛拢茫聛娄茫聛聞茫聜聥\n     */\n    function _existInvalidSpecificsAttached(specifics, specifics_row_name) {\n        if (!specifics) return false;\n\n        // 忙聵聨莽麓掳猫隆篓茫聛庐茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵氓驴\u0085茅聽聢茫聝聛茫聜搂茫聝聝茫聜炉茫聝聲茫聝漏茫聜掳茫聜聮false茫聛芦茫聝陋茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n        _resetShowSpecificsAttachedError(specifics);\n        // 猫隆篓莽陇潞盲赂颅茫聛聥茫聛陇氓\u0085楼氓聤聸忙赂聢茫聛驴茫聛庐忙聵聨莽麓掳猫隆篓盲赂聙猫娄搂\n        var displayingInputtedSpecificsSheets = _getDisplayingInputtedSpecificsSheets(specifics);\n\n        var exist_invalid = false;\n        angular.forEach(displayingInputtedSpecificsSheets, function(sheet) {\n            // 忙聵聨莽麓掳茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聛聦氓驴\u0085茅聽聢茫聛聥茫聛陇忙聹陋忙路禄盲禄聵茫聛庐氓聽麓氓聬聢茫聙聛忙聵聨莽麓掳猫隆篓莽聰篓茫聛庐茫聜篓茫聝漏茫聝录茫聝隆茫聝聝茫聜禄茫聝录茫聜赂猫隆篓莽陇潞茫聝聲茫聝漏茫聜掳茫聜聮True茫聛芦茫聛聶茫聜聥\n            sheet.showSpecificsAttachedError = !isValidAttachmentSetting(sheet[specifics_row_name]);\n            if (sheet.showSpecificsAttachedError) {\n                exist_invalid = true;\n            }\n        });\n        return exist_invalid;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥ID茫聛聥茫聜聣盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐猫篓颅氓庐職茫聜聮猫陋颅茫聛驴猫戮录茫聜聙茫聛聥茫聛漏茫聛聠茫聛聥\n     * @param {string} kind 莽聰鲁猫芦聥茫聛庐莽篓庐茅隆聻\n     * @return {bool}\n     */\n    function isRelatedFormLimitSettingFromRequestId(kind){\n        const CREATE_REQUEST_KIND = Const.miscellaneous.CREATE_REQUEST_KIND;\n        return [\n            CREATE_REQUEST_KIND.NEW,\n            CREATE_REQUEST_KIND.EDIT,\n            CREATE_REQUEST_KIND.COPY,\n            CREATE_REQUEST_KIND.FEEDBACK,\n        ].indexOf(kind) === -1;\n    }\n\n    /**\n     * 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐莽聰鲁猫芦聥茫聛庐盲潞聥氓聣聧莽聰鲁猫芦聥忙聴楼盲禄聵忙聹聼茅聳聯茫聝聛茫聜搂茫聝聝茫聜炉莽碌聬忙聻聹茫聛庐忙聸麓忙聳掳\n     */\n    $scope.$on(\u0027update_expense_date_period_error\u0027, function(e, value) {\n        expense_date_period_error = value;\n    });\n\n    /**\n     * 忙聵聨莽麓掳猫隆篓茫聛庐茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵氓驴\u0085茅聽聢茫聝聛茫聜搂茫聝聝茫聜炉茫聝聲茫聝漏茫聜掳茫聜聮茫聝陋茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥(false茫聛芦茫聛聶茫聜聥)\n     * @param {Array} specifics 忙聵聨莽麓掳猫隆篓\n     */\n    function _resetShowSpecificsAttachedError(specifics){\n        angular.forEach(specifics, function(sheet) {\n            sheet.showSpecificsAttachedError = false;\n        });\n    }\n\n    /**\n     * 茫聜芦茫聝录茫聝聣ID茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠茫聛庐氓聫聳氓戮聴\n     * @param {Array} card_ids 氓聫聳氓戮聴氓炉戮猫卤隆茫聛庐茫聜芦茫聝录茫聝聣ID茫聝陋茫聜鹿茫聝聢\n     * @return {object} 茫聜芦茫聝录茫聝聣ID茫聛芦莽麓聬茫聛楼茫聛聫氓聦潞氓聢聠\n     */\n    function _getDivisionByCardId(card_ids) {\n        if (card_ids.length === 0) {\n            return;\n        }\n        return createRequestService.getDivisionsByCardId(card_ids);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥ID茫聛芦莽麓聬茫聛楼茫聛聫RequestExpense茫聛庐氓聫聳氓戮聴\n     * @param {Number} request_id 莽聰鲁猫芦聥id\n     * @param {Number} form_type 茫聝聲茫聜漏茫聝录茫聝聽茫聜驴茫聜陇茫聝聴\n     * @return {Promise} Promise\n     */\n    function _getRequestExpense(request_id, form_type) {\n        const deferred = $q.defer();\n        if (util.isUndefinedOrNull(request_id) || util.isUndefinedOrNull(form_type)) {\n            deferred.resolve(null);\n        }\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉忙聹卢 API 茫聛炉氓庐聼猫隆聦茫聛聴茫聛陋茫聛聞\n        else if (form_type != Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            deferred.resolve(null);\n        }\n        else {\n            // TODO 茫聛禄茫聛录氓聢陇氓庐職莽聰篓茫聛庐氓聙陇茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聛聞茫聜聥茫聛聦茫聙聛氓聢陇氓庐職茫聛炉茫聜碌茫聝录茫聝聬茫聝录氓聛麓茫聛搂茫聛聶茫聜聥茫聛鹿茫聛聧\n            RequestService.getRequestExpenseForRelatedRequest(request_id).then(function(response) {\n                deferred.resolve(response.data);\n            }).catch(function(res) {\n                // eslint-disable-next-line angular/typecheck-string\n                if (typeof res.data === \u0027string\u0027) {\n                    notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n                }\n                deferred.reject();\n            });\n        }\n        return deferred.promise;\n    }\n\n    /**\n     * 忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼茫聜聮茫聝陋茫聜禄茫聝聝茫聝聢\n     * @private\n     */\n    function _resetPaymentDateTermReflectConditions() {\n        $scope.payment_date_term = null;\n        $scope.form_related_payment_options = [];\n        $scope.reflect_payment_date_terms = [];\n        $scope.payment_terms_reference_date_type = Const.miscellaneous.PAYMENT_TERMS_REFERENCE_DATE_TYPE.REQUEST_DATE;\n    }\n\n    /**\n     * 忙聹聙忙聳掳茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼茫聜聮氓聫聳氓戮聴\n     * @param {number} form_id\n     * @return {promise}\n     * @private\n     */\n    function _getFormPaymentDateTermReflectConditions(form_id) {\n        const deferred = $q.defer();\n        PaymentOptionService.getPaymentDateTermReflectConditions(form_id).then(function (res) {\n            const conditions = res.data.payment_date_term_reflect_conditions;\n            if (conditions.length === 0) {\n                _resetPaymentDateTermReflectConditions();\n                deferred.resolve();\n                return;\n            }\n            // 忙聰炉忙聣聲忙聺隆盲禄露\n            $scope.payment_date_term = conditions[0].payment_date_term.id;\n            // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲\n            $scope.payment_date_type =\n                conditions[0].payment_date_term.payment_date_term_payment_date_terms_detail[0].payment_date_type;\n            // 茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌\n            $scope.form_related_payment_options =\n                PaymentOptionService.getPaymentOptionsFromReflectConditions(conditions);\n            // 氓聼潞忙潞聳忙聴楼\n            $scope.payment_terms_reference_date_type = conditions[0].payment_terms_reference_date_type;\n            deferred.resolve();\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录莽聰篓 忙聹聙忙聳掳茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼茫聜聮氓聫聳氓戮聴\n     * @param {number} form_id\n     * @return {promise}\n     * @private\n     */\n    function _getFormPaymentDateTermReflectConditionsForPayment(form_id) {\n        const deferred = $q.defer();\n        PaymentOptionService.getPaymentDateTermReflectConditions(form_id).then(function (res) {\n            const conditions = res.data.payment_date_term_reflect_conditions;\n            if (conditions.length === 0) {\n                _resetPaymentDateTermReflectConditions();\n                deferred.resolve();\n                return;\n            }\n            // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁茅聛赂忙聤聻猫聜垄茫聜禄茫聝聝茫聝聢\n            $scope.reflect_payment_date_terms = conditions.map(function (condition) {\n                return condition.payment_date_term;\n            });\n\n            // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐忙聹聙氓聢聺茫聛庐茅聽\u0085莽聸庐茫聜聮氓聫聳氓戮聴\n            const first_condition = conditions[0];\n            const first_obj = first_condition.payment_date_term;\n            const first_detail_obj = first_obj.payment_date_term_payment_date_terms_detail[0];\n            // 盲赂聙猫娄搂茫聛庐忙聹聙氓聢聺茫聛庐茅聽\u0085莽聸庐茫聜聮猫篓颅氓庐職\n            $scope.form_data.payment.payment_date_term = first_obj.id;\n            // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茫聜聮茫聜禄茫聝聝茫聝聢\n            $scope.payment_date_term_detail.payment_date_type = first_detail_obj.payment_date_type;\n            // 氓聼潞忙潞聳忙聴楼茫聜聮茫聜禄茫聝聝茫聝聢\n            $scope.form_data.payment.reference_date_type = first_condition.payment_terms_reference_date_type;\n            deferred.resolve();\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥忙聶聜茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼茫聜聮氓聫聳氓戮聴\n     * @return {promise}\n     * @private\n     */\n    function _getRequestPaymentDateTermReflectConditions() {\n        const deferred = $q.defer();\n        PaymentOptionService.getRequestPaymentDateTermReflectConditions($scope.request_id).then(function (res) {\n            const conditions = res.data.payment_date_term_reflect_conditions;\n            if (conditions.length === 0) {\n                _resetPaymentDateTermReflectConditions();\n                deferred.resolve();\n                return;\n            }\n            // 忙聰炉忙聣聲忙聺隆盲禄露\n            $scope.payment_date_term = conditions[0].payment_date_term.id;\n            // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲\n            $scope.payment_date_type =\n                conditions[0].payment_date_term.payment_date_term_payment_date_terms_detail[0].payment_date_type;\n            // 茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌\n            $scope.form_related_payment_options =\n                PaymentOptionService.getPaymentOptionsFromReflectConditions(conditions);\n            // 氓聼潞忙潞聳忙聴楼\n            $scope.payment_terms_reference_date_type = conditions[0].payment_terms_reference_date_type;\n            deferred.resolve();\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录莽聰篓 莽聰鲁猫芦聥忙聶聜茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聰炉忙聣聲忙聺隆盲禄露茫聙聛茅聛漏莽聰篓茫聛聶茫聜聥忙聰炉忙聣聲忙聣聥忙庐碌茫聙聛氓聼潞忙潞聳忙聴楼茫聜聮氓聫聳氓戮聴\n     * @return {promise}\n     * @private\n     */\n    function _getRequestPaymentDateTermReflectConditionsForPayment() {\n        const deferred = $q.defer();\n        PaymentOptionService.getRequestPaymentDateTermReflectConditions($scope.request_id).then(function (res) {\n            const conditions = res.data.payment_date_term_reflect_conditions;\n            if (conditions.length === 0) {\n                _resetPaymentDateTermReflectConditions();\n                deferred.resolve();\n                return;\n            }\n            // 忙聰炉忙聣聲忙聺隆盲禄露茫聛庐茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁茅聛赂忙聤聻猫聜垄\n            $scope.reflect_payment_date_terms = conditions.map(function (condition) {\n                return condition.payment_date_term;\n            });\n            // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲 茅聛赂忙聤聻茫聛聴茫聛娄茫聛聞茫聜聥忙聰炉忙聣聲忙聺隆盲禄露茫聛聥茫聜聣茫聜禄茫聝聝茫聝聢\n            const select_payment_date_terms = $scope.reflect_payment_date_terms.filter(function (term) {\n                return $scope.form_data.payment.payment_date_term === term.id;\n            });\n            if (select_payment_date_terms.length) {\n                // 忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛庐忙卤潞氓庐職忙聳鹿忙鲁聲茫聜聮茫聜禄茫聝聝茫聝聢\n                $scope.payment_date_term_detail.payment_date_type =\n                    select_payment_date_terms[0].payment_date_term_payment_date_terms_detail[0].payment_date_type;\n                // 盲驴庐忙颅拢氓聣聧茫聛庐忙聰炉忙聣聲忙聺隆盲禄露茫聜聮茫聜禄茫聝聝茫聝聢\n                paymentDateTermOld.id = select_payment_date_terms[0].id;\n                paymentDateTermOld.title = select_payment_date_terms[0].title;\n            } else {\n                $scope.payment_date_term_detail.payment_date_type = Const.miscellaneous.PAYMENT_TERM_TYPE.APPLICATION;\n            }\n            // 氓聼潞忙潞聳忙聴楼\n            $scope.form_data.payment.reference_date_type = conditions[0].payment_terms_reference_date_type;\n            deferred.resolve();\n        });\n        return deferred.promise;\n    }\n\n    function _makeCustomSpecifics(data, sheet) {\n        // 茫聜路茫聝录茫聝聢忙聝\u0085氓聽卤\n        CustomSpecificsConvertService.makeCustomSpecifics(data, sheet);\n        // 忙聴垄氓庐職茅聽\u0085莽聸庐茫聛庐氓卤聲茅聳聥\n        CustomSpecificsConvertService.convertCustomSpecifics(data, sheet);\n    }\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聬聞茅聽\u0085莽聸庐茫聛庐氓鹿\u0085茫聜聮氓聫聳氓戮聴\n     * @param {string} specific_item_code 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茅聽\u0085莽聸庐茫聜鲁茫聝录茫聝聣\n     * @param {column} column 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茅聽\u0085莽聸庐\n     * @return {string}\n     */\n    $scope.getCustomSpecificsColumnWidth = function (specific_item_code, column) {\n        return CustomSpecificsItemsService.getCustomSpecificsColumnWidth(specific_item_code, column);\n    };\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聬聞茅聽\u0085莽聸庐茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @param {object} sheet 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳猫隆篓\n     * @param {object} column 氓聢聴茫聝聡茫聝录茫聜驴\n     * @return {boolean} true: 猫隆篓莽陇潞茫聛聶茫聜聥, false: 猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n     */\n    $scope.showColumnByCustomSpecifics = function (sheet, column) {\n        const payment_due_date_setting = (\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT\n                ? $scope.form_data.payment.payment_due_date_setting\n                : false\n        );\n        const PayeePerRequest = {\n            isPayeePerRequest: false,\n            isCompanyPaymentFormat: false,\n        };\n        if (!util.isUndefinedOrNull($scope.form_data.payment)) {\n            PayeePerRequest.isPayeePerRequest = $scope.form_data.payment.is_payee_per_request;\n            PayeePerRequest.isCompanyPaymentFormat = $scope.form_data.payment.is_company_payment_format;\n        }\n        return CustomSpecificsItemsService.showColumnByCustomSpecifics(\n            sheet,\n            column,\n            PayeePerRequest.isPayeePerRequest,\n            PayeePerRequest.isCompanyPaymentFormat,\n            payment_due_date_setting,\n        );\n    };\n\n    /**\n     * 忙聵聨莽麓掳茫聛庐茫聝聻茫聜陇茫聝聤茫聜鹿茅聡聭茅隆聧茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {Array} specifics 忙聵聨莽麓掳\n     * @return {boolean} true:茫聜篓茫聝漏茫聝录茫聛聜茫聜聤 false:茫聜篓茫聝漏茫聝录茫聛陋茫聛聴\n     */\n    function _isMinusAmountDetailError(specifics){\n        if (\n            util.isUndefinedOrNull($scope.form_data.expense.related_request) ||\n            $scope.form_data.expense.related_request_form_type !== Const.miscellaneous.FORM_TYPE_EXPENSE\n        ){\n            return false\n        }\n        for (var i = 0; i \u003c specifics.length; i++) {\n            var rows = specifics[i].request_expense_specifics_rows;\n            for (var j = 0; j \u003c rows.length; j++) {\n                // 茅聡聭茅隆聧茫聛聦忙聹陋氓\u0085楼氓聤聸茫聛戮茫聛聼茫聛炉0盲禄楼盲赂聤茫聛庐氓聽麓氓聬聢茫聙聛忙卢隆茫聛庐忙聵聨莽麓掳猫隆聦茫聛赂\n                if (util.isUndefinedOrNull(rows[j].amount) || 0 \u003c= (rows[j].amount)) continue;\n                // 茫聜炉茫聝卢茫聜赂茫聝聝茫聝聢茫聜芦茫聝录茫聝聣猫陋颅猫戮录盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n                if (util.isUndefinedOrNull(rows[j].card_id)) {\n                    return true;\n                }\n                // 茫聜炉茫聝卢茫聜赂茫聝聝茫聝聢茫聜芦茫聝录茫聝聣猫陋颅猫戮录茫聛搂盲潞聥氓聣聧莽聰鲁猫芦聥茫聛聦盲禄庐忙聣聲茫聛庐氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n                if (!util.isUndefinedOrNull($scope.related_request_expense) \u0026\u0026\n                    $scope.related_request_expense.use_suspense_payment \u0026\u0026\n                    $scope.related_request_expense.settlement_flg===\n                    Const.miscellaneous._FORM_TYPE.EXPENSE_PRE_APPLY.settlement_flg){\n                    return true;\n                }\n            }\n        }\n        return false;\n    }\n\n    /**\n     * 盲潞聥忙楼颅猫聙\u0085氓聦潞氓聢聠茫聛篓莽聶禄茅聦虏莽聲陋氓聫路茫聛庐茅聳垄茅聙拢茫聝聛茫聜搂茫聝聝茫聜炉茫聜篓茫聝漏茫聝录茫聜聮氓聢陇氓庐職茫聛聶茫聜聥\n     * @param {Object} request_form request_form\n     * @return {boolean} true:茫聝聛茫聜搂茫聝聝茫聜炉NG false:茫聝聛茫聜搂茫聝聝茫聜炉OK\n     */\n    function checkInvalidInvoiceRequestError(request_form) {\n        var has_error = false;\n\n        if (!angular.isUndefinedOrNull($scope.account_title_parts_in_req)) {\n            const account_title_parts_in_req = $scope.account_title_parts_in_req.data;\n            const _isPayeePerRequest = (\n                $scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT\n                \u0026\u0026 $scope.form_data.payment.is_payee_per_request\n            );\n            if (!$scope.isSpecificsSheet() || _isPayeePerRequest) {\n                if (angular.isUndefined(request_form.company_name)) {\n                    // 茅聺聻忙聵聨莽麓掳茫聛搂忙聰炉忙聣聲氓\u0085聢氓聬聧茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聝聛茫聜搂茫聝聝茫聜炉OK\n                    return has_error;\n                }\n\n                const qualified_business = account_title_parts_in_req[0].tax_category.qualified_business;\n                var invoice_registrated_number = null;\n                // 茅聺聻忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聛炉茫聝聛茫聜搂茫聝聝茫聜炉氓聣聧茫聛芦$invalid茫聜聮氓聢聺忙聹聼氓聦聳\n                if (!$scope.isSpecificsSheet()) {\n                    request_form.account_title_part.$invalid = false;\n                }\n                request_form.company_name.$invalid = false;\n\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    // 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐茅聺聻忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n                    invoice_registrated_number = $scope.form_data.expense.invoice_registrated_number;\n                } else {\n                    if ($scope.form_data.payment.is_new_company) {\n                        // 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐茅聺聻忙聵聨莽麓掳(忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢)茫聛庐氓聽麓氓聬聢\n                        invoice_registrated_number = $scope.form_data.payment.invoice_registrated_number_part;\n                    } else {\n                        // 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐茅聺聻忙聵聨莽麓掳(忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢)茫聛庐氓聽麓氓聬聢\n                        invoice_registrated_number = $scope.form_data.payment.invoice_registrated_number;\n                    }\n                }\n\n                if (_isInvalidInvoiceRequest(qualified_business, invoice_registrated_number)) {\n                    if (!$scope.isSpecificsSheet()) {\n                        request_form.account_title_part.$invalid = true;\n                    }\n                    request_form.company_name.$invalid = true;\n                    has_error = true;\n                }\n            }\n            if ($scope.isSpecificsSheet()) {\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    // 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n                    $scope.form_data.expense.request_expense_specifics.forEach(function(specifics, i) {\n                        specifics.request_expense_specifics_rows.forEach(function(row, j) {\n                            const item = account_title_parts_in_req.filter(function(atp) {\n                                return atp.id === row.account_title_part;\n                            });\n                            const specifics_type = specifics.specifics_type;\n                            var account_title_name = null;\n                            // 氓聢聠氓聣虏氓戮聦茫聛庐猫娄陋忙聵聨莽麓掳猫隆聦茫聛篓茫聜陇茫聝鲁茫聝聹茫聜陇茫聜鹿氓聢露氓潞娄氓炉戮氓驴聹氓聣聧茫聛庐忙聵聨莽麓掳茫聛炉氓聡娄莽聬聠茫聜聮茫聜鹿茫聜颅茫聝聝茫聝聴\n                            if (row.is_parent_specifics || angular.isUndefined(row.company_name)) {\n                                return;\n                            }\n                            if (_isInvalidInvoiceRequest(item[0].tax_category.qualified_business, row.invoice_registrated_number)) {\n                                const sheet_name = \u0027expenseSpecificsForm_{}\u0027.format(i);\n                                // 忙聣聥氓陆聯忙聵聨莽麓掳茫聛庐茫聛驴name茫聛聦莽聲掳茫聛陋茫聜聥\n                                if (specifics_type === \u0027allowance\u0027) {\n                                    account_title_name = \u0027allowance_{}_{}\u0027.format(i, j);\n                                } else {\n                                    account_title_name = \u0027account_title_part_{}_{}\u0027.format(i, j);\n                                }\n                                const company_name = \u0027company_input_{}_{}\u0027.format(i, j);\n                                request_form[sheet_name][account_title_name].$invalid = true;\n                                request_form[sheet_name][company_name].$invalid = true;\n                                has_error = true;\n                            }\n                        });\n                        specifics.validate_error = has_error;\n                    });\n                } else {\n                    // 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n                    $scope.form_data.payment.request_payment_specifics.forEach(function(specifics, i) {\n                        specifics.request_payment_specifics_rows.forEach(function(row, j) {\n                            // 莽聰鲁猫芦聥忙聸赂茫聛聰茫聛篓茫聛芦忙聰炉忙聣聲氓\u0085聢茫聜聮忙聦聡氓庐職茫聛聶茫聜聥氓聽麓氓聬聢茫聛炉茫聙聛莽漏潞猫隆聦茫聛搂茫聜聜company_name茫聛聦氓\u0085楼茫聜聥茫聛聼茫聜聛茫聙聛氓聠\u0085猫篓鲁茫聛聥茫聜聣莽聞隆茫聛聭茫聜聦茫聛掳忙卢隆茫聛庐忙聵聨莽麓掳猫隆聦茫聛芦茅聙虏茫聜聙\n                            if (util.isUndefinedOrNull(row.account_title_part)) {\n                                return;\n                            }\n                            const item = account_title_parts_in_req.filter(function(atp) {\n                                return atp.id === row.account_title_part;\n                            });\n                            if (angular.isDefined(row.company_name)\n                                \u0026\u0026 _isInvalidInvoiceRequest(\n                                    item[0].tax_category.qualified_business, row.invoice_registrated_number)) {\n                                const sheet_name = \u0027paymentSpecificsForm_{}\u0027.format(i);\n                                const account_title_name = \u0027account_title_part_{}_{}\u0027.format(i, j);\n                                const company_name = \u0027company_{}_{}\u0027.format(i, j);\n                                request_form[sheet_name][account_title_name].$invalid = true;\n                                if (!_isPayeePerRequest) {\n                                    request_form[sheet_name][company_name].$invalid = true;\n                                }\n                                has_error = true;\n                            }\n                        });\n                        specifics.validate_error = has_error;\n                    });\n                }\n            }\n        }\n        return has_error;\n    }\n\n    /**\n     * 盲潞聥忙楼颅猫聙\u0085氓聦潞氓聢聠茫聛篓莽聶禄茅聦虏莽聲陋氓聫路茫聛庐茅聳垄茅聙拢茫聝聛茫聜搂茫聝聝茫聜炉\n     * @param {Number} qualified_business 盲潞聥忙楼颅猫聙\u0085氓聦潞氓聢聠\n     * @param {string} invoice_registrated_number 莽聶禄茅聦虏莽聲陋氓聫路\n     * @return {boolean} true:茫聝聛茫聜搂茫聝聝茫聜炉NG false:茫聝聛茫聜搂茫聝聝茫聜炉OK\n     */\n    function _isInvalidInvoiceRequest(qualified_business, invoice_registrated_number) {\n        if (qualified_business === Const.miscellaneous.QUALIFIED_BUSINESS.NON_QUALIFIED_BUSINESS.id\n            \u0026\u0026 invoice_registrated_number) {\n            // 茅聛漏忙聽录猫芦聥忙卤聜忙聸赂莽聶潞猫隆聦盲潞聥忙楼颅猫聙\u0085盲禄楼氓陇聳茫聛聥茫聛陇莽聶禄茅聦虏莽聲陋氓聫路茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茫聛炉NG\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 氓聥陇忙聙聽忙聣聯氓聢禄忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴\n     * 莽碌聦猫虏禄茫聝聲茫聜漏茫聝录茫聝聽莽虏戮莽庐聴莽聰鲁猫芦聥茫聛搂茫聛聴茫聛聥盲陆驴莽聰篓茫聛聴茫聛陋茫聛聞\n     */\n    function _getAttendanceData() {\n        // 氓聥陇忙聙聽茅聙拢忙聬潞茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳茫聙聛盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if (!isUsingAttendanceLink()) {\n            return;\n        }\n\n        // 忙聹陋忙聣驴猫陋聧忙聴楼盲禄聵盲赂聙猫娄搂茫聜聮茫聝陋茫聜禄茫聝聝茫聝聢\n        if (!$scope.form_data.expense.request_expense_specifics) {\n            // 忙聵聨莽麓掳茫聛陋茫聛聴\n            $scope.un_engraving = [];\n        } else {\n            // 忙聵聨莽麓掳忙聹聣茫聜聤\n            $scope.form_data.expense.request_expense_specifics.forEach(function (sheet) {\n                sheet.un_engraving = [];\n            });\n        }\n\n        var request_user_id;\n        // 莽聰鲁猫芦聥盲驴庐忙颅拢茫聛庐氓聽麓氓聬聢茫聛炉莽聰鲁猫芦聥猫聙\u0085\n        if (!util.isUndefinedOrNull($scope.form_data.request_user)) {\n            request_user_id = $scope.form_data.request_user.id;\n        }\n        // 茫聛聺茫聜聦盲禄楼氓陇聳茫聛炉茫聝颅茫聜掳茫聜陇茫聝鲁茫聝娄茫聝录茫聜露(茫聛聜茫聜聥茫聛聞茫聛炉盲禄拢莽聬聠氓\u0085聝茫聛庐茫聝娄茫聝录茫聜露)\n        else {\n            request_user_id = $scope.login_user.id;\n        }\n        // 莽聰鲁猫芦聥氓聠\u0085茫聛庐氓聢漏莽聰篓忙聴楼茫聜聮氓聫聳氓戮聴\n        const allocation_date_list = _getAllocationDates();\n        attendanceService.getAttendanceDataByAllocationDates(\n            request_user_id,\n            allocation_date_list\n        ).then(function (result) {\n            // 氓聥陇忙聙聽茅聙拢忙聬潞茫聜篓茫聝漏茫聝录茫聝聲茫聝漏茫聜掳茫聜聮茫聛聼茫聛聼茫聜聙\n            attendance_api_error = false;\n            // 忙聣聯氓聢禄忙聝\u0085氓聽卤茫聜聮茫聜禄茫聝聝茫聝聢\n            request_attendance_snapshots = result;\n            // 忙聣聯氓聢禄忙聝\u0085氓聽卤茫聛聥茫聜聣忙聹陋忙聣聯氓聢禄茫聛庐氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂茫聜聮茫聜禄茫聝聝茫聝聢\n            _setUnEngraving();\n            // 盲禄拢莽聬聠莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聛炉氓聥陇忙聙聽忙聝\u0085氓聽卤茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛庐氓聥陇忙聙聽莽庐隆莽聬聠茫聛赂茫聛庐茫聝陋茫聝鲁茫聜炉茫聛炉猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦url茫聜聮氓聫聳茫聜聤茅聶陇茫聛聫\n            if (!util.isUndefinedOrNull($scope.requester_id) || request_user_id != $scope.login_user.id) {\n                Object.keys(request_attendance_snapshots.attendance_snapshots).forEach(function (key) {\n                    delete request_attendance_snapshots.attendance_snapshots[key].attendance_link_url;\n                });\n            }\n        }).catch(function () {\n            // 氓聥陇忙聙聽茅聙拢忙聬潞茫聜篓茫聝漏茫聝录茫聝聲茫聝漏茫聜掳茫聜聮莽芦聥茫聛娄茫聜聥\n            attendance_api_error = true;\n            // 忙聣聯氓聢禄忙聝\u0085氓聽卤氓聫聳氓戮聴茫聛芦氓陇卤忙聲聴茫聛庐茫聜篓茫聝漏茫聝录茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聜聮猫隆篓莽陇潞\n            dialogService.showConfirmDialog(\n                _(\u0027茅聙拢忙聬潞忙聝\u0085氓聽卤茫聛庐莽垄潞猫陋聧\u0027),\n                _(\u0027氓聥陇忙聙聽忙聝\u0085氓聽卤茫聛庐茅聙拢忙聬潞忙聝\u0085氓聽卤茫聛聦氓聫聳氓戮聴茫聛搂茫聛聧茫聛戮茫聛聸茫聜聯茫聛搂茫聛聴茫聛聼茫聙聜\u003cbr/\u003e茫聜赂茫聝搂茫聝聳茫聜芦茫聝鲁氓聥陇忙聙聽莽庐隆莽聬聠莽聰禄茅聺垄盲赂聤茫聛庐氓聥陇忙聙聽忙聣聯氓聢禄茫聛庐莽聤露忙\u0085聥茫聜聮茫聛聰莽垄潞猫陋聧茫聛庐盲赂聤茫聙聛莽聰鲁猫芦聥茫聜聮猫隆聦茫聛拢茫聛娄茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u0027),\n                Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP.hide,\n                Const.miscellaneous._DIALOG_OK_BUTTON_TYPE.consent\n            );\n        });\n    }\n\n    /**\n     * 莽聰鲁猫芦聥氓聠\u0085茫聛庐氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂茫聜聮氓聫聳氓戮聴\n     * @return {Array} 氓聢漏莽聰篓忙聴楼茫聛庐yyyy/mm/dd茫聝聲茫聜漏茫聝录茫聝聻茫聝聝茫聝聢忙聳聡氓颅聴氓聢聴茫聛庐盲赂聙猫娄搂\n     */\n    function _getAllocationDates() {\n        if (!$scope.form_data.expense.request_expense_specifics) {\n            // 莽聰鲁猫芦聥茫聛芦忙聵聨莽麓掳猫隆篓茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥盲赂聤茫聛庐氓聢漏莽聰篓忙聴楼茫聜聮茂录聭猫娄聛莽麓聽茫聛聽茫聛聭茫聛庐茫聝陋茫聜鹿茫聝聢茫聛篓茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢\n            return [$scope.form_data.expense.allocation_date];\n        } else {\n            // 莽聰鲁猫芦聥茫聛芦忙聵聨莽麓掳猫隆篓茫聛聦忙聹聣茫聜聥氓聽麓氓聬聢茫聙聛氓聬聞莽碌聦猫虏禄莽鲁禄忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼茫聝陋茫聜鹿茫聝聢茫聜聮氓聫聳氓戮聴\n            return _getAllocationDatesFromAllExpenseSpecifics();\n        }\n    }\n\n    /**\n     * 氓聥陇忙聙聽忙聣聯氓聢禄茅聙拢忙聬潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean}\n     */\n    function isUsingAttendanceLink() {\n        // 茫聝聴茫聝漏茫聝鲁氓聢陇氓庐職茫聛搂False茫聛庐氓聽麓氓聬聢茫聛炉茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞\n        if (!$scope.price_plan) {\n            return false;\n        }\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聛炉茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_EXPENSE ||\n            util.isUndefinedOrNull($scope.form_data.expense) ||\n            $scope.form_data.expense.settlement_flg !== Const.miscellaneous._FORM_TYPE.EXPENSE.settlement_flg\n        ) {\n            return false;\n        }\n        // 忙聴垄茫聛芦氓聥陇忙聙聽茅聙拢忙聬潞API茫聛搂茫聜篓茫聝漏茫聝录茫聛庐氓聽麓氓聬聢茫聛炉茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞\n        if (attendance_api_error) {\n            return false;\n        }\n        return (\n            atd_settings.use_attendance_record ||\n            atd_settings.use_attendance_location\n        );\n    }\n\n    /**\n     * 忙聹陋忙聣驴猫陋聧茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳猫隆篓莽陇潞\n     * @param {Array} un_engraving 忙聹陋忙聣驴猫陋聧茫聛庐忙聣聯氓聢禄忙聴楼盲赂聙猫娄搂 yyyy/mm/dd忙聸赂氓录聫茫聛庐忙聳聡氓颅聴氓聢聴\n     * @return {boolean}\n     * @private\n     */\n    function _showUnEngravingDialog(un_engraving) {\n        const title = _(\u0027茅聙拢忙聬潞忙聝\u0085氓聽卤茫聛庐莽垄潞猫陋聧\u0027);\n        const body = _(\n            \u0027盲赂聥猫篓聵茫聛庐忙聴楼盲禄聵茫聛庐忙聣聯氓聢禄忙聣驴猫陋聧茫聛聦茫聛聲茫聜聦茫聛娄茫聛聞茫聛戮茫聛聸茫聜聯茫聙聜\u003cbr/\u003e茫聛聰莽垄潞猫陋聧茫聛庐盲赂聤茫聙聛莽聰鲁猫芦聥茫聜聮猫隆聦茫聛聠氓聽麓氓聬聢茫聛炉OK茫聝聹茫聜驴茫聝鲁茫聜聮忙聤录盲赂聥茫聛聴茫聛娄茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u003cbr/\u003e茫聜颅茫聝拢茫聝鲁茫聜禄茫聝芦忙聶聜茫聛炉茫聜颅茫聝拢茫聝鲁茫聜禄茫聝芦茫聝聹茫聜驴茫聝鲁茫聜聮忙聤录盲赂聥茫聛聴茫聛娄茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u0027) + \u0027\u003cbr/\u003e\u003cbr/\u003e\u0027 +\n            _(\u0027氓炉戮猫卤隆忙聴楼\u0027) + \u0027\u003cbr/\u003e\u0027 +\n            un_engraving.join(\u0027\u003cbr/\u003e\u0027);\n        return dialogService.showConfirmDialog(title, body);\n    }\n\n    /**\n     * 忙聹陋忙聣驴猫陋聧茫聛庐氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂茫聜聮氓聫聳氓戮聴\n     * @return {Array} yyyy/mm/dd氓陆垄氓录聫茫聛庐忙聳聡氓颅聴氓聢聴茫聛庐盲赂聙猫娄搂\n     */\n    function _getUnEngraving() {\n        // 氓聥陇忙聙聽茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞茫聝聲茫聜漏茫聝录茫聝聽茫聛戮茫聛聼茫聛炉茫聙聛氓聥陇忙聙聽忙聝\u0085氓聽卤茫聛庐猫隆篓莽陇潞茫聛聦OFF茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛莽漏潞茫聛庐茅\u0085聧氓聢聴茫聛搂猫驴聰茫聛聶\n        if (!isUsingAttendanceLink() || !atd_settings.use_attendance_record) {\n            return [];\n        }\n        var request_allocation_date_list;\n        if ($scope.form_data.expense.request_expense_specifics) {\n            // 莽聰鲁猫芦聥茫聛芦忙聵聨莽麓掳猫隆篓茫聛聦忙聹聣茫聜聥氓聽麓氓聬聢茫聙聛氓聬聞莽碌聦猫虏禄莽鲁禄忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼茫聝陋茫聜鹿茫聝聢茫聜聮氓聫聳氓戮聴\n            request_allocation_date_list = _getAllocationDatesFromAllExpenseSpecifics();\n        } else {\n            // 莽聰鲁猫芦聥茫聛芦忙聵聨莽麓掳猫隆篓茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥盲赂聤茫聛庐氓聢漏莽聰篓忙聴楼茫聜聮茂录聭猫娄聛莽麓聽茫聛聽茫聛聭茫聛庐茫聝陋茫聜鹿茫聝聢茫聛篓茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢\n            request_allocation_date_list = [$scope.form_data.expense.allocation_date];\n        }\n        // 忙聹聙忙聳掳茫聝聡茫聝录茫聜驴茫聛聥茫聜聣忙聹陋忙聣驴猫陋聧茫聛陋忙聣聯氓聢禄忙聴楼茫聝陋茫聜鹿茫聝聢茫聜聮盲陆聹忙聢聬\n        return request_allocation_date_list.filter(function (key) {\n            if (util.isUndefinedOrNull(key)) {\n                return false;\n            }\n            if (!(key in request_attendance_snapshots.attendance_snapshots)) {\n                return true;\n            }\n            return request_attendance_snapshots.attendance_snapshots[key].attendance_status !=\n                Ctrans._APPROVAL_STATUS.APPROVAL_DONE.value;\n        });\n    }\n\n    /**\n     * 忙聹陋忙聣驴猫陋聧茫聛庐氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂茫聜聮茫聜禄茫聝聝茫聝聢\n     */\n    function _setUnEngraving() {\n        if (!$scope.form_data.expense.request_expense_specifics) {\n            // 忙聵聨莽麓掳茫聛陋茫聛聴\n            const key = $scope.form_data.expense.allocation_date;\n            if (!(key in request_attendance_snapshots.attendance_snapshots) ||\n                !request_attendance_snapshots.attendance_snapshots[key].attendance_status\n            ) {\n                $scope.un_engraving = [new Date($scope.form_data.expense.allocation_date)];\n            }\n            return;\n        }\n        // 忙聵聨莽麓掳忙聹聣茫聜聤\n        $scope.form_data.expense.request_expense_specifics.forEach(function (sheet) {\n            // 忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂茫聜聮氓聫聳氓戮聴\n            const allocation_date_list = _getAllocationDatesByExpenseSpecifics(sheet);\n\n            // 氓聢漏莽聰篓忙聴楼茫聛庐茅聡聧猫陇聡氓聣聤茅聶陇茫聛篓盲赂娄茫聛鲁忙聸驴茫聛聢\n            const allocation_dates_set = new Set(allocation_date_list);\n            var distinct_allocation_dates = [];\n            allocation_dates_set.forEach(function (allocation_date) {\n                distinct_allocation_dates.push(allocation_date);\n            });\n            const sorted_distinct_allocation_dates = distinct_allocation_dates.sort();\n\n            // 忙聵聨莽麓掳猫隆篓茫聛芦忙聹陋忙聣驴猫陋聧茫聛陋忙聴楼盲禄聵茫聜聮茫聜禄茫聝聝茫聝聢\n            sheet.un_engraving = sorted_distinct_allocation_dates.filter(function (date) {\n                const format_date = dateFormat.format(new Date(date), \u0027yyyy/MM/dd\u0027);\n                const snapshots = request_attendance_snapshots.attendance_snapshots;\n                const snapshotDate = snapshots[format_date];\n                if (util.isUndefinedOrNull(snapshotDate)) {\n                    return true;\n                }\n                return snapshotDate.attendance_status != Ctrans._APPROVAL_STATUS.APPROVAL_DONE.value;\n            }).map(function (date) {\n                return new Date(date);\n            });\n        });\n    }\n\n    /**\n     * 莽碌聦猫虏禄莽鲁禄忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼茫聜聮茫聝陋茫聜鹿茫聝聢茫聛搂氓聫聳氓戮聴\n     * 茅聡聧猫陇聡氓聣聤茅聶陇茫聛聴茫聛娄忙聴楼盲禄聵茅聽聠茫聛芦盲赂娄茫聛鲁忙聸驴茫聛聢茫聛聼茫聜聜茫聛庐茫聜聮猫驴聰茫聛聶\n     * allocation_date_view茫聛搂茫聛炉茫聛陋茫聛聞茫聛庐茫聛搂忙鲁篓忙聞聫\n     * @param {object} sheet\n     * @return {Array}\n     * @private\n     */\n    function _getAllocationDatesByExpenseSpecifics(sheet) {\n        return sheet.request_expense_specifics_rows.map(function (row) {\n            return row.allocation_date;\n        });\n    }\n\n    /**\n     * 氓聬聞莽碌聦猫虏禄莽鲁禄忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼(yyyy/mm/dd氓陆垄氓录聫)茫聝陋茫聜鹿茫聝聢茫聜聮盲陆聹忙聢聬\n     * @return {Array}\n     * @private\n     */\n    function _getAllocationDatesFromAllExpenseSpecifics() {\n        var all_allocation_dates = [];\n        // 氓聬聞莽碌聦猫虏禄莽鲁禄忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼茫聝陋茫聜鹿茫聝聢茫聜聮盲陆聹忙聢聬\n        $scope.form_data.expense.request_expense_specifics.forEach(function (sheet) {\n            // 忙聵聨莽麓掳猫隆篓茫聛聥茫聜聣氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂茫聜聮氓聫聳氓戮聴\n            const detail_allocation_dates = _getAllocationDatesByExpenseSpecifics(sheet);\n            all_allocation_dates = all_allocation_dates.concat(detail_allocation_dates);\n        });\n\n        // 氓聢漏莽聰篓忙聴楼茫聛庐茅聡聧猫陇聡氓聣聤茅聶陇茫聛聴茫聛娄盲赂娄茫聛鲁忙聸驴茫聛聢\n        return all_allocation_dates.filter(function (date, idx) {\n            return all_allocation_dates.indexOf(date) === idx;\n        }).map(function(allocation_date){\n            // yyyy/mm/dd氓陆垄氓录聫茫聛芦氓陇聣忙聫聸茫聛聴茫聛娄猫驴聰茫聛聶\n            return dateFormat.format(new Date(allocation_date), \u0027yyyy/MM/dd\u0027);\n        }).sort();\n    }\n\n    /**\n     * 氓聥陇忙聙聽忙聣聯氓聢禄忙聝\u0085氓聽卤茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聜聮猫隆篓莽陇潞\n     * @param {object} request_attendance_snapshots 氓聥陇忙聙聽忙聣聯氓聢禄忙聝\u0085氓聽卤\n     * @param {object} atd_settings 氓聥陇忙聙聽茅聙拢忙聬潞猫篓颅氓庐職\n     * @param {string} allocation_date_view 氓聢漏莽聰篓忙聴楼 yyyy/mm/dd\n     * @private\n     */\n    function _showAttendanceAditInformationDialog(request_attendance_snapshots, atd_settings, allocation_date_view) {\n        var request_user_id;\n        // 莽聰鲁猫芦聥盲驴庐忙颅拢茫聛庐氓聽麓氓聬聢茫聛炉莽聰鲁猫芦聥猫聙\u0085\n        if (!util.isUndefinedOrNull($scope.form_data.request_user)) {\n            request_user_id = $scope.form_data.request_user.id;\n        }\n        // 茫聛聺茫聜聦盲禄楼氓陇聳茫聛炉茫聝颅茫聜掳茫聜陇茫聝鲁茫聝娄茫聝录茫聜露(茫聛聜茫聜聥茫聛聞茫聛炉盲禄拢莽聬聠氓\u0085聝茫聛庐茫聝娄茫聝录茫聜露)\n        else {\n            request_user_id = $scope.login_user.id;\n        }\n        const params = {\n            allocation_date: new Date(allocation_date_view),\n            attendance_setting: atd_settings,\n            request_attendance_snapshot: request_attendance_snapshots,\n            request_user_id: request_user_id,\n            login_user_id: $scope.login_user.id,\n        };\n        $uibModal.open({\n            templateUrl: \u0027../static/wf/views/dialogs/show_attendance_information_templ.html\u0027,\n            controller: \u0027AttendanceAditInformationDialogController\u0027,\n            resolve: {\n                params: function () {\n                    return params;\n                },\n            },\n        });\n    }\n\n    /**\n     * 忙聣聯氓聢禄忙聝\u0085氓聽卤茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳氓聭录茫聛鲁氓聡潞茫聛聴\n     * @param {string} allocation_date_view 氓聢漏莽聰篓忙聴楼 yyyy/mm/dd\n     */\n    function showAttendanceInfoDialog(allocation_date_view) {\n        // 氓聢漏莽聰篓忙聴楼茫聛聦textlink茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聛陋茫聛聭茫聜聦茫聛掳茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛炉氓聭录茫聛鲁氓聡潞茫聛聲茫聛陋茫聛聞\n        if (!isUsingAttendanceLink()) {\n            return;\n        }\n        if (!isTextLinkAllocationDate(allocation_date_view)) {\n            return;\n        }\n        _showAttendanceAditInformationDialog(\n            request_attendance_snapshots, atd_settings, allocation_date_view\n        );\n    }\n\n    /**\n     * 忙聣聯氓聢禄忙赂聢茫聙聛忙聹陋忙聣聯氓聢禄茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean}\n     */\n    function isDisplayAttendanceApproveStatus() {\n        if (attendance_api_error) {\n            return false;\n        }\n        // 氓聥陇忙聙聽氓庐聼莽赂戮茅聙拢忙聬潞猫篓颅氓庐職茫聛聦茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞茫聛庐氓聽麓氓聬聢茫聛炉猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n        if (!atd_settings.use_attendance_record) {\n            return false;\n        }\n        if (!request_attendance_snapshots) {\n            return false;\n        }\n        return true;\n    }\n\n    /**\n     * 忙聹陋忙聣驴猫陋聧茫聜垄茫聝漏茫聝录茫聝聢茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @param {Array} un_engraving 忙聹陋忙聣驴猫陋聧茫聛陋氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂\n     * @return {boolean}\n     */\n    function isDisplayAttendanceApproveStatusAlert(un_engraving) {\n        if (attendance_api_error) {\n            return false;\n        }\n        if (util.isUndefinedOrNull(un_engraving)) {\n            return false;\n        }\n        if (!un_engraving.length) {\n            return false;\n        }\n        if (!request_attendance_snapshots) {\n            return false;\n        }\n        return atd_settings.use_attendance_record;\n    }\n\n    /**\n     * 忙聹陋忙聣驴猫陋聧茫聜垄茫聝漏茫聝录茫聝聢茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @param {Array} un_engraving 忙聹陋忙聣驴猫陋聧茫聛陋氓聢漏莽聰篓忙聴楼盲赂聙猫娄搂\n     * @param {string} allocation_date 氓聢漏莽聰篓忙聴楼 yyyy/mm/dd\n     * @return {boolean}\n     */\n    function isUnApproveAllocationDate(un_engraving, allocation_date) {\n        if (!isDisplayAttendanceApproveStatusAlert(un_engraving)) {\n            return false;\n        }\n\n        // request_attendance_snapshots茫聛炉猫陋颅茫聛驴猫戮录茫聜聙茫聜驴茫聜陇茫聝聼茫聝鲁茫聜掳茫聛聦茅聛\u0085茫聛聞茫聛庐茫聛搂莽漏潞茫聛聽茫聛拢茫聛聼茫聜聣false茫聛搂猫驴聰茫聛聶\n        if (!request_attendance_snapshots) {\n            return false;\n        }\n        if (!request_attendance_snapshots.attendance_snapshots) {\n            return false;\n        }\n        if (!(allocation_date in request_attendance_snapshots.attendance_snapshots)) {\n            return true;\n        }\n        return !request_attendance_snapshots.attendance_snapshots[allocation_date].attendance_status;\n    }\n\n    /**\n     * 茫聜掳茫聝录茫聜掳茫聝芦茫聝聻茫聝聝茫聝聴猫隆篓莽陇潞忙聶聜茫聛篓莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聜聮猫隆篓莽陇潞忙聶聜茫聛芦忙聣驴猫陋聧莽聤露忙\u0085聥茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥茫聙聜\n     * @param {string} allocation_date_view 氓聢漏莽聰篓忙聴楼 yyyy/mm/dd\n     * @return {string} 忙聣聯氓聢禄忙赂聢/忙聹陋忙聣聯氓聢禄\n     */\n    function getAttendanceStatus(allocation_date_view) {\n        if (attendance_api_error) {\n            return \u0027\u0027;\n        }\n        // 氓聥陇忙聙聽忙聝\u0085氓聽卤氓聫聳氓戮聴茫聛戮茫聛搂莽漏潞茫聛拢茫聛陆茫聛陋茫聛庐茫聛搂氓聫聳氓戮聴茫聛搂茫聛聧茫聜聥茫聛戮茫聛搂莽漏潞忙聳聡氓颅聴茫聛搂猫驴聰茫聛聶\n        if (!request_attendance_snapshots) {\n            return \u0027\u0027;\n        }\n        if (util.isUndefinedOrNull(request_attendance_snapshots.attendance_snapshots)) {\n            return \u0027\u0027;\n        }\n        // 氓聢漏莽聰篓忙聴楼茫聛芦氓炉戮氓驴聹茫聛聶茫聜聥忙聣聯氓聢禄忙聝\u0085氓聽卤茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉\u0027忙聹陋忙聣聯氓聢禄\u0027\n        if (!(allocation_date_view in request_attendance_snapshots.attendance_snapshots)) {\n            return _(Ctrans._APPROVAL_STATUS.APPROVAL_NOT.name);\n        }\n        return attendanceService.getAttendanceApprovalStatus(\n            request_attendance_snapshots.attendance_snapshots[allocation_date_view].attendance_status);\n    }\n\n    /**\n     * 茫聝聴茫聝漏茫聝鲁茫聛聦茅聛漏莽聰篓茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥盲赂聰茫聛陇茫聙聛氓聥陇忙聙聽茅聙拢忙聬潞茫聛聦true盲赂聰茫聛陇茫聙聛忙聣驴猫陋聧莽聤露忙\u0085聥茫聛聦莽漏潞茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢\n     * 茫聛戮茫聛聼茫聛炉茫聝聴茫聝漏茫聝鲁茫聛聦茅聛漏莽聰篓茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥盲赂聰茫聛陇茫聙聛忙聣聯氓聢禄忙聝\u0085氓聽卤茫聛聦true盲赂聰茫聛陇茫聙聛忙聣驴猫陋聧莽聤露忙\u0085聥茫聛聦莽漏潞茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢茫聛庐茫聛驴茫聝陋茫聝鲁茫聜炉茫聜聮忙聹聣氓聤鹿茫聛芦茫聛聶茫聜聥\n     * @param {string} allocation_date yyyy/mm/dd\n     * @return {boolean}\n     */\n    function isTextLinkAllocationDate(allocation_date) {\n        var result = false;\n        // 氓聥陇忙聙聽茅聙拢忙聬潞氓聫炉猫聝陆茫聛陋茫聝聴茫聝漏茫聝鲁茫聛聵茫聜聝茫聛陋茫聛聭茫聜聦茫聛掳茫聝陋茫聝鲁茫聜炉氓聦聳茫聛聴茫聛陋茫聛聞\n        if (!$scope.price_plan) {\n            return false;\n        }\n        if (attendance_api_error) {\n            return false;\n        }\n        // request_attendance_snapshots茫聛炉猫陋颅茫聛驴猫戮录茫聜聙茫聜驴茫聜陇茫聝聼茫聝鲁茫聜掳茫聛聦茅聛\u0085茫聛聞茫聛庐茫聛搂莽漏潞茫聛聽茫聛拢茫聛聼茫聜聣false茫聛搂猫驴聰茫聛聶\n        if (!request_attendance_snapshots) {\n            return false;\n        }\n        if (!request_attendance_snapshots.attendance_snapshots) {\n            return false;\n        }\n        // 氓聢漏莽聰篓忙聴楼茫聛芦氓炉戮氓驴聹茫聛聶茫聜聥忙聣聯氓聢禄忙聝\u0085氓聽卤茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉茫聝陋茫聝鲁茫聜炉氓聦聳茫聛聴茫聛陋茫聛聞\n        if (!(allocation_date in request_attendance_snapshots.attendance_snapshots)) {\n            return false;\n        }\n        if (atd_settings.use_attendance_record){\n            result = true;\n        }\n        if (allocation_date in request_attendance_snapshots.attendance_snapshots_gps \u0026\u0026\n            request_attendance_snapshots.attendance_snapshots_gps[allocation_date].length) {\n            result = true;\n        }\n        return result;\n    }\n\n    /**\n     * 忙聰炉忙聣聲氓\u0085聢氓\u0085楼氓聤聸茅聽\u0085莽聸庐茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean} True: 猫隆篓莽陇潞茫聛聶茫聜聥 False: 猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n     */\n    $scope.isVisibleCounterPartyInputItem = function () {\n        return canEditForm() \u0026\u0026 $scope.form_data.payment.is_allowed_edit_payee;\n    };\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录 忙聰炉忙聣聲氓\u0085聢茫聛庐氓聫聳氓录聲氓\u0085聢茫聛庐盲陆聫忙聣聙忙聝\u0085氓聽卤茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean} true: 猫隆篓莽陇潞茫聛聶茫聜聥, false: 猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n     */\n    $scope.isDisplayPaymentCompanyAddress = function(){\n        if (util.isUndefinedOrNull($scope.form_data)){\n            return false;\n        }\n        if (util.isUndefinedOrNull($scope.form_data.payment)){\n            return false;\n        }\n        return (\n            $scope.form_data.payment.company_name\n            \u0026\u0026 $scope.form_data.payment.is_show_address\n        );\n    };\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录 忙聰炉忙聣聲氓\u0085聢茫聛庐氓聫聳氓录聲氓\u0085聢茫聛庐忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean} true: 猫隆篓莽陇潞茫聛聶茫聜聥, false: 猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n     */\n    $scope.isDisplayPaymentCompanyPayee = function () {\n        if (util.isUndefinedOrNull($scope.form_data)) {\n            return false;\n        }\n        if (util.isUndefinedOrNull($scope.form_data.payment)) {\n            return false;\n        }\n        return (\n            $scope.form_data.payment.company_name\n            \u0026\u0026 ($scope.isDisplayBank || $scope.isModifyStep)\n            \u0026\u0026 $scope.form_data.payment.is_show_payee\n        );\n    };\n\n    /**\n     * br茫聜驴茫聜掳茫聜聮忙聰鹿猫隆聦忙聳聡氓颅聴茫聛芦氓陇聣忙聫聸茫聛聴茫聛娄猫驴聰茫聛聶\n     * @param {string} note\n     * @return {string}\n     */\n    $scope.convertLineBreak = (note) =\u003e {\n        if (util.isUndefinedOrNull(note)) {\n            return note;\n        }\n        return FormService.convertLineBreak(note, false);\n    };\n\n    /**\n     * 忙聰炉忙聣聲氓\u0085聢茫聛庐氓\u0085楼氓聤聸莽聤露忙\u0085聥茫聛篓茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聲麓氓聬聢忙聙搂茫聛聦盲驴聺茫聛拢茫聛娄茫聛聞茫聜聥茫聛聥莽垄潞猫陋聧(忙聰炉忙聣聲茫聝聲茫聜漏茫聝录茫聝聽莽聰篓)\n     * 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛聦茅聛赂忙聤聻忙赂聢茫聛驴茫聛陋茫聜聣茫聙聛盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐忙聰炉忙聣聲莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聛聥茫聜聣莽垄潞猫陋聧茫聛聶茫聜聥\n     * @param {boolean} is_allowed_edit_payee 莽聫戮氓聹篓茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄\n     * @private\n     */\n    function _validatePayeeAndFormSettingForPayment(is_allowed_edit_payee) {\n        // 忙聰炉忙聣聲茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            return;\n        }\n        if (util.isUndefinedOrNull($scope.form_data.payment.pre_request)) {\n            _checkPayeeAndFormSettingForPayment(is_allowed_edit_payee);\n        } else {\n            RequestService.getRequestPayment($scope.form_data.payment.pre_request).then((response) =\u003e {\n                $scope.pre_data = response.data;\n                _checkPayeeAndFormSettingForPayment(is_allowed_edit_payee);\n            });\n        }\n    }\n\n    /**\n     * 氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聛聦莽聫戮氓聹篓茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聶聜茫聛篓莽聲掳茫聛陋茫聜聥氓聽麓氓聬聢茫聙聛盲潞聥氓聣聧莽聰鲁猫芦聥茫聜聞忙聰炉忙聣聲氓\u0085聢茫聛庐茫聜炉茫聝陋茫聜垄茫聛篓茫聝聲茫聝漏茫聝聝茫聜路茫聝楼茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥\n     * 盲赂聥忙聸赂茫聛聧莽路篓茅聸聠茫聜聞莽聰鲁猫芦聥茫聜鲁茫聝聰茫聝录茫聛搂茅聳聥茫聛聞茫聛聼茅職聸茫聛芦猫隆聦茫聛聠\n     * @param {boolean} is_allowed_edit_payee 莽聫戮氓聹篓茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄\n     */\n    function _checkPayeeAndFormSettingForPayment(is_allowed_edit_payee) {\n        // 氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聛庐猫篓颅氓庐職氓聙陇茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛茫聙聦猫篓卤氓聫炉茫聛聶茫聜聥茫聙聧茫聛篓茫聛聴茫聛娄氓聢陇氓庐職茫聙聛茫聛聜茫聜聥氓聽麓氓聬聢茫聛炉茫聙聛茫聛聺茫聛庐猫篓颅氓庐職氓聙陇茫聜聮猫娄聥茫聜聥\n        const before_is_allowed_edit_payee = (\n            util.isUndefinedOrNull($scope.form_data.payment.before_is_allowed_edit_payee)\n                ? true : $scope.form_data.payment.before_is_allowed_edit_payee\n        );\n        // 盲赂聥忙聸赂茫聛聧莽路篓茅聸聠茫聜聞莽聰鲁猫芦聥茫聜鲁茫聝聰茫聝录忙聶聜茫聛芦茫聙聛氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聛聦莽聫戮氓聹篓茫聛庐茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐忙聶聜茫聛篓莽聲掳茫聛陋茫聜聥氓聽麓氓聬聢\n        if (before_is_allowed_edit_payee === is_allowed_edit_payee) {\n            return;\n        }\n        // 茫聝聲茫聝漏茫聝聝茫聜路茫聝楼茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聛篓忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤茫聛庐茫聜炉茫聝陋茫聜垄茫聜聮猫隆聦茫聛聠\n        notifyService.showNotify(\n            gettextCatalog.getString(\u0027茫聝聲茫聜漏茫聝录茫聝聽茫聛庐茅聽\u0085莽聸庐茫聛聦氓陇聣忙聸麓茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聼茫聜聛茫聙聛盲赂聙茅聝篓茫聛庐茅聽\u0085莽聸庐茫聛炉茫聜鲁茫聝聰茫聝录茫聛聲茫聜聦茫聛戮茫聛聸茫聜聯茫聛搂茫聛聴茫聛聼\u0027),\n            \u0027alert-danger\u0027\n        );\n\n        // 忙聰炉忙聣聲氓\u0085聢茫聛庐茫聜炉茫聝陋茫聜垄\n        // 忙聰炉忙聣聲氓\u0085聢茫聛聦茫聝聵茫聝聝茫聝聙茫聝录茫聛芦茫聛聜茫聜聥氓聽麓氓聬聢\n        const isPayeeInHeader = !$scope.isSpecificsSheet() || $scope.form_data.payment.is_payee_per_request;\n        if (isPayeeInHeader) {\n            _clearPayeeForPayment($scope.form_data.payment);\n        }\n        // 忙聰炉忙聣聲氓\u0085聢茫聛聦忙聵聨莽麓掳猫隆聦茫聛芦茫聛聜茫聜聥氓聽麓氓聬聢\n        else {\n            $scope.form_data.payment.request_payment_specifics.forEach((sheet) =\u003e {\n                sheet.request_payment_specifics_rows.forEach((row) =\u003e {\n                    _clearPayeeForPayment(row);\n                });\n            });\n        }\n\n        // 氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茂录職猫篓卤氓聫炉茫聛聴茫聛陋茫聛聞茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聛娄茫聙聛茫聛陋茫聛聤茫聛聥茫聛陇茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥盲潞聥氓聣聧莽聰鲁猫芦聥茫聛聦茅聛赂忙聤聻盲赂聧氓聫炉猫聝陆茫聛庐氓聽麓氓聬聢茫聙聛盲潞聥氓聣聧莽聰鲁猫芦聥茫聜聮茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n        if (\n            !$scope.form_data.payment.is_allowed_edit_payee\n            \u0026\u0026 !util.isUndefinedOrNull($scope.form_data.payment.pre_request)\n        ) {\n            // 茅聛赂忙聤聻氓聫炉猫聝陆茫聛陋盲潞聥氓聣聧莽聰鲁猫芦聥茫聛陋茫聛庐茫聛聥氓聢陇氓庐職\n            const isUsablePreRequestForPayment = _isUsablePreRequestForPayment();\n            if (!isUsablePreRequestForPayment) {\n                // 盲潞聥氓聣聧莽聰鲁猫芦聥茫聜聮茫聜炉茫聝陋茫聜垄\n                $scope.form_data.payment.pre_request = null;\n                $scope.form_data.payment.pre_request_view_id = null;\n                $scope.form_data.payment.pre_request_title = null;\n                $scope.form_data.payment.pre_request_cuid = null;\n                $scope.form_data.payment.related_request_payee = null;\n\n                // 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐猫颅娄氓聭聤茫聙聛茫聜篓茫聝漏茫聝录茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聝聲茫聝漏茫聜掳茫聜聮茫聜炉茫聝陋茫聜垄\n                $scope.form_data.payment.alert_limited_companies = false;\n                $scope.form_data.payment.error_not_allowed_new_company = false;\n                $scope.form_data.payment.error_un_match_payment_format = false;\n            } else {\n                // 茅聛赂忙聤聻氓聫炉猫聝陆茫聛陋盲潞聥氓聣聧莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聙聛猫颅娄氓聭聤茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聛庐猫隆篓莽陇潞茫聝聲茫聝漏茫聜掳茫聜聮莽芦聥茫聛娄茫聜聥\n                $scope.form_data.payment.alert_limited_companies = true;\n            }\n        }\n\n        // 氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茂录職猫篓卤氓聫炉茫聛聶茫聜聥茫聛芦茫聛陋茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛猫颅娄氓聭聤茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聛庐猫隆篓莽陇潞茫聝聲茫聝漏茫聜掳茫聜聮莽聲鲁茫聜聙\n        if ($scope.form_data.payment.is_allowed_edit_payee) {\n            $scope.form_data.payment.alert_limited_companies = false;\n        }\n    }\n\n    /**\n     * 茫聝聵茫聝聝茫聝聙茫聝录茅聝篓氓聢聠茫聛庐忙聰炉忙聣聲氓\u0085聢茫聛庐氓聫聳氓录聲氓\u0085聢茫聛篓忙聰炉忙聣聲氓\u0085聢茫聝娄茫聝录茫聜露茫聜聮茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n     * @param {object} paymentData\n     * @private\n     */\n    function _clearPayeeForPayment(paymentData) {\n        // 茫聝聵茫聝聝茫聝聙茫聝录茅聝篓氓聢聠茫聛庐忙聰炉忙聣聲氓\u0085聢茫聛庐氓聫聳氓录聲氓\u0085聢茫聛篓忙聰炉忙聣聲氓\u0085聢茫聝娄茫聝录茫聜露茫聜聮茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n        if (util.isUndefinedOrNull(paymentData)) {\n            return;\n        }\n        // 氓聫聳氓录聲氓\u0085聢\n        // 忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢莽聶禄茅聦虏莽聰篓茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦氓聫聳氓录聲氓\u0085聢茫聜鲁茫聝录茫聝聣茫聛庐氓\u0085楼氓聤聸忙卢聞茫聛聦茫聛陋茫聛聞茫聛聼茫聜聛company_code茫聛庐氓聢聺忙聹聼氓聦聳茫聛炉盲赂聧猫娄聛\n        paymentData.is_new_company = false;\n        delete paymentData.company_id;\n        delete paymentData.company_name;\n        delete paymentData.company_code;\n        delete paymentData.zip_code;\n        delete paymentData.address;\n        delete paymentData.bank_code;\n        delete paymentData.bank_name;\n        delete paymentData.bank_name_kana;\n        delete paymentData.branch_code;\n        delete paymentData.branch_name;\n        delete paymentData.branch_name_kana;\n        delete paymentData.bank_account_type_code;\n        delete paymentData.bank_account_type_name;\n        delete paymentData.bank_account_code;\n        delete paymentData.bank_account_name_kana;\n        delete paymentData.is_manual_input;\n        delete paymentData.invoice_registrated_number;\n        delete paymentData.invoice_registrated_number_part;\n        delete paymentData.is_valid_invoice_registrated_number;\n        delete paymentData.invoice_check_result;\n\n        // 忙聰炉忙聣聲氓\u0085聢茫聝娄茫聝录茫聜露\n        delete paymentData.payee_user;\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录莽聰鲁猫芦聥茫聛搂茅聛赂忙聤聻氓聫炉猫聝陆茫聛陋盲潞聥氓聣聧莽聰鲁猫芦聥茫聛陋茫聛庐茫聛聥氓聢陇氓庐職\n     * @return {boolean} true: 茅聛赂忙聤聻氓聫炉猫聝陆, false: 茅聛赂忙聤聻盲赂聧氓聫炉\n     */\n    function _isUsablePreRequestForPayment() {\n        // 忙聰炉忙聣聲茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉 茅聛赂忙聤聻氓聫炉猫聝陆 茫聛搂猫驴聰茫聛聶\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            return true;\n        }\n\n        if (!$scope.isSpecificsSheet() || $scope.form_data.payment.is_payee_per_request) {\n            // 忙聰炉忙聣聲氓\u0085聢茫聛聦茫聝聵茫聝聝茫聝聙茫聝录茫聛芦茫聛聜茫聜聥氓聽麓氓聬聢\n            if (!_isSingleCounterPartyInCustomSpecifics()) {\n                // 盲潞聥氓聣聧莽聰鲁猫芦聥忙聸赂氓聠\u0085茫聛庐忙聰炉忙聣聲氓\u0085聢茫聛聦猫陇聡忙聲掳茫聛庐茫聛篓茫聛聧\n                return false;\n            }\n\n            // 盲戮聺茅聽录莽聰鲁猫芦聥茫聛聦茫聙聦氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聙聧茫聛聦茫聙聦猫篓卤氓聫炉茫聛聴茫聛陋茫聛聞茫聙聧茫聛搂\n            // 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛篓盲戮聺茅聽录莽聰鲁猫芦聥茫聛搂忙聵聨莽麓掳茫聛庐氓陆垄氓录聫茫聛聦盲赂聙猫聡麓茫聛聴茫聛陋茫聛聞 茫聜聜茫聛聴茫聛聫茫聛炉 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛炉茫聝聵茫聝聝茫聝聙茫聝录茫聛芦忙聰炉忙聣聲氓\u0085聢茫聛聦莽聞隆茫聛聞猫篓颅氓庐職茫聛庐氓聽麓氓聬聢茫聛炉茫聜篓茫聝漏茫聝录\n            const isMatchFormatPayment = (\n                $scope.form_data.payment.is_company_payment_format === $scope.pre_data.is_company_payment_format\n                \u0026\u0026 $scope.form_data.payment.is_user_payment_format === $scope.pre_data.is_user_payment_format\n            );\n            // 盲潞聥氓聣聧莽聰鲁猫芦聥茫聛炉茫聝聵茫聝聝茫聝聙茫聝录茫聛芦忙聰炉忙聣聲氓\u0085聢茫聛聦茫聛聜茫聜聥猫篓颅氓庐職茫聛陋茫聛庐茫聛聥\n            const isExistsHeaderPayeeByRelatedRequest = (\n                $scope.pre_data.request_payment_specifics.length === 0\n                || $scope.pre_data.is_payee_per_request\n            );\n            if (\n                !$scope.form_data.payment.is_allowed_edit_payee\n                \u0026\u0026 (\n                    !isMatchFormatPayment\n                    || !isExistsHeaderPayeeByRelatedRequest\n                )\n            ) {\n                return false;\n            }\n        }\n        // 茫聛聞茫聛職茫聜聦茫聛聥茫聛庐忙聺隆盲禄露茫聜聮忙潞聙茫聛聼茫聛聶氓聽麓氓聬聢茫聙聛茫聜篓茫聝漏茫聝录\n        // 猫禄垄猫篓聵茫聛聶茫聜聥盲潞聥氓聣聧莽聰鲁猫芦聥茫聛芦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛聦茫聛聜茫聜聤茫聙聛盲戮聺茅聽录莽聰鲁猫芦聥茫聛庐茫聙聦氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聙聧茫聛聦茫聙聦猫篓卤氓聫炉茫聛聴茫聛陋茫聛聞茫聙聧茫聛搂茫聛聜茫聜聥\n        // 猫禄垄猫篓聵茫聛聶茫聜聥盲潞聥氓聣聧莽聰鲁猫芦聥茫聛芦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛聦茫聛聜茫聜聤茫聙聛盲戮聺茅聽录莽聰鲁猫芦聥茫聛庐茫聙聦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛庐氓\u0085楼氓聤聸茫聙聧茫聛聦茫聙聦猫篓卤氓聫炉茫聛聴茫聛陋茫聛聞茫聙聧茫聛搂茫聛聜茫聜聥\n        const isExistsNewCompany = _hasNewCompanyInCopyRequest();\n        if (isExistsNewCompany\n            \u0026\u0026 (\n                !$scope.form_data.payment.is_allowed_edit_payee\n                || !$scope.form_data.is_allowed_new_company\n            )\n        ) {\n            return false;\n        }\n        return true;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥忙聸赂氓\u0085篓盲陆聯茫聛搂忙聰炉忙聣聲氓\u0085聢or茫聝娄茫聝录茫聜露茫聛聥氓聧聵盲赂聙茫聛搂茫聛聜茫聜聥茫聛聥氓聢陇氓庐職\n     * 氓聢陇氓庐職茫聛聶茫聜聥忙聵聨莽麓掳茫聛炉茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐茫聛驴茫聛搂忙聴垄氓庐職忙聵聨莽麓掳茫聛炉氓炉戮猫卤隆氓陇聳\n     * @return {boolean} true: 忙聰炉忙聣聲氓\u0085聢茫聛聦茫聛虏茫聛篓茫聛陇茫聙聛false: 忙聰炉忙聣聲氓\u0085聢茫聛聦猫陇聡忙聲掳\n     * @private\n     */\n    function _isSingleCounterPartyInCustomSpecifics() {\n        // 忙聵聨莽麓掳猫隆篓茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉忙聰炉忙聣聲氓\u0085聢茫聛聦1茫聛陇茫聛芦茫聛陋茫聜聥\n        if ($scope.pre_data.request_payment_specifics.length === 0) {\n            return true;\n        }\n        // 莽聰鲁猫芦聥忙聸赂茫聛聰茫聛篓茫聛芦忙聰炉忙聣聲氓\u0085聢茫聜聮忙聦聡氓庐職茫聛聶茫聜聥氓聽麓氓聬聢茫聛炉忙聰炉忙聣聲氓\u0085聢茫聛聦盲赂聙茫聛陇茫聛芦茫聛陋茫聜聥\n        if ($scope.pre_data.is_payee_per_request) {\n            return true;\n        }\n\n        // 忙聵聨莽麓掳猫隆篓茫聛聦茫聛聜茫聜聤茫聙聛莽聰鲁猫芦聥忙聸赂茫聛聰茫聛篓茫聛芦忙聰炉忙聣聲氓\u0085聢茫聜聮忙聦聡氓庐職茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛猫陇聡忙聲掳忙聰炉忙聣聲氓\u0085聢茫聛篓茫聛聶茫聜聥\n        return false;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥忙聸赂氓聠\u0085茫聛芦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛聦茫聛聜茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean} true:忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛聜茫聜聤 false:忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛陋茫聛聴\n     * @private\n     */\n    function _hasNewCompanyInCopyRequest() {\n        // 茫聙聦忙聵聨莽麓掳茫聛陋茫聛聴茫聙聧茫聙聦1莽聰鲁猫芦聥1忙聰炉忙聣聲氓\u0085聢茫聙聧茫聛庐茫聛篓茫聛聧\n        if (\n            $scope.pre_data.request_payment_specifics.length === 0\n            || $scope.pre_data.is_payee_per_request\n        ) {\n            return $scope.pre_data.is_new_company;\n        }\n        // 茫聙聦忙聵聨莽麓掳茫聛聜茫聜聤 1莽聰鲁猫芦聥猫陇聡忙聲掳忙聰炉忙聣聲氓\u0085聢茫聙聧茫聛庐茫聛篓茫聛聧\n        const SPECIFICS_ITEM_CODE_COMPANY_NAME = Const.miscellaneous.SPECIFICS_ITEM.PAYMENT.NORMAL.COMPANY_NAME.key;\n        const hasNewCompany = $scope.pre_data.request_payment_specifics.filter((sheet) =\u003e {\n            // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐茫聛驴氓炉戮猫卤隆\n            return (\n                CustomSpecificsService.isCustomSpecifics(sheet)\n                || sheet.specifics_type === Const.miscellaneous.CUSTOM_SPECIFICS\n            );\n        }).some((custom_specific_sheet) =\u003e {\n            return custom_specific_sheet.request_custom_specific.some((row) =\u003e {\n                return row.request_custom_specific_cells.filter((cell) =\u003e {\n                    // 忙聰炉忙聣聲氓\u0085聢氓聬聧茫聜聮氓炉戮猫卤隆\n                    return cell.custom_specific_item.specific_item_code === SPECIFICS_ITEM_CODE_COMPANY_NAME;\n                }).some((company_name_cell) =\u003e {\n                    return company_name_cell.value.is_new_company;\n                });\n            });\n        });\n        return hasNewCompany;\n    }\n}\n",
                  "form_item_services.js":  "\u0027use strict\u0027;\n\nangular.module(\u0027WfApp.create_request_services\u0027)\n    .factory(\u0027CreateRequestFormItemService\u0027, CreateRequestFormItemService);\n\nfunction CreateRequestFormItemService(Const, $rootScope) {\n    return {\n        getSelectItemLabelsData: getSelectItemLabelsData,\n        clearSelectRequest: clearSelectRequest,\n        clearCompany: clearCompany,\n        clearUser: clearUser,\n        clearFormGroup: clearFormGroup,\n        clearFormProject: clearFormProject,\n        clearFormTableGroup: clearFormTableGroup,\n        clearGenericMasterRecord: clearGenericMasterRecord,\n        clearTime: clearTime,\n        initFormItem: initFormItem,\n        makeMappedItems: makeMappedItems,\n    };\n\n    // TODO: form_item茫聜聮茫聝芦茫聝录茫聝聴茫聛聶茫聜聥氓驴\u0085猫娄聛茫聛炉茫聛陋茫聛聲茫聛聺茫聛聠茫聙聜茫聜鲁茫聝鲁茫聝聢茫聝颅茫聝录茫聝漏茫聛聥茫聜聣茫聛聺茫聛庐茫聛戮茫聛戮莽搂禄忙陇聧茫聛聴茫聛聼茫聛庐茫聛搂茫聙聛茫聛聜茫聛篓茫聛搂茫聝陋茫聝聲茫聜隆茫聜炉茫聜驴茫聝陋茫聝鲁茫聜掳\n    function getSelectItemLabelsData(form_item) {\n        angular.forEach(form_item, function(value, key) {\n            if (key == \"select_item_labels\") {\n                var arr = value.split(/\\r\\n|\\r|\\n/);\n                form_item.select_item_labels = arr;\n                // 茫聝漏茫聜赂茫聜陋茫聝聹茫聜驴茫聝鲁茫聛庐氓聽麓氓聬聢茫聛炉氓聢聺忙聹聼氓聙陇茫聜聮猫篓颅氓庐職\n                if (form_item.item_type === Const.form.ITEM_TYPE_RADIO) {\n                    form_item.custom_radio = arr[0];\n                    form_item.request_content = arr[0];\n                }\n                // 茫聝聛茫聜搂茫聝聝茫聜炉茫聝聹茫聝聝茫聜炉茫聜鹿茫聛庐氓聽麓氓聬聢茫聛炉object茫聛芦氓陇聣忙聫聸茫聛聴茫聙聛checked茫聛篓label茫聜聮猫篓颅氓庐職\n                if (form_item.item_type === Const.form.ITEM_TYPE_CHECK) {\n                    form_item.select_item_labels_obj = [];\n                    angular.forEach(form_item.select_item_labels, function(item ,j) {\n                        // label 茫聛篓 checked茫聛庐盲潞聦茫聛陇茫聛庐氓卤聻忙聙搂茫聜聮忙聦聛茫聛陇茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛芦氓陇聣忙聫聸\n                        form_item.select_item_labels_obj[j] = {};\n                        form_item.select_item_labels_obj[j].label = form_item.select_item_labels[j];\n                        form_item.select_item_labels_obj[j].checked = false;\n                    });\n                }\n            }\n        });\n        return form_item\n    }\n\n    function clearSelectRequest(form_item) {\n        form_item.request_id = null;\n        form_item.request_title = null;\n        form_item.request_content = null;\n        if (angular.isDefined(form_item.request_content_json)){\n            form_item.request_content_json = {};\n        }\n        form_item.is_cleared = true;\n    }\n\n    /**\n     * 茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聛庐氓聫聳氓录聲氓\u0085聢茫聛庐氓\u0085楼氓聤聸忙聝\u0085氓聽卤茫聜聮茫聜炉茫聝陋茫聜垄茫聛聶茫聜聥\n     * @param {object} form_item 茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聛庐氓聫聳氓录聲氓\u0085聢茅聛赂忙聤聻\n     */\n    function clearCompany(form_item) {\n        form_item.custom_company = \u0027\u0027;\n        form_item.request_content = \u0027\u0027;\n        form_item.is_cleared = true;\n\n        delete form_item.company_id;\n    }\n\n    function clearUser(form_item) {\n        form_item.custom_user = \"\";\n        form_item.request_content = \"\";\n        delete form_item.request_content_json;\n        form_item.is_cleared = true;\n    }\n\n    function clearFormGroup(form_item) {\n        form_item.custom_group = \"\";\n        form_item.request_content = \"\";\n        delete form_item.request_content_json;\n        form_item.is_cleared = true;\n    }\n    \n    function clearFormProject(form_item) {\n        form_item.custom_project = \"\";\n        form_item.request_content = \"\";\n        form_item.request_content_json = {};\n        form_item.is_cleared = true;\n    }\n    \n    function clearFormTableGroup(table_cell, select_type) {\n        if (select_type === \"single\") {\n            table_cell.value = \"\";\n        } else {\n            delete table_cell.value;\n        }\n    }\n\n    function clearGenericMasterRecord(form_item) {\n        form_item.generic_master_record_name = \u0027\u0027;\n        form_item.generic_master_record_code = \u0027\u0027;\n        form_item.items = \u0027\u0027; // 茫聜芦茫聜鹿茫聜驴茫聝聽茫聝卢茫聜鲁茫聝录茫聝聣茅聽\u0085莽聸庐\n        form_item.content = \u0027\u0027;\n        form_item.request_content = \u0027\u0027;\n        if (angular.isDefined(form_item.request_content_json)){\n            form_item.request_content_json = {};\n        }\n        form_item.is_cleared = true;\n    }\n\n    function clearTime(form_item) {\n        // 盲赂聧忙颅拢茫聛陋氓\u0085楼氓聤聸氓聙陇茫聛庐氓聽麓氓聬聢茫聛炉null茫聜炉茫聝陋茫聜垄氓聡潞忙聺楼茫聛陋茫聛聞茫聛庐茫聛搂茫聙聛盲赂聙忙聴娄00:00茫聜聮盲禄拢氓\u0085楼茫聛聴茫聛娄茫聛聥茫聜聣茫聜炉茫聝陋茫聜垄\n        form_item.time = new Date(\u00271970/01/01 00:00:00\u0027);\n        $rootScope.$apply();\n        form_item.time = null;\n\n        form_item.request_content = null;\n        form_item.is_cleared = true;\n    }\n\n    /**\n     * 茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐茫聛庐氓聢聺忙聹聼氓聦聳氓聡娄莽聬聠\n     * @param {Object} form_json\n     * @return {Object}\n     */\n    function initFormItem(form_json) {\n        angular.forEach(form_json, function(record, i) {\n            // select_item_labels茫聛聦氓聬芦茫聛戮茫聜聦茫聜聥氓聽麓氓聬聢茫聙聛忙聰鹿猫隆聦茫聛搂茫聝聭茫聝录茫聜鹿茫聛聴茫聛娄Array茫聛芦氓陇聣忙聫聸茫聛聶茫聜聥\n            form_json[i] = getSelectItemLabelsData(record);\n\n            if (record.item_type === Const.form.ITEM_TYPE_TIME) {\n                // 忙聶聜氓聢禄茅聽\u0085莽聸庐茫聛炉null茫聛搂氓聢聺忙聹聼氓聦聳\n                form_json[i].time = null;\n            }\n            else if (record.item_type === Const.form.ITEM_TYPE_CHECK) {\n                // 茫聝聛茫聜搂茫聝聝茫聜炉茫聝聹茫聝聝茫聜炉茫聜鹿茫聛炉茫聙聛氓\u0085楼氓聤聸氓聠\u0085氓庐鹿茫聜聮莽漏潞忙聳聡氓颅聴茫聛搂氓聢聺忙聹聼氓聦聳\n                form_json[i].request_content = \u0027\u0027;\n            }\n        });\n        return form_json;\n    }\n\n    /**\n     * 莽碌聦猫路炉氓聢聠氓虏聬茫聛篓茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛庐氓聢陇氓庐職茫聛芦盲陆驴茫聛聠茫聙聛盲赂聥猫篓聵茫聛庐氓陆垄茫聛庐茅聙拢忙聝鲁茅\u0085聧氓聢聴茫聜聮盲陆聹忙聢聬茫聛聶茫聜聥\n     * {form_item.id: form_item茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢}\n     * @param {Array.\u003cObject\u003e} form_items 茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛庐茅\u0085聧氓聢聴\n     * @return {Object} key茫聛聦茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聛庐ID, value茫聛聦茫聝聲茫聝陋茫聝录茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聛庐茅聙拢忙聝鲁茅\u0085聧氓聢聴\n     */\n    function makeMappedItems(form_items) {\n        var mapped_items = {};\n        angular.forEach(form_items, function(form_item) {\n            mapped_items[form_item.id] = form_item;\n        });\n        return mapped_items;\n    }\n}\n",
                  "request_new_controllers.js":  "\u0027use strict\u0027;\n\nangular.module(\u0027WfApp.create_request_controllers\u0027)\n    .controller(\u0027requestNewCtrl\u0027, requestNewCtrl);\n\nrequestNewCtrl.$inject = [\n    \u0027$http\u0027,\n    \u0027$location\u0027,\n    \u0027$rootScope\u0027,\n    \u0027$routeParams\u0027,\n    \u0027$scope\u0027,\n    \u0027$uibModal\u0027,\n    \u0027Const\u0027,\n    \u0027dialogService\u0027,\n    \u0027loginUserService\u0027,\n    \u0027permissionService\u0027,\n    \u0027planService\u0027,\n    \u0027searchParamsService\u0027,\n];\n\n/**\n * @param {object} $http\n * @param {object} $location\n * @param {object} $rootScope\n * @param {object} $routeParams\n * @param {object} $scope\n * @param {object} $uibModal\n * @param {object} Const\n * @param {object} dialogService\n * @param {object} loginUserService\n * @param {object} permissionService\n * @param {object} planService\n * @param {object} searchParamsService\n */\nfunction requestNewCtrl(\n    $http,\n    $location,\n    $rootScope,\n    $routeParams,\n    $scope,\n    $uibModal,\n    Const,\n    dialogService,\n    loginUserService,\n    permissionService,\n    planService,\n    searchParamsService\n) {\n    $scope.requester_id = $routeParams.requester_id;\n    $scope.search_params = {};\n    $scope.search_params.search_text = searchParamsService.request_form_list_search_params.search_text;\n    $scope.select_category = searchParamsService.request_form_list_search_params.select_category;\n    $scope.plan = loginUserService.login_user.wf_plan;\n    $scope._FORM_TYPE = Const.miscellaneous._FORM_TYPE;\n\n    $scope.init = function() {\n        if ($scope.requester_id != undefined) {\n            // 盲禄拢莽聬聠茫聝娄茫聝录茫聜露茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉\n            const proxy_requester = loginUserService.login_user.proxy_requests.find(function(proxy_request) {\n                const proxy_requester_id = parseInt(proxy_request.requester.id);\n                const requester_id = parseInt($scope.requester_id);\n                return proxy_requester_id === requester_id;\n            });\n            if (proxy_requester) {\n                // 茫聜掳茫聝颅茫聝录茫聝聬茫聝芦氓陇聣忙聲掳茫聛芦忙聦聛茫聛拢茫聛娄茫聛聞茫聜聥茫聛陋茫聜聣盲陆驴莽聰篓茫聛聶茫聜聥\n                $scope.requester = proxy_requester.requester;\n            }else{\n                // 茫聜掳茫聝颅茫聝录茫聝聬茫聝芦氓陇聣忙聲掳茫聛芦忙聦聛茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉API茫聜聮氓聫漏茫聛聫\n                $http.get(\u0027/api/v1/proxyrequest/checkagent/\u0027 + $scope.requester_id)\n                .then(function(response) {\n                    $scope.requester = response.data;\n                });\n            }\n        }\n        $scope.readForms();\n    };\n\n    $scope.readForms = function() {\n        $scope.search_params.kind = \"request\";\n        $scope.search_params.plan = $scope.plan;\n        if(angular.isUndefined($scope.requester_id)){\n            $scope.search_params.request_user_id = $scope.login_user.id;\n        }else{\n            $scope.search_params.request_user_id = $scope.requester_id;\n        }\n        if(!angular.isUndefinedOrNull($scope.select_category)){\n            $scope.search_params.form_category_id = $scope.select_category.id;\n        }else{\n            $scope.search_params.form_category_id = null;\n        }\n        $http.get(\u0027/api/v1/forms/\u0027, {params: $scope.search_params}).success(function(response) {\n            $scope.forms = response;\n            _reorderIfLimited()\n        });\n    };\n\n    $scope.changeSearchParams = function () {\n        searchParamsService.request_form_list_search_params.search_text = $scope.search_params.search_text;\n    };\n\n    $scope.clearSearchText = function(){\n        $scope.search_params.search_text = null;\n        searchParamsService.request_form_list_search_params.search_text = $scope.search_params.search_text;\n        $scope.readForms();\n    };\n\n    $scope.showSelectFormCategoryDialog = function () {\n        var params = {};\n        var size = \"\";\n        params.kind = \u0027single\u0027;\n        if ($rootScope.is_mobile){\n            size = \"mobile\";\n        }\n        var modalInstance = $uibModal.open({\n            templateUrl: \u0027../static/wf/views/dialogs/select_form_category_templ.html\u0027,\n            controller: \u0027selectFormCategoryDialogCtrl\u0027,\n            size: size,\n            resolve: {\n                params: function () {\n                  return params;\n                }\n            }\n        });\n        modalInstance.result.then(function (selected_form_category) {\n            $scope.select_category = selected_form_category;\n            searchParamsService.request_form_list_search_params.select_category = $scope.select_category;\n            $scope.readForms();\n        }, function () {\n              // dismiss\n        });\n    };\n\n    $scope.clearFormCategory = function() {\n        $scope.select_category = null;\n        searchParamsService.request_form_list_search_params.select_category = $scope.select_category;\n        $scope.readForms();\n    };\n\n    // 莽聰鲁猫芦聥茫聜聮茅聛赂忙聤聻茫聛聴茫聛聼忙聶聜茫聛庐氓聡娄莽聬聠\n    $scope.item_clicked = function(requester, form) {\n        // 氓聢露茅聶聬盲赂颅茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢茫聛炉茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳猫隆篓莽陇潞茫聝禄茅聛路莽搂禄茫聛聲茫聛聸茫聛陋茫聛聞\n        if (permissionService.isFreeUser() \u0026\u0026 form.limited) {\n            _showChargeDialog();\n            return;\n        }\n        if (!requester) {\n            $location.path(\"/request/new/\" + form.id);\n        } else {\n            $location.path(\"/proxyrequest/\" + requester.id + \"/new/\" + form.id);\n        }\n    };\n\n    var _showChargeDialog = function() {\n        var message = _(\u0027莽庐隆莽聬聠猫聙\u0085茫聛芦茫聛聤氓聲聫茫聛聞氓聬聢茫聜聫茫聛聸茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u0027);\n        var link = \u0027\u0027;\n        if (permissionService.hasPaidPermission()) {\n            message = _(\u0027忙聹聣忙聳聶茫聝聴茫聝漏茫聝鲁茫聛庐茫聛聰氓聢漏莽聰篓茫聛芦茫聜聢茫聜聤茫聙聛氓\u0085篓茫聛娄茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聦氓聢漏莽聰篓氓聫炉猫聝陆茫聛芦茫聛陋茫聜聤茫聛戮茫聛聶茫聙聜\u0027);\n            link = _(\u0027忙聹聣忙聳聶茫聝聴茫聝漏茫聝鲁茫聛聤莽聰鲁茫聛聴猫戮录茫聛驴茫聛炉茫聛聯茫聛隆茫聜聣\u0027);\n        }\n        dialogService.showChargeDialog(message, link);\n    };\n\n    $scope.isUseableForm = function(form) {\n        // 莽聞隆忙聳聶茫聝娄茫聝录茫聜露茫聛芦茫聛炉茫聛聶茫聛鹿茫聛娄茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥\n        // 忙聹聣忙聳聶茫聝娄茫聝录茫聜露茫聛炉氓聢漏莽聰篓盲赂颅茫聛庐茫聝聴茫聝漏茫聝鲁茫聛芦氓卤聻茫聛聶茫聜聥茫聝聲茫聜漏茫聝录茫聝聽茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聜聥\n        return (permissionService.isFreeUser() || form.planMatched);\n    };\n\n    // 莽聞隆忙聳聶茫聝聴茫聝漏茫聝鲁茫聛庐氓聽麓氓聬聢茫聙聛氓聢漏莽聰篓氓聫炉猫聝陆茫聛陋茫聝聲茫聜漏茫聝录茫聝聽3茫聛陇茫聜聮茫聝陋茫聜鹿茫聝聢茫聛庐盲赂聤茅聝篓茫聛芦莽搂禄氓聥聲茫聛聲茫聛聸茫聜聥\n    var _reorderIfLimited = function () {\n        // 莽聞隆忙聳聶茫聝聴茫聝漏茫聝鲁茫聛庐茫聝娄茫聝录茫聜露盲禄楼氓陇聳茫聛炉氓聡娄莽聬聠茫聛聴茫聛陋茫聛聞\n        if (!permissionService.isFreeUser()) {\n            return;\n        }\n        var unlimited_forms = [];\n        var limited_forms = [];\n        angular.forEach($scope.forms, function (form) {\n            if (form.limited) {\n                limited_forms.push(form);\n            } else {\n                unlimited_forms.push(form);\n            }\n        });\n        $scope.forms = unlimited_forms.concat(limited_forms);\n    };\n\n    /**\n     * 氓陆聯猫漏虏茫聝聲茫聜漏茫聝录茫聝聽茫聛聦莽聫戮氓聹篓茫聛庐茫聝聴茫聝漏茫聝鲁盲赂聤氓聢漏莽聰篓氓聫炉茫聛庐氓聽麓氓聬聢茫聛炉莽聹聼\n     * @param {object} form\n     * @return {boolean}\n     */\n    $scope.planMatch = function(form) {\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聴茫聝漏茫聝鲁茫聛庐茅職聸茫聙聛茫聝聲茫聜漏茫聝录茫聝聽莽篓庐氓聢楼茫聛聦忙卤聨莽聰篓茫聛庐茫聜聜茫聛庐茫聛炉氓聢漏莽聰篓盲赂聧氓聫炉\n        if (planService.isExpensePlan() \u0026\u0026 form.form_type === Const.miscellaneous._FORM_TYPE.GENERAL.type) {\n            return false;\n        }\n        // WF茫聝聴茫聝漏茫聝鲁茫聛庐茅職聸茫聙聛忙卤聨莽聰篓茫聙聛EC猫鲁录氓\u0085楼莽聰鲁猫芦聥盲禄楼氓陇聳茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛炉氓聢漏莽聰篓盲赂聧氓聫炉\n        if (planService.isWfPlan() \u0026\u0026\n            form.form_type !== Const.miscellaneous._FORM_TYPE.GENERAL.type \u0026\u0026\n            form.form_type !== Const.miscellaneous._FORM_TYPE.EC.type) {\n            return false;\n        }\n        return true;\n    };\n\n    $scope.init();\n\n}\n"
              }
}
