 } else {\n                $scope.form_data.payment.request_payment_specifics.forEach(function(specifics) {\n                    specifics.request_payment_specifics_rows.forEach(function(row) {\n                        if (!angular.isUndefinedOrNull(row.invoice_registrated_number)) {\n                            invoice_registrated_numbers.push(row.invoice_registrated_number);\n                        }\n                    });\n                });\n            }\n\n            if (invoice_registrated_numbers.length === 0) {\n                // 茫聝聛茫聜搂茫聝聝茫聜炉氓炉戮猫卤隆茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n                return;\n            }\n            // 茫聝聛茫聜搂茫聝聝茫聜炉莽碌聬忙聻聹茫聜聮氓\u0085聝茫聛芦莽聶禄茅聦虏莽聲陋氓聫路茫聛芦氓炉戮氓驴聹茫聛聶茫聜聥invoice_check_result茫聜聮忙聸麓忙聳掳\n            createRequestService.checkInvoiceRegistratedNumbers(invoice_registrated_numbers)\n            .then(function (res) {\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    $scope.form_data.expense.request_expense_specifics.forEach(function(specifics) {\n                        specifics.request_expense_specifics_rows.forEach(function(row) {\n                            const item = res.check_results.filter(function(result) {\n                                return result.invoice_registrated_number === row.invoice_registrated_number;\n                            });\n                            if (item.length \u003e 0) {\n                                row.invoice_check_result = item[0].invoice_check_result;\n                                row.is_valid_invoice_registrated_number = (\n                                    item[0].invoice_check_result == Const.miscellaneous.INVOICE_CHECK_RESULT.MATCHED.id\n                                );\n                            }\n                        });\n                    });\n                } else {\n                    $scope.form_data.payment.request_payment_specifics.forEach(function(specifics) {\n                        specifics.request_payment_specifics_rows.forEach(function(row) {\n                            const item = res.check_results.filter(function(result) {\n                                return result.invoice_registrated_number === row.invoice_registrated_number;\n                            });\n                            if (item.length \u003e 0) {\n                                row.invoice_check_result = item[0].invoice_check_result;\n                                row.is_valid_invoice_registrated_number = (\n                                    item[0].invoice_check_result == Const.miscellaneous.INVOICE_CHECK_RESULT.MATCHED.id\n                                );\n                            }\n                        });\n                    });\n                }\n            });\n        });\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聛芦莽麓聬茫聛楼茫聛聫氓聠\u0085猫篓鲁茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @return {Promise} Promise\n     */\n    function _getAccountTitlePartIdsInRequest() {\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_EXPENSE \u0026\u0026\n            $scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽茫聛篓忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            return;\n        }\n\n        var account_title_part_ids = [];\n        if (!$scope.isSpecificsSheet()) {\n            // 茅聺聻忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n            var account_title_part = null;\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                account_title_part = $scope.form_data.expense.account_title_part;\n            } else {\n                account_title_part = $scope.form_data.payment.account_title_part;\n            }\n            if (angular.isUndefinedOrNull(account_title_part)) {\n                // 茫聝聛茫聜搂茫聝聝茫聜炉氓炉戮猫卤隆茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n                return;\n            }\n            account_title_part_ids.push(account_title_part);\n        } else {\n        // 忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢\n            // 氓\u0085篓忙聵聨莽麓掳茫聛庐氓聠\u0085猫篓鲁茫聜聮account_title_part_ids茫聛芦忙聽录莽麓聧\n            if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                $scope.form_data.expense.request_expense_specifics.forEach(function(specifics) {\n                    specifics.request_expense_specifics_rows.forEach(function(row) {\n                        if (!angular.isUndefinedOrNull(row.account_title_part)) {\n                            account_title_part_ids.push(row.account_title_part);\n                        }\n                    });\n                });\n            } else {\n                $scope.form_data.payment.request_payment_specifics.forEach(function(specifics) {\n                    specifics.request_payment_specifics_rows.forEach(function(row) {\n                        if (!angular.isUndefinedOrNull(row.account_title_part)) {\n                            account_title_part_ids.push(row.account_title_part);\n                        }\n                    });\n                });\n            }\n        }\n\n        if (account_title_part_ids.length === 0) {\n            // 茫聝聛茫聜搂茫聝聝茫聜炉氓炉戮猫卤隆茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聭茫聜聦茫聛掳盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n            return;\n        }\n\n        // 茅聡聧猫陇聡猫娄聛莽麓聽茫聜聮忙聨聮茅聶陇茫聛聴茫聛娄氓聠\u0085猫篓鲁茫聜聮氓聫聳氓戮聴\n        var params = {\n            // eslint-disable-next-line es5/no-es6-static-methods\n            account_title_part_ids: Array.from(new Set(account_title_part_ids)).join(\u0027,\u0027),\n            no_pagination: true,\n        };\n        return AccountTitlePartService.getList(params);\n    }\n\n    /**\n     * flow_circulation_users茫聜聮茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦忙赂隆茫聛聶茫聛聼茫聜聛茫聛芦茫聜掳茫聝芦茫聝录茫聝聴茫聛篓茫聝娄茫聝录茫聜露茫聛庐茅\u0085聧氓聢聴茫聛芦氓聢聠茫聛聭茫聜聥\n     * @param {Array.\u003cObject\u003e} flow_circulation_users\n     */\n    function setCirculationPositionAndUsers(flow_circulation_users) {\n        dlog_flow_circulation_settings = [];\n        dlog_flow_circulation_users = [];\n        flow_circulation_users.forEach(function(user) {\n            // 茫聙聦茫聛聶茫聛鹿茫聛娄茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茫聙聧茫聛陋茫聜聣\n            if (!angular.isUndefinedOrNull(user.group) \u0026\u0026 angular.isUndefinedOrNull(user.group.id)) {\n                // 莽驴禄猫篓鲁茫聛聶茫聜聥\n                user.group.name = gettextCatalog.getString(user.group.name);\n            }\n            // 茫聙聦茫聛聶茫聛鹿茫聛娄茫聛庐氓陆鹿猫聛路茫聙聧茫聛陋茫聜聣\n            if (!angular.isUndefinedOrNull(user.position) \u0026\u0026 angular.isUndefinedOrNull(user.position.id)) {\n                // 莽驴禄猫篓鲁茫聛聶茫聜聥\n                user.position.position_name = gettextCatalog.getString(user.position.position_name);\n            }\n            // 茫聜垄茫聜陇茫聝聠茫聝聽茫聛聦忙聺隆盲禄露茫聛陋茫聜聣\n            if (user.user == null) {\n                // 茅聳虏猫娄搂氓聫炉猫聝陆忙聺隆盲禄露茫聛芦猫驴陆氓聤聽\n                dlog_flow_circulation_settings.push(user);\n            }\n            // 茫聜垄茫聜陇茫聝聠茫聝聽茫聛聦莽聣鹿氓庐職茫聝娄茫聝录茫聜露茫聛陋茫聜聣\n            else {\n                // 茅聳虏猫娄搂氓聫炉猫聝陆茫聝娄茫聝录茫聜露茫聛芦猫驴陆氓聤聽\n                dlog_flow_circulation_users.push(user);\n            }\n        });\n    }\n\n    /**\n     * 莽碌聦猫路炉氓聢聠氓虏聬忙聝\u0085氓聽卤茫聜聮氓聫聳茫聛拢茫聛娄茫聛聫茫聜聥\n     * @param {number} form_id\n     * @return {Promise}\n     */\n    function getExtraFlowData(form_id) {\n        var deferred = $q.defer();\n        // 莽聰鲁猫芦聥氓\u0085聝忙聝\u0085氓聽卤茫聛庐茫聜禄茫聝聝茫聝聢\n        var request_user_id = angular.isDefined($scope.requester_id) ? $scope.requester_id : null;\n        var params = {\n            group_id: $scope.requester_info.requester_group_id,\n            position_id: $scope.requester_info.requester_position_id,\n            requester_id: request_user_id,\n        };\n        FormService.getExtraFlowList(form_id, params).then(function(response) {\n            $scope.form_data.extra_flows = response.data.extra_flows;\n\n            // 忙聣聙氓卤聻茫聜掳茫聝芦茫聝录茫聝聴茫聛聦猫陇聡忙聲掳茫聛聜茫聜聥氓聽麓氓聬聢茫聛炉茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁猫隆篓莽陇潞\n            if ($scope.requester_group_choices.length \u003e 1) {\n                $scope.disp_group_select = true;\n            }\n\n            deferred.resolve();\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢莽碌聦猫路炉茂录聢form茫聛芦莽麓聬茫聛楼茫聛聫莽碌聦猫路炉茂录聣茫聛庐id茫聜聮盲驴聺氓颅聵茫聛聴茫聛娄茫聛聤茫聛聫\n     * 莽聰禄茅聺垄猫隆篓莽陇潞忙聶聜茫聙聛茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢茫聛搂猫篓颅氓庐職茫聛聲茫聜聦茫聜聥莽碌聦猫路炉茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茫聛聴茫聛娄茫聙聛use_extra_flow_priority茫聛芦priority茫聜聮茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * 忙聳掳猫娄聫茫聙聛茫聜鲁茫聝聰茫聝录茫聛庐氓聽麓氓聬聢茫聛炉茫聝漏茫聜赂茫聜陋茫聝聹茫聜驴茫聝鲁茫聛庐氓聢聺忙聹聼氓聙陇茫聛庐茅聳垄盲驴聜盲赂聤茫聙聛茫聝娄茫聝录茫聜露茫聛聦盲陆聲茫聜聜氓\u0085楼氓聤聸茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛搂茫聜聜莽碌聦猫路炉茫聛聦氓陇聣忙聸麓茫聛聲茫聜聦茫聜聥氓聽麓氓聬聢茫聛聦茫聛聜茫聜聥\n     * 莽路篓茅聸聠茫聙聛氓聠聧莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聛炉莽聰鲁猫芦聥忙聶聜茫聛庐莽碌聦猫路炉priority茫聛聦茫聜禄茫聝聝茫聝聢茫聛聲茫聜聦茫聜聥\n     * @param {number} default_flow_id\n     * @param {boolean} notify_flg\n     * @param {boolean} refresh_flow_flg\n     * @param {boolean} change_group_flg\n     * @return {Number}\n     * @private\n     */\n    function _setDefaultFlow(default_flow_id, notify_flg, refresh_flow_flg, change_group_flg) {\n        $scope.default_flow_data = {id: default_flow_id};\n        return changeExtraFlow(checkExtraFlowPriority(), notify_flg, refresh_flow_flg, change_group_flg);\n    }\n\n    /**\n     * 氓\u0085楼氓聤聸茫聛庐茫聝聬茫聝陋茫聝聡茫聝录茫聜路茫聝搂茫聝鲁茫聝聭茫聜驴茫聝录茫聝鲁茫聜聮氓聫聳氓戮聴\n     * @param {object} form_item\n     * @return {string}\n     */\n    function handleInputPattern(form_item) {\n        // 茂录聢氓聨聼莽聤露茫聛搂茫聛炉茂录聣氓聧聵盲赂聙忙聳聡氓颅聴氓聢聴茫聛庐茫聛驴茫聜聮氓炉戮猫卤隆茫聛篓茫聛聶茫聜聥\n        if (form_item.item_type !== Const.form.ITEM_TYPE_TEXT) return \u0027\u0027;\n        // [氓聧聤猫搂聮猫聥卤忙聲掳氓颅聴]茫聛戮茫聛聼茫聛炉[氓聢露茅聶聬茫聛陋茫聛聴]\n        return \u0027input_pattern\u0027 in form_item \u0026\u0026 form_item.input_pattern === 2 ? \u0027^[a-zA-Z0-9]+$\u0027 : \u0027\u0027;\n    }\n\n    /**\n     * 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥 盲驴庐忙颅拢氓聣聧茫聝禄盲驴庐忙颅拢氓戮聦猫隆篓莽陇潞\n     * @param {object} settingRule setting.settlement_deadline\n     * @param {object} requestFreeItems 盲驴庐忙颅拢氓聣聧忙聝\u0085氓聽卤\n     * @param {object} modifyFreeItems 盲驴庐忙颅拢氓戮聦忙聝\u0085氓聽卤\n     * @private\n     */\n    function _setChangeDeadlineFreeItems(settingRule, requestFreeItems, modifyFreeItems) {\n        // key茫聛聦茅聲路茫聛聞茫聛庐茫聛搂忙路路盲鹿卤茅聵虏忙颅垄\n        const REFERENCE_ITEM = \u0027settlement_deadline_reference_item\u0027;\n        const REFERENCE_FORM_ITEM = \u0027reference_form_item\u0027;\n        const PERIOD_FORM_ITEM = \u0027settlement_deadline_period_form_item\u0027;\n        const CONDITION_FORM_ITEM = \u0027condition_form_item\u0027;\n        const SETTING_REFERENCE_FORM_ITEM = \u0027reference_form_item\u0027;\n        const SETTING_PERIOD_FORM_ITEN = \u0027period_form_item\u0027;\n        const DEADLINE_DATE = \u0027settlement_deadline_date\u0027;\n        const settings = settingRule[\u0027settlement_deadline_setting\u0027];\n\n        function _setData(targetObject, params) {\n            // 氓聫聜莽\u0085搂茫聛聦氓聢聡茫聜聦茫聜聥茫聛驴茫聛聼茫聛聞茫聛陋茫聛庐茫聛搂object茫聛庐茫聜颅茫聝录忙炉聨茫聛芦猫篓颅氓庐職茫聛聶茫聜聥\n            Object.keys(params).forEach(function(key) {\n                if (params[key]) {\n                    targetObject[key] = angular.copy(params[key]);\n                }\n            });\n        }\n        function _isChangeRule(source, compare) {\n            return source[\u0027id\u0027] !== compare[\u0027id\u0027] || source[\u0027item_type\u0027] !== compare[\u0027item_type\u0027];\n        }\n\n        // 盲驴庐忙颅拢氓聣聧茫聜禄茫聜炉茫聜路茫聝搂茫聝鲁\n        var requestReferenceFormItem = null;\n        var requestConditionFormItem = null;\n        requestReferenceFormItem = requestFreeItems[REFERENCE_ITEM][REFERENCE_FORM_ITEM];\n        if (PERIOD_FORM_ITEM in requestFreeItems \u0026\u0026 requestFreeItems[PERIOD_FORM_ITEM]) {\n            requestConditionFormItem = requestFreeItems[PERIOD_FORM_ITEM][CONDITION_FORM_ITEM];\n        }\n        const requestParams = {\n            reference_date: requestReferenceFormItem,\n            condition_date: requestConditionFormItem,\n            settlement_deadline_date: requestFreeItems[DEADLINE_DATE],\n        };\n        _setData($scope.request_settlement_deadline, requestParams);\n\n        var modifyConditionFormItem = null;\n        var modifyDeadlineDate = modifyFreeItems[DEADLINE_DATE];\n        var modifyReferenceFormItem = modifyFreeItems[REFERENCE_ITEM][REFERENCE_FORM_ITEM];\n        if (_isChangeRule(settings[SETTING_REFERENCE_FORM_ITEM], modifyReferenceFormItem)) {\n            // 茫聝芦茫聝录茫聝芦氓陇聣忙聸麓茫聛聦茫聛聜茫聛拢茫聛聼氓聽麓氓聬聢茫聙聛忙聹聙忙聳掳茫聛庐茫聝芦茫聝录茫聝芦茫聛搂莽聰鲁猫芦聥茫聛聶茫聜聥茫聛聯茫聛篓茫聛芦茫聛陋茫聜聥茫聛庐茫聛搂settingRule茫聛聥茫聜聣\n            modifyReferenceFormItem = settings[SETTING_REFERENCE_FORM_ITEM];\n            modifyDeadlineDate = null;\n        }\n        const _BRANCH_CONDITION_TYPE = Const.miscellaneous._BRANCH_CONDITION_TYPE;\n        if (settings.branch_condition_type === _BRANCH_CONDITION_TYPE.USE_REFERENCE_DATE_AND_CONDITIONS\n            \u0026\u0026 PERIOD_FORM_ITEM in modifyFreeItems \u0026\u0026 modifyFreeItems[PERIOD_FORM_ITEM]\n        ) {\n            modifyConditionFormItem = modifyFreeItems[PERIOD_FORM_ITEM][CONDITION_FORM_ITEM];\n            if (_isChangeRule(settings[SETTING_PERIOD_FORM_ITEN], modifyConditionFormItem)\n            ) {\n                // 茫聝芦茫聝录茫聝芦氓陇聣忙聸麓茫聛聦茫聛聜茫聛拢茫聛聼氓聽麓氓聬聢茫聙聛忙聹聙忙聳掳茫聛庐茫聝芦茫聝录茫聝芦茫聛搂莽聰鲁猫芦聥茫聛聶茫聜聥茫聛聯茫聛篓茫聛芦茫聛陋茫聜聥茫聛庐茫聛搂settingRule茫聛聥茫聜聣\n                modifyConditionFormItem = settings[SETTING_PERIOD_FORM_ITEN];\n                modifyDeadlineDate = null;\n            }\n        }\n        var modifyConditionFormItemOld = angular.copy(modifyConditionFormItem);\n        if (settings.branch_condition_type === _BRANCH_CONDITION_TYPE.USE_REFERENCE_DATE\n            \u0026\u0026 PERIOD_FORM_ITEM in modifyFreeItems \u0026\u0026 modifyFreeItems[PERIOD_FORM_ITEM]\n        ) {\n            // 茫聝芦茫聝录茫聝芦氓陇聣忙聸麓茫聛聦茫聛聜茫聜聤猫隆篓莽陇潞茫聛聲茫聜聦茫聛陋茫聛聞茫聙聜盲驴庐忙颅拢氓卤楼忙颅麓茫聛庐莽聜潞猫篓颅氓庐職\n            modifyConditionFormItemOld = modifyFreeItems[PERIOD_FORM_ITEM][CONDITION_FORM_ITEM];\n        }\n        const modifyParams = {\n            reference_date: modifyReferenceFormItem,\n            condition_date: modifyConditionFormItem,\n            settlement_deadline_date: modifyDeadlineDate,\n        };\n        _setData($scope.modify_settlement_deadline, modifyParams);\n        const modifyOldParams = angular.copy(modifyParams);\n        modifyOldParams[\u0027condition_date\u0027] = modifyConditionFormItemOld;\n        _setData($scope.modify_settlement_deadline_old, modifyOldParams);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥莽路篓茅聸聠茫聙聛茫聜鲁茫聝聰茫聝录莽聰鲁猫芦聥忙聶聜茫聛芦茫聝聡茫聝录茫聜驴茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @param {string} kind 莽聰鲁猫芦聥盲陆聹忙聢聬莽篓庐氓聢楼 Const.miscellaneous.CREATE_REQUEST_KIND\n     * @private\n     */\n    function _readRequest(kind) {\n        var current_url = $location.url();\n        var params = {};\n        if (angular.isUndefined($scope.requester_id)) {\n            params.request_user_id = $scope.login_user.id;\n        }\n        else {\n            params.request_user_id = $scope.requester_id;\n        }\n\n        $q.all([RequestService.getRequestForUpdate(kind, current_url, $scope.request_id, params),\n                attendanceService.getBusinessTripDestination(),\n                attendanceService.getRequestBusinessTripInfo($scope.request_id)])\n        .then(function(res) {\n            var data = res[0].data;\n            data.destinations = res[1].data;\n            data.business_trip_info = res[2].data;\n            var flow_id = data.flow; // 莽聰鲁猫芦聥忙聶聜茫聛庐莽碌聦猫路炉ID\n            var request_id = data.id; // 莽聰鲁猫芦聥忙聶聜茫聛庐莽聰鲁猫芦聥ID\n\n            // 盲驴庐忙颅拢/氓聠聧莽聰鲁猫芦聥忙聶聜茫聛炉莽聰鲁猫芦聥忙聴楼茫聜聮忙聽录莽麓聧茫聙聛忙聰炉忙聣聲盲潞聢氓庐職忙聴楼氓聫聳氓戮聴茫聛搂盲陆驴茫聛聠\n            if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY ||\n                kind === Const.miscellaneous.CREATE_REQUEST_KIND.FEEDBACK) {\n                $scope.request_date = data.request_date; // 莽聰鲁猫芦聥忙聴楼\n            }\n\n            // 忙聹卢氓陆聯茫聛炉茫聙聦$scope.request = data茫聙聧茫聛庐茫聜聢茫聛聠茫聛芦茫聛聺茫聛庐茫聛戮茫聛戮氓陇聣忙聲掳茫聜禄茫聝聝茫聝聢茫聛聴茫聛聼茫聛聞茫聙聜\n            // 茫聛聼茫聛聽茫聛聴忙聴垄氓颅聵茫聛庐茫聜鲁茫聝录茫聝聣茫聜聮氓\u0085篓茫聛娄$scope.request.xx茫聜聮氓聫聜莽\u0085搂茫聛聶茫聜聥茫聜聢茫聛聠茫聛芦氓陇聣忙聸麓茫聛聶茫聜聥茫聛庐茫聛炉氓陇搂氓陇聣茫聛陋茫聛庐茫聛搂茫聙聛猫戮聸茫聛聞茫聛搂茫聛聶茫聛聦fetched_request茫聛芦氓\u0085楼茫聜聦茫聛娄茫聛戮茫聛聶茫聙聜\n            fetched_request.flow = data.flow;\n            fetched_request.created_at = data.created_at;\n            fetched_request.edit_flow_flg = data.edit_flow_flg;\n            fetched_request.is_set_step_user = data.is_set_step_user;\n            // Hubble\n            if (HubbleService.hasHubbleDocuments(data)) fetched_request.hubble_data = data.hubble_data;\n\n            // 氓\u0085卢茅聳聥猫篓颅氓庐職\n            $scope.form_publish_settings = data.form_publish_settings;\n            $scope.publish_setting_kind = data.request_form.publish_setting_kind;\n            if ($scope.publish_setting_kind === Const.miscellaneous.PUBLISH_SETTING_KIND.PARTLY_PUBLIC.key) {\n                setFormPublishedPatterns();\n            }\n\n            initRequesterInfo();\n\n            // 莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聛庐猫篓颅氓庐職\n            _setFormData(kind, data);\n\n            // 茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐茫聛庐氓聢聺忙聹聼氓聦聳\n            // 茫聛聯茫聛庐form_json茫聛芦茫聛炉忙卤聨莽聰篓茅聽\u0085莽聸庐茫聛庐氓聠\u0085氓庐鹿茫聛聦忙聽录莽麓聧茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥\n            $scope.form_data.form_json = createRequestService.initFormItemForCopy(\n                $scope.form_data.request_data_json.form_json\n            );\n            mapped_items = CreateRequestFormItemService.makeMappedItems($scope.form_data.form_json);\n            // 盲赂聥忙聸赂茫聛聧莽路篓茅聸聠茫聛篓莽聰鲁猫芦聥茫聜鲁茫聝聰茫聝录茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛氓聫聳氓录聲氓\u0085聢茅聛赂忙聤聻茫聛庐氓\u0085楼氓聤聸茫聝聡茫聝录茫聜驴茫聜聮忙聹聙忙聳掳氓聦聳茫聛聶茫聜聥\n            if (\n                [\n                    Const.miscellaneous.CREATE_REQUEST_KIND.EDIT,\n                    Const.miscellaneous.CREATE_REQUEST_KIND.COPY,\n                ].includes(kind)\n            ) {\n                _setLatestCompanyToFormItem(\n                    $scope.form_data.request_data_json.form_json\n                );\n            }\n\n            var specifics = null;\n            var form_type = $scope.form_type;\n            if (form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                if ($scope.form_data.request_data_json.expense.request_expense_specifics) {\n                    specifics = $scope.form_data.request_data_json.expense.request_expense