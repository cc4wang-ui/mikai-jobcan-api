              formJsonItemsNote.BASE_ITEM\n                    );\n\n                    if (util.isUndefinedOrNull(baseFormItemsNote.NON_SPECIFICS_ITEM)) {\n                        // 忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛搂忙聵聨莽麓掳茫聛聜茫聜聤茫聛庐忙鲁篓猫篓聵茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛氓聣聤茅聶陇茫聛聶茫聜聥\n                        // 1莽聰鲁猫芦聥N忙聰炉忙聣聲氓\u0085聢芒聡聮1莽聰鲁猫芦聥1忙聰炉忙聣聲氓\u0085聢茫聛赂茫聛庐氓陇聣忙聸麓茫聛陋茫聛漏\n                        formJsonItemsNote.NON_SPECIFICS_ITEM = null;\n                    }\n                    resultFormItemsNote.NON_SPECIFICS_ITEM = FormService.getFormJsonNote(\n                        baseFormItemsNote.NON_SPECIFICS_ITEM,\n                        formJsonItemsNote.NON_SPECIFICS_ITEM\n                    );\n\n                    if (\n                        !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM) \u0026\u0026\n                        util.isUndefinedOrNull(specifics)\n                    ) {\n                        // 忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛搂忙聵聨莽麓掳茫聛聜茫聜聤茫聛庐忙鲁篓猫篓聵茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛氓聣聤茅聶陇茫聛聶茫聜聥\n                        // 茅聛聨氓聨禄茫聛庐忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥茫聛聦盲禄聤茫聛庐茫聛篓茫聛聯茫聜聧猫漏虏氓陆聯茫聛聶茫聜聥\n                        formJsonItemsNote.SPECIFICS_ITEM = null;\n                    }\n\n                    // form_json茫聛庐盲赂颅茫聛芦氓陇聳猫虏篓氓聬聢猫篓聢茅聡聭茅隆聧(TOTAL_EXCHANGE_FEE)茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛芦猫驴陆氓聤聽茫聛聶茫聜聥\n                    if (\n                        !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM)\n                        \u0026\u0026 util.isUndefinedOrNull(\n                            formJsonItemsNote.SPECIFICS_ITEM.TOTAL_EXCHANGE_FEE\n                        )\n                    ) {\n                        formJsonItemsNote.SPECIFICS_ITEM.TOTAL_EXCHANGE_FEE = (\n                            FormService.getNoteSpecificsTotalExchangeFee(\n                                form_type,\n                                specifics\n                            )\n                        );\n                    }\n\n                    // 忙聵聨莽麓掳茅聽\u0085莽聸庐茫聛庐忙鲁篓猫篓聵茫聛庐\u003cbr\u003e茫聜聮忙聰鹿猫隆聦忙聳聡氓颅聴茫聛芦氓陇聣忙聫聸\n                    if (\n                        !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM)\n                        \u0026\u0026 !util.isUndefinedOrNull(formJsonItemsNote.SPECIFICS_ITEM.ROW)\n                    ) {\n                        formJsonItemsNote.SPECIFICS_ITEM.ROW.forEach((noteRow) =\u003e {\n                            if (util.isUndefinedOrNull(noteRow)) {\n                                return;\n                            }\n                            Object.keys(noteRow).forEach((key) =\u003e {\n                                const item = noteRow[key];\n                                if (util.isUndefinedOrNull(item)) {\n                                    return;\n                                }\n                                item.note = item.note ? FormService.convertLineBreak(item.note, false) : item.note;\n                            });\n                        });\n                    }\n\n                    // SPECIFICS_ITEM茫聛芦茫聛陇茫聛聞茫聛娄茫聛炉茫聙聛忙聴垄氓颅聵忙聵聨莽麓掳茫聛庐茅聽\u0085莽聸庐茫聛聦盲禄聤氓戮聦氓垄聴茫聛聢茫聜聥茫聛聯茫聛篓茫聛炉茫聛聤茫聛聺茫聜聣茫聛聫茫聛陋茫聛聞茫聛聼茫聜聛form_json茫聛庐忙聝\u0085氓聽卤茫聜聮莽聸麓忙聨楼忙聽录莽麓聧茫聛聶茫聜聥\n                    resultFormItemsNote.SPECIFICS_ITEM = formJsonItemsNote.SPECIFICS_ITEM;\n                } else {\n                    // 忙鲁篓猫篓聵茫聛庐茫聜颅茫聝录茫聜聮忙聦聛茫聛聼茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛氓庐職忙聲掳茫聛聥茫聜聣莽聸麓忙聨楼茫聜鲁茫聝聰茫聝录茫聛聶茫聜聥\n                    const baseFormItemsNoteKeys = Object.keys(baseFormItemsNote);\n                    baseFormItemsNoteKeys.forEach((key) =\u003e {\n                        resultFormItemsNote[key] = baseFormItemsNote[key];\n                    });\n                }\n\n                // 忙聹聙忙聳掳茫聛芦盲陆聹忙聢聬茫聛聴茫聛聼忙鲁篓猫篓聵茫聛庐氓聠\u0085氓庐鹿茫聜聮茫聙聛茫聝聲茫聜漏茫聝录茫聝聽茫聛庐忙聝\u0085氓聽卤茫聛芦忙聽录莽麓聧茫聛聶茫聜聥\n                form_json.form_items_note = resultFormItemsNote;\n\n                // 茫聝聠茫聝鲁茫聝聴茫聝卢茫聝录茫聝聢氓聛麓茫聛庐茫聝聬茫聜陇茫聝鲁茫聝聣莽聰篓茫聛芦莽聼颅莽赂庐\n                $scope.BASE_ITEM = form_json.form_items_note.BASE_ITEM;\n                $scope.NON_SPECIFICS_ITEM = form_json.form_items_note.NON_SPECIFICS_ITEM;\n                $scope.SPECIFICS_ITEM = form_json.form_items_note.SPECIFICS_ITEM;\n            }\n\n            // 莽碌聦猫路炉茫聛庐氓聢聠氓虏聬忙聝\u0085氓聽卤氓聫聳氓戮聴\n            var extraflow_promise = getExtraFlowData($scope.form_data.form_id);\n\n            // 氓聢聺忙聹聼氓聦聳茫聛芦盲陆驴茫聛聠Promise莽聰篓氓陇聣忙聲掳\n            var flow_promise;\n            var circulation_promise;\n            var comment_promise;\n\n            // 忙聣驴猫陋聧莽聤露忙鲁聛茫聛芦忙聣驴猫陋聧猫聙\u0085茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茫聙聛氓陆鹿猫聛路忙聝\u0085氓聽卤茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥茫聛庐猫篓颅氓庐職茫聜聮氓聫聜莽\u0085搂茫聛聶茫聜聥\n            var params = {};\n            params.request_user_id = data.request_user.id;\n            FormService.readCustomForm(data.request_form.id, params)\n            .then(function(form) {\n                $scope.form_data.approval_group_position_setting_flg\n                    = form.approval_group_position_setting_flg;\n            });\n\n            // 茫聜驴茫聜陇茫聝聢茫聝芦猫聡陋氓聥聲猫篓颅氓庐職\n            const request_data_json = $scope.form_data.request_data_json;\n            $scope.form_data.edit_title_setting_flg = CreateRequestTitleService.isEditTitle(\n                request_data_json.edit_title_setting_flg\n            );\n\n            // eslint-disable-next-line require-jsdoc\n            function loadCloudsignDocument() {\n                if (!angular.isUndefinedOrNull(data.cloudsign_document)) {\n                    $scope.loading_cloudsign = true;\n                    CloudsignService.loadDocument(data.cloudsign_document, $scope.requester_id).then(\n                        // success\n                        function(response) {\n                            $scope.req = {\n                                cloudsign_document: response.data,\n                                cloudsign_document_id: data.cloudsign_document,\n                            };\n                            $scope.loading_cloudsign = false;\n                        }, function(error) {\n                            var message = error.data;\n                            notifyService.showNotify(message, \u0027alert-danger\u0027);\n                            $scope.req = {\n                                cloudsign_document: null,\n                                cloudsign_document_id: data.cloudsign_document,\n                            };\n                        },\n                    );\n                }\n            }\n\n            // 忙聹聼忙聴楼氓陇聣忙聸麓莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聙聛莽虏戮莽庐聴忙聹聼忙聴楼茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥氓聡娄莽聬聠\n            if ($scope.form_data.request_data_json.expense \u0026\u0026\n                $scope.form_data.request_data_json.expense.settlement_flg ===\n                    Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg \u0026\u0026\n                $scope.form_data.request_data_json.expense.related_request\n            ) {\n                const related_request_expense = $scope.form_data.request_data_json.expense;\n                $q.all([\n                    SettlementDeadlineService.getSetting(related_request_expense.related_request_form_id),\n                    SettlementDeadlineService.getChangeDeadlinePastFreeItems(\n                        related_request_expense.related_request, $scope.request_id),\n                    SettlementDeadlineService.getSettlementDeadlineRequests(related_request_expense.related_request),\n                ]).then(function(results) {\n                    const setting = results[0];\n                    if (setting) {\n                        $scope.settlement_deadline.setting = setting;\n                        _setChangeDeadlineFreeItems(setting, results[1][\u0027request\u0027], results[1][\u0027modify\u0027]);\n                        $scope.settlement_request_errors.unselectable =\n                            !results[2].results[\u00270\u0027][\u0027exists_settlement_request\u0027];\n                    }\n                });\n            }\n\n            // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳忙聝\u0085氓聽卤茫聛庐氓聫聳氓戮聴\n            // 氓聬聞kind茫聛搂氓\u0085卤茅聙職茫聛搂氓聫聳氓戮聴茫聛聶茫聜聥氓驴\u0085猫娄聛茫聛聦茫聛聜茫聜聥茫聛聼茫聜聛茫聙聛茫聛聯茫聛聯茫聛搂氓聭录茫聛鲁氓聡潞茫聛聶茂录聢茅聺聻氓聬聦忙聹聼茂录聣\n            const custom_specific_promise = _getCustomSpecificsData(kind, specifics);\n\n            // 盲禄楼盲赂聥茫聙聛kind茫聛聰茫聛篓茫聛芦莽聲掳茫聛陋茫聜聥氓聡娄莽聬聠\n            if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.EDIT) {\n                $scope.form_data.title = $scope.form_data.request_data_json.title;\n                // 忙聹聙莽碌聜忙聣驴猫陋聧忙聴楼茫聛庐猫篓颅氓庐職\n                _setLastApprovalPeriod(data);\n                // 忙聹聙忙聳掳茫聛庐莽碌聦猫路炉氓聫聳氓戮聴\n                flow_promise = _getLatestFlow(flow_id);\n                // 忙聹聙忙聳掳茫聛庐茅聳虏猫娄搂猫聙\u0085氓聫聳氓戮聴\n                circulation_promise = getLatestCirculationUsers(flow_id, $scope.requester_info.requester_group_id);\n                // 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴茫聛庐氓聫聳氓戮聴\n                getRequestFiles();\n\n                // 氓聢聺忙聹聼莽聰鲁猫芦聥忙聶聜莽聜鹿茫聛庐茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢氓聠\u0085猫篓鲁茫聜聮氓聫聳氓戮聴\n                $scope.form_data.default_atp = angular.fromJson(data.request_data_json || \u0027null\u0027).default_atp || null;\n                // 氓聥陇忙聙聽茅聙拢忙聬潞盲潞陇茅聙職猫虏禄茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛茫聜鲁茫聝聰茫聝录茫聛炉茫聛搂茫聛聧茫聛娄茫聜聜莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聙聛茫聛聺茫聛庐忙聵聨莽麓掳茫聛芦茫聝聛茫聜搂茫聝聝茫聜炉茫聜聮茫聛陇茫聛聭茫聜聥茂录聢茫聜鲁茫聝聰茫聝录莽聰鲁猫芦聥茫聜聮盲赂聥忙聸赂茫聛聧盲驴聺氓颅聵茫聛聴茫聙聛茫聛聺茫聛庐盲赂聥忙聸赂茫聛聧茫聜聮莽路篓茅聸聠茫聛聶茫聜聥茫聙聛茫聛篓茫聛聞茫聛聠忙聶聜茫聛芦茫聛庐茫聛驴氓陆聯氓聡娄莽聬聠茫聛聦氓陆卤茅聼驴茫聛聶茫聜聥茂录聣\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n                    CreateRequestExpenseSpecificsService.setRowAsCopyKintaiTransport(\n                        $scope.form_data.request_data_json.expense.request_expense_specifics);\n                }\n\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聫聳氓戮聴茂录聢custom_specific_promise茂录聣茫聛庐莽碌聬忙聻聹茫聜聮氓戮\u0085茫聛聼茫聛陋茫聛聞茫聛篓茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐氓聽麓氓聬聢茫聛芦氓聠\u0085猫篓鲁茫聛聦氓聫聳茫聜聦茫聛職茫聙聛_setDefaultFlow茫聛聦莽漏潞茫聛露茫聜聤茫聛聶茫聜聥茫聛聼茫聜聛茫聙聛氓戮\u0085茫聛陇氓驴\u0085猫娄聛茫聛聦茫聛聜茫聜聥茫聙聜\n                $q.all([\n                    flow_promise,\n                    circulation_promise,\n                    extraflow_promise,\n                    custom_specific_promise,\n                ]).then(function(result) {\n                    $scope.flow_data = result[0];\n                    // 莽碌聦猫路炉氓聢聠氓虏聬茫聛搂茫聙聛莽聰鲁猫芦聥忙聝\u0085氓聽卤茫聜聮忙聢禄茫聛聶莽聰篓茫聛庐氓陇聣忙聲掳茫聛芦茫聜禄茫聝聝茫聝聢\n                    $scope.request_flow_data = angular.copy($scope.flow_data);\n                    $scope.flow_circulation_users = data.request_circulation_users || result[1];\n                    return _setLatestExchange();\n                }).then(function(){\n                    checkInvoiceRegistratedNumbers(false);\n                    setCirculationPositionAndUsers($scope.flow_circulation_users);\n                    _setDefaultFlow(data.request_form.flow, true, false);\n                    _getSumPaymentExchangeSpecificsAmount();\n                    // 氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n                    _setCompanyDataByRequest();\n                    _validatePayeeAndFormSettingForPayment(data.request_form.is_allowed_edit_payee);\n                    $scope.$broadcast(\u0027update_invalid_allocation_date_info\u0027);\n                });\n\n                // 莽聰鲁猫芦聥忙聶聜茫聛庐茅聤聙猫隆聦忙聝\u0085氓聽卤茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥\n                $scope.isDisplayBank = true;\n            }\n\n            if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                $scope.form_data.title = $scope.form_data.request_data_json.title;\n                // 忙聹聙莽碌聜忙聣驴猫陋聧忙聴楼茫聛庐猫篓颅氓庐職\n                _setLastApprovalPeriod(data);\n                // 莽碌聦猫路炉忙聝\u0085氓聽卤茫聛庐氓聫聳氓戮聴\n                flow_promise = CreateRequestFlowService.getModifyFlow($scope.request_id);\n                // 茫聜鲁茫聝隆茫聝鲁茫聝聢茫聛庐氓聫聳氓戮聴\n                comment_promise = getComment(request_id);\n                // 茅聳虏猫娄搂猫聙\u0085茫聛庐氓聫聳氓戮聴\n                circulation_promise = getCurrentCirculationUsers(request_id);\n                // 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴茫聛庐氓聫聳氓戮聴\n                getRequestFiles(kind);\n           