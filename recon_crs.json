          || isSpecificsSheet()\n                    ) {\n                        $scope.form_data.payment.is_user_payment_format = true;\n                    }\n                }\n            }\n            else if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EC) { // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥\n                $scope.form_data.ec = $scope.form_data.request_data_json.ec;\n                // 忙聵聨莽麓掳茫聛芦氓聲聠氓聯聛茫聛聦氓\u0085楼茫聛拢茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛氓聧聵盲戮隆茫聛庐莽篓聨猫戮录茫聙聛莽篓聨忙聤聹茫聜聮氓聢陇氓庐職\n                if (!angular.isUndefinedOrNull($scope.form_data.ec.request_ec_specifics_rows)\n                    \u0026\u0026 $scope.form_data.ec.request_ec_specifics_rows.length \u003e 0) {\n                    $scope.form_data.ec.tax_included = RequestEcService.isTaxIncludedFromRequest(\n                        $scope.form_data.ec.request_ec_specifics_rows\n                    );\n                }\n                // EC茫聜碌茫聜陇茫聝聢茫聛聥茫聜聣茫聛庐茫聜鲁茫聝录茫聝芦茫聝聬茫聝聝茫聜炉茫聛搂茫聛聜茫聜聦茫聛掳茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛聥茫聜聣茫聝聡茫聝录茫聜驴茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n                const ec_session_data_promise = getEcCallBackSessionData();\n                ec_session_data_promise.then(function(result) {\n                    // EC茫聜碌茫聜陇茫聝聢茫聛聥茫聜聣茫聜鲁茫聝录茫聝芦茫聝聬茫聝聝茫聜炉茫聛聲茫聜聦茫聛聼氓聽麓氓聬聢茫聛庐茫聛驴茫聙聛茫聜鹿茫聝聢茫聝卢茫聝录茫聜赂茫聜聞茫聜禄茫聝聝茫聜路茫聝搂茫聝鲁茫聛庐茫聝聡茫聝录茫聜驴茫聜聮莽聰鲁猫芦聥茫聛芦氓聫聧忙聵聽茫聛聶茫聜聥\n                    if (result.CALLBACK_FROM_EC_FLG) {\n                        getEcEvacuationData(result);\n                    }\n                });\n            }\n\n            // 莽聰鲁猫芦聥盲驴庐忙颅拢忙聶聜茫聛庐盲驴庐忙颅拢氓聣聧忙聝\u0085氓聽卤茫聜聮茫聜鲁茫聝聰茫聝录\n            if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                form_data_old = angular.copy($scope.form_data);\n                last_approval_period_old = angular.copy($scope.last_approval_period);\n                // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聛炉氓陇聳茅聝篓EC茫聜碌茫聜陇茫聝聢茫聛赂茫聛庐莽聰禄茅聺垄茅聛路莽搂禄茫聛聦莽聶潞莽聰聼茫聛聶茫聜聥茫聛聼茫聜聛localStorage茫聛芦茫聜聜茅聙聙茅聛驴茫聛聶茫聜聥\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EC) {\n                    const accessor = EcStorageAccessorService.ecStorageData;\n                    if (angular.isUndefinedOrNull(accessor.getStorageData(EcConst.evacuation.CALLBACK_FLG))) {\n                        accessor.setStorageData(EcConst.evacuation.FORM_DATA_OLD, angular.toJson(form_data_old));\n                        accessor.setStorageData(\n                            EcConst.evacuation.LAST_APPROVAL_PERIOD_OLD, angular.toJson(last_approval_period_old)\n                        );\n                    }\n                }\n                $scope.modify_logs = angular.fromJson(data.modify_logs);\n            }\n            updateTotalAmount();\n            readBoxFolderName($scope.form_data.form_id);\n            generateTitleAuto();\n            // 氓聥陇忙聙聽忙聣聯氓聢禄茅聙拢忙聬潞忙聝\u0085氓聽卤氓聫聳氓戮聴\n            _getAttendanceSettings();\n        })\n        .catch(function (res) {\n            var data = res.data;\n            $scope.is_request_error = true;\n            // 茫聝聭茫聝录茫聝聼茫聝聝茫聜路茫聝搂茫聝鲁茫聜篓茫聝漏茫聝录茫聛聦莽聶潞莽聰聼茫聛聶茫聜聥莽篓庐茅隆聻\n            const permissonErrorKinds = [\n                Const.miscellaneous.CREATE_REQUEST_KIND.COPY,\n                Const.miscellaneous.CREATE_REQUEST_KIND.FEEDBACK,\n                Const.miscellaneous.CREATE_REQUEST_KIND.EDIT,\n            ];\n            // eslint-disable-next-line es5/no-es6-methods\n            if (res.status == 403 \u0026\u0026 permissonErrorKinds.includes(kind) ) {\n                const error_message = data.detail;\n                notifyService.showNotify(error_message, \u0027alert-danger\u0027);\n            } else {\n                $scope.error_message = data;\n                if (!util.isUndefinedOrNull(data.error_message)) {\n                    notifyService.showNotify(data.error_message, \u0027alert-danger\u0027);\n                }\n            }\n            $location.path(\u0027/myrequests/\u0027);\n        });\n    }\n\n    /**\n     * 氓聫聳氓录聲氓\u0085聢茅聛赂忙聤聻茫聛庐氓\u0085楼氓聤聸茫聝聡茫聝录茫聜驴茫聜聮忙聹聙忙聳掳氓聦聳茫聛聶茫聜聥\n     * @param {array} form_items 茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐盲赂聙猫娄搂\n     * @private\n     */\n    function _setLatestCompanyToFormItem(form_items) {\n        // 茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐茫聛聦莽聞隆茫聛聞氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if (util.isUndefinedOrNull(form_items)) {\n            return;\n        }\n\n        const target_form_items = form_items.filter((form_item) =\u003e\n            form_item.item_type === Const.form.ITEM_TYPE_COMPANY\n            \u0026\u0026 !util.isUndefinedOrNull(form_item.company_id)\n        );\n        const company_ids = [...new Set(target_form_items.map((item) =\u003e item.company_id))];\n        // 茫聝聲茫聜漏茫聝录茫聝聽茅聽\u0085莽聸庐茫聛聦茫聛聜茫聛拢茫聛娄茫聜聜茫聙聛氓聫聳氓录聲氓\u0085聢茅聛赂忙聤聻茫聛庐茅聽\u0085莽聸庐茫聛聦莽聞隆茫聛聞茫聙聛忙聹聣茫聛拢茫聛娄茫聜聜氓聫聳氓录聲氓\u0085聢id茫聛聦莽聞隆茫聛聭茫聜聦茫聛掳盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if (company_ids.length === 0) {\n            return;\n        }\n        createRequestService.getCompanyListByIds(company_ids).then((res) =\u003e {\n            const res_data_map = {};\n            res.data.forEach((res_data) =\u003e {\n                res_data_map[res_data.id] = res_data;\n            });\n            target_form_items.filter((form_item) =\u003e\n                !util.isUndefinedOrNull(res_data_map[form_item.company_id])\n            ).forEach((form_item) =\u003e {\n                const latest_company = res_data_map[form_item.company_id];\n                form_item.custom_company = latest_company.name;\n                form_item.request_content = latest_company.name;\n            });\n        });\n    }\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐忙聵聨莽麓掳猫隆聦茫聛庐莽聜潞忙聸驴茫聝卢茫聝录茫聝聢茫聜聮忙聹聙忙聳掳茫聛芦茫聛聴茫聛娄茅聡聭茅隆聧茫聜聮氓聠聧猫篓聢莽庐聴茫聛聶茫聜聥\n     * @private\n     * 莽聰鲁猫芦聥盲赂聤茫聛庐忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄猫隆篓莽陇潞氓聢露氓戮隆茫聝聲茫聝漏茫聜掳茫聛庐茫聛驴茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * 莽聸庐莽職聞茫聛炉request_data_json茫聛聥茫聜聣氓聫聳氓戮聴茫聛聶茫聜聥茫聛篓茫聝聠茫聝录茫聝聳茫聝芦茫聛篓氓路庐莽聲掳茫聛聦氓聡潞茫聜聥茫聛聼茫聜聛茫聝聠茫聝录茫聝聳茫聝芦茫聛聥茫聜聣氓聫聳氓戮聴\n     * @private\n     */\n    function _setCompanyIsShowFlagsByRequest() {\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            return;\n        }\n\n        _complementCompanyDataByRequestPayment();\n    }\n\n    /**\n     * 忙聣聥氓陆聯氓聬聢猫篓聢茅聡聭茅隆聧茫聛庐氓聠聧猫篓聢莽庐聴\n     * @private\n     */\n    function _recalcAllowanceAmount() {\n        // 莽碌聦猫虏禄莽虏戮莽庐聴盲禄楼氓陇聳茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n        if ($scope.form_type !== Const.miscellaneous._FORM_TYPE.EXPENSE.type) {\n            return;\n        }\n        const expense_data = $scope.form_data.expense;\n        const specifics = expense_data.request_expense_specifics;\n        // 忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐氓聽麓氓聬聢茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n        if (util.isUndefinedOrNull(specifics)) {\n            return;\n        }\n\n        specifics.map((specific) =\u003e {\n            // 忙聣聥氓陆聯忙聵聨莽麓掳盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n            if (specific.specifics_type !== Const.miscellaneous.EXPENSE_SPECIFICS_ALLOWANCE) {\n                return specific;\n            }\n            const specificsRows = specific.request_expense_specifics_rows;\n            specificsRows.map((row) =\u003e {\n                if (!row.is_manual_input) {\n                    // 忙聣聥氓聥聲氓\u0085楼氓聤聸茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳茫聜鹿茫聜颅茫聝聝茫聝聴\n                    return row;\n                }\n                if (\n                    util.isUndefinedOrNull(row.allowance_amount) ||\n                    util.isUndefinedOrNull(row.applying_days) ||\n                    !angular.isNumber(row.allowance_amount) ||\n                    !angular.isNumber(row.applying_days)\n                ) {\n                    // 忙聣聥氓陆聯氓聧聵盲戮隆茫聙聛忙聲掳茅聡聫茫聛聦茫聛陋茫聛聞茫聙聛茫聜聜茫聛聴茫聛聫茫聛炉忙聲掳氓聙陇盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聙聛氓聬聢猫篓聢茅聡聭茅隆聧茫聜聮null茫聛篓茫聛聶茫聜聥\n                    row.amount = null;\n                    row.is_manual_input = 0;\n                    return row;\n                }\n                // 氓聬聢猫篓聢茅聡聭茅隆聧茫聜聮氓聠聧猫篓聢莽庐聴\n                row.amount = row.allowance_amount * row.applying_days;\n                row.is_manual_input = 0;\n                return row;\n            });\n            return specific;\n        });\n    }\n\n    /**\n     * 莽聰鲁猫芦聥盲赂聤茫聛庐忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * 茫聛聼茫聛聽茫聛聴茫聙聛盲陆聫忙聣聙茫聜聞忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤茫聛炉氓聫聳氓录聲氓\u0085聢茫聛庐猫篓颅氓庐職忙卢隆莽卢卢茫聛搂茫聛炉氓聫聳氓戮聴茫聛聲茫聜聦茫聛陋茫聛聞\n     * 莽聸庐莽職聞茫聛炉request_data_json茫聛聥茫聜聣氓聫聳氓戮聴茫聛聶茫聜聥茫聛篓茫聝聠茫聝录茫聝聳茫聝芦茫聛篓氓路庐莽聲掳茫聛聦氓聡潞茫聜聥茫聛聼茫聜聛茫聝聠茫聝录茫聝聳茫聝芦茫聛聥茫聜聣氓聫聳氓戮聴\n     * @private\n     */\n    function _setCompanyDataByRequest() {\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            return;\n        }\n\n        // 氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聛庐茅聽\u0085莽聸庐\n        const companyProperties = [\n            \u0027name\u0027, // company_name\n            \u0027zip_code\u0027,\n            \u0027address\u0027,\n            \u0027bank_code\u0027,\n            \u0027bank_name\u0027,\n            \u0027bank_name_kana\u0027,\n            \u0027branch_code\u0027,\n            \u0027branch_name\u0027,\n            \u0027branch_name_kana\u0027,\n            \u0027bank_account_type_code\u0027,\n            \u0027bank_account_type_name\u0027,\n            \u0027bank_account_code\u0027,\n            \u0027bank_account_name\u0027,\n            \u0027bank_account_name_kana\u0027,\n            \u0027company_code\u0027,\n            \u0027invoice_registrated_number\u0027,\n            \u0027invoice_check_result\u0027,\n            \u0027is_show_address\u0027,\n            \u0027is_show_payee\u0027,\n        ];\n        // 莽聰鲁猫芦聥茫聛庐忙聵聨莽麓掳猫隆篓茫聛庐忙聹聣莽聞隆茫聛搂氓聢聠氓虏聬\n        if (!$scope.isSpecificsSheet() || $scope.form_data.payment.is_payee_per_request) {\n            // 忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐氓聽麓氓聬聢\n            _setCompanyDataByRequestPaymentNoSpecifics(companyProperties);\n        }\n        else {\n            // 忙聵聨莽麓掳茫聛聜茫聜聤茫聛庐氓聽麓氓聬聢\n            _setCompanyDataByRequestDefaultPaymentSpecifics(companyProperties);\n        }\n    }\n\n    /**\n     * 莽聰鲁猫芦聥盲赂聤茫聛庐忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * 茫聛聼茫聛聽茫聛聴茫聙聛盲陆聫忙聣聙茫聜聞忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤茫聛炉氓聫聳氓录聲氓\u0085聢茫聛庐猫篓颅氓庐職忙卢隆莽卢卢茫聛搂茫聛炉氓聫聳氓戮聴茫聛聲茫聜聦茫聛陋茫聛聞\n     * @param {array} companyProperties 氓聫聳氓录聲氓\u0085聢茫聛庐茅聽\u0085莽聸庐氓聬聧茫聛庐茫聝陋茫聜鹿茫聝聢\n     * @private\n     */\n    function _setCompanyDataByRequestPaymentNoSpecifics(companyProperties) {\n        if (\n            $scope.form_data.payment.is_new_company\n            || !$scope.form_data.payment.company_id\n        ) {\n            return;\n        }\n        CompanyService.getRequestSecuredCompanyList($scope.request_id).then(function (res) {\n            // 氓聬聞忙聵聨莽麓掳猫隆聦茫聛芦茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥茫聛聼茫聜聛茫聛芦茫聙聛氓聫聳氓戮聴茫聝聡茫聝录茫聜驴茫聛搂{氓聫聳氓录聲氓\u0085聢id:氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤}茫聛庐茫聝聻茫聝聝茫聝聰茫聝鲁茫聜掳茫聜聮盲陆聹忙聢聬\n            const resDataMap = res.data.reduce((acc, resData) =\u003e {\n                acc[resData.id] = resData;\n                return acc;\n            }, {});\n            const companyData = resDataMap[$scope.form_data.payment.company_id];\n            // 氓聫聳氓录聲氓\u0085聢茫聛聦猫娄聥茫聛陇茫聛聥茫聜聣茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉猫隆篓莽陇潞氓聢露氓戮隆茫聝聲茫聝漏茫聜掳茫聛庐茫聛驴false茫聛芦茫聛聶茫聜聥\n            if (!companyData) {\n                $scope.form_data.payment.is_show_address = false;\n                $scope.form_data.payment.is_show_payee = false;\n                return;\n            }\n            companyProperties.forEach((key) =\u003e {\n                if (companyData.deleted) {\n                    // 氓聫聳氓录聲氓\u0085聢茫聛聦氓聣聤茅聶陇忙赂聢茫聛驴茫聛庐氓聽麓氓聬聢茫聛炉氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聢聺忙聹聼氓聦聳\n                    if (key === \u0027name\u0027) {\n                        $scope.form_data.payment.company_name = null;\n                    } else {\n                        $scope.form_data.payment[key] = null;\n                    }\n                }\n                else if (key === \u0027name\u0027) {\n                    $scope.form_data.payment.company_name = companyData[key];\n                } else {\n                    $scope.form_data.payment[key] = companyData[key];\n                }\n            });\n            if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.COPY \u0026\u0026 companyData.deleted) {\n                // 茫聜鲁茫聝聰茫聝录氓\u0085聝莽聰鲁猫芦聥茫聛庐氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓录聲氓\u0085聢ID茫聜聮忙聺隆盲禄露茫聛芦氓聫聳氓戮聴氓聡潞忙聺楼茫聛陋茫聛聥茫聛拢茫聛聼氓聽麓氓聬聢\n                notifyService.showNotify(\n                    gettextCatalog.getString(\u0027茫聝聻茫聜鹿茫聜驴茫聛庐忙聝\u0085氓聽卤茫聛聦氓陇聣忙聸麓茫聛戮茫聛聼茫聛炉茫聙聛氓聣聤茅聶陇茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聼茫聜聛茫聙聛盲赂聙茅聝篓茫聛庐茅聽\u0085莽聸庐茫聛炉茫聜鲁茫聝聰茫聝录茫聛聲茫聜聦茫聛戮茫聛聸茫聜聯茫聛搂茫聛聴茫聛聼茫聙聜\u0027),\n                    \u0027alert-danger\u0027,\n                );\n            }\n        }).catch(function () {\n            // dismiss\n        });\n    }\n\n    /**\n     * 忙聰炉忙聣聲氓\u0085聢茫聛庐氓聫聳氓录聲氓\u0085聢茫聛庐盲陆聫忙聣聙茫聜聞忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮猫拢聹氓庐聦茫聛聶茫聜聥\n     * @private\n     */\n    function _complementCompanyDataByRequestPayment() {\n        const isHeaderCompany = (!$scope.isSpecificsSheet() || $scope.form_data.payment.is_payee_per_request) \u0026\u0026 $scope.form_data.payment.is_company_payment_format;\n\n        RequestService.getRequestPayment($scope.request_id).then(function (response) {\n            const requestPayment = response.data;\n            // 茫聝聵茫聝聝茫聝聙茫聝录茫聛庐氓聫聳氓录聲氓\u0085聢茫聛庐氓聽麓氓聬聢\n            if (isHeaderCompany) {\n                _mergeCompanyData($scope.form_data.payment, requestPayment);\n                if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                    // 盲驴庐忙颅拢氓聣聧茫聛庐忙聝\u0085氓聽卤茫聜聮氓聠聧茫聜鲁茫聝聰茫聝录\n                    form_data_old.payment = angular.copy($scope.form_data.payment);\n                }\n                return;\n            }\n\n            // 忙聵聨莽麓掳猫隆聦茫聛庐氓聫聳氓录聲氓\u0085聢茫聛庐氓聽麓氓聬聢\n            const defaultPayeeCompanySpecifics = requestPayment.request_payment_specifics.filter((sheet) =\u003e\n                !CustomSpecificsService.isCustomSpecifics(sheet)\n                \u0026\u0026 sheet.specifics_type === Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL\n            );\n            const isNotNewCompany = (row) =\u003e (\n                (!util.isUndefinedOrNull(row.company_id) || !util.isUndefinedOrNull(row.company)) \u0026\u0026 !row.is_new_company\n            );\n            const targetSheets = defaultPayeeCompanySpecifics.map((sheet) =\u003e\n                sheet.request_payment_specifics_normal.filter((row) =\u003e isNotNewCompany(row))\n            );\n            // specifics_row_number 忙聵聨莽麓掳猫隆聦莽聲陋氓聫路茫聛聰茫聛篓茫聛芦忙聵聨莽麓掳猫隆聦茫聜聮茫聝聻茫聝聝茫聝聰茫聝鲁茫聜掳\n            const specifics_row_number_map = {};\n            targetSheets.forEach((rows) =\u003e {\n                rows.forEach((row) =\u003e {\n                    specifics_row_number_map[row.specifics_row_number] = row;\n                });\n            });\n\n            // 氓陆垄氓录聫茫聛聦氓聫聳氓录聲氓\u0085聢盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聙聛盲禄楼茅聶聧茫聛庐盲驴庐忙颅拢氓聣聧忙聝\u0085氓聽卤氓聫聳氓戮聴氓聡娄莽聬聠茫聛炉盲赂聧猫娄聛茫聛陋茫聛聼茫聜聛return茫聛聶茫聜聥\n            if (!$scope.form_data.payment.is_company_payment_format) {\n                return;\n            }\n            const scopeTargetSheets = $scope.form_data.payment.request_payment_specifics.filter((sheet) =\u003e\n                !CustomSpecificsService.isCustomSpecifics(sheet)\n                \u0026\u0026 sheet.specifics_type === Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL\n            ).map((sheet) =\u003e\n                sheet.request_payment_specifics_rows.filter((row) =\u003e isNotNewCompany(row))\n            );\n\n            scopeTargetSheets.forEach((rows) =\u003e {\n                rows.forEach((row) =\u003e {\n                    // 氓聫聳氓戮聴茫聝聻茫聝聝茫聝聰茫聝鲁茫聜掳茫聝聡茫聝录茫聜驴茫聜聮莽聰鲁猫芦聥氓聠\u0085茫聛庐氓聬聞忙聵聨莽麓掳茫聛庐氓聬聞忙聵聨莽麓掳猫隆聦茫聛聥茫聜聣忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢茫聛芦茫聜禄茫聝聝茫聝聢\n                    const companyData = specifics_row_number_map[row.specifics_row_number];\n                    // 氓聫聳氓录聲氓\u0085聢茫聛聦猫娄聥茫聛陇茫聛聥茫聜聣茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉猫隆篓莽陇潞氓聢露氓戮隆茫聝聲茫聝漏茫聜掳茫聛庐茫聛驴false茫聛芦茫聛聶茫聜聥\n                    if (!companyData) {\n                        row.is_show_address = false;\n                        row.is_show_payee = false;\n                        return;\n                    }\n                    _mergeCompanyData(row, companyData);\n                });\n            });\n            if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                // 盲驴庐忙颅拢氓聣聧茫聛庐忙聝\u0085氓聽卤茫聜聮氓聠聧茫聜鲁茫聝聰茫聝录\n                form_data_old.payment = angular.copy($scope.form_data.payment);\n                if (!util.isUndefinedOrNull($scope.originalPaymentDueDate)){\n                    // 茅聙聙茅聛驴茫聛聴茫聛娄茫聛聞茫聛聼忙聰炉茅\u0085聧盲潞聢氓庐職忙聴楼茫聛芦忙聢禄茫聛聶茂录聢氓聠聧猫篓聢莽庐聴茫聛聲茫聜聦茫聛聼忙聰炉忙聣聲盲潞聢氓庐職忙聴楼茫聛聦old茫聛芦氓\u0085楼茫聜聣茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦氓炉戮氓驴聹茂录聣\n                    form_data_old.payment.payment_due_date = $scope.originalPaymentDueDate;\n                }\n            }\n        });\n    }\n\n    /**\n     * 莽聰禄茅聺垄氓聛麓茫聛庐忙聰炉忙聣聲茫聝聡茫聝录茫聜驴茫聛芦氓聫聳氓录聲氓\u0085聢茫聝聡茫聝录茫聜驴茫聜聮氓聫聳茫聜聤猫戮录茫聜聙\n     * @param {object} paymentData 莽聰禄茅聺垄氓聛麓茫聛庐忙聰炉忙聣聲茫聝聡茫聝录茫聜驴\n     * @param {object} companyData 氓聫聳茫聜聤猫戮录茫聜聙氓聫聳氓录聲氓\u0085聢茫聝聡茫聝录茫聜驴\n     * @private\n     */\n    function _mergeCompanyData(paymentData, companyData) {\n        // 氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聛庐茅聽\u0085莽聸庐\n        const companyProperties = [];\n        const companyOnlyProperties = [\n            \u0027is_show_address\u0027,\n            \u0027is_show_payee\u0027,\n        ];\n        const companyAddressProperties = [\n            \u0027zip_code\u0027,\n            \u0027address\u0027,\n        ];\n        const companyPayeeProperties = [\n            \u0027bank_code\u0027,\n            \u0027bank_name\u0027,\n            \u0027bank_name_kana\u0027,\n            \u0027branch_code\u0027,\n            \u0027branch_name\u0027,\n            \u0027branch_name_kana\u0027,\n            \u0027bank_account_type_code\u0027,\n            \u0027bank_account_type_name\u0027,\n            \u0027bank_account_code\u0027,\n            \u0027bank_account_name\u0027,\n            \u0027bank_account_name_kana\u0027,\n        ];\n        // 莽聰禄茅聺垄氓聛麓茫聛炉茫聙聦猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞茫聙聧茫聛搂茫聙聛忙聹聙忙聳掳茫聛庐氓聫聳氓录聲氓\u0085聢茫聛炉茫聙聦猫隆篓莽陇潞茫聛聶茫聜聥茫聙聧茫聛庐氓聽麓氓聬聢茫聛炉猫拢聹氓庐聦茫聛聶茫聜聥\n        if (companyData.company) {\n            if (!paymentData.is_show_address \u0026\u0026 companyData.company.is_show_address) {\n                companyProperties.push(...companyAddressProperties);\n            }\n            if (!paymentData.is_show_payee \u0026\u0026 companyData.company.is_show_payee) {\n                companyProperties.push(...companyPayeeProperties);\n            }\n            // 氓聫聳氓录聲氓\u0085聢茫聛聴茫聛聥忙聦聛茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞茅聽\u0085莽聸庐\n            companyOnlyProperties.forEach((key) =\u003e {\n                paymentData[key] = companyData.company[key];\n            });\n        }\n        companyProperties.forEach((key) =\u003e {\n            paymentData[key] = companyData[key];\n        });\n        paymentData[\u0027source_id\u0027] = companyData[\u0027id\u0027];\n        paymentData[\u0027is_company_reselected\u0027] = false;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥盲赂聤茫聛庐忙聵聨莽麓掳猫隆篓茫聛庐忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥\n     * 茫聛聼茫聛聽茫聛聴茫聙聛盲陆聫忙聣聙茫聜聞忙聰炉忙聣聲氓\u0085聢忙聝\u0085氓聽卤茫聛炉氓聫聳氓录聲氓\u0085聢茫聛庐猫篓颅氓庐職忙卢隆莽卢卢茫聛搂茫聛炉氓聫聳氓戮聴茫聛聲茫聜聦茫聛陋茫聛聞\n     * @param {array} companyProperties 氓聫聳氓录聲氓\u0085聢茫聛庐茅聽\u0085莽聸庐氓聬聧茫聛庐茫聝陋茫聜鹿茫聝聢\n     * @private\n     */\n    function _setCompanyDataByRequestDefaultPaymentSpecifics(companyProperties) {\n        // 茫聛聼茫聛聽茫聛聴茫聙聛茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛炉氓聢楼氓聡娄莽聬聠茫聛搂氓聫聳氓戮聴茫聛聴茫聛娄茫聛聞茫聜聥茫聛庐茫聛搂茫聙聛茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢忙聵聨莽麓掳茫聛庐茫聛驴氓炉戮猫卤隆茫聛篓茫聛聶茫聜聥\n        // 莽聰鲁猫芦聥氓聠\u0085茫聛庐氓聬聞忙聵聨莽麓掳茫聛庐氓聬聞忙聵聨莽麓掳猫隆聦茫聛聥茫聜聣忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢茫聜聮忙聤陆氓聡潞\n        const defaultPayeeCompanySpecifics = $scope.form_data.payment.request_payment_specifics.filter((sheet) =\u003e\n            !CustomSpecificsService.isCustomSpecifics(sheet)\n            \u0026\u0026 sheet.specifics_type === Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL\n        );\n        const isNotNewCompany = (row) =\u003e !util.isUndefinedOrNull(row.company_id) \u0026\u0026 !row.is_new_company;\n        const targetSheets = defaultPayeeCompanySpecifics.map((sheet) =\u003e\n            sheet.request_payment_specifics_rows.filter((row) =\u003e isNotNewCompany(row))\n        );\n\n        // 氓聫聳氓戮聴茫聛聴茫聛聼茫聛聞氓聫聳氓录聲氓\u0085聢茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜茫聛聴茫聛陋茫聛聞\n        if (!targetSheets.length) {\n            return;\n        }\n\n        // 忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢茫聛庐忙聝\u0085氓聽卤茫聜聮茫聛戮茫聛篓茫聜聛茫聛娄氓聫聳氓戮聴\n        CompanyService.getRequestSecuredCompanyList($scope.request_id).then(function (res) {\n            // 氓聬聞忙聵聨莽麓掳猫隆聦茫聛芦茫聜禄茫聝聝茫聝聢茫聛聶茫聜聥茫聛聼茫聜聛茫聛芦茫聙聛氓聫聳氓戮聴茫聝聡茫聝录茫聜驴茫聛搂{氓聫聳氓录聲氓\u0085聢id:氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤}茫聛庐茫聝聻茫聝聝茫聝聰茫聝鲁茫聜掳茫聜聮盲陆聹忙聢聬\n            const resDataMap = res.data.reduce((acc, resData) =\u003e {\n                acc[resData.id] = resData;\n                return acc;\n            }, {});\n            let _deleted = false;\n            targetSheets.forEach((rows) =\u003e {\n                rows.forEach((row) =\u003e {\n                    // 氓聫聳氓戮聴茫聝聻茫聝聝茫聝聰茫聝鲁茫聜掳茫聝聡茫聝录茫聜驴茫聜聮莽聰鲁猫芦聥氓聠\u0085茫聛庐氓聬聞忙聵聨莽麓掳茫聛庐氓聬聞忙聵聨莽麓掳猫隆聦茫聛聥茫聜聣忙聴垄氓颅聵氓聫聳氓录聲氓\u0085聢茫聛芦茫聜禄茫聝聝茫聝聢\n                    const companyData = resDataMap[row.company_id];\n                    // 氓聫聳氓录聲氓\u0085聢茫聛聦猫娄聥茫聛陇茫聛聥茫聜聣茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉猫隆篓莽陇潞氓聢露氓戮隆茫聝聲茫聝漏茫聜掳茫聛庐茫聛驴false茫聛芦茫聛聶茫聜聥\n                    if (!companyData) {\n                        row.is_show_address = false;\n                        row.is_show_payee = false;\n                        return;\n                    }\n\n                    // 氓聫聳氓录聲氓\u0085聢茫聛聦氓聣聤茅聶陇忙赂聢茫聛驴茫聛庐氓聽麓氓聬聢茫聛炉茫聝聲茫聝漏茫聜掳茫聜聮茫聛聼茫聛娄茫聜聥\n                    _deleted = _deleted || companyData.deleted;\n\n                    companyProperties.forEach((key) =\u003e {\n                        // 氓聫聳氓录聲氓\u0085聢茫聛聦氓聣聤茅聶陇忙赂聢茫聛驴茫聛庐氓聽麓氓聬聢茫聛炉氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聢聺忙聹聼氓聦聳\n                        if (companyData.deleted) {\n                            if (key === \u0027name\u0027) {\n                                row.company_name = null;\n                            } else {\n                                row[key] = null;\n                            }\n                        }\n                        else if (key === \u0027name\u0027) {\n                            row.company_name = companyData[key];\n                        } else {\n                            row[key] = companyData[key];\n                        }\n                    });\n                });\n            });\n            if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.COPY) {\n                // 茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛搂氓聣聤茅聶陇茫聛聲茫聜聦茫聛聼氓聫聳氓录聲氓\u0085聢茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢忙聹聣氓聤鹿茫聛芦茫聛聶茫聜聥\n                const has_deleted_for_custom = $scope.form_data.payment.request_payment_specifics.some((specifics) =\u003e\n                    specifics.request_payment_specifics_rows.some((row) =\u003e row._is_company_deleted_for_message));\n                if (_deleted || has_deleted_for_custom) {\n                    // 茫聜鲁茫聝聰茫聝录氓\u0085聝莽聰鲁猫芦聥茫聛庐氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聫聳氓录聲氓\u0085聢ID茫聜聮忙聺隆盲禄露茫聛芦氓聫聳氓戮聴氓聡潞忙聺楼茫聛陋茫聛聥茫聛拢茫聛聼氓聽麓氓聬聢\n                    notifyService.showNotify(\n                        gettextCatalog.getString(\u0027茫聝聻茫聜鹿茫聜驴茫聛庐忙聝\u0085氓聽卤茫聛聦氓陇聣忙聸麓茫聛戮茫聛聼茫聛炉茫聙聛氓聣聤茅聶陇茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聼茫聜聛茫聙聛盲赂聙茅聝篓茫聛庐茅聽\u0085莽聸庐茫聛炉茫聜鲁茫聝聰茫聝录茫聛聲茫聜聦茫聛戮茫聛聸茫聜聯茫聛搂茫聛聴茫聛聼茫聙聜\u0027),\n                        \u0027alert-danger\u0027,\n                    );\n                }\n            }\n        }).catch(function () {\n            // dismiss\n        });\n    }\n\n    /**\n     * 茫聜芦茫聜鹿茫聜驴茫聝聽忙聰炉忙聣聲盲戮聺茅聽录忙聵聨莽麓掳(氓聫聳氓录聲氓\u0085聢茫聝禄莽聜潞忙聸驴茫聝卢茫聝录茫聝聢茫聙聛茫聝娄茫聝录茫聜露茫聝禄莽聜潞忙聸驴茫聝卢茫聝录茫聝聢)茫聛庐忙聵聨莽麓掳猫隆聦茫聛庐莽聜潞忙聸驴茫聝卢茫聝录茫聝聢茫聜聮忙聹聙忙聳掳茫聛芦茫聛聴茫聛娄茅聡聭茅隆聧茫聜聮氓聠聧猫篓聢莽庐聴茫聛聶茫聜聥\n     */\n    function _setLatestExchange() {\n        switch ($scope.form_type) {\n            case Const.miscellaneous.FORM_TYPE_EXPENSE:\n                return RequestExpenseService.setLatestExchange($scope.form_type, $scope.form_data);\n            case Const.miscellaneous.FORM_TYPE_PAYMENT:\n                return RequestPaymentService.setLatestExchange($scope.form_type, $scope.form_data);\n            default:\n                return Promise.resolve();\n        }\n    }\n\n    /**\n     * 茫聙聦氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛庐氓聫炉氓聬娄茫聙聧茫聛庐茫聝聲茫聝漏茫聜掳茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @param {string} kind 莽聰鲁猫芦聥盲陆聹忙聢聬莽篓庐氓聢楼\n     * @param {number} request_id 莽聰鲁猫芦聥忙聸赂ID\n     * @param {object} request_form 莽聰鲁猫芦聥茫聝聲茫聜漏茫聝录茫聝聽\n     * @return {promise}\n     * @private\n     */\n    function _getIsAllowedEditPayee(kind, request_id, request_form) {\n        const deferred = $q.defer();\n        const pendRequestKinds = [\n            Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY,\n            Const.miscellaneous.CREATE_REQUEST_KIND.FEEDBACK,\n        ];\n        $scope.form_data.payment.before_is_allowed_edit_payee = $scope.form_data.payment.is_allowed_edit_payee;\n        // 莽聰鲁猫芦聥盲驴庐忙颅拢茫聝禄氓聠聧莽聰鲁猫芦聥茫聛庐忙聶聜茫聛炉忙聰炉忙聣聲盲戮聺茅聽录莽聰篓莽聰鲁猫芦聥茫聝聡茫聝录茫聜驴茫聛聥茫聜聣氓聫聳氓戮聴\n        if(pendRequestKinds.includes(kind)) {\n            RequestPaymentService.getRequestPaymentLite(request_id).then((response) =\u003e {\n                deferred.resolve(response.data.is_allowed_edit_payee);\n            });\n        // 茫聛聺茫聜聦盲禄楼氓陇聳茫聛炉莽聰鲁猫芦聥茫聝聲茫聜漏茫聝录茫聝聽茫聛聥茫聜聣氓聫聳氓戮聴\n        } else {\n            deferred.resolve(request_form.is_allowed_edit_payee);\n        }\n        return deferred.promise;\n    }\n\n    /**\n     * 忙聰炉忙聣聲盲戮聺茅聽录茫聛庐忙聵聨莽麓掳茫聛庐茫聜鲁茫聝聰茫聝录忙聶聜茫聛芦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛聦猫篓卤氓聫炉茫聛聲茫聜聦茫聛娄茫聛聤茫聜聣茫聛職茫聙聛茫聛聥茫聛陇忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛聦氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聛炉氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n     * @return {bool} true: 氓聣聤茅聶陇茫聛聜茫聜聤茫聙聛false: 氓聣聤茅聶陇茫聛陋茫聛聴\n     */\n    function _deleteNewCompanyByCopy() {\n        /**\n         * 忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢氓聫聳氓录聲氓\u0085聢忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n         * @param {object} data 忙聵聨莽麓掳茫聛陋茫聛聴茫聙聛茫聜聜茫聛聴茫聛聫茫聛炉忙聵聨莽麓掳猫隆聦\n         * @return {bool} true: 氓聣聤茅聶陇茫聛聜茫聜聤茫聙聛false: 氓聣聤茅聶陇茫聛陋茫聛聴\n         */\n        function _deleteNewCompany(data) {\n            // 氓聫聳氓录聲氓\u0085聢茫聛聦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茂录聢company_id茫聛聦null茂录聣茫聛庐氓聽麓氓聬聢茫聙聛盲录職莽陇戮忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n            // 忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢莽聶禄茅聦虏莽聰篓茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦氓聫聳氓录聲氓\u0085聢茫聜鲁茫聝录茫聝聣茫聛庐氓\u0085楼氓聤聸忙卢聞茫聛聦茫聛陋茫聛聞茫聛聼茫聜聛company_code茫聛庐氓聢聺忙聹聼氓聦聳茫聛炉盲赂聧猫娄聛\n            if (data.is_new_company) {\n                data.company_name = null;\n                data.company_code = null;\n                data.is_new_company = false;\n                data.zip_code = null;\n                data.address = null;\n                data.bank_account_code = null;\n                data.bank_account_name_kana = null;\n                data.bank_account_type_code = null;\n                data.bank_code = null;\n                data.bank_name = null;\n                data.bank_name_kana = null;\n                data.branch_code = null;\n                data.branch_name = null;\n                data.branch_name_kana = null;\n                data.bank_transfer_fee_type = 0;\n                data.invoice_check_result = null;\n                data.invoice_registrated_number = null;\n                data.invoice_registrated_number_part = null;\n                return true;\n            }\n            return false;\n        }\n\n        // 忙聰炉忙聣聲盲戮聺茅聽录盲禄楼氓陇聳茫聛聥茫聙聛忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢氓\u0085楼氓聤聸茫聛聦猫篓卤氓聫炉茫聛聶茫聜聥氓聽麓氓聬聢茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n        if (\n            $scope.form_type !== Const.miscellaneous._FORM_TYPE.PAYMENT.type ||\n            $scope.form_data.is_allowed_new_company\n        ) {\n            return false;\n        }\n        const payment_data = $scope.form_data.payment;\n        const specifics = payment_data.request_payment_specifics;\n        // 忙聵聨莽麓掳茫聛陋茫聛聴or1莽聰鲁猫芦聥1忙聰炉忙聣聲氓\u0085聢茫聛搂茫聙聛茫聛聥茫聛陇忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茂录聢company_id茫聛聦null茂录聣茫聛庐氓聽麓氓聬聢茫聙聛盲录職莽陇戮忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n        if (util.isUndefinedOrNull(specifics) || payment_data.is_payee_per_request) {\n            return _deleteNewCompany(payment_data);\n        }\n        const isDeleteNewCompany = specifics.filter((specific) =\u003e {\n            // 氓聫聳氓录聲氓\u0085聢忙聵聨莽麓掳盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聜鹿茫聜颅茫聝聝茫聝聴\n            if (\n                specific.specifics_type !== Const.miscellaneous.PAYMENT_SPECIFICS_NORMAL \u0026\u0026\n                specific.specifics_type !== Const.miscellaneous.PAYMENT_SPECIFICS_EXCHANGE_COMPANY\n            ) {\n                return false;\n            }\n            const specificsRows = specific.request_payment_specifics_rows;\n            const filteredSpecificRows = specificsRows.filter((row) =\u003e {\n                // 氓聫聳氓录聲氓\u0085聢茫聛聦忙聳掳猫娄聫氓聫聳氓录聲氓\u0085聢茂录聢company_id茫聛聦null茂录聣茫聛庐氓聽麓氓聬聢茫聙聛盲录職莽陇戮忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n                return _deleteNewCompany(row);\n            });\n            return filteredSpecificRows.length \u003e 0;\n        });\n        return isDeleteNewCompany.length \u003e 0;\n    }\n\n    /**\n     * 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐莽聰鲁猫芦聥茫聜鲁茫聝聰茫聝录忙聶聜茫聛芦盲陆驴莽聰篓忙篓漏茅聶聬茫聛聦茫聛陋茫聛聞忙聣聥氓陆聯茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聙聛忙聣聥氓陆聯忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n     * @return {bool} true: 氓聣聤茅聶陇茫聛聜茫聜聤茫聙聛false: 氓聣聤茅聶陇茫聛陋茫聛聴\n     * @private\n     */\n    function _deleteAllowanceByCopy() {\n        /**\n         * 盲陆驴莽聰篓忙篓漏茅聶聬茫聛聦茫聛陋茫聛聞忙聣聥氓陆聯茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥忙聣聥氓陆聯忙聝\u0085氓聽卤茫聜聮氓聣聤茅聶陇茫聛聶茫聜聥\n         * @param {object} row 忙聵聨莽麓掳猫隆聦\n         * @return {bool} true: 氓聣聤茅聶陇茫聛聜茫聜聤茫聙聛false: 氓聣聤茅聶陇茫聛陋茫聛聴\n         */\n        function _deleteAllowance(row) {\n            const canUse = $scope.available_allowances.some((item) =\u003e item.id === row.allowance_id);\n            if (!canUse) {\n                row.allowance_id = undefined;\n                row.allowance_name = undefined;\n                row.allowance_amount = undefined;\n                row.allowance_amount_details_flg = undefined;\n                row.allowance_category_name = undefined;\n                row.account_title_part = undefined;\n                row.account_title_part_name = undefined;\n                row.amount = null;\n                row.is_manual_input = 0;\n                row.attachment_setting = undefined;\n            }\n            return !canUse;\n        }\n\n        // 莽碌聦猫虏禄莽虏戮莽庐聴盲禄楼氓陇聳茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n        if ($scope.form_type !== Const.miscellaneous._FORM_TYPE.EXPENSE.type) {\n            return false;\n        }\n        const expense_data = $scope.form_data.expense;\n        const specifics = expense_data.request_expense_specifics;\n        // 忙聵聨莽麓掳茫聛陋茫聛聴茫聛庐氓聽麓氓聬聢茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n        if (util.isUndefinedOrNull(specifics)) {\n            return false;\n        }\n\n        const isDeletedAllowance = specifics.filter((specific) =\u003e {\n            // 忙聣聥氓陆聯忙聵聨莽麓掳盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聛炉茫聜鹿茫聜颅茫聝聝茫聝聴\n            if (specific.specifics_type !== Const.miscellaneous.EXPENSE_SPECIFICS_ALLOWANCE) {\n                return false;\n            }\n            const specificsRows = specific.request_expense_specifics_rows;\n            const filteredSpecificRows = specificsRows.filter((row) =\u003e {\n                return _deleteAllowance(row);\n            });\n            return filteredSpecificRows.length \u003e 0;\n        });\n        return isDeletedAllowance.length \u003e 0;\n    }\n\n    /**\n     * 茫聜碌茫聝录茫聝聬茫聛聥茫聜聣氓聫聳氓戮聴茫聛聴茫聛聼茫聜芦茫聜鹿茫聜驴茫聝聽忙聵聨莽麓掳茫聛庐忙聝\u0085氓聽卤茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @param {string} kind 莽聰鲁猫芦聥盲陆聹忙聢聬莽篓庐氓聢楼 Const.miscellaneous.CREATE_REQUEST_KIND\n     * @param {Array} specifics 莽碌聦猫虏禄忙聵聨莽麓掳猫隆篓茂录聫忙聰炉忙聣聲忙聵聨莽麓掳猫隆篓\n     * @return {object} promise\n     * @private\n     */\n    function _getCustomSpecificsData(kind, specifics) {\n        if (util.isUndefinedOrNull(specifics)){\n            return;\n        }\n        // TODO 茫聝聠茫聝录茫聝聳茫聝芦忙搂聥茅聙聽茫聛芦氓聬聢茫聜聫茫聛聸茫聙聛request_custom_specifics茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n        $scope.form_data.request_custom_specifics = [];\n        return $q.all(specifics.map(function(specific){\n            if (!CustomSpecificsService.isCustomSpecifics(specific)) {\n                return;\n            }\n            if (util.isUndefinedOrNull(specific.request_custom_specific)) {\n                return;\n            }\n            // 莽聰鲁猫芦聥忙聶聜莽聜鹿茫聛庐1忙聵聨莽麓掳茫聜聮氓聫聳氓戮聴茫聛聴茫聙聛茅聽\u0085莽聸庐猫篓颅氓庐職茫聛聶茫聜聥\n            return CustomSpecificsConvertService.setRequestCustomSpecifics(\n                    specific, kind, $scope.form_data.request_data_json.division_by_integration_ids)\n                .then(function(request_custom_specific_obj){\n                    // TODO 茫聝聠茫聝录茫聝聳茫聝芦忙搂聥茅聙聽茫聛芦氓聬聢茫聜聫茫聛聸茫聙聛request_custom_specifics茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n                    $scope.form_data.request_custom_specifics.push(request_custom_specific_obj);\n                    if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                        // 盲驴庐忙颅拢氓聣聧茫聛庐忙聝\u0085氓聽卤茫聜聮氓聠聧茫聜鲁茫聝聰茫聝录\n                        form_data_old = angular.copy($scope.form_data);\n                    }\n                });\n        }));\n    }\n\n    /**\n     * 茫聜碌茫聝录茫聝聬茫聛聥茫聜聣氓聫聳氓戮聴茫聛聴茫聛聼莽聰鲁猫芦聥忙聝\u0085氓聽卤茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n     * @param {string} kind 莽聰鲁猫芦聥盲陆聹忙聢聬莽篓庐氓聢楼 Const.miscellaneous.CREATE_REQUEST_KIND\n     * @param {Object} data 茫聜碌茫聝录茫聝聬茫聛聥茫聜聣氓聫聳氓戮聴茫聛聴茫聛聼莽聰鲁猫芦聥忙聝\u0085氓聽卤 RequestService.getRequestForUpdate茫聛庐猫驴聰茫聜聤氓聙陇\n     * @private\n     */\n    function _setFormData(kind, data) {\n        // 氓\u0085卤茅聙職茫聛庐茫聝聡茫聝录茫聜驴\n        $scope.form_type = data.form_type;\n        $scope.form_data.request_data_json = angular.fromJson(data.request_data_json);\n        $scope.form_data.request_user = data.request_user;\n        $scope.form_data.currency_code = data.currency_code;\n        $scope.form_data.currency_show_flg = data.currency_show_flg;\n\n        if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n            // 莽聰鲁猫芦聥盲驴庐忙颅拢忙聶聜茫聛炉茫聙聛莽聰鲁猫芦聥忙聶聜莽聜鹿茫聛庐猫篓颅氓庐職茫聜聮氓聫聳氓戮聴\n            $scope.form_data.form_name = $scope.form_data.request_data_json.form_name;\n            $scope.form_data.description = $scope.form_data.request_data_json.description;\n            $scope.form_data.form_id = $scope.form_data.request_data_json.form_id;\n            $scope.form_data.flow_id = $scope.form_data.request_data_json.flow_id;\n            $scope.form_data.approval_period_setting_flg =\n                $scope.form_data.request_data_json.approval_period_setting_flg;\n            $scope.form_data.circulation_user_setting_flg =\n                $scope.form_data.request_data_json.circulation_user_setting_flg;\n            $scope.form_data.edit_flow_setting_flg = $scope.form_data.request_data_json.edit_flow_setting_flg;\n            $scope.form_data.related_group_setting_flg = $scope.form_data.request_data_json.related_group_setting_flg;\n            $scope.form_data.related_project_setting_flg =\n                $scope.form_data.request_data_json.related_project_setting_flg;\n            $scope.form_data.related_request_view_setting_flg =\n                $scope.form_data.request_data_json.related_request_view_setting_flg;\n            $scope.form_data.pre_request_view_setting_flg =\n                data.request_payment[0] ? data.request_payment[0].pre_request_view_setting_flg : null;\n            $scope.form_data.pay_content_setting_flg = $scope.form_data.request_data_json.pay_content_setting_flg;\n            $scope.form_data.attachment_setting_flg = $scope.form_data.request_data_json.attachment_setting_flg;\n            $scope.form_data.cloudsign_setting_flg = $scope.form_data.request_data_json.cloudsign_setting_flg;\n            $scope.form_data.box_setting_flg = $scope.form_data.request_data_json.box_setting_flg;\n            $scope.form_data.hubble_setting_flg = $scope.form_data.request_data_json.hubble_setting_flg;\n            $scope.form_data.company_input_setting_flg = $scope.form_data.request_data_json.company_input_setting_flg;\n            $scope.form_data.specifics_type = $scope.form_data.request_data_json.specifics_type;\n            $scope.form_data.is_allowed_new_company =\n                data.request_payment[0] ? data.request_payment[0].is_allowed_new_company : null;\n        }\n        else {\n            // 茫聛聺茫聜聦盲禄楼氓陇聳茫聛炉茫聙聛忙聹聙忙聳掳茫聛庐猫篓颅氓庐職茫聜聮氓聫聳氓戮聴\n            $scope.form_data.form_name = data.request_form.form_name;\n            $scope.form_data.description = data.request_form.description;\n            $scope.form_data.form_id = data.request_form.id;\n            $scope.form_data.flow_id = data.request_form.flow;\n            $scope.form_data.approval_period_setting_flg = data.request_form.approval_period_setting_flg;\n            $scope.form_data.circulation_user_setting_flg = data.request_form.circulation_user_setting_flg;\n            $scope.form_data.edit_flow_setting_flg = data.request_form.edit_flow_setting_flg;\n            $scope.form_data.related_group_setting_flg = data.request_form.related_group_setting_flg;\n            $scope.form_data.related_project_setting_flg = data.request_form.related_project_setting_flg;\n            $scope.form_data.related_request_view_setting_flg = data.request_form.related_request_view_setting_flg;\n            $scope.form_data.pre_request_view_setting_flg = data.request_form.pre_request_view_setting_flg;\n            $scope.form_data.pay_content_setting_flg = data.request_form.pay_content_setting_flg;\n            $scope.form_data.attachment_setting_flg = data.request_form.attachment_setting_flg;\n            $scope.form_data.cloudsign_setting_flg = data.request_form.cloudsign_setting_flg;\n            $scope.form_data.box_setting_flg = data.request_form.box_setting_flg;\n            $scope.form_data.hubble_setting_flg = data.request_form.hubble_setting_flg;\n            $scope.form_data.company_input_setting_flg = data.request_form.company_input_setting_flg;\n            $scope.form_data.specifics_type = data.request_form.specifics_type;\n            $scope.form_data.is_allowed_new_company = data.request_form.is_allowed_new_company;\n        }\n\n        // 氓\u0085卢茅聳聥猫篓颅氓庐職\n        $scope.form_publish_settings = data.form_publish_settings;\n\n        // 茅聳垄茅聙拢茫聜掳茫聝芦茫聝录茫聝聴\n        const HIDE = Const.miscellaneous.RELATED_REQUEST_VIEW_SETTING_FLG.HIDE;\n        const hidden = ($scope.form_data.related_group_setting_flg === HIDE);\n        const empty = (kind === Const.miscellaneous.CREATE_REQUEST_KIND.NEW);\n        $scope.form_data.group = (hidden \u0026\u0026 empty) ? getPrimaryGroup() : $scope.form_data.request_data_json.group;\n\n        // 茅聳垄茅聙拢茫聝聴茫聝颅茫聜赂茫聜搂茫聜炉茫聝聢\n        if (ProjectService.isVisibleProjectSetting($scope.form_data.related_project_setting_flg)) {\n            $scope.form_data.project = $scope.form_data.request_data_json.project;\n            $scope.form_data.project_name = $scope.form_data.request_data_json.project_name;\n            $scope.form_data.project_code = $scope.form_data.request_data_json.project_code;\n        }\n        else {\n            $scope.form_data.project = null;\n            $scope.form_data.project_name = null;\n            $scope.form_data.project_code = null;\n        }\n\n        // 氓聡潞氓录碌忙聝\u0085氓聽卤茫聛庐猫篓颅氓庐職\n        $scope.form_data.business_trip_info = null;\n        if (Object.keys(data.business_trip_info).length) {\n            mapped_items = CreateRequestFormItemService.makeMappedItems($scope.form_data.request_data_json.form_json);\n            // 氓聡潞氓录碌忙聝\u0085氓聽卤茫聜聮茅聙拢忙聬潞茫聛聶茫聜聥\n            $scope.form_data.is_share_business_trip_date = true;\n            $scope.form_data.business_trip_info = {\n                // 氓聡潞氓录碌氓\u0085聢茫聛庐猫篓颅氓庐職\n                destinations: data.destinations,\n                destination: data.business_trip_info.destination.id,\n                date_or_term_item: mapped_items[data.business_trip_info.business_trip_date_form_item.form_item],\n                business_trip_date_form_items_id: data.business_trip_info.business_trip_date_form_item.id,\n            };\n        } else {\n            // 氓聡潞氓录碌忙聝\u0085氓聽卤茫聜聮茅聙拢忙聬潞茫聛聴茫聛陋茫聛聞\n            $scope.form_data.is_share_business_trip_date = false;\n        }\n\n        // 盲禄聲猫篓鲁茅聽\u0085莽聸庐茫聛庐猫篓颅氓庐職\n        $scope.form_data.request_form_custom_item = CreateRequestFormCustomItemService.initRequestFormCustomItem(\n            data.request_form_custom_item\n        );\n    }\n\n    /**\n     * 忙聹聙莽碌聜忙聣驴猫陋聧忙聹聼茅聶聬茫聛庐猫篓颅氓庐職\n     * @param {Object} data\n     * @private\n     */\n    function _setLastApprovalPeriod(data) {\n        if (!angular.isUndefinedOrNull(data.last_approval_period) \u0026\u0026 $scope.form_data.approval_period_setting_flg) {\n            $scope.last_approval_period.selected_flg = 1;\n            $scope.last_approval_period.selected_date = data.last_approval_period.substring(0, 4) +\n                \u0027/\u0027 + data.last_approval_period.substring(5, 7) + \u0027/\u0027 + data.last_approval_period.substring(8, 10);\n        }\n        else {\n            $scope.last_approval_period.selected_flg = 0;\n        }\n    }\n\n    /**\n     * 忙聹聙忙聳掳莽碌聦猫路炉氓聫聳氓戮聴茫聜炉茫聝漏茫聜鹿\n     */\n    function LatestFlowFetcher() {\n        // eslint-disable-next-line angular/controller-as-vm\n        const _this = this;\n        /** 氓聣聧氓聸聻茫聛庐忙陇聹莽麓垄茫聝聭茫聝漏茫聝隆茫聝录茫聜驴茫聝录 */\n        _this._previousRequestParams = {};\n        /**\n         * 忙陇聹莽麓垄茫聝聭茫聝漏茫聝隆茫聝录茫聜驴茫聝录盲陆聹忙聢聬\n         * @param {number} flow_id flow id\n         * @return {Object}\n         */\n        _this._createRequestParams = function(flow_id) {\n            const requester_id = angular.isDefined($scope.requester) ? $scope.requester.id : null;\n            return {\n                flow_id: flow_id,\n                requester_id: requester_id,\n                request_id: $scope.request_id,\n                form_id: form_id,\n                kind: $scope.kind,\n                group_id: $scope.requester_info.requester_group_id,\n                position_id: $scope.requester_info.requester_position_id,\n            };\n        };\n        /**\n         * 忙聹聙忙聳掳茫聛庐flow茫聝聡茫聝录茫聜驴氓聫聳氓戮聴\n         * @param {number} flow_id\n         * @param {Object} prev_flow\n         * @return {Promise}\n         */\n        _this.getLatestFlow = function(flow_id, prev_flow) {\n            const deferred = $q.defer();\n            const flowParams = _this._createRequestParams(flow_id);\n            FlowService.getForNewRequest(flow_id, flowParams, false)\n            .then(function(res) {\n                var data = res.data;\n                data = CreateRequestFlowService.setFlowStepUsers(data);\n                // 氓聠聧莽聰鲁猫芦聥忙聶聜茂录聢prev_flow茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茂录聣茫聙聛flow_version茫聛篓flow_step_number_in_version茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n                data = CreateRequestFlowService.setFlowVersion(data, prev_flow);\n                // 忙陇聹莽麓垄忙聺隆盲禄露茫聛庐盲驴聺氓颅聵\n                _this._previousRequestParams = flowParams;\n                deferred.resolve(data);\n            })\n            .catch(function() {\n            });\n\n            return deferred.promise;\n        };\n        /**\n         * 莽聫戮氓聹篓莽聰聼忙聢聬茫聛聲茫聜聦茫聜聥忙陇聹莽麓垄忙聺隆盲禄露茫聛篓氓聣聧氓聸聻茫聛庐忙陇聹莽麓垄忙聺隆盲禄露茫聛聦盲赂聙猫聡麓茫聛聶茫聜聥茫聛聥茂录聼\n         * @param {number} flow_id flow id\n         * @return {boolean}\n         */\n        _this.areSameCurrentAndPreviousRequestParams = function(flow_id) {\n            const currentParams = _this._createRequestParams(flow_id);\n            return angular.equals(currentParams, _this._previousRequestParams);\n        };\n    }\n\n    /**\n     * 氓聠聧莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聛庐茫聝聲茫聝颅茫聝录氓聫聳氓戮聴\n     * @param {Object} data\n     * @return {Promise}\n     */\n    function getFeedbackFlow(data) {\n        var deferred = $q.defer();\n        // 氓聠聧莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛氓路庐茫聛聴忙聢禄茫聛聴茫聛戮茫聛搂茫聛庐忙聣驴猫陋聧茫聝聲茫聝颅茫聝录茫聛篓茫聜鲁茫聝隆茫聝鲁茫聝聢茫聜聜氓聫聳氓戮聴茫聛聴猫隆篓莽陇潞茫聛聶茫聜聥\n        RequestService.getRequestFlow($scope.request_id).then(function(response) {\n            $scope.prev_flow = response.data;\n            // 氓路庐茫聛聴忙聢禄茫聛聴盲禄楼氓戮聦茫聛庐茫聝聲茫聝颅茫聝录茂录聢忙聹聙忙聳掳茫聛庐茫聝聲茫聝颅茫聝录茂录聣茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n            _getLatestFlow(data.flow, $scope.prev_flow).then(function(data) {\n                $scope.flow_data = data;\n                deferred.resolve();\n            });\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 莽碌聦猫路炉盲驴庐忙颅拢忙聶聜茫聛庐茫聝聲茫聝颅茫聝录氓聫聳氓戮聴\n     * @return {Promise}\n     */\n    function getModifyStepFlow() {\n        var deferred = $q.defer();\n        RequestService.getRequestFlowForModify($scope.request_id)\n        .then(function(response) {\n            var current_version_steps = CreateRequestFlowService.getCurrentVersionSteps(response.data.flow_steps);\n            $scope.modify_step_data.first_flow_step_number = current_version_steps[0] ?\n                current_version_steps[0].flow_step_number : 0;\n            $scope.modify_step_data.current_flow_step_number = CreateRequestFlowService.getCurrentFlowStepNumber(\n                response.data.flow_steps\n            );\n            $scope.modify_step_data.update_target_version = CreateRequestFlowService.getMaxFlowVersion(\n                response.data.flow_steps\n            );\n            deferred.resolve(response.data);\n        }, function(error) {\n            if (error.status === 403) {\n                $location.path(\u0027/unauthorized\u0027);\n            }\n            else {\n                notifyService.showNotify(error.data.message, \u0027alert-danger\u0027);\n                $location.path(\u0027/myrequests/\u0027);\n            }\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥莽碌聦猫路炉盲驴庐忙颅拢氓卤楼忙颅麓茫聜聮氓聫聳氓戮聴\n     * @private\n     */\n    function _getModifyStepLogs() {\n        RequestService.getModifyStepLogs($scope.request_id).then(function(response) {\n            $scope.modify_step_data.modify_step_logs_count = response.data.length;\n        });\n    }\n\n    /**\n     * 茫聜鲁茫聝隆茫聝鲁茫聝聢茫聛庐氓聫聳氓戮聴\n     * @param {number} request_id\n     * @return {Promise}\n     */\n    function getComment(request_id) {\n        var deferred = $q.defer();\n        RequestCommentService.getList(request_id).then(function(response) {\n            deferred.resolve(response.data);\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 忙聹聙忙聳掳茫聛庐茅聳虏猫娄搂猫聙\u0085茫聛庐氓聫聳氓戮聴\n     * @param {number} flow_id\n     * @param {number} group_id\n     * @return {Promise}\n     */\n    function getLatestCirculationUsers(flow_id, group_id) {\n        var deferred = $q.defer();\n        var params = {\n            \u0027group_id\u0027: group_id,\n        };\n        FlowService.getCirculationUsersForRequest(\n            flow_id, params, false\n        ).then(function(res) {\n            deferred.resolve(prepareDispCirculation(res.data));\n        })\n        .catch(function() {\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 莽聫戮氓聹篓茫聛庐茅聳虏猫娄搂猫聙\u0085茫聛庐氓聫聳氓戮聴\n     * @param {number} request_id\n     * @return {Promise}\n     */\n    function getCurrentCirculationUsers(request_id) {\n        var deferred = $q.defer();\n        RequestService.getCirculationUsers(request_id)\n        .then(function(res) {\n            deferred.resolve(prepareDispCirculation(res.data));\n        })\n        .catch(function() {\n        });\n        return deferred.promise;\n    }\n\n    /**\n     * 茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085莽路篓茅聸聠茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳\n     */\n    function editFlowCirculation() {\n        var params = {};\n\n        params.type = \u0027flow_circulation_setting\u0027;\n        params.selected_group_positions = dlog_flow_circulation_settings;\n        params.selected_users = dlog_flow_circulation_users;\n        params.new_group_position_set = {\n            group: default_group_obj,\n            position: all_position_obj,\n            position_condition_type: Const.miscellaneous._COMPARISON.EQ,\n            group_condition_type: Const.miscellaneous._COMPARISON.EQ,\n            user: null,\n        };\n        params.group_position_set_max = Const.miscellaneous.CIRCULATION_GROUP_POSITION_SET_MAX;\n        // 猫篓颅氓庐職茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛庐氓\u0085聢茫聛搂氓聭录茫聛鲁氓聡潞茫聛聶茫聙聛茫聜掳茫聝芦茫聝录茫聝聴茫聜聞氓陆鹿猫聛路茫聛庐茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛庐茅聛赂忙聤聻猫聜垄茫聛芦猫驴陆氓聤聽茫聛聴茫聛聼茫聛聞茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢茫聜聮茅\u0085聧氓聢聴茫聛搂忙赂隆茫聛聶\n        params.add_position_dialog_objects = [all_position_obj];\n        params.add_group_dialog_objects = [all_group_obj, default_group_obj];\n        // 茅聳虏猫娄搂氓聫炉猫聝陆茫聜掳茫聝芦茫聝录茫聝聴茫聜聜茫聛聴茫聛聫茫聛炉茅聳虏猫娄搂氓聫炉猫聝陆茫聝娄茫聝录茫聜露茫聛聦忙聦聡氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聛聼忙聶聜茫聛芦茫聛炉茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳氓聛麓茫聛搂氓聣聤茅聶陇茫聝聹茫聜驴茫聝鲁茫聜聮猫隆篓莽陇潞\n        if ($scope.flow_circulation_users.length \u003e 0) {\n            params.disp_delete_button = true;\n        }\n        else {\n            params.disp_delete_button = false;\n        }\n\n        var modalInstance = $uibModal.open({\n            templateUrl: \u0027../static/wf/views/dialogs/select_group_position_user_templ.html\u0027,\n            controller: \u0027SelectGroupPositionUserDialogController\u0027,\n            resolve: {\n                params: function() {\n                    return params;\n                },\n            },\n        });\n        modalInstance.result.then(function(result) {\n            // dlog_circulation_茫聝聡茫聝录茫聜驴茫聛炉茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦茅聛赂忙聤聻茫聛聲茫聜聦茫聛聼茫聜掳茫聝芦茫聝录茫聝聴茫聛篓茫聝娄茫聝录茫聜露茫聜聮忙赂隆茫聛聶茫聛聼茫聜聛氓聦潞氓聢楼茫聛聴茫聛娄茅\u0085聧氓聢聴茫聛芦茫聛聶茫聜聥\n            // flow_circulation_users茫聛炉茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聛篓茫聛聴茫聛娄茫聝聯茫聝楼茫聝录茫聛芦猫隆篓莽陇潞茫聛聶茫聜聥茫聛聼茫聜聛茫聛芦茫聜掳茫聝芦茫聝录茫聝聴茫聜聜茫聝娄茫聝录茫聜露茫聜聜氓聬聦茫聛聵茅\u0085聧氓聢聴茫聛芦茫聛聶茫聜聥\n            if (result.action === \u0027delete\u0027) {\n                dlog_flow_circulation_settings = [];\n                dlog_flow_circulation_users = [];\n                $scope.flow_circulation_users = [];\n            }\n            else if (result.action === \u0027add\u0027) {\n                dlog_flow_circulation_settings = result.selected_group_positions;\n\n                dlog_flow_circulation_settings.forEach(function (row, index) {\n                    // 莽碌聦猫路炉茫聛搂氓聢聺忙聹聼猫篓颅氓庐職茫聛聲茫聜聦茫聛聼茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳default_setting茫聜聮false茫聛篓茫聛聶茫聜聥\n                    if (angular.isUndefinedOrNull(row.default_setting)) {\n                        row.default_setting = false;\n                    }\n                });\n\n                result.selected_users.forEach(function (row, index) {\n                    // 莽碌聦猫路炉茫聛搂氓聢聺忙聹聼猫篓颅氓庐職茫聛聲茫聜聦茫聛聼茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳default_setting茫聜聮false茫聛篓茫聛聶茫聜聥\n                    var before_user = dlog_flow_circulation_users.filter(function(users){\n                        return users.user.id === row.user.id;\n                    });\n                    // 氓聢聺忙聹聼猫篓颅氓庐職茫聛聲茫聜聦茫聛聼茫聝娄茫聝录茫聜露茫聝录茫聛芦茅聡聧猫陇聡茫聛炉茫聛陋茫聛聞茫聛炉茫聛職茫聛聽茫聛聦氓驴碌茫聛庐茫聛聼茫聜聛茫聝聛茫聜搂茫聝聝茫聜炉\n                    if (before_user.length === 1 ){\n                        row.default_setting = before_user[0].default_setting;\n                    }\n                    else{\n                        row[\u0027default_setting\u0027] = false;\n                        row[\u0027group\u0027] = null;\n                    }\n                });\n                dlog_flow_circulation_users = result.selected_users;\n                $scope.flow_circulation_users = angular.copy(dlog_flow_circulation_users);\n\n                var requester_id = angular.isDefined($scope.requester) ? $scope.requester.id : null;\n                var params = {\n                    requester_id: requester_id,\n                    flow_circulation_users: dlog_flow_circulation_settings,\n                    group_id: $scope.requester_info.requester_group_id,\n                };\n                 FlowService.convertSpecificFlowCirculationUsers(params).then(function(response) {\n                    Array.prototype.push.apply($scope.flow_circulation_users, response.data);\n                });\n            }\n        }, function(data) {\n            // dismiss\n        });\n    }\n\n    /**\n     * 忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥茫聛聥茫聜聣莽碌聦猫路炉忙聝\u0085氓聽卤茫聜聮氓聫聳茫聛拢茫聛娄茫聛聫茫聜聥\n     */\n    function copyFlowFromRequest() {\n        /**\n         * 忙聦聡氓庐職茫聛聲茫聜聦茫聛聼莽聰鲁猫芦聥茫聛聥茫聜聣莽碌聦猫路炉忙聝\u0085氓聽卤茫聜聮茫聜鲁茫聝聰茫聝录\n         * @param {number} request_id\n         * @private\n         */\n        function _copyFromRequest(request_id) {\n            // 莽碌聦猫路炉氓聫聧忙聵聽茫聝聹茫聜驴茫聝鲁茫聛庐猫隆篓莽陇潞氓聫炉氓聬娄猫篓颅氓庐職茫聛搂猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜猫隆聦茫聜聫茫聛陋茫聛聞\n            if ($scope.show_reflect_flow_button === Const.miscellaneous.SHOW_REFLECT_FLOW_BUTTON.HIDE) {\n                return;\n            }\n\n            $scope.setting_flow = true;\n            RequestService.getRequestFlowForEdit(request_id)\n            .then(function(res) {\n                // 莽碌聦猫路炉茫聛炉莽路篓茅聸聠忙赂聢茫聛驴茫聛篓茫聛聶茫聜聥\n                var data = CreateRequestFlowService.setFlowStepUsers(res.data);\n                // 氓聠聧莽聰鲁猫芦聥忙聶聜茂录聢prev_flow茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茂录聣茫聙聛flow_version茫聛篓flow_step_number_in_version茫聜聮猫篓颅氓庐職茫聛聶茫聜聥\n                data = CreateRequestFlowService.setFlowVersion(data, $scope.prev_flow);\n                $scope.flow_data = data;\n                $scope.form_data.edit_flow_flg = true;\n                $scope.copy_request_flow_flg = true;\n                $scope.setting_flow = false;\n                notifyService.showNotify(CreateRequestFlowService.getCopiedFlowMessage($scope.kind), \u0027alert-success\u0027);\n            }, function() {\n                $scope.setting_flow = false;\n                notifyService.showNotify(gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聛庐氓聫聧忙聵聽茫聛芦氓陇卤忙聲聴茫聛聴茫聛戮茫聛聴茫聛聼\u0027), \u0027alert-danger\u0027);\n            });\n        }\n\n        // 莽碌聦猫路炉猫篓颅氓庐職盲赂颅茫聜聜茫聛聴茫聛聫茫聛炉茫聜鲁茫聝聰茫聝录莽娄聛忙颅垄莽聤露忙\u0085聥茫聛庐氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜猫隆聦茫聜聫茫聛陋茫聛聞\n        if ($scope.setting_flow || !canUseCopyFlowBtn()) {\n            return;\n        }\n\n        var request_id = $scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.NEW ? last_request.id : $scope.request_id;\n        _copyFromRequest(request_id);\n    }\n\n    /**\n     * 莽碌聦猫路炉茫聜鲁茫聝聰茫聝录茫聝聹茫聜驴茫聝鲁茫聛芦猫隆篓莽陇潞茫聛聶茫聜聥忙聳聡猫篓聙茫聜聮氓聫聳氓戮聴\n     * @return {string}\n     */\n    function getCopyFlowBtnLabel() {\n        return CreateRequestFlowService.getCopyFlowBtnLabel($scope.kind);\n    }\n\n    /**\n     * 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴(茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢)茫聛庐氓聫聳氓戮聴\n     * @param {string|undefined} kind\n     */\n    function getRequestFiles(kind) {\n        RequestService.getFiles($scope.request_id)\n        .then(function(res) {\n            $scope.request_files = res.data;\n            // 莽聰鲁猫芦聥盲驴庐忙颅拢忙聶聜茫聛炉忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦忙聝\u0085氓聽卤茫聜聮茫聜鲁茫聝聰茫聝录\n            if (kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY) {\n                request_files_old = angular.copy($scope.request_files);\n                // EC猫鲁录氓\u0085楼莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢茫聛炉氓陇聳茅聝篓EC茫聜碌茫聜陇茫聝聢茫聛赂茫聛庐莽聰禄茅聺垄茅聛路莽搂禄茫聛聦莽聶潞莽聰聼茫聛聶茫聜聥茫聛聼茫聜聛localStorage茫聛芦茫聜聜茅聙聙茅聛驴茫聛聶茫聜聥\n                const accessor = EcStorageAccessorService.ecStorageData;\n                if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EC \u0026\u0026\n                    angular.isUndefinedOrNull(accessor.getStorageData(EcConst.evacuation.CALLBACK_FLG))) {\n                    accessor.setStorageData(EcConst.evacuation.REQUEST_FILES_OLD, angular.toJson(request_files_old));\n                }\n            }\n        })\n        .catch(function(res) {\n            notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n        });\n    }\n\n    /**\n     * 猫陋卢忙聵聨猫鲁聡忙聳聶茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聝聡茫聝录茫聜驴茫聛庐氓聫聳氓戮聴\n     * @param {number} form_id\n     */\n    function getFormFiles(form_id) {\n        UserFileService.getFormFileList(form_id)\n        .then(function(res) {\n            $scope.form_files = res.data;\n        })\n        .catch(function(res) {\n            notifyService.showNotify(res.data, \u0027alert-danger\u0027);\n        });\n    }\n\n    /**\n     * 茅聛赂忙聤聻盲赂颅茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聦忙聦聡氓庐職茫聜掳茫聝芦茫聝录茫聝聴茫聛篓氓陆鹿猫聛路茫聛芦氓\u0085卢茅聳聥茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥\n     * @param {number} group_id 忙聦聡氓庐職茫聜掳茫聝芦茫聝录茫聝聴ID\n     * @param {number} position_id 忙聦聡氓庐職氓陆鹿猫聛路\n     * @return {boolean} 茅聛赂忙聤聻盲赂颅茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聦忙聦聡氓庐職茫聜掳茫聝芦茫聝录茫聝聴茫聛篓氓陆鹿猫聛路茫聛芦氓\u0085卢茅聳聥茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥\n     */\n    function isPublished(group_id, position_id) {\n        // 氓\u0085篓盲陆聯氓\u0085卢茅聳聥茫聛庐氓聽麓氓聬聢茫聛炉true\n        if ($scope.publish_setting_kind === Const.miscellaneous.PUBLISH_SETTING_KIND.ENTIRELY_PUBLIC.key) return true;\n        // 茅聺聻氓\u0085卢茅聳聥茫聛庐氓聽麓氓聬聢茫聛炉false\n        if ($scope.publish_setting_kind === Const.miscellaneous.PUBLISH_SETTING_KIND.UNPUBLISHED.key) return false;\n\n        // 盲禄楼盲赂聥盲赂聙茅聝篓氓\u0085卢茅聳聥盲赂颅茫聛庐氓聽麓氓聬聢茫聛庐氓聢陇氓庐職茫聙聜\n        // 氓\u0085篓盲陆聯氓\u0085卢茅聳聥茫聙聛茅聺聻氓\u0085卢茅聳聥茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聛炉$scope.published_group_positions茫聛聦undefined茫聛搂盲潞聥忙聲\u0085茫聜聥茫聛聼茫聜聛茫聙聛\n        // 氓\u0085篓盲陆聯氓\u0085卢茅聳聥茫聙聛茅聺聻氓\u0085卢茅聳聥茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛搂盲禄楼盲赂聥茫聛庐氓聡娄莽聬聠茫聜聮茅聙職茫聜聥茫聜聢茫聛聠茫聛芦忙聰鹿盲驴庐茫聛聶茫聜聥茅職聸茫聛芦茫聛炉忙鲁篓忙聞聫茫聙聜\n\n        // null茫聛庐氓聽麓氓聬聢茫聛炉0茫聛芦氓路庐茫聛聴忙聸驴茫聛聢茫聜聥\n        if (group_id === null) group_id = 0;\n        if (position_id === null) position_id = 0;\n\n        // 盲禄拢莽聬聠莽聰鲁猫芦聥茫聛庐氓聽麓氓聬聢 group_id = null 茫聛搂茫聛聯茫聛聯茫聛芦茅拢聸茫聛鲁猫戮录茫聜聯茫聛搂茫聛聫茫聜聥茫聛聯茫聛篓茫聛聦茫聛聜茫聜聥茫聛聼茫聜聛茫聙聛忙聴漏忙聤聹茫聛聭茫聛聶茫聜聥\n        const item = $scope.published_group_positions[group_id];\n        if (angular.isUndefinedOrNull(item)) {\n            return false;\n        }\n\n        // 茫聜掳茫聝芦茫聝录茫聝聴氓\u0085篓盲陆聯茫聛聦猫篓卤氓聫炉茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥\n        if (item.published === true) return true;\n\n        const positions = item.positions;\n        if (positions.length \u003e 0) {\n            // 茫聜掳茫聝芦茫聝录茫聝聴氓\u0085篓盲陆聯茫聛芦猫篓卤氓聫炉茫聛聦氓聡潞茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉氓陆鹿猫聛路茫聛戮茫聛搂茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n            for (var k in positions) {\n                if (!positions.hasOwnProperty(k)) continue;\n                if (positions[k].position.id === position_id \u0026\u0026 positions[k].published === true) {\n                    return true;\n                }\n            }\n        }\n        return false;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥猫聙\u0085茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茫聙聛氓陆鹿猫聛路茅聛赂忙聤聻忙聶聜茫聛庐氓聡娄莽聬聠\n     * @param {string} type\n     * @param {number} id\n     * @param {number} before_id\n     */\n    function selectRequesterInfo(type, id, before_id) {\n        var form_id = $scope.form_data.form_id;\n        // 氓\u0085卢茅聳聥忙聺隆盲禄露茫聜聮忙潞聙茫聛聼茫聛聴茫聛娄茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉氓\u0085聝茫聛芦忙聢禄茫聛聶莽聜潞茫聛芦盲驴聺忙聦聛\n        var before_group_id = type === \u0027group\u0027 ? before_id : $scope.requester_info.requester_group_id;\n        var before_position_id = type === \u0027group\u0027 ? $scope.requester_info.requester_position_id : before_id;\n        // 氓陇聣忙聸麓氓戮聦茫聛庐ID\n        var after_group_id = type === \u0027group\u0027 ? id : $scope.requester_info.requester_group_id;\n        var after_position_id = type === \u0027group\u0027 ? getDefaultPositionChoice(after_group_id) : id;\n        // 茅聛赂忙聤聻猫聜垄茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁\n        var before_position_choices = $scope.requester_position_choices;\n        var after_position_choices = CreateRequestFlowService.getPositionChoices(after_group_id,\n                                                                                 $scope.login_user.user_positions);\n\n        if (isPublished(after_group_id, after_position_id)) {\n            $scope.requester_position_choices = after_position_choices;\n            $scope.requester_info.requester_group_id = after_group_id;\n            $scope.requester_info.requester_position_id = after_position_id;\n            $scope.disp_position_select = after_position_id !== null;\n\n            getExtraFlowData(form_id).then(function() {\n                const new_flow_id = _setDefaultFlow($scope.default_flow_data.id, true, true, true);\n\n                // 忙聳掳茫聛聴茫聛聫茅聛赂忙聤聻茫聛聴茫聛聼氓陆鹿猫聛路茫聛庐盲赂聤茅聶聬猫篓颅氓庐職茅聡聭茅隆聧茫聜聮氓聫聳氓戮聴\n                FormLimitAmountService.getLimitAmountSetting(\n                    form_id,\n                    $scope.kind,\n                    $scope.requester_info.requester_position_id,\n                    $scope.request_id\n                )\n                    .then(function(data) {\n                        $scope.form_limit_amount_setting = data;\n                        // 氓聫聳氓戮聴茫聛聴茫聛聼猫篓颅氓庐職茫聜聮氓\u0085聝茫聛芦茫聝聬茫聝陋茫聝聡茫聝录茫聝聢茫聛聶茫聜聥\n                        validateLimitAmountSettings();\n                    })\n                    .catch(function() {\n                        $scope.form_limit_amount_setting = null;\n                    });\n                // 茫聝娄茫聝录茫聜露忙聦聡氓庐職茫聜聮莽聰禄茅聺垄猫隆篓莽陇潞莽聰篓氓陇聣忙聲掳茫聛芦茫聜禄茫聝聝茫聝聢\n                $scope.flow_circulation_users = angular.copy(dlog_flow_circulation_users);\n\n                const requester_id = angular.isDefined($scope.requester) ? $scope.requester.id : null;\n                // 茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛搂氓陇聣忙聸麓茫聙聛猫驴陆氓聤聽茫聛聲茫聜聦茫聛聼茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路猫篓颅氓庐職茫聜聮茅聙聙茅聛驴\n                const added_settings = filterFilter(dlog_flow_circulation_settings, {default_setting: false});\n                const added_users = filterFilter(dlog_flow_circulation_users, {default_setting: false});\n                dlog_flow_circulation_settings = [];\n                dlog_flow_circulation_users = [];\n                // 氓陇聣忙聸麓氓戮聦茫聛庐茫聜掳茫聝芦茫聝录茫聝聴茫聛搂茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聜聮氓聠聧氓聫聳氓戮聴\n                getLatestCirculationUsers(new_flow_id, $scope.requester_info.requester_group_id)\n                    .then(function (result) {\n                        // 氓聠聧氓聫聳氓戮聴茫聛聴茫聛聼茅聳虏猫娄搂氓聫炉猫聝陆茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聜聮氓聠聧氓潞娄茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦茫聜禄茫聝聝茫聝聢\n                        for (var i=0; i\u003cresult.length; i++) {\n                            if (angular.isUndefinedOrNull(result[i].user)) {\n                                // 茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛搂茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聜聮猫篓颅氓庐職茫聛聶茫聜聥氓聽麓氓聬聢茫聛炉group_condition_type茫聜聞position_condition_type茫聛聦\n                                // null茫聛庐氓聽麓氓聬聢茫聛芦0茫聛芦莽陆庐茫聛聧忙聫聸茫聛聢茫聛娄茫聛聞茫聜聥茫聛庐茫聛搂茫聛聺茫聜聦茫聛芦氓聬聢茫聜聫茫聛聸茫聜聥\n                                if (result[i].group_condition_type === null) {\n                                    result[i].group_condition_type = Const.miscellaneous._COMPARISON.EQ;\n                                }\n                                if (result[i].position_condition_type === null) {\n                                    result[i].position_condition_type = Const.miscellaneous._COMPARISON.EQ;\n                                }\n                            }\n                            dlog_flow_circulation_settings.push(result[i]);\n                        }\n                        // 茅聙聙茅聛驴茫聛聴茫聛娄茫聛聞茫聛聼茅聳虏猫娄搂氓聫炉猫聝陆茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聜聮茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦猫驴陆氓聤聽\n                        for (var j=0; j\u003cadded_settings.length; j++) {\n                            dlog_flow_circulation_settings.push(added_settings[j]);\n                        }\n                        // 茅聙聙茅聛驴茫聛聴茫聛娄茫聛聞茫聛聼茅聳虏猫娄搂氓聫炉猫聝陆茫聝娄茫聝录茫聜露茫聝录茫聜聮茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦猫驴陆氓聤聽\n                        for (var k=0; k\u003cadded_users.length; k++) {\n                            dlog_flow_circulation_settings.push(added_users[k]);\n                        }\n                        // 茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛芦茫聜禄茫聝聝茫聝聢茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茅聳虏猫娄搂氓聫炉猫聝陆茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聜聮莽聰禄茅聺垄猫隆篓莽陇潞莽聰篓氓陇聣忙聲掳茫聛芦猫驴陆氓聤聽\n                        convertSpecificFlowCirculationUsers(\n                            requester_id,\n                            dlog_flow_circulation_settings,\n                            $scope.requester_info.requester_group_id\n                        );\n                    });\n            });\n        }\n        else {\n            // 茅聺聻氓\u0085卢茅聳聥茫聛庐茅聛赂忙聤聻猫聜垄茫聜聮茅聛赂茫聜聯茫聛聽氓聽麓氓聬聢茫聛炉茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁茫聜聮茫聝颅茫聝录茫聝芦茫聝聬茫聝聝茫聜炉\n            $scope.requester_position_choices = before_position_choices;\n            if (!angular.isUndefinedOrNull(before_group_id)) {\n                $scope.requester_info.requester_group_id = before_group_id;\n            }\n            if (!angular.isUndefinedOrNull(before_position_id)) {\n                $scope.requester_info.requester_position_id = before_position_id;\n            }\n            notifyService.showNotify(_(\u0027茅聛赂忙聤聻茫聛聴茫聛聼茫聜掳茫聝芦茫聝录茫聝聴茫聛戮茫聛聼茫聛炉氓陆鹿猫聛路茫聛炉茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓\u0085卢茅聳聥忙聺隆盲禄露茫聛芦氓聬芦茫聛戮茫聜聦茫聛娄茫聛聞茫聛戮茫聛聸茫聜聯茫聙聜\u0027), \u0027alert-danger\u0027);\n        }\n    }\n\n    /**\n     * 茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛陋茫聛漏茫聛芦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茅聳虏猫娄搂氓聫炉猫聝陆茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聜聮氓卤聲茅聳聥茫聛聴莽聰禄茅聺垄猫隆篓莽陇潞莽聰篓氓陇聣忙聲掳茫聛芦猫驴陆氓聤聽茫聛聶茫聜聥\n     * @param {object} requester_id\n     * @param {object} flow_circulation_users\n     * @param {number} group_id\n     */\n    function convertSpecificFlowCirculationUsers(requester_id, flow_circulation_users, group_id) {\n        // 茅聳虏猫娄搂氓聫炉猫聝陆茫聜掳茫聝芦茫聝录茫聝聴茫聝禄氓陆鹿猫聛路茫聜聮莽聰禄茅聺垄猫隆篓莽陇潞莽聰篓氓陇聣忙聲掳茫聛芦猫驴陆氓聤聽\n        var params = {\n            requester_id: requester_id,\n            flow_circulation_users: flow_circulation_users,\n            group_id: group_id,\n        };\n        FlowService.convertSpecificFlowCirculationUsers(params).then(function(response) {\n            $scope.flow_circulation_users = response.data;\n            setCirculationPositionAndUsers($scope.flow_circulation_users);\n        });\n    }\n\n    /**\n     * 莽聫戮忙聶聜莽聜鹿茫聛庐茫聝聲茫聜漏茫聝录茫聝聽忙聝\u0085氓聽卤茫聛搂盲赂聤茅聶聬茅聡聭茅隆聧猫篓颅氓庐職茫聛庐茫聝聬茫聝陋茫聝聡茫聝录茫聜路茫聝搂茫聝鲁茫聜聮茫聛聥茫聛聭茫聜聥\n     * 莽碌聦猫虏禄莽虏戮莽庐聴茫聛庐茫聛驴\n     */\n    function validateLimitAmountSettings() {\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聛搂茫聛庐茫聛驴茫聝聬茫聝陋茫聝聡茫聝录茫聜路茫聝搂茫聝鲁茫聜聮氓庐聼猫隆聦\n        if ($scope.form_type !== Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            return;\n        }\n\n        // 氓聫聳氓戮聴茫聛聴茫聛聼猫篓颅氓庐職茫聜聮氓\u0085聝茫聛芦茫聝聬茫聝陋茫聝聡茫聝录茫聝聢茫聛聶茫聜聥\n        if (\u0027amount\u0027 in $scope.form_data.expense) {\n            $scope.limit_amount_alert_level =\n                FormLimitAmountService.validate_total_amount(\n                    $scope.form_data.expense,\n                    $scope.form_limit_amount_setting,\n                    $scope.form_data.expense.amount,\n                    $scope.form_data.expense.account_title_part);\n        }\n\n        if (\u0027request_expense_specifics\u0027 in $scope.form_data.expense) {\n            var specifics = $scope.form_data.expense.request_expense_specifics;\n            FormLimitAmountService.validate_specifics(specifics, $scope.form_limit_amount_setting);\n        }\n    }\n\n    /**\n     * 茅聛赂忙聤聻茫聛聴茫聛聼茫聜掳茫聝芦茫聝录茫聝聴茫聛搂氓聢聺忙聹聼茅聛赂忙聤聻茫聛聲茫聜聦茫聜聥氓陆鹿猫聛路ID茫聜聮氓聫聳氓戮聴(氓\u0085卢茅聳聥猫篓颅氓庐職茫聜聮猫聙聝忙\u0085庐)\n     * @param {number} group_id\n     * @return {number|null}\n     */\n    function getDefaultPositionChoice(group_id) {\n        var positionChoices = CreateRequestFlowService.getPositionChoices(group_id, $scope.login_user.user_positions);\n\n        // 茫聜掳茫聝芦茫聝录茫聝聴茫聛芦莽麓聬茫聛楼茫聛聫氓陆鹿猫聛路茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聙聛氓陆鹿猫聛路茫聛庐茫聛驴茫聛搂氓\u0085卢茅聳聥猫篓颅氓庐職茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n        if (positionChoices.length \u003e= 1) {\n            // 氓\u0085卢茅聳聥忙篓漏茅聶聬茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茫聛聴茫聛娄猫篓卤氓聫炉茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥忙聹聙氓聢聺茫聛庐氓陆鹿猫聛路茫聜聮茅聛赂忙聤聻\n            for (var i = 0; i \u003c positionChoices.length; ++i) {\n                var position_id = positionChoices[i].id;\n                if (isPublished(group_id, position_id) === true) {\n                    return position_id;\n                }\n            }\n        }\n        return null;\n    }\n\n    /**\n     * 莽碌聦猫路炉莽路篓茅聸聠茫聜聮茅聳聥氓搂聥茫聛聶茫聜聥\n     */\n    function editFlowStepConfirm() {\n        var title = gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮莽路篓茅聸聠茫聛聴茫聛戮茫聛聶茫聛聥茂录聼\u0027);\n        var body = gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮莽路篓茅聸聠茫聛聴茫聛戮茫聛聶茫聛聦茫聙聛茫聜聢茫聜聧茫聛聴茫聛聞茫聛搂茫聛聶茫聛聥茂录聼\u0027);\n        dialogService.showConfirmDialogYesNo(\n            title,\n            body,\n            Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP.show,\n            Const.miscellaneous._DIALOG_OK_BUTTON_TYPE.consent\n        ).then(function(flg) {\n            if (flg) {\n                _editFlowStep();\n            }\n        });\n    }\n\n    /**\n     * 莽碌聦猫路炉莽路篓茅聸聠忙聶聜茫聛庐氓聢聺忙聹聼氓聦聳\n     * @private\n     */\n    function _editFlowStep() {\n        $scope.edit_flow_step_mode = true;\n        // 茫聜颅茫聝拢茫聝鲁茫聜禄茫聝芦忙聶聜茫聛芦忙聢禄茫聛聶茫聜聢茫聛聠茫聛芦茫聝聬茫聝聝茫聜炉茫聜垄茫聝聝茫聝聴茫聛聴茫聛娄茫聛聤茫聛聫\n        $scope.before_flow_step_number = angular.copy(add_flow_step_number);\n        $scope.before_edit_flow_step = angular.copy($scope.flow_data.flow_steps);\n        $scope.sortableOptions = {};\n    }\n\n    /**\n     * 莽碌聦猫路炉莽路篓茅聸聠茫聜颅茫聝拢茫聝鲁茫聜禄茫聝芦\n     */\n    function cancelEditFlowStep() {\n        $scope.edit_flow_step_mode = false;\n        $scope.flow_data.flow_steps = $scope.before_edit_flow_step;\n        add_flow_step_number = $scope.before_flow_step_number;\n        notifyService.showNotify(gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聛庐莽路篓茅聸聠茫聜聮茫聜颅茫聝拢茫聝鲁茫聜禄茫聝芦茫聛聴茫聛戮茫聛聴茫聛聼\u0027), \u0027alert-success\u0027);\n        // 莽聰鲁猫芦聥盲赂聙猫娄搂茫聛聥茫聜聣莽碌聦猫路炉莽路篓茅聸聠茫聜聮茫聛聴茫聛聼氓聽麓氓聬聢茫聛庐茫聛驴茅聛路莽搂禄氓\u0085聝茫聛芦忙聢禄茫聜聥茫聙聜\n        if($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY_STEP) {\n            backToPreviousPage();\n        }\n    }\n\n    /**\n     * 莽碌聦猫路炉忙聝\u0085氓聽卤茫聛聦盲驴聺氓颅聵茫聛搂茫聛聧茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean}\n     */\n    function canUpdateFlowStep() {\n        if (angular.isUndefined($scope.flow_data)) {\n            return false;\n        }\n        return $scope.flow_data.flow_steps.length \u003e 0;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥莽碌聦猫路炉茫聛庐茫聜鲁茫聝聰茫聝录茫聛聦茫聛搂茫聛聧茫聜聥茫聛聥氓聢陇氓庐職\n     * @return {boolean}\n     */\n    function canCopyFlow() {\n        // 莽碌聦猫路炉氓聫聧忙聵聽茫聝聹茫聜驴茫聝鲁茫聛庐猫隆篓莽陇潞氓聫炉氓聬娄猫篓颅氓庐職茫聛搂猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉false\n        if ($scope.show_reflect_flow_button === Const.miscellaneous.SHOW_REFLECT_FLOW_BUTTON.HIDE) {\n            return false;\n        }\n\n        // 茫聝聡茫聝录茫聜驴猫陋颅茫聛驴猫戮录茫聛驴氓聣聧茫聛炉false\n        if (!($scope.form_data \u0026\u0026 $scope.flow_data \u0026\u0026 fetched_request)) {\n            return false;\n        }\n        // 莽垄潞猫陋聧莽聰禄茅聺垄茫聛搂茫聛聜茫聜聦茫聛掳false\n        if ($scope.isConfirm) {\n            return false;\n        }\n        // 忙聴垄茫聛芦茫聜鲁茫聝聰茫聝录忙赂聢茫聛驴茫聛搂茫聛聜茫聜聦茫聛掳false\n        if ($scope.copy_request_flow_flg) {\n            return false;\n        }\n        // 忙聹聙忙聳掳茫聛庐茫聝聲茫聜漏茫聝录茫聝聽茫聛聦莽路篓茅聸聠氓聫炉猫聝陆茫聛搂茫聛陋茫聛聭茫聜聦茫聛掳false\n        if (!$scope.form_data.edit_flow_setting_flg) {\n            return false;\n        }\n        // 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉莽路篓茅聸聠莽聰禄茅聺垄茫聛庐氓聽麓氓聬聢茫聛炉false\n        if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY_STEP) {\n            return false;\n        }\n\n        // 茫聜鲁茫聝聰茫聝录茫聙聛氓路庐茫聛聴忙聢禄茫聛聴氓聠聧莽聰鲁猫芦聥茫聙聛盲赂聥忙聸赂茫聛聧莽路篓茅聸聠茫聛庐氓聽麓氓聬聢茫聙聛氓\u0085聝茫聛庐莽聰鲁猫芦聥茫聛聦莽碌聦猫路炉莽路篓茅聸聠茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聯茫聛篓\n        var request_kinds = [\n            Const.miscellaneous.CREATE_REQUEST_KIND.COPY,\n            Const.miscellaneous.CREATE_REQUEST_KIND.EDIT,\n            Const.miscellaneous.CREATE_REQUEST_KIND.FEEDBACK,\n        ];\n        if (request_kinds.indexOf($scope.kind) \u003e -1) {\n            if (!fetched_request.edit_flow_flg \u0026\u0026 !fetched_request.is_set_step_user) return false;\n        }\n        // 忙聳掳猫娄聫茫聛庐氓聽麓氓聬聢茫聙聛莽聸麓猫驴聭茫聛庐莽聰鲁猫芦聥茫聛聦莽碌聦猫路炉莽路篓茅聸聠茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聯茫聛篓\n        if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.NEW) {\n            if (!last_request.edit_flow_flg) return false;\n        }\n        return true;\n    }\n\n    /**\n     * 莽碌聦猫路炉茫聜鲁茫聝聰茫聝录茫聝聹茫聜驴茫聝鲁茫聛聦盲陆驴莽聰篓氓聫炉猫聝陆茫聛聥茫聛漏茫聛聠茫聛聥\n     * @return {boolean}\n     */\n    function canUseCopyFlowBtn() {\n        // 莽碌聦猫路炉莽路篓茅聸聠茫聝垄茫聝录茫聝聣盲赂颅茫聛炉盲陆驴莽聰篓盲赂聧氓聫炉\n        if ($scope.edit_flow_step_mode) {\n            return false;\n        }\n        // 茫聜鲁茫聝聰茫聝录氓\u0085聝茫聛庐莽聰鲁猫芦聥氓戮聦茫聙聛莽碌聦猫路炉茫聝聻茫聜鹿茫聜驴茫聛聦忙聸麓忙聳掳茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢茫聛炉莽碌聦猫路炉茫聜鲁茫聝聰茫聝录茫聝聹茫聜驴茫聝鲁茫聛炉盲陆驴莽聰篓盲赂聧氓聫炉\n        return !_isFlowUpdated();\n    }\n\n    function _isFlowUpdated() {\n        // 茫聜鲁茫聝聰茫聝录氓\u0085聝茫聛庐莽聰鲁猫芦聥氓戮聦茫聙聛莽碌聦猫路炉茫聝聻茫聜鹿茫聜驴茫聛聦忙聸麓忙聳掳茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥\n        var created_at =\n            (\n                $scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.NEW ?\n                last_request.created_at : fetched_request.created_at\n            );\n        return !(created_at \u003e= $scope.flow_data.updated_at);\n    }\n\n    /**\n     * 莽碌聦猫路炉茫聜鲁茫聝聰茫聝录茫聝聹茫聜驴茫聝鲁茫聛庐氓聢漏莽聰篓盲赂聧氓聫炉茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @return {String}\n     */\n    function getUnAvalableMessageForCopyFlowBtn() {\n        // 莽碌聦猫路炉莽路篓茅聸聠茫聝垄茫聝录茫聝聣盲赂颅茫聛炉茫聝隆茫聝聝茫聜禄茫聝录茫聜赂茫聜聮猫隆篓莽陇潞茫聛聴茫聛陋茫聛聞\n        if ($scope.edit_flow_step_mode) {\n            return \u0027\u0027;\n        }\n        // 茫聜鲁茫聝聰茫聝录氓\u0085聝茫聛庐莽聰鲁猫芦聥氓戮聦茫聙聛莽碌聦猫路炉茫聝聻茫聜鹿茫聜驴茫聛聦忙聸麓忙聳掳茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥氓聽麓氓聬聢\n        if(_isFlowUpdated()) {\n            return gettextCatalog.getString(\u0027莽碌聦猫路炉茫聝聻茫聜鹿茫聜驴茫聛聦忙聸麓忙聳掳茫聛聲茫聜聦茫聛聼茫聛聼茫聜聛茫聙聛茫聜鲁茫聝聰茫聝录茫聛搂茫聛聧茫聛戮茫聛聸茫聜聯\u0027);\n        }\n        return \u0027\u0027;\n    }\n\n    /**\n     * 忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥莽碌聦猫路炉茫聛庐氓聫聧忙聵聽茫聛聦茫聛搂茫聛聧茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function canSetLatestFlow() {\n        // 莽碌聦猫路炉茫聛庐猫陋颅茫聛驴猫戮录茫聛驴氓庐聦盲潞聠氓聣聧茫聛炉猫隆篓莽陇潞茫聛聲茫聛聸茫聛陋茫聛聞\n        if (util.isUndefinedOrNull($scope.flow_data)) {\n            return false;\n        }\n\n        const conditions = [\n            // 莽垄潞猫陋聧莽聰禄茅聺垄茫聛炉茅聺聻猫隆篓莽陇潞\n            $scope.isConfirm,\n            // 莽聰鲁猫芦聥盲驴庐忙颅拢忙聶聜茫聛炉茅聺聻猫隆篓莽陇潞\n            $scope.isModify,\n            // 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉盲驴庐忙颅拢忙聶聜茫聛炉茅聺聻猫隆篓莽陇潞\n            $scope.isModifyStep,\n        ];\n        // 盲赂聙茫聛陇茫聛搂茫聜聜 true 茫聛陋茫聜聣猫篓卤氓聫炉茫聛聴茫聛陋茫聛聞\n        return !conditions.some(function(condition) {\n            return condition === true;\n        });\n    }\n\n    /**\n     * 忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥莽碌聦猫路炉茫聜聮氓聫聧忙聵聽茫聛聶茫聜聥\n     */\n    function setLatestFlow() {\n        // 莽碌聦猫路炉猫篓颅氓庐職盲赂颅 茫聜聜茫聛聴茫聛聫茫聛炉 莽碌聦猫路炉莽路篓茅聸聠盲赂颅 茫聛庐氓聽麓氓聬聢茫聛炉盲陆聲茫聜聜猫隆聦茫聜聫茫聛陋茫聛聞\n        if ($scope.setting_flow || $scope.edit_flow_step_mode) {\n            return;\n        }\n\n        // 猫隆篓莽陇潞茫聛聶茫聜聥 HTML 忙聳聡茫聛庐盲陆聹忙聢聬\n        const title = gettextCatalog.getString(\u0027忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥莽碌聦猫路炉氓聫聧忙聵聽莽垄潞猫陋聧\u0027);\n        const body = $document[0].createElement(\u0027div\u0027);\n        const caption = $document[0].createElement(\u0027div\u0027);\n        caption.innerText = gettextCatalog.getString(\u0027忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥莽碌聦猫路炉茫聜聮氓聫聧忙聵聽茫聛聴茫聛戮茫聛聶茫聛聥茂录聼\u0027);\n        const caution = $document[0].createElement(\u0027div\u0027);\n        caution.innerText = gettextCatalog.getString(\u0027莽聫戮氓聹篓茫聛庐忙聣驴猫陋聧猫聙\u0085茫聝禄茅聳虏猫娄搂氓聫炉猫聝陆猫聙\u0085茫聛炉盲赂聤忙聸赂茫聛聧茫聛聲茫聜聦茫聜聥茫聛聼茫聜聛茫聙聛忙鲁篓忙聞聫茫聛聴茫聛娄茫聛聫茫聛聽茫聛聲茫聛聞茫聙聜\u0027);\n        caution.style.color = \u0027red\u0027;\n        body.appendChild(caption);\n        body.appendChild(caution);\n\n        dialogService.showConfirmDialogYesNo(\n            title,\n            $sce.trustAsHtml(body.outerHTML)\n        ).then(function(result) {\n            if (!result) {\n                return;\n            }\n            const top_priority = checkExtraFlowPriority();\n            const refreshFlowId = (top_priority === null) ? $scope.default_flow_data.id : top_priority.flow.id;\n            refreshFlow(refreshFlowId, true).then(function () {\n                notifyService.showNotify(gettextCatalog.getString(\u0027忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥莽碌聦猫路炉茫聜聮氓聫聧忙聵聽茫聛聴茫聛戮茫聛聴茫聛聼\u0027), \u0027alert-success\u0027);\n            }).catch(function() {\n                notifyService.showNotify(gettextCatalog.getString(\u0027忙聹聙忙聳掳茫聛庐莽聰鲁猫芦聥莽碌聦猫路炉氓聫聳氓戮聴茫聛芦氓陇卤忙聲聴茫聛聴茫聛戮茫聛聴茫聛聼\u0027), \u0027alert-danger\u0027);\n            });\n        });\n    }\n\n    /**\n     * 莽碌聦猫路炉猫篓颅氓庐職盲赂颅茫聛搂茫聛聜茫聜聥茫聛聥\n     * @return {bool}\n     */\n    $scope.isSettingFlow = function() {\n        return $scope.setting_flow;\n    };\n\n    /**\n     * 莽碌聦猫路炉莽路篓茅聸聠盲赂颅茫聛搂茫聛聜茫聜聥茫聛聥\n     * @return {bool}\n     */\n    $scope.isEdittingFlow = function() {\n        return $scope.edit_flow_step_mode;\n    };\n\n    /**\n     * 茫聜鹿茫聝聠茫聝聝茫聝聴茫聛聦氓庐聦盲潞聠莽聤露忙\u0085聥茫聛聥\n     * @param {object} step\n     * @return {boolean}\n     */\n    function isApprovedStep(step) {\n        return step.status === Const.request.STATUS_FIN;\n    }\n\n    /**\n     * 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉莽路篓茅聸聠茫聛搂茫聛庐莽垄潞猫陋聧忙聶聜茫聛芦茫聙聛盲驴庐忙颅拢茫聛聲茫聜聦茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛搂茫聛聜茫聜聥茫聛聥氓聢陇氓庐職\n     * @param {object} step\n     * @return {boolean}\n     */\n    function isModifiedStep(step) {\n        if ($scope.isModifyStep \u0026\u0026 $scope.isConfirm \u0026\u0026 step.custom_step_flg) {\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 忙聣驴猫陋聧莽碌聦猫路炉茫聛庐盲驴聺氓颅聵氓聡娄莽聬聠\n     */\n    function updateFlowStep() {\n        $scope.edit_flow_step_mode = false;\n        $scope.form_data.edit_flow_flg = true;\n        edit_flow_after_copy_flg = $scope.copy_request_flow_flg;\n        notifyService.showNotify(gettextCatalog.getString(\u0027忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮盲驴聺氓颅聵茫聛聴茫聛戮茫聛聴茫聛聼\u0027), \u0027alert-success\u0027);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐猫驴陆氓聤聽\n     * @param {number} idx\n     */\n    function addFlowStep(idx) {\n        add_flow_step_number++;\n        var flow_step_name = gettextCatalog.getString(\u0027莽聰鲁猫芦聥忙聶聜茫聛芦猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴\u0027) + add_flow_step_number.toString();\n        custom_flow_step.flow_step_number = add_flow_step_number;\n        if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY_STEP) {\n            // 莽聫戮氓聹篓茫聛庐JST忙聶聜氓聢禄茫聜聮氓聫聳氓戮聴茫聛聴茫聛娄茫聜驴茫聜陇茫聝聽茫聜戮茫聝录茫聝鲁氓陇聣忙聫聸\n            const nowJst = TimezoneService.getNowJstDatetimeString();\n            const convertedDatetime = TimezoneService.convertTz(nowJst);\n            flow_step_name = gettextCatalog.getString(\u0027[[datetime_string]] 茫聛芦猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴\u0027,\n                {datetime_string: convertedDatetime});\n        }\n        custom_flow_step.flow_step_name = flow_step_name;\n        var add_step_obj = angular.copy(custom_flow_step);\n        $scope.flow_data.flow_steps.splice(idx + 1, 0, add_step_obj);\n        $scope.flow_data = CreateRequestFlowService.setFlowStepUsers($scope.flow_data);\n        $scope.flow_data = CreateRequestFlowService.setFlowVersion($scope.flow_data, $scope.prev_flow);\n\n        _resetFlowStepNumber();\n    }\n\n    /**\n     * 忙聦聡氓庐職茫聛聲茫聜聦茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐盲赂聥茫聛芦茫聜鹿茫聝聠茫聝聝茫聝聴茫聜聮猫驴陆氓聤聽氓聫炉猫聝陆茫聛聥\n     * @param {object} step\n     * @return {boolean}\n     */\n    function canAddStep(step) {\n        return !($scope.isModifyStep \u0026\u0026 isApprovedStep(step));\n    }\n\n    /**\n     * 忙聣驴猫陋聧猫聙\u0085茫聛庐氓聣聤茅聶陇茫聛聦猫隆聦茫聛聢茫聜聥茫聛聥茂录聢氓聬聧氓聣聧莽職聞茫聛芦氓\u0085篓氓聣聤茅聶陇茫聛拢茫聛陆茫聛聞茫聛聦茫聙聛盲赂聙盲潞潞茫聛職茫聛陇氓聣聤茅聶陇茫聛聦猫隆聦茫聛聢茫聜聥茫聛聥茫聛庐氓聢陇氓庐職茂录聣\n     * @param {object} step\n     * @return {boolean}\n     */\n    function canClearApprover(step) {\n        if ($scope.edit_flow_step_mode) {\n            let ADDABLE = Const.miscellaneous.EDIT_FLOW.ADDABLE;\n            if ($scope.isModifyStep || $scope.form_data.edit_flow_setting_flg === ADDABLE) {\n                return step.custom_step_flg === 1;\n            }\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐茅聽聠莽聲陋茫聜聮氓\u0085楼茫聜聦忙聸驴茫聛聢茫聜聣茫聜聦茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function canChangeStepOrder() {\n        return $scope.edit_flow_step_mode \u0026\u0026 !$scope.isModifyStep;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥氓\u0085聝茫聜掳茫聝芦茫聝录茫聝聴茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function showRequesterGroup() {\n        return $scope.disp_group_select \u0026\u0026 !$scope.isModify \u0026\u0026 !$scope.isModifyStep;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥氓\u0085聝氓陆鹿猫聛路茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function showRequesterPosition() {\n        return $scope.disp_position_select \u0026\u0026 !$scope.isModify \u0026\u0026 !$scope.isModifyStep;\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聝聲茫聜漏茫聝录茫聝聽茫聜芦茫聜鹿茫聜驴茫聝聽茅聽\u0085莽聸庐茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function showRequestFormCustomItem() {\n        return (\n            $scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE \u0026\u0026\n            $scope.form_data.expense.settlement_flg\n                !== Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg\n        );\n    }\n\n    /**\n     * 莽聰鲁猫芦聥氓\u0085聝茫聜掳茫聝芦茫聝录茫聝聴茫聜聮氓陇聣忙聸麓茫聛搂茫聛聧茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function canChangeRequesterGroup() {\n        return !$scope.isConfirm \u0026\u0026 showRequesterGroup();\n    }\n\n    /**\n     * 莽聰鲁猫芦聥氓\u0085聝氓陆鹿猫聛路茫聜聮氓陇聣忙聸麓茫聛搂茫聛聧茫聜聥茫聛聥\n     * @return {boolean}\n     */\n    function canChangeRequesterPosition() {\n        return !$scope.isConfirm \u0026\u0026 showRequesterPosition();\n    }\n\n    /**\n     * 忙聣驴猫陋聧猫聙\u0085茫聜聮芒聵聯茫聝聹茫聜驴茫聝鲁茫聛搂氓聣聤茅聶陇茫聛聶茫聜聥氓聽麓氓聬聢茫聛庐氓聡娄莽聬聠\n     * @param {Array.\u003cobject\u003e} selected_users\n     * @param {number} idx\n     */\n    function deleteStepUser(selected_users, idx) {\n        if ($scope.edit_flow_step_mode) {\n            selected_users.splice(idx, 1);\n        }\n    }\n\n    /**\n     * 莽碌聦猫路炉茫聛庐忙聦聡氓庐職茫聛聲茫聜聦茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聜聮氓聣聤茅聶陇\n     * @param {number} idx\n     */\n    function deleteFlowStepConfirm(idx) {\n        const escaped = util.escapeHtml($scope.flow_data.flow_steps[idx].flow_step_name);\n        var title = gettextCatalog.getString(\u0027氓聣聤茅聶陇茫聛聴茫聛戮茫聛聶茫聛聥茂录聼\u0027);\n        var body = escaped + \u0027 \u0027 + gettextCatalog.getString(\u0027茫聛聦氓聣聤茅聶陇茫聛聲茫聜聦茫聛戮茫聛聶\u0027);\n        dialogService.showConfirmDialogYesNo(\n            title,\n            body,\n            Const.miscellaneous._DIALOG_CLOSE_BUTTON_DISP.show,\n            Const.miscellaneous._DIALOG_OK_BUTTON_TYPE.consent\n        ).then(function(flg) {\n            if (flg) {\n                var message = escaped + \u0027 \u0027 +\n                    gettextCatalog.getString(\u0027茫聜聮氓聣聤茅聶陇茫聛聴茫聛戮茫聛聴茫聛聼\u0027);\n                $scope.flow_data.flow_steps.splice(idx, 1);\n                _resetFlowStepNumber();\n                notifyService.showNotify(message, \u0027alert-danger\u0027);\n            }\n        });\n    }\n\n    /**\n     * 莽碌聦猫路炉莽聤露忙\u0085聥茫聛聦氓陇聣茫聜聫茫聛拢茫聛聼茅職聸茫聛芦莽碌聦猫路炉莽聲陋氓聫路茫聜聮猫篓颅氓庐職茫聛聴莽聸麓茫聛聶\n     * @private\n     */\n    function _resetFlowStepNumber() {\n        if (angular.isUndefinedOrNull($scope.flow_data)) {\n            return;\n        }\n        var first_flow_step_number = $scope.modify_step_data.first_flow_step_number || 0;\n        angular.forEach($scope.flow_data.flow_steps, function(record, idx) {\n            record.flow_step_number_in_version = idx;\n            record.flow_step_number = first_flow_step_number + idx;\n        });\n    }\n\n    /**\n     * 莽碌聦猫路炉茫聛庐茫聜鹿茫聝聠茫聝聝茫聝聴莽聲陋氓聫路茫聛庐忙聸麓忙聳掳氓聡娄莽聬聠\n     * TODO: 氓录聲忙聲掳茫聜聮盲陆驴茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞茫聛庐茫聛搂忙露聢茫聛聶茫聙聜氓庐聼猫拢\u0085茫聛聦_resetFlowStepNumber茫聜聮氓聭录茫聛露茫聛聽茫聛聭茫聛陋茫聛庐茫聛搂茫聙聛茫聛漏茫聛隆茫聜聣茫聛聥茫聛庐茅聳垄忙聲掳茫聛芦莽碌卤盲赂聙\n     * @param {object} e\n     * @param {object} ui\n     */\n    function updateFlowStepOrder(e, ui) {\n        _resetFlowStepNumber();\n    }\n\n    /**\n     * 茫聝漏茫聜赂茫聜陋茫聝聹茫聜驴茫聝鲁茅聽\u0085莽聸庐茫聛庐氓聫聳氓戮聴\n     * @param {object} custom_radio\n     * @param {number} idx\n     * @param {number} item_id TODO:盲陆驴茫聜聫茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞\n     */\n    function onChangeRadio(custom_radio, idx, item_id) {\n        $scope.form_data.form_json[idx].request_content = custom_radio;\n        checkExtraFlow(false);\n        updateTotalAmount();\n        $rootScope.$broadcast(\u0027update_specifics_type_map\u0027);\n    }\n\n    /**\n     * 茫聝聴茫聝芦茫聝聙茫聜娄茫聝鲁茅聽\u0085莽聸庐茫聛庐氓聫聳氓戮聴\n     * @param {object} custom_pulldown\n     * @param {number} idx\n     * @param {number} item_id TODO:盲陆驴茫聜聫茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞\n     */\n    function onChangePulldown(custom_pulldown, idx, item_id) {\n        if (!angular.isUndefinedOrNull(custom_pulldown)) {\n            $scope.form_data.form_json[idx].request_content = custom_pulldown;\n        }\n        else {\n            $scope.form_data.form_json[idx].request_content = \u0027\u0027;\n        }\n        checkExtraFlow(false);\n        updateTotalAmount();\n        $rootScope.$broadcast(\u0027update_specifics_type_map\u0027);\n    }\n\n    /**\n     * 茫聝聛茫聜搂茫聝聝茫聜炉茫聝聹茫聝聝茫聜炉茫聜鹿茫聛庐氓聢聡茫聜聤忙聸驴茫聛聢\n     * @param {number} item_idx\n     * @param {number} label_idx\n     */\n    $scope.onChangeCheckBox = function onChangeCheckBox(item_idx, label_idx) {\n        toggle(item_idx, label_idx);\n        updateTotalAmount();\n        $rootScope.$broadcast(\u0027update_specifics_type_map\u0027);\n    };\n\n    /**\n     * 忙聹聙莽碌聜忙聣驴猫陋聧忙聹聼茅聶聬茫聛庐茅聛赂忙聤聻忙聶聜茫聛庐氓聡娄莽聬聠\n     */\n    function onChangePeriod() {\n        if ($scope.last_approval_period.selected_flg === 0) {\n            delete $scope.last_approval_period.selected_date;\n        }\n    }\n\n    /**\n     * 茫聝聛茫聜搂茫聝聝茫聜炉茫聝聹茫聝聝茫聜炉茫聜鹿茅聽\u0085莽聸庐茫聛庐猫驴陆氓聤聽茫聙聛氓聣聤茅聶陇\n     * @param {number} item_idx\n     * @param {number} label_idx\n     */\n    function toggle(item_idx, label_idx) {\n        var item = $scope.form_data.form_json[item_idx];\n        var labels_obj = item.select_item_labels_obj;\n\n        // 茫聝聛茫聜搂茫聝聝茫聜炉莽聤露忙\u0085聥茫聜聮氓聢聡茫聜聤忙聸驴茫聛聢\n        labels_obj[label_idx].checked = !labels_obj[label_idx].checked;\n\n        item.request_content = createRequestService.createRequestContent(labels_obj);\n        item.is_cleared = true;\n        checkExtraFlow(false);\n    }\n\n    /**\n     * mobile氓掳聜莽聰篓 忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴莽聰篓茫聛庐茫聜垄茫聜炉茫聜路茫聝搂茫聝鲁茫聝聹茫聜驴茫聝鲁猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥茫聛庐氓聢陇氓庐職\n     * @param {object} flow_step\n     * @return {boolean}\n     */\n    function dispActionButtonForStep(flow_step) {\n        if (!$rootScope.is_mobile) {\n            return false;\n        }\n        if ($scope.isConfirm) {\n            return false;\n        }\n        if (_getPossibleActionsForStep(flow_step).length \u003e 0) {\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 忙聦聡氓庐職茫聛聲茫聜聦茫聛聼忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聛芦氓炉戮茫聛聴茫聛娄茫聙聛忙聯聧盲陆聹氓聫炉猫聝陆茫聛陋茫聝陋茫聜鹿茫聝聢茫聜聮猫驴聰氓聧麓茫聛聶茫聜聥\n     * @param {Object} flow_step\n     * @return {Array.\u003cObject\u003e}\n     * @private\n     */\n    function _getPossibleActionsForStep(flow_step) {\n        var action_buttons = [];\n        if (canSearchApprover(flow_step)) {\n            action_buttons.push({text: gettextCatalog.getString(\u0027忙聣驴猫陋聧猫聙\u0085茫聜聮忙陇聹莽麓垄\u0027),\n                                 action: Const.miscellaneous.ACTION_SHEET_KEY_SEARCH_APPROVER});\n        }\n        if (canChangeApproveCondition(flow_step) \u0026\u0026 flow_step.condition === Const.miscellaneous.APPROVE_CONDITION_ALL) {\n            action_buttons.push({text: gettextCatalog.getString(\u0027茫聙聦猫陋掳茫聛聥盲赂聙盲潞潞茫聛聦忙聣驴猫陋聧茫聙聧茫聛芦茫聛聶茫聜聥\u0027),\n                                 action: Const.miscellaneous.ACTION_SHEET_KEY_APPROVE_CONDITION_ONE});\n        }\n        if (canChangeApproveCondition(flow_step) \u0026\u0026 flow_step.condition === Const.miscellaneous.APPROVE_CONDITION_ONE) {\n            action_buttons.push({text: gettextCatalog.getString(\u0027茫聙聦氓\u0085篓氓聯隆茫聛庐忙聣驴猫陋聧茫聛聦氓驴\u0085猫娄聛茫聙聧茫聛芦茫聛聶茫聜聥\u0027),\n                                 action: Const.miscellaneous.ACTION_SHEET_KEY_APPROVE_CONDITION_ALL});\n        }\n        return action_buttons;\n    }\n\n    /**\n     * 忙聦聡氓庐職茫聛聲茫聜聦茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛芦忙聣驴猫陋聧猫聙\u0085茫聛聦茫聛聞茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉true茫聛聦猫驴聰茫聜聥\n     * @param {object} flow_step\n     * @return {boolean}\n     */\n    function noExistApprovers(flow_step) {\n        // 猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐氓聽麓氓聬聢茫聜聮茅聶陇茫聛聫\n        if (flow_step.custom_step_flg) {\n            return false;\n        }\n        // 茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦茅聛赂忙聤聻茫聙聧茫聛庐氓聽麓氓聬聢茫聛炉茫聝娄茫聝录茫聜露茅聛赂忙聤聻莽聰禄茅聺垄茫聛搂猫隆篓莽陇潞茫聛聲茫聛聸茫聜聥\n        if (flow_step.approval_kind === Const.miscellaneous._APPROVAL_KIND_KEY.SELECT_APPROVER) {\n            return false;\n        }\n        return !flow_step.flow_step_users.length;\n    }\n\n    /**\n     * 忙聣驴猫陋聧猫聙\u0085茫聜聮忙陇聹莽麓垄茫聛搂茫聛聧茫聜聥茫聛聥\n     * @param {object} flow_step\n     * @return {boolean}\n     */\n    function canSearchApprover(flow_step) {\n        // 莽碌聦猫路炉茫聜鲁茫聝聰茫聝录茫聛聴茫聛聼氓聽麓氓聬聢茫聙聛茫聜鲁茫聝聰茫聝录茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐忙聣驴猫陋聧猫聙\u0085茫聛炉氓聣聤茅聶陇茫聛聴茫聛聥茫聛搂茫聛聧茫聛陋茫聛聞\n        if ($scope.copy_request_flow_flg \u0026\u0026 flow_step.custom_step_flg !== 1) {\n            return false;\n        }\n        // 莽垄潞猫陋聧莽聰禄茅聺垄盲禄楼氓陇聳\n        if (!$scope.isConfirm) {\n            // 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉盲驴庐忙颅拢忙聶聜茫聛炉茫聙聛猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐茫聛驴忙聣驴猫陋聧猫聙\u0085茫聜聮茅聛赂忙聤聻茫聛搂茫聛聧茫聜聥\n            const ADDABLE = Const.miscellaneous.EDIT_FLOW.ADDABLE;\n            if ($scope.isModifyStep || $scope.form_data.edit_flow_setting_flg === ADDABLE) {\n                // 盲陆聹忙聢聬忙赂聢茫聛驴茫聛庐莽聰鲁猫芦聥盲赂聙猫娄搂茫聛聥茫聜聣忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮莽路篓茅聸聠茫聛聶茫聜聥氓聽麓氓聬聢($scope.isModifyStep)\n                // 茫聝聲茫聜漏茫聝录茫聝聽猫篓颅氓庐職茫聛庐莽碌聦猫路炉莽路篓茅聸聠(莽聰鲁猫芦聥猫聙\u0085)茫聛聦茫聙聦猫驴陆氓聤聽茫聛庐茫聛驴猫篓卤氓聫炉茫聙聧茫聛庐氓聽麓氓聬聢(edit_flow_setting_flg === ADDABLE)\n                // 盲赂聤猫篓聵茫聛聞茫聛職茫聜聦茫聛聥茫聛芦猫漏虏氓陆聯茫聛聶茫聜聥氓聽麓氓聬聢茫聙聛茫聙聦猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聙聧(custom_step_flg === 1)茫聛芦茫聛庐茫聛驴茫聙聦忙聣驴猫陋聧猫聙\u0085茫聜聮忙陇聹莽麓垄茫聙聧茫聝聹茫聜驴茫聝鲁茫聜聮猫隆篓莽陇潞茫聛聴茫聛娄\n                // 茫聛聤茫聜聤茫聙聛忙聳掳猫娄聫莽聰鲁猫芦聥茫聛聥茫聛陇茫聙聦猫驴陆氓聤聽茫聛庐茫聛驴猫篓卤氓聫炉茫聙聧茫聛庐氓聽麓氓聬聢茫聛炉茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聙聧茫聛庐茫聜鹿茫聝聠茫聝聝茫聝聴茫聛芦茫聙聦忙聣驴猫陋聧猫聙\u0085茫聜聮忙陇聹莽麓垄茫聙聧茫聝聹茫聜驴茫聝鲁茫聛聦猫隆篓莽陇潞茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聥茫聛拢茫聛聼\n                // 茫聛聺茫聛庐茫聛聼茫聜聛茫聙聛忙聳掳猫娄聫莽聰鲁猫芦聥茫聛搂茫聜聜茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聙聧茫聛搂茫聛聜茫聜聦茫聛掳茫聙聛茫聙聦忙聣驴猫陋聧猫聙\u0085茫聜聮忙陇聹莽麓垄茫聙聧茫聝聹茫聜驴茫聝鲁茫聜聮猫隆篓莽陇潞茫聛聲茫聛聸茫聜聥氓聡娄莽聬聠茫聜聮猫驴陆氓聤聽\n                if (!$scope.isModifyStep) {\n                    // 忙聳掳猫娄聫莽聰鲁猫芦聥忙聶聜茫聜聜茫聙聦莽聰鲁猫芦聥忙聶聜茫聛芦忙聦聡氓庐職茫聙聧茫聛搂茫聛聜茫聜聦茫聛掳True茫聜聮猫驴聰茫聛聶茂录聢莽聰鲁猫芦聥忙聶聜茫聛芦猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聜聜茫聛聯茫聛庐忙聺隆盲禄露茫聛芦猫漏虏氓陆聯茫聛聴True茫聛篓茫聛陋茫聜聥茂录聣\n                    return flow_step.approval_kind === Const.miscellaneous._APPROVAL_KIND_KEY.SELECT_APPROVER;\n                }\n                // 忙聳掳猫娄聫莽聰鲁猫芦聥茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢茫聜聜茫聙聦猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聙聧茫聛炉True茫聜聮猫驴聰茫聛聶\n                return flow_step.custom_step_flg === 1;\n            }\n            if ($scope.edit_flow_step_mode) {\n                return true;\n            }\n            return flow_step.approval_kind === Const.miscellaneous._APPROVAL_KIND_KEY.SELECT_APPROVER;\n        }\n        return false;\n    }\n\n    /**\n     * 忙聣驴猫陋聧忙聺隆盲禄露(猫陋掳茫聛聥1盲潞潞or氓\u0085篓氓聯隆)茫聜聮氓陇聣忙聸麓茫聛搂茫聛聧茫聜聥茫聛聥\n     * @param {object} flow_step\n     * @return {boolean}\n     */\n    function canChangeApproveCondition(flow_step) {\n        // 莽垄潞猫陋聧莽聰禄茅聺垄盲禄楼氓陇聳氓聫聤茫聛鲁忙聣驴猫陋聧猫聙\u0085茫聛聦茫聛聞茫聜聥茫聛戮茫聛聼茫聛炉忙聦聡氓庐職茫聛聲茫聜聦茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐盲赂颅茫聛芦忙聣驴猫陋聧猫聙\u0085茫聛聦茫聛聞茫聜聥氓聽麓氓聬聢\n        if (!$scope.isConfirm \u0026\u0026 flow_step.flow_step_users.length \u003e 0 || !noExistApprovers(flow_step)) {\n            if ($scope.edit_flow_step_mode) {\n                // 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉盲驴庐忙颅拢忙聶聜茫聛炉茫聙聛猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐茫聛驴忙聣驴猫陋聧猫聙\u0085茫聜聮茅聛赂忙聤聻茫聛搂茫聛聧茫聜聥\n                const ADDABLE = Const.miscellaneous.EDIT_FLOW.ADDABLE;\n                if ($scope.isModifyStep || $scope.form_data.edit_flow_setting_flg === ADDABLE) {\n                    return flow_step.custom_step_flg === 1;\n                }\n                return true;\n            }\n        }\n        return false;\n    }\n\n    /**\n     * 忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聜聮氓聣聤茅聶陇茫聛搂茫聛聧茫聜聥茫聛聥\n     * @param {object} flow_step\n     * @return {boolean}\n     */\n    function canDeleteStep(flow_step) {\n        if ($scope.edit_flow_step_mode) {\n            var ADDABLE = Const.miscellaneous.EDIT_FLOW.ADDABLE;\n            if ($scope.isModifyStep || $scope.form_data.edit_flow_setting_flg === ADDABLE) {\n                return flow_step.custom_step_flg === 1;\n            }\n            return true;\n        }\n        return false;\n    }\n\n    /**\n     * 茫聝垄茫聝聬茫聜陇茫聝芦茫聝禄茫聜垄茫聝聴茫聝陋莽聰篓茫聛庐茫聙聛忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聛庐莽路篓茅聸聠氓聠\u0085氓庐鹿茫聛庐茅聛赂忙聤聻茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茂录聢茫聜垄茫聜炉茫聜路茫聝搂茫聝鲁茫聜路茫聝录茫聝聢茂录聣猫隆篓莽陇潞\n     * @param {object} flow_step\n     */\n    function showMobileActionsForStep(flow_step) {\n        // 茫聜垄茫聝聴茫聝陋茫聛庐氓聽麓氓聬聢茫聛庐氓聡娄莽聬聠\n        if ($rootScope.is_sp_app) {\n            app__showActionSheetForStep(flow_step);\n            return;\n        }\n        var params = {};\n        params.possible_actions = _getPossibleActionsForStep(flow_step);\n        var modalInstance = $uibModal.open({\n            templateUrl: \u0027../static/wf/views/dialogs/mobile_request_action_templ.html\u0027,\n            controller: \u0027mobileRequestActionDialog\u0027,\n            resolve: {\n                params: function() {\n                  return params;\n                },\n            },\n            size: \u0027mobile\u0027,\n        });\n        modalInstance.result.then(function(action_key) {\n            _doActionForStepFromSheet(action_key, flow_step);\n        }, function() {\n              // dismiss\n        });\n    }\n\n    /**\n     * 忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴莽路篓茅聸聠氓聡娄莽聬聠茫聛庐氓聭录茫聛鲁氓聡潞茫聛聴茂录聢茫聜垄茫聜炉茫聜路茫聝搂茫聝鲁茫聜路茫聝录茫聝聢茫聛庐莽碌聬忙聻聹茫聜聮氓聫聴茫聛聭茫聛娄茂录聣\n     * @param {string} action_key\n     * @param {Object} flow_step\n     * @private\n     */\n    function _doActionForStepFromSheet(action_key, flow_step) {\n        if (action_key == Const.miscellaneous.ACTION_SHEET_KEY_SEARCH_APPROVER) {\n            showFlowStepUserSearchDialog(flow_step);\n        }\n        if (action_key == Const.miscellaneous.ACTION_SHEET_KEY_APPROVE_CONDITION_ALL) {\n            onChangeCondition(flow_step);\n        }\n        if (action_key == Const.miscellaneous.ACTION_SHEET_KEY_APPROVE_CONDITION_ONE) {\n            onChangeCondition(flow_step);\n        }\n    }\n\n    /**\n     * 忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐莽路篓茅聸聠莽聰篓茫聜垄茫聜炉茫聜路茫聝搂茫聝鲁茫聜路茫聝录茫聝聢\n     * @param {Object} flow_step\n     */\n    function app__showActionSheetForStep(flow_step) {\n        if (!$rootScope.is_sp_app) {\n            return;\n        }\n        var ionicActionSheet = $injector.get(\u0027$ionicActionSheet\u0027);\n        var action_buttons = _getPossibleActionsForStep(flow_step);\n\n        var hideSheet = ionicActionSheet.show({\n            buttons: action_buttons,\n            titleText: \u0027\u0027,\n            cancelText: _(\u0027茅聳聣茫聛聵茫聜聥\u0027),\n            cancel: function() {\n            },\n            buttonClicked: function(btn_idx) {\n              hideSheet();\n              _doActionForStepFromSheet(action_buttons[btn_idx].action, flow_step);\n            },\n        });\n    }\n\n    /**\n     * 忙聣驴猫陋聧茫聜鹿茫聝聠茫聝聝茫聝聴茫聛庐氓\u0085篓氓聯隆茫聛庐忙聣驴猫陋聧茫聛聦氓驴\u0085猫娄聛茫聛聥茫聛漏茫聛聠茫聛聥茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉茫聛庐氓聢聡忙聸驴忙聶聜茫聛庐氓聡娄莽聬聠\n     * @param {object} flow_step\n     */\n    function onChangeCondition(flow_step) {\n        if (flow_step.condition == Const.miscellaneous.APPROVE_CONDITION_ALL) {\n            flow_step.condition = Const.miscellaneous.APPROVE_CONDITION_ONE;\n        }\n        else {\n            flow_step.condition = Const.miscellaneous.APPROVE_CONDITION_ALL;\n        }\n    }\n\n    /**\n     * 忙聣驴猫陋聧猫聙\u0085氓聬聧茫聝聙茫聜陇茫聜垄茫聝颅茫聜掳茫聛庐猫隆篓莽陇潞\n     * @param {object} flow_step\n     */\n    function showFlowStepUserSearchDialog(flow_step) {\n        const size = $rootScope.is_mobile ? \u0027mobile\u0027 : \u0027\u0027;\n        const previous_selected_users = [...flow_step.selected_users];\n        const params = {\n            flowStepUsers: flow_step.flow_step_users,\n            selected_users: previous_selected_users,\n            request_id: $scope.request_id ,\n            form_id: $scope.form_data.form_id,\n            flow_step_id: flow_step.id || null,\n            requester_id: angular.isDefined($scope.requester) ? $scope.requester.id : null,\n            group_id: $scope.requester_info.requester_group_id,\n        };\n        const modalInstance = $uibModal.open({\n            templateUrl: \u0027../static/wf/views/dialogs/select_flow_step_users_templ.html\u0027,\n            controller: \u0027flowStepUserSearchDialogCtrl\u0027,\n            size: size,\n            scope: $scope,\n            resolve: {\n                params: function() {\n                    return params;\n                },\n            },\n        });\n        modalInstance.result.then(function(result) {\n            $scope.selected_users = result;\n            flow_step.selected_users = result;\n        }, function() {\n            // dismiss\n        });\n    }\n\n    /**\n     * 氓聠\u0085猫篓鲁茫聝聡茫聝录茫聜驴茫聛庐氓聫聳氓戮聴\n     * @param {Array.\u003cObject\u003e} default_atp\n     */\n    function getAccountTitleParts(default_atp) {\n        // 茫聝聲茫聜漏茫聝录茫聝聽茫聛芦莽麓聬盲禄聵茫聛聞茫聛聼氓聠\u0085猫篓鲁茫聛庐id茫聜聮忙赂隆茫聛聶\n        var atp_ids = [];\n        angular.forEach(default_atp, function(atp) {\n            atp_ids.push(atp.id);\n        });\n        var params = {\n            \u0027account_title_part_ids\u0027: atp_ids.join(\u0027,\u0027),\n        };\n\n        AccountTitlePartService.getList(params)\n        .then(function(res) {\n            var data = res.data;\n            // default_atp茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茫聙聛茫聛聺茫聜聦茫聛庐茫聛驴茫聜聮猫隆篓莽陇潞\n            if (!angular.isUndefinedOrNull(default_atp)) {\n                var default_atp_json = default_atp;\n                if (default_atp_json.length != 0) {\n                    var account_title_parts = [];\n                    for (var i = 0; i \u003c default_atp_json.length; i++) {\n                        for (var j = 0; j\u003c data.results.length; j++) {\n                            if (default_atp_json[i].id == data.results[j].id) {\n                                account_title_parts.push(data.results[j]);\n                            }\n                        }\n                    }\n                    // 茫聝聲茫聜漏茫聝录茫聝聽茫聛芦莽麓聬茫聛楼茫聛聭茫聛聼氓聠\u0085猫篓鲁茫聛聦氓聣聤茅聶陇茫聛聲茫聜聦茫聙聛茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢氓聠\u0085猫篓鲁忙聲掳茫聛聦0茫聛芦茫聛陋茫聛拢茫聛聼茫聜聣氓\u0085篓茫聛娄茫聛庐氓聠\u0085猫篓鲁茫聜聮猫隆篓莽陇潞茫聛聲茫聛聸茫聜聥\n                    if (account_title_parts.length != 0) {\n                        $scope.account_title_parts = account_title_parts;\n                    }\n                    else {\n                        $scope.account_title_parts = data.results;\n                    }\n                }\n            }\n            else {\n                $scope.account_title_parts = data.results;\n            }\n        })\n        .catch(function() {\n        });\n    }\n\n    /**\n     * 忙聰炉忙聣聲忙聳鹿忙鲁聲茫聝聡茫聝录茫聜驴茫聛庐氓聫聳氓戮聴茂录聢莽碌聦猫虏禄莽虏戮莽庐聴莽聰篓茂录聣\n     */\n    function getPaymentTypes() {\n        PaymentTypeService.getList({\u0027excludes_corporate_cards\u0027: true})\n        .then(function(res) {\n            $scope.payment_types = res.data;\n        })\n        .catch(function() {\n        });\n    }\n\n    /**\n     * 茫聝聲茫聝陋茫聝录猫篓颅氓庐職茅聽\u0085莽聸庐茫聛聦氓驴\u0085茅聽聢茫聛聥茫聛漏茫聛聠茫聛聥氓聢陇氓庐職\n     * @param {object} form_item\n     * @return {boolean}\n     */\n    function isRequired(form_item) {\n        // 氓驴\u0085茅聽聢茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛聜茫聜聤\n        if (createRequestService.hasExtraOptions(form_item, \u0027is_required\u0027) \u0026\u0026\n            checkItemOptionStatus(form_item, \u0027is_required\u0027)\n        ) {\n            return true;\n        }\n\n        // 氓驴\u0085茅聽聢猫篓颅氓庐職茫聛聜茫聜聤茂录聠氓驴\u0085茅聽聢茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛聜茫聜聤茫聛庐氓聽麓氓聬聢茫聛炉茫聙聛氓驴\u0085茅聽聢茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聜聮氓聞陋氓\u0085聢茫聛聶茫聜聥\n        if (form_item.is_required \u0026\u0026 createRequestService.hasExtraOptions(form_item, \u0027is_required\u0027)) {\n            return checkItemOptionStatus(form_item, \u0027is_required\u0027);\n        }\n\n        // 氓驴\u0085茅聽聢猫篓颅氓庐職茫聛聜茫聜聤茂录聠氓驴\u0085茅聽聢茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛陋茫聛聴\n        if (form_item.is_required \u0026\u0026 !createRequestService.hasExtraOptions(form_item, \u0027is_required\u0027)) {\n            return true;\n        }\n        else {\n            return false;\n        }\n    }\n\n    /**\n     * form_item茫聛庐茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茂录聢氓录聲忙聲掳茫聛搂忙聦聡氓庐職茫聛聲茫聜聦茫聛聼茫聜颅茫聝录茫聛庐茫聜聜茫聛庐茂录聣茫聛聦茫聙聛忙潞聙茫聛聼茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉\n     * ex. option_key = \u0027is_disp\u0027 茫聛搂茫聛聜茫聜聦茫聛掳茫聙聛form_item 茫聛聦茫聙聛猫隆篓莽陇潞氓聢露氓戮隆茫聛庐氓聢陇氓庐職茫聛庐莽碌聬忙聻聹茫聙聛猫隆篓莽陇潞茫聛聶茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥茫聜聮猫驴聰茫聛聶茫聙聜\n     * @param {object} form_item 忙聵聨莽麓掳猫隆篓茫聙聛茫聛戮茫聛聼茫聛炉茫聝聲茫聝陋茫聝录猫篓颅氓庐職茅聽\u0085莽聸庐茫聜陋茫聝聳茫聜赂茫聜搂茫聜炉茫聝聢\n     * @param {string} option_key 猫隆篓莽陇潞茫聜陋茫聝聴茫聜路茫聝搂茫聝鲁茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉忙聶聜茫聛炉\u0027is_disp\u0027茫聙聛氓驴\u0085茅聽聢茫聝聛茫聜搂茫聝聝茫聜炉忙聶聜茫聛炉\u0027is_required\u0027茫聜聮忙聦聡氓庐職\n     * @return {boolean} 忙聺隆盲禄露茫聛聦忙潞聙茫聛聼茫聛聲茫聜聦茫聛娄茫聛聞茫聜聦茫聛掳true茫聜聮猫驴聰茫聛聶\n     */\n    function checkItemOptionStatus(form_item, option_key) {\n        return createRequestService.checkItemOptionStatus(form_item, option_key, mapped_items);\n    }\n\n    // 氓聙聥氓聢楼茫聝聡茫聝录茫聜驴茫聛庐氓聢楼茅聙聰猫陋颅茫聛驴猫戮录茫聛驴茫聛庐莽聜潞茫聙聛0.5s氓戮\u0085茫聛拢茫聛娄茫聛聥茫聜聣猫隆篓莽陇潞茫聛聶茫聜聥\n    $rootScope.$on(\u0027$viewContentLoaded\u0027, function() {\n        $timeout(function() {\n            $scope.display_now = true;\n        }, 500);\n    });\n\n    /**\n     * 莽碌聦猫虏禄茫聛庐氓聠\u0085猫篓鲁茫聙聛忙聰炉忙聣聲茫聛庐氓聠\u0085猫篓鲁茫聛搂茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵氓驴\u0085茅聽聢茫聛庐氓聠\u0085猫篓鲁茫聜聮茅聛赂忙聤聻茫聛聴茫聛聼氓聽麓氓聬聢茫聙聛茫聝聲茫聜漏茫聝录茫聝聽茫聛庐茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵忙卢聞茫聜聮猫隆篓莽陇潞茫聛聶茫聜聥\n     * @return {boolean}\n     */\n     function showFileAttachment() {\n         // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            return $scope.form_data.expense.attachment_setting !== Const.miscellaneous.ATTACHMENT_SETTING.REQUIRED;\n        }\n\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            return $scope.form_data.payment.attachment_setting !== Const.miscellaneous.ATTACHMENT_SETTING.REQUIRED;\n        }\n        return true;\n     }\n\n    /**\n     * 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聛庐氓驴\u0085茅聽聢茫聝聛茫聜搂茫聝聝茫聜炉\n     * @return {boolean}\n     */\n    function attachment_validation() {\n        if (permissionService.isFreeUser()) {\n            return true;\n        }\n\n        // 忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茫聛炉莽垄潞猫陋聧茫聛聴茫聛陋茫聛聞\n        if ($scope.request_files.length \u003e 0) {\n            return true;\n        }\n\n        // 忙路禄盲禄聵氓驴\u0085茅聽聢茫聛搂茫聛聜茫聜聥茫聛聥莽垄潞猫陋聧茫聛聶茫聜聥\n        if ($scope.form_data.attachment_setting_flg === Const.miscellaneous.ATTACHMENT_SETTING_FLG.REQUIRED) {\n            return false;\n        }\n\n        // 莽碌聦猫虏禄莽虏戮莽庐聴茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聛聜茫聜聥氓聽麓氓聬聢\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_EXPENSE) {\n            // 氓驴\u0085茅聽聢茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉 OK\n            return $scope.form_data.expense.attachment_setting !== Const.miscellaneous.ATTACHMENT_SETTING.REQUIRED;\n        }\n\n        // 忙聰炉忙聣聲盲戮聺茅聽录茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聛聜茫聜聥氓聽麓氓聬聢\n        if ($scope.form_type === Const.miscellaneous.FORM_TYPE_PAYMENT) {\n            // 氓驴\u0085茅聽聢茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉 OK\n            return $scope.form_data.payment.attachment_setting !== Const.miscellaneous.ATTACHMENT_SETTING.REQUIRED;\n        }\n\n        return true;\n    }\n\n    /**\n     * 忙聵聨莽麓掳猫隆聦茫聛庐忙路禄盲禄聵茫聝聲茫聜隆茫聜陇茫聝芦茫聛聦氓驴\u0085猫娄聛茫聛聥氓聢陇氓庐職\n     * @param {object} row 忙聵聨莽麓掳猫隆聦\n     * @return {boolean} true:忙路禄盲禄聵茫聛聦氓驴\u0085猫娄聛/false:忙路禄盲禄聵忙赂聢茫聙聛茫聜聜茫聛聴茫聛聫茫聛炉忙路禄盲禄聵茫聛聦盲禄禄忙聞聫\n     */\n    function _shouldAttachSpecificsDetail(row) {\n        // 忙聵聨莽麓掳氓聢聠氓聣虏氓戮聦茫聛庐氓颅聬忙聵聨莽麓掳茫聛炉氓聢陇氓庐職茫聛聴茫聛陋茫聛聞\n        if (row.is_child_specifics){\n            return false;\n        }\n        // 忙路禄盲禄聵茫聛聦氓驴\u0085茅聽聢盲禄楼氓陇聳茫聛庐氓聽麓氓聬聢茫聙聛氓聢陇氓庐職茫聛聶茫聜聥氓驴\u0085猫娄聛茫聛聦茫聛陋茫聛聞\n        if (row.attachment_setting !== Const.miscellaneous.ATTACHMENT_SETTING.REQUIRED){\n            return false;\n        }\n        return row.files == null || row.files.length === 0;\n    }\n\n    /**\n    * 茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵茫聛聦氓驴\u0085猫娄聛茫聛陋忙聵聨莽麓掳茫聛聦忙庐聥茫聛拢茫聛娄茫聛聞茫聜聥茫聛聥茫聝聛茫聜搂茫聝聝茫聜炉\n    * @param {Array} rows\n    * @return {boolean} true:忙庐聥茫聛拢茫聛娄茫聛聞茫聛陋茫聛聞/false:忙庐聥茫聛拢茫聛娄茫聛聞茫聜聥\n    */\n    function isValidAttachmentSetting(rows) {\n        // 忙聹聼忙聴楼氓陇聣忙聸麓茫聝聲茫聜漏茫聝录茫聝聽茫聛庐氓聽麓氓聬聢茫聙聛茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵盲赂聧猫娄聛\n        if ($scope.form_data.expense \u0026\u0026 $scope.form_data.expense.settlement_flg ===\n            Const.miscellaneous._FORM_TYPE.EXPENSE_CHANGE_DEADLINE.settlement_flg\n        ) {\n            return true;\n        }\n        // 忙路禄盲禄聵氓驴\u0085茅聽聢茫聛庐忙聵聨莽麓掳猫隆聦茫聛芦氓炉戮茫聛聴茫聙聛茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵茫聛聦莽聞隆茫聛聞莽聤露忙\u0085聥茫聛庐忙聵聨莽麓掳猫隆聦茫聜聮茫聝聲茫聜拢茫聝芦茫聜驴\n        const filtered = rows.filter(function(row) {\n            return _shouldAttachSpecificsDetail(row);\n        });\n        // 忙路禄盲禄聵氓驴\u0085茅聽聢茫聛庐忙聵聨莽麓掳猫隆聦茫聛庐氓\u0085篓茫聛娄茫聛聦茫聝聲茫聜隆茫聜陇茫聝芦忙路禄盲禄聵茫聛聜茫聜聤茫聛庐莽聤露忙\u0085聥茫聛搂茫聛聜茫聜聦茫聛掳茫聙聛茫聝聲茫聜拢茫聝芦茫聜驴莽碌聬忙聻聹茫聛聦0盲禄露茫聛芦茫聛陋茫聜聥\n        return filtered.length === 0;\n    }\n\n    /**\n     * 忙聵聨莽麓掳茫聛聦茫聛聜茫聜聥茫聛聥茫聛漏茫聛聠茫聛聥茫聜聮氓聢陇氓庐職\n     * @return {boolean}\n     */\n    function isSpecificsSheet() {\n        return createRequestService.isSpecificsSheet($scope.form_type, $scope.form_data);\n    }\n\n    /**\n     * 茫聝聲茫聜漏茫聝录茫聝聽茫聛芦猫隆篓莽陇潞茫聛聶茫聜聥茅聙職猫虏篓氓聬聧茫聜聮氓聫聳氓戮聴茫聛聶茫聜聥\n     * @param {number} currencyCode 茅聙職猫虏篓茫聜鲁茫聝录茫聝聣\n     * @return {String}\n     */\n    function getCurrencySymbol(currencyCode) {\n        return FormService.getCurrencySymbol(currencyCode);\n    }\n\n    /**\n     * 莽聰鲁猫芦聥茫聛搂茫聛聧茫聜聥莽聤露忙\u0085聥茫聛聥茫聛漏茫聛聠茫聛聥茫聙聛茫聝聛茫聜搂茫聝聝茫聜炉茫聛聶茫聜聥\n     * @param {Object} request_form\n     * @param {Array} present_divisions\n     * @return {{result: (string|null), data: {sheet_index_for_clear: Array.\u003cnumber\u003e}}}\n     */\n    function checkFormError(request_form, present_divisions) {\n        var sheet_index_for_clear = [];\n        var result = {result: null, data: {sheet_index_for_clear: sheet_index_for_clear}};\n        var i; // for茫聝芦茫聝录茫聝聴茫聛庐茫聜芦茫聜娄茫聝鲁茫聜驴\n\n        // 茫聝聡茫聝聲茫聜漏茫聝芦茫聝聢茫聛庐忙路禄盲禄聵忙漏聼猫聝陆茫聛聦氓驴\u0085茅聽聢茫聛搂茫聙聛忙路禄盲禄聵茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞茫聛聥茫聝聛茫聜搂茫聝聝茫聜炉\n        if (!attachment_validation()) {\n            result.result = ATTACHMENT_VALIDATION_ERROR;\n            return result;\n        }\n\n\n        // 茫聜炉茫聝漏茫聜娄茫聝聣茫聜碌茫聜陇茫聝鲁忙聸赂茅隆聻茫聛庐盲赂聧氓聜聶茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉\n        if (CloudsignService.hasDocument($scope.req)) {\n            if (!CloudsignService.isValid($scope.req.cloudsign_document)) {\n                result.result = CLOUDSIGN_VALIDATION_ERROR;\n                return result;\n            }\n        }\n        else {\n            if ($scope.form_data.cloudsign_setting_flg === 2) {\n                result.result = NO_CLOUDSIGN_ERROR;\n                return result;\n            }\n        }\n\n        // Box 茫聛庐盲赂聧氓聜聶茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉\n        if ($scope.form_data.box_setting_flg === 2) {\n            if (angular.isUndefinedOrNull($scope.box_folder_name) || $scope.box_folder_name === \u0027\u0027) {\n                result.result = NO_BOX_ERROR;\n                return result;\n            }\n        }\n\n        // Hubble茫聛庐盲赂聧氓聜聶茫聜聮茫聝聛茫聜搂茫聝聝茫聜炉茂录聢茫聝聲茫聜隆茫聜陇茫聝芦茫聛聦茅聛赂忙聤聻茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞茫聙聛茫聛聥茫聛陇茫聜垄茫聝聝茫聝聴茫聝颅茫聝录茫聝聣茫聛聲茫聜聦茫聛娄茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉茫聜篓茫聝漏茫聝录茂录聣\n        if ($scope.form_data.hubble_setting_flg === 2 \u0026\u0026\n            $scope.hubbleCreateData.selectedFiles.length === 0 \u0026\u0026\n            angular.isUndefinedOrNull(fetched_request.hubble_data)) {\n            result.result = NO_HUBBLE_FILE_ERROR;\n            return result;\n        }\n\n        // approval_kind茫聛聦1茫聛搂茫聙聛茫聜掳茫聝芦茫聝录茫聝聴忙聣驴猫陋聧猫聙\u0085茫聛聦茫聛聞茫聛陋茫聛聞茫聛聥茫聛陇猫驴陆氓聤聽茫聛聴茫聛聼茫聜鹿茫聝聠茫聝聝茫聝聴茫聛搂茫聛陋茫聛聞氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if (angular.isDefined($scope.flow_data) \u0026\u0026\n            angular.isDefined($scope.flow_data.flow_steps) \u0026\u0026\n            custom_flow_step.custom_step_flg !== 1) {\n            if ($scope.flow_data.flow_steps.length === 0) {\n                result.result = APPROVER_VALIDATION_ERROR;\n                return result;\n            }\n\n            for (i = 0; i \u003c $scope.flow_data.flow_steps.length; i++) {\n                if (angular.isUndefinedOrNull($scope.flow_data.flow_steps[i].flow_step_users)) {\n                    result.result = APPROVER_VALIDATION_ERROR;\n                    return result;\n                }\n                else if ($scope.flow_data.flow_steps[i].flow_step_users.length === 0) {\n                    result.result = APPROVER_VALIDATION_ERROR;\n                    return result;\n                }\n            }\n        }\n\n        /**\n         * 氓\u0085篓茫聛娄茫聛庐莽聰鲁猫芦聥茫聜鹿茫聝聠茫聝聝茫聝聴茫聛芦忙聣驴猫陋聧猫聙\u0085茫聛聦猫篓颅氓庐職茫聛聲茫聜聦茫聛娄茫聛聞茫聜聥茫聛聥\n         * @return {boolean}\n         */\n        function canConfirm() {\n            if (angular.isDefined($scope.isModify)) {\n                return true;\n            }\n            if (angular.isUndefinedOrNull($scope.flow_data)) {\n                return false;\n            }\n            // 莽聰鲁猫芦聥茫聜鹿茫聝聠茫聝聝茫聝聴茫聛聦茫聛陋茫聛聞(茫聜鹿茫聜颅茫聝聝茫聝聴忙聺隆盲禄露茫聛庐猫篓颅氓庐職茫聛芦茫聜聢茫聜聤茫聙聛茫聛聶茫聛鹿茫聛娄茫聛庐茫聜鹿茫聝聠茫聝聝茫聝聴茫聛聦茫聜鹿茫聜颅茫聝聝茫聝聴茫聛聲茫聜聦茫聜聥氓聽麓氓聬聢茫聜聜氓聬芦茫聜聙)氓聽麓氓聬聢茫聛炉茫聜篓茫聝漏茫聝录\n            if ($scope.flow_data.flow_steps.length === 0){\n                return false;\n            }\n            return $scope.flow_data.flow_steps.every(function(step) {\n                return step.selected_users.length \u003e 0;\n            });\n        }\n\n        // 忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聛芦忙聣驴猫陋聧猫聙\u0085茫聛聦莽漏潞茫聛庐茫聜鹿茫聝聠茫聝聝茫聝聴茫聛聦茫聛聜茫聜聥氓聽麓氓聬聢茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if (!canConfirm()) {\n            result.result = APPROVER_VALIDATION_ERROR;\n            return result;\n        }\n\n        // 莽聣鹿氓庐職茅聽\u0085莽聸庐茫聛庐茫聝聬茫聝陋茫聝聡茫聝录茫聜路茫聝搂茫聝鲁 ($invalid茫聜聮氓聢漏莽聰篓茫聛聴茫聛陋茫聛聞茫聝聛茫聜搂茫聝聝茫聜炉)\n        for (i = 0; i \u003c $scope.form_data.form_json.length; i++) {\n            var item = $scope.form_data.form_json[i];\n\n            if (item.item_type === Const.form.ITEM_TYPE_CHECK) {\n                if (!isValidCheckbox(item)) {\n                    result.result = CHECKBOX_VALIDATION_ERROR;\n                    return result;\n                }\n            }\n            else if (item.item_type === Const.form.ITEM_TYPE_ATTACHMENT) {\n                if (!permissionService.isFreeUser() \u0026\u0026 !isValidAttachment(item)) {\n                    result.result = ATTACHMENT_VALIDATION_ERROR;\n                    return result;\n                }\n            }\n        }\n\n        // 忙聣驴猫陋聧茫聝芦茫聝录茫聝聢茫聜聮莽路篓茅聸聠盲赂颅茫聛炉茫聙聛莽聰鲁猫芦聥茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if ($scope.edit_flow_step_mode) {\n            result.result = EDIT_FLOW_STEP_MODE_ERROR;\n            return result;\n        }\n\n        // 忙聣驴猫陋聧猫聙\u0085茫聛芦茫聜聢茫聜聥莽碌聦猫路炉莽路篓茅聸聠茫聛搂茫聙聛氓路庐氓聢聠茫聛聦茫聛陋茫聛聞氓聽麓氓聬聢茫聛炉忙聸麓忙聳掳茫聛搂茫聛聧茫聛陋茫聛聞茫聜聢茫聛聠茫聛芦茫聛聶茫聜聥\n        if ($scope.kind === Const.miscellaneous.CREATE_REQUEST_KIND.MODIFY_STEP\n            \u0026\u0026 !CreateRequestFlowService.existModifySteps($scope.flow_data.flow_steps)\n        ) {\n            result.result = NO_MODIFY_STEPS_ERROR;\n            return result;\n        }\n\n        // form 茫聛庐茫聝聬茫聝陋茫聝聡茫聝录茫聜路茫聝搂茫聝鲁茫聜篓茫聝漏茫聝录茫聛庐茫聝聛茫聜搂茫聝聝茫聜炉\n        // 茫聛聼茫聛聽茫聛聴茫聙聛氓聧聵茫聛芦 request_form.$invalid 茫聛搂茫聛聜茫聜聦茫聛掳茫聜篓茫聝漏茫聝录茫聜聮猫驴聰茫聛聶茫聙聛茫聛庐茫聛搂茫聛炉茫聛陋茫聛聫茫聙聛\n        // 盲禄楼盲赂聥茫聛庐氓聽麓氓聬聢茫聛庐茫聛驴茫聙聛茫聜篓茫聝漏茫聝录茫聜聮猫驴聰茫聛聶\n        //  1.茅聙職氓赂赂茫聛庐茫聝聬茫聝陋茫聝聡茫聝录茫聜路茫聝搂茫聝鲁茫聜篓茫聝漏茫聝录茂录聢莽碌聦猫虏禄忙聵聨莽麓掳茫聝聲茫聜漏茫聝录茫聝聽盲禄楼氓陇聳茂录聣\n        //  2.莽碌聦猫虏禄忙聵聨莽麓掳茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聙聛氓驴\u0085茅聽聢茫聜篓茫聝漏茫聝录盲禄楼氓陇聳茫聛庐茫聜篓茫聝漏茫聝录\n        //  3.莽碌聦猫虏禄忙聵聨莽麓掳茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聙聛氓\u0085楼氓聤聸茫聛聲茫聜聦茫聛娄茫聛聞茫聛陋茫聛聞忙聵聨莽麓掳猫隆篓茫聛庐茫聜篓茫聝漏茫聝录\n        //  4.莽碌聦猫虏禄忙聵聨莽麓掳茫聝聲茫聜漏茫聝录茫聝聽茫聛搂茫聙聛氓\u0085篓忙聵聨莽麓掳猫隆篓茫聛搂茂录聭猫隆聦茫聜聜忙聵聨莽麓掳茫聛聦氓颅聵氓聹篓茫聛聴茫聛陋茫聛聞\n        //\n        // 茫聛陋茫聛聤茫聙聛 request_form.$invalid 茫聛搂茫聛聜茫聜聦茫聛掳 FORM_VALIDATION_ERROR 茫聜聮猫驴聰茫聛聶茫聙聛茫聛篓茫聛聞茫聛聠氓聧聵莽麓聰茫聛陋茫聝颅茫聜赂茫聝聝茫聜炉茫聛搂茫聛炉NG茫聙聜\n        // 莽聰鲁猫芦聥忙聸赂茫聛芦氓颅聵氓聹篓茫聛聶茫聜聥氓\u0085篓忙聵聨莽麓掳猫隆篓茫聛庐茫聛